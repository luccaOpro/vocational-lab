# Headers de seguridad servidos por Cloudflare Pages.
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

/*
  # Nadie puede meter el sitio en un iframe (clickjacking).
  X-Frame-Options: DENY
  # El navegador no "adivina" content-types (evita ejecutar archivos disfrazados).
  X-Content-Type-Options: nosniff
  # No filtramos URLs completas a otros sitios al navegar afuera.
  Referrer-Policy: strict-origin-when-cross-origin
  # APIs del navegador que el sitio no usa: bloqueadas explícitamente.
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()

# Assets con hash en el nombre (los genera Astro): cache inmutable de 1 año.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
