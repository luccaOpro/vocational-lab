# Plantilla para las variables de entorno del proyecto.
# Copiar este archivo a .env y completar con los valores reales.
# El archivo .env NO se sube a GitHub (está en .gitignore).
#
# Cómo obtener estos valores:
#   1. Entrar al dashboard de Supabase del proyecto
#   2. Settings → API
#   3. Copiar "Project URL" y la "publishable key"

PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxx
