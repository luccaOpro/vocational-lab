        <text font-family="Fraunces, Georgia, serif" font-size="70.622" fill="#ffffff" transform="translate(217.294 274.919)">
          <tspan x="0" y="0">VOCATIONAL</tspan>
          <tspan font-weight="700" x="0" y="68.482">LAB</tspan>
        </text>
      </svg>
      <span class="footer__tag">Donde futuro y vocación se encuentran.</span>
    </div>

    <div class="footer__links">
      <a href="mailto:hola@vlab.com.ar">hola@vlab.com.ar</a>
      <a href="https://instagram.com/vocationallab" target="_blank" rel="noopener">@vocationallab</a>
      <a href="/aula/login">Acceso al aula →</a>
    </div>

    <p class="footer__legal">© {anio} Vocational Lab. Todos los derechos reservados.</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-ink);
    color: var(--color-bg);
    padding: 3rem 0 2rem;
    margin-top: 2rem;
  }
  .footer__inner {
    display: grid;
    gap: 1.25rem;
  }
  .footer__brand {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  /* Logo completo en el footer (fondo oscuro), versión light.
     Más alto que el del Nav porque acá hay más espacio. */
  .footer__brand-logo {
    width: auto;
    height: 80px;
    display: block;
  }
  .footer__tag {
    font-style: italic;
    color: rgba(250, 247, 242, 0.6);
    font-size: 0.95rem;
  }
  .footer__links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    font-size: 0.95rem;
  }
  .footer__links a {
    color: rgba(250, 247, 242, 0.85);
    border-bottom: 1px solid transparent;
  }
  .footer__links a:hover {
    border-bottom-color: var(--color-accent);
  }
  .footer__legal {
    margin: 0;
    color: rgba(250, 247, 242, 0.45);
    font-size: 0.85rem;
  }
</style>
