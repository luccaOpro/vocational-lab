---
/*
  Pie del sitio: legal / créditos / links rápidos.
  Mínimo por ahora; lo expandimos cuando definamos legales / política
  de privacidad.
*/

const anio = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner container">
    <div class="footer__brand">
      <img src="/logo.svg" alt="Vocational Lab" class="footer__brand-logo" width="160" height="127" />
      <span class="footer__tag">Donde futuro y vocación se encuentran.</span>
    </div>

    <div class="footer__links">
      <a href="mailto:hola@vocationallab.com">hola@vocationallab.com</a>
      <a href="https://instagram.com/vocationallab" target="_blank" rel="noopener">@vocationallab</a>
      <a href="/aula/login">Acceso al aula →</a>
    </div>

    <p class="footer__legal">© {anio} Vocational Lab. Todos los derechos reservados.</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-ink);
    color: var(--color-bg);
    padding: 3rem 0 2rem;
    margin-top: 2rem;
  }
  .footer__inner {
    display: grid;
    gap: 1.25rem;
  }
  .footer__brand {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  /* Logo en el footer (fondo oscuro): lo invertimos para que se vea. */
  .footer__brand-logo {
    width: auto;
    height: 60px;
    display: block;
    filter: invert(1) brightness(2);
  }
  .footer__tag {
    font-style: italic;
    color: rgba(250, 247, 242, 0.6);
    font-size: 0.95rem;
  }
  .footer__links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    font-size: 0.95rem;
  }
  .footer__links a {
    color: rgba(250, 247, 242, 0.85);
    border-bottom: 1px solid transparent;
  }
  .footer__links a:hover {
    border-bottom-color: var(--color-accent);
  }
  .footer__legal {
    margin: 0;
    color: rgba(250, 247, 242, 0.45);
    font-size: 0.85rem;
  }
</style>
