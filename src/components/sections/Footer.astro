---
/*
  Pie del sitio: legal / créditos / links rápidos.
  Mínimo por ahora; lo expandimos cuando definamos legales / política
  de privacidad.
*/

const anio = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner container">
    <div class="footer__brand">
      {/* Logo completo (ícono + texto) — versión clara para
          fondo oscuro del footer. */}
