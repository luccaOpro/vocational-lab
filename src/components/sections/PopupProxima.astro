---
/*
  Pop-up flotante de próxima edición.
  El contenido se carga desde la tabla site_config de Supabase,
  con fallback a los valores hardcodeados si la carga falla.
  Un admin puede editarlo desde /aula/admin/configuracion.
*/
---

<aside id="popup-proxima" class="popup" hidden>
  <div class="popup__body">
    <p class="popup__titulo" id="popup-titulo">Próxima edición</p>
    <p class="popup__sub" id="popup-sub">Agosto 2026</p>
    <a href="#contacto" class="popup__cta" id="popup-cta">Reserva tu lugar →</a>
  </div>
  <button class="popup__close" type="button" aria-label="Cerrar aviso">×</button>
</aside>

<script>
  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL as string;
  const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY as string;

  const DEFAULTS: Record<string, string> = {
    popup_activo:    "true",
    popup_titulo:    "Próxima edición",
    popup_fecha:     "Agosto 2026",
    popup_cta_texto: "Reserva tu lugar →",
    popup_cta_url:   "#contacto",
  };

  const SESSION_KEY = "vl_popup_cerrado";
  const popup = document.getElementById("popup-proxima") as HTMLElement | null;

  async function initPopup() {
    if (!popup || sessionStorage.getItem(SESSION_KEY)) return;

    // Cargamos config desde Supabase; si falla usamos los defaults.
    const config = { ...DEFAULTS };
    try {
      const claves = Object.keys(DEFAULTS).join(",");
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/site_config?select=clave,valor&clave=in.(${claves})`,
        { headers: { apikey: SUPABASE_KEY, Authorization: `Bearer ${SUPABASE_KEY}` } }
      );
      if (res.ok) {
        const rows = (await res.json()) as { clave: string; valor: string }[];
        rows.forEach((r) => { config[r.clave] = r.valor; });
      }
    } catch { /* fallback a defaults sin romper la página */ }

    if (config.popup_activo === "false") return;

    (document.getElementById("popup-titulo") as HTMLElement).textContent = config.popup_titulo;
    (document.getElementById("popup-sub") as HTMLElement).textContent = config.popup_fecha;
    const $cta = document.getElementById("popup-cta") as HTMLAnchorElement;
    $cta.textContent = config.popup_cta_texto;
    // Solo aceptamos URLs seguras: anclas (#...), rutas internas (/...)
    // o http(s). Bloquea esquemas peligrosos tipo javascript: por si la
    // config viniera comprometida — defensa en profundidad, la RLS de
    // site_config ya restringe la escritura a admins (migración 12).
    const url = config.popup_cta_url.trim();
    const urlSegura = /^(#|\/(?!\/)|https?:\/\/)/i.test(url) ? url : DEFAULTS.popup_cta_url;
    $cta.href = urlSegura;

    const onScroll = () => {
      if (window.scrollY > 400) {
        popup.hidden = false;
        popup.classList.add("popup--visible");
        window.removeEventListener("scroll", onScroll);
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });

    popup.querySelector(".popup__close")?.addEventListener("click", () => {
      popup.classList.remove("popup--visible");
      sessionStorage.setItem(SESSION_KEY, "1");
      setTimeout(() => { popup.hidden = true; }, 200);
    });
  }

  initPopup();
</script>

<style>
  .popup {
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    z-index: 60;
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    max-width: 340px;
    background: var(--color-ink);
    color: var(--color-bg);
    padding: 1.1rem 1.25rem 1.1rem 1.25rem;
    border-radius: var(--radius-md);
    box-shadow: 0 20px 40px -20px rgba(0, 0, 0, 0.4);
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .popup--visible {
    opacity: 1;
    transform: translateY(0);
  }

  .popup__titulo {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .popup__sub {
    margin: 0.15rem 0 0.7rem;
    font-family: var(--font-serif);
    font-size: 1.15rem;
  }
  .popup__cta {
    color: var(--color-bg);
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    font-size: 0.95rem;
  }
  .popup__cta:hover { color: var(--color-accent); }

  .popup__close {
    background: transparent;
    border: 0;
    color: rgba(250, 247, 242, 0.6);
    font-size: 1.4rem;
    line-height: 1;
    cursor: pointer;
    padding: 0;
    margin-left: 0.25rem;
  }
  .popup__close:hover { color: var(--color-bg); }

  @media (max-width: 560px) {
    .popup {
      left: 0.75rem;
      right: 0.75rem;
      bottom: 0.75rem;
      max-width: none;
      padding: 0.7rem 0.9rem;
      align-items: center;
      gap: 0.75rem;
    }
    .popup__body {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex: 1;
    }
    .popup__titulo { display: none; }
    .popup__sub {
      margin: 0;
      font-size: 0.95rem;
      flex-shrink: 0;
    }
    .popup__cta {
      font-size: 0.85rem;
      white-space: nowrap;
      margin-left: auto;
    }
    .popup__close {
      font-size: 1.2rem;
      margin-left: 0;
    }
  }
</style>
