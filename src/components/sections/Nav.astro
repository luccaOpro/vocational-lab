---
/*
  Navegación superior — fija arriba mientras se hace scroll.
  Los links apuntan a los IDs de cada sección de la home.
*/
---

<header class="nav">
  <div class="nav__inner container">
    <a href="#hero" class="nav__brand">
      <span class="nav__brand-mark">VL</span>
      <span class="nav__brand-name">Vocational Lab</span>
    </a>

    <nav class="nav__links" aria-label="Navegación principal">
      <a href="#caminos">Programas</a>
      <a href="#programa">El proceso</a>
      <a href="#equipo">Equipo</a>
      <a href="#contacto" class="nav__cta">Hablemos</a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(250, 247, 242, 0.92);
    backdrop-filter: saturate(140%) blur(8px);
    border-bottom: 1px solid var(--color-line);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1rem;
    padding-bottom: 1rem;
  }

  .nav__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-serif);
    font-weight: 500;
  }

  .nav__brand-mark {
    display: inline-grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--color-ink);
    color: var(--color-bg);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0;
  }

  .nav__brand-name {
    font-size: 1.05rem;
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: 1.8rem;
    font-size: 0.95rem;
  }

  .nav__links a {
    color: var(--color-ink-soft);
    transition: color 0.15s ease;
  }
  .nav__links a:hover { color: var(--color-ink); }

  .nav__cta {
    padding: 0.55rem 1rem;
    border-radius: var(--radius-sm);
    background: var(--color-accent);
    color: #fff !important;
  }
  .nav__cta:hover { background: var(--color-accent-dark); }

  /* En pantallas chicas escondemos los links del medio y dejamos solo el CTA */
  @media (max-width: 720px) {
    .nav__links a:not(.nav__cta) { display: none; }
    .nav__brand-name { display: none; }
  }
</style>
