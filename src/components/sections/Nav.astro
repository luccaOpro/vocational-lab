---
/*
  Navegación superior — fija arriba mientras se hace scroll.
  En desktop: links visibles en línea.
  En mobile (≤720px): se esconde la fila de links y aparece el botón
  hamburguesa, que abre un panel lateral desde la derecha.
*/
---

<header class="nav">
  <div class="nav__inner container">
    <a href="/" class="nav__brand" aria-label="Vocational Lab — Inicio">
      {/* Logo completo (ícono + texto VOCATIONAL LAB) inline.
          Inline para que aparezca junto con el HTML inicial,
          sin un segundo round-trip que provoca flash de carga.
          La fuente del texto se hereda del sitio (Fraunces). */}
      <svg class="nav__brand-logo" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 697.431 460" aria-hidden="true">
        <path fill="#1b1f3b" d="M0,443.73l.03-45.407c23.216.636,45.683-4.407,66.324-14.637,36.23-18.152,63.593-50.904,74.253-90.112,10.187-37.467,4.874-77.408-15.454-110.56-6.952-11.393-15.189-21.809-25.037-30.712C72.82,127.121,37.263,113.652,0,114.496l.037-46.499c44.551-.826,87.825,14.16,122.067,42.496,13.748,11.427,25.844,24.486,35.722,39.444,8.994,13.102,16.167,27.094,21.57,42.023,12.435,34.36,14.355,70.023,6.359,105.724-8.974,40.066-30.991,76.227-62.228,102.842-22.961,19.111-50.003,32.569-79.197,39.003-14.634,3.128-29.245,4.514-44.329,4.2Z"/>
        <path fill="#d85527" d="M26.34,305.497l-.613-1.82c-.122-.361-.996-.54-1.611-.716l.476-1.582-19.161.152,10.251-10.602,13.716,1.059-.058-1.175-12.423-1.026,6.091-6.282,13.612,1.104-.034-1.185-12.454-1.038,6.18-6.275,13.336,1.094.131-1.185-12.437-1.034,3.919-3.942c3.487-3.508,12.645-.401,18.901-1.622L217.149,100.94c-3.31-1.789-6.564-2.322-9.947-2.602l-11.392-.355,15.203-7.816,29.993-15.686c3.798-1.847,7.134-3.708,11.428-5.274l-22.756,50.442-3.415,6.55-2.236-15.178c-.229-1.554-.973-3.126-1.887-4.554L59.04,275.068l.589,10.139c.36,6.203-.746,7.708-5.857,12.288l-1.477-13.103c-.048-.076-.922-.053-1.189.021l1.603,14.354-6.078,6.182-1.514-13.294-1.183.053,1.629,14.478-6.088,6.301-1.474-13.253c-.017-.073-.587-.473-.717-.338l-.494.515,1.634,14.233-9.718,10.161-.463-19.249-1.902.943Z"/>
        <path fill="#1b1f3b" d="M298.919,59.572c.276,3.224,1.168,6.074,2.204,9.026,2.16,6.156,4.711,11.974,7.4,17.959,6.086,13.543,12.882,26.533,19.526,39.841l-23.439-38.61c-4.11-6.442-8.219-12.707-12.752-18.811-1.875-2.524-3.751-4.794-5.971-6.944-4.892-4.739-13.586,2.872-17.91,7.246,3.126-5.608,8.67-14.951,3.291-19.349-3.952-3.231-9.751-4.655-14.659-5.984,4.837.167,14.61-.004,16.446-3.913,2.574-5.479-11.443-32.405-14.854-40.032,4.469,6.811,8.531,13.575,13.323,20.097,3.24,4.318,7.109,9.638,11.451,12.579,1.286.871,2.775.931,4.205.328,5.04-2.126,10.72-7.591,14.833-11.63,6.152-6.041,11.61-12.426,17.388-18.918-4.544,6.896-9.014,13.503-12.92,20.714-2.467,4.671-5.647,10.714-5.955,15.79-.099,1.628.557,2.988,1.887,3.893,1.342.913,2.811,1.678,4.364,2.294,9.163,3.639,19.708,5.764,29.429,7.928l30.791,5.675c-13-1.19-25.692-2.499-38.701-3.088-6.689-.303-13.097-.497-19.708-.122-2.697.153-5.285.46-7.791,1.277-1.195.389-2.002,1.319-1.879,2.757Z"/>
        <text font-family="Fraunces, Georgia, serif" font-size="70.622" fill="#1b1f3b" transform="translate(217.294 274.919)">
          <tspan x="0" y="0">VOCATIONAL</tspan>
          <tspan font-weight="700" x="0" y="68.482">LAB</tspan>
        </text>
      </svg>
    </a>

    {/* Links visibles en desktop.
        El "Hablemos" no va acá: vive como CTA secundario en el Hero. */}
    {/* Links con "/#" (no "#" pelado): así también funcionan desde
        /inscripcion, /protocolo o cualquier otra página. */}
    <nav class="nav__links" aria-label="Navegación principal">
      <a href="/#caminos">Programas</a>
      <a href="/#programa">Proceso</a>
      <a href="/#equipo">Equipo</a>
      <a href="/aula" class="nav__cta">Aula</a>
    </nav>

    {/* Acciones de la derecha en mobile: CTA Aula + hamburguesa.
        Se muestran sólo en el breakpoint mobile (≤720px).
        El "Hablemos" no va acá: vive como CTA secundario en el Hero. */}
    <div class="nav__mobile-actions">
      <a href="/aula" class="nav__cta-mobile">Aula</a>

      <button
        class="nav__burger"
        type="button"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-menu-toggle
      >
        <span class="nav__burger-bar"></span>
        <span class="nav__burger-bar"></span>
        <span class="nav__burger-bar"></span>
      </button>
    </div>
  </div>

  {/* Barra de progreso de lectura: una línea coral que crece a medida
      que se recorre la página. Decorativa (aria-hidden). */}
  <span class="nav__progreso" data-nav-progreso aria-hidden="true"></span>
</header>

{/* Backdrop oscurecido detrás del panel */}
<div class="nav__backdrop" data-menu-backdrop hidden></div>

{/* Panel lateral del menú mobile */}
<aside
  id="mobile-menu"
  class="nav__panel"
  aria-label="Menú"
  aria-hidden="true"
  inert
>
  <div class="nav__panel-head">
    <span class="nav__panel-brand">Vocational Lab</span>
    <button
      class="nav__close"
      type="button"
      aria-label="Cerrar menú"
      data-menu-toggle
    >
      <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
        <path d="M6 6 L18 18 M18 6 L6 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" fill="none" />
      </svg>
    </button>
  </div>

  <nav class="nav__panel-links" aria-label="Navegación mobile">
    <a href="/#caminos" data-menu-link>Programas</a>
    <a href="/#programa" data-menu-link>Proceso</a>
    <a href="/#equipo" data-menu-link>Equipo</a>
  </nav>
</aside>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(250, 247, 242, 0.92);
    backdrop-filter: saturate(140%) blur(8px);
    border-bottom: 1px solid var(--color-line);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
  }

  .nav__brand {
    display: inline-flex;
    align-items: center;
    line-height: 0;
  }

  /* Logo completo: alto fijo para que el texto VOCATIONAL LAB
     se lea bien. El ancho lo calcula el SVG en base al viewBox.
     Achicado (96→64) para que el nav sticky no se coma la pantalla:
     la marca sigue presente pero el contenido respira. */
  .nav__brand-logo {
    width: auto;
    height: 64px;
    display: block;
    flex-shrink: 0;
  }

  @media (max-width: 720px) {
    .nav__brand-logo { height: 56px; }
  }

  /* ===== Barra de progreso de lectura ===== */
  .nav__progreso {
    position: absolute;
    left: 0;
    bottom: -1px; /* pisa la línea del borde inferior */
    width: 100%;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left center;
    pointer-events: none;
  }

  /* Links del nav superior (desktop) */
  .nav__links {
    display: flex;
    align-items: center;
    gap: 1.8rem;
    font-size: 0.95rem;
  }

  .nav__links a {
    color: var(--color-ink-soft);
    transition: color 0.15s ease;
    /* Subrayado coral que aparece en hover y en la sección activa. */
    text-decoration: underline;
    text-decoration-color: transparent;
    text-decoration-thickness: 2px;
    text-underline-offset: 6px;
    transition: color 0.15s ease, text-decoration-color 0.2s ease;
  }
  .nav__links a:hover { color: var(--color-ink); }
  .nav__links a.is-active {
    color: var(--color-ink);
    text-decoration-color: var(--color-accent);
  }

  .nav__cta {
    padding: 0.55rem 1rem;
    border-radius: var(--radius-sm);
    background: var(--color-accent);
    color: #fff !important;
  }
  .nav__cta:hover { background: var(--color-accent-dark); }

  /* ===== Acciones mobile (CTA + hamburguesa) ===== */
  /* En desktop el contenedor es invisible — los links inline se encargan. */
  .nav__mobile-actions {
    display: none;
    align-items: center;
    gap: 0.6rem;
  }

  /* CTA principal en mobile (Aula) — al lado del hamburguesa. */
  .nav__cta-mobile {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.9rem;
    border-radius: var(--radius-sm);
    background: var(--color-accent);
    color: #fff;
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1;
    white-space: nowrap;
    transition: background 0.15s ease;
  }
  .nav__cta-mobile:hover { background: var(--color-accent-dark); }

  /* ===== Botón hamburguesa ===== */
  .nav__burger {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 42px;
    height: 42px;
    padding: 0;
    background: transparent;
    border: 0;
    cursor: pointer;
    color: var(--color-ink);
  }
  .nav__burger-bar {
    display: block;
    width: 22px;
    height: 1.6px;
    margin: 0 auto;
    background: currentColor;
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }
  /* Cuando el menú está abierto, el ícono ☰ se transforma en X */
  .nav__burger[aria-expanded="true"] .nav__burger-bar:nth-child(1) {
    transform: translateY(6.6px) rotate(45deg);
  }
  .nav__burger[aria-expanded="true"] .nav__burger-bar:nth-child(2) {
    opacity: 0;
  }
  .nav__burger[aria-expanded="true"] .nav__burger-bar:nth-child(3) {
    transform: translateY(-6.6px) rotate(-45deg);
  }

  /* ===== Backdrop oscurecido ===== */
  .nav__backdrop {
    position: fixed;
    inset: 0;
    background: rgba(19, 27, 61, 0.45); /* Azul noche translúcido */
    backdrop-filter: blur(2px);
    opacity: 0;
    transition: opacity 0.25s ease;
    z-index: 60;
  }
  .nav__backdrop[data-open="true"] {
    opacity: 1;
  }

  /* ===== Panel lateral derecho ===== */
  .nav__panel {
    position: fixed;
    top: 0;
    right: 0;
    height: 100dvh;
    width: min(82vw, 360px);
    background: var(--color-bg);
    border-left: 1px solid var(--color-line);
    box-shadow: -20px 0 60px rgba(19, 27, 61, 0.18);
    transform: translateX(100%);
    transition: transform 0.32s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 70;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
  }
  .nav__panel[data-open="true"] {
    transform: translateX(0);
  }

  .nav__panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem 1.5rem;
    border-bottom: 1px solid var(--color-line);
  }

  .nav__panel-brand {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--color-ink);
  }

  .nav__close {
    display: inline-grid;
    place-items: center;
    width: 38px;
    height: 38px;
    padding: 0;
    background: transparent;
    border: 0;
    cursor: pointer;
    color: var(--color-ink);
    border-radius: var(--radius-sm);
    transition: background 0.15s ease;
  }
  .nav__close:hover {
    background: var(--color-surface);
  }

  .nav__panel-links {
    display: flex;
    flex-direction: column;
    padding: 1.5rem 1.5rem 2rem;
    gap: 0.25rem;
  }

  .nav__panel-links a {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    color: var(--color-ink);
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--color-line);
    transition: color 0.15s ease, padding 0.15s ease;
  }
  .nav__panel-links a:hover {
    color: var(--color-accent);
    padding-left: 0.25rem;
  }

  .nav__panel-cta {
    margin-top: 1.2rem;
    border-bottom: 0 !important;
    background: var(--color-accent);
    color: #fff !important;
    text-align: center;
    border-radius: var(--radius-sm);
    padding: 0.95rem 1rem !important;
    font-family: var(--font-sans) !important;
    font-size: 1rem !important;
  }
  .nav__panel-cta:hover {
    background: var(--color-accent-dark);
    padding-left: 1rem !important;
  }

  /* ===== Breakpoint mobile ===== */
  @media (max-width: 720px) {
    /* Esconder los links inline del nav superior */
    .nav__links { display: none; }
    /* Mostrar el bloque mobile (CTA Hablemos + hamburguesa) */
    .nav__mobile-actions { display: inline-flex; }
  }

  /* Respeta usuarios que prefieren menos movimiento */
  @media (prefers-reduced-motion: reduce) {
    .nav__panel,
    .nav__backdrop,
    .nav__burger-bar { transition: none; }
  }

  /* Bloqueo del scroll del body mientras el menú está abierto */
  :global(body.menu-open) {
    overflow: hidden;
  }
</style>

<script>
  // ============================================================
  // Lógica del menú mobile
  // ------------------------------------------------------------
  // - Abre/cierra al tocar cualquier elemento [data-menu-toggle]
  //   (botón hamburguesa o botón X).
  // - Cierra al tocar el backdrop oscurecido.
  // - Cierra al tocar un link de navegación (para ir a la sección).
  // - Cierra al apretar la tecla ESC.
  // - Bloquea el scroll del body mientras está abierto.
  // ============================================================

  const toggles = document.querySelectorAll<HTMLElement>('[data-menu-toggle]');
  const panel = document.getElementById('mobile-menu');
  const backdrop = document.querySelector<HTMLElement>('[data-menu-backdrop]');
  const burger = document.querySelector<HTMLElement>('.nav__burger');
  const closeBtn = panel?.querySelector<HTMLElement>('.nav__close');
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-menu-link]');

  function setMenu(open: boolean, returnFocus = false) {
    if (!panel || !backdrop || !burger) return;

    panel.dataset.open = String(open);
    panel.setAttribute('aria-hidden', String(!open));

    if (open) {
      // Sacamos `inert` para que el panel y sus links sean enfocables.
      panel.removeAttribute('inert');
      backdrop.hidden = false;
      // Forzar reflow para que la transición de opacidad arranque
      void backdrop.offsetWidth;
      backdrop.dataset.open = 'true';
    } else {
      // `inert` saca el panel del tab order cuando está cerrado/fuera de
      // pantalla (sino sus links quedan enfocables por teclado, invisibles).
      panel.setAttribute('inert', '');
      backdrop.dataset.open = 'false';
      // Esconder el backdrop después de la transición
      setTimeout(() => { if (backdrop.dataset.open !== 'true') backdrop.hidden = true; }, 280);
    }

    burger.setAttribute('aria-expanded', String(open));
    burger.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');

    document.body.classList.toggle('menu-open', open);

    // Foco: al abrir, lo llevamos al botón de cerrar; al cerrar por
    // X/ESC/backdrop (no al clickear un link, que navega), lo devolvemos
    // a la hamburguesa.
    if (open) {
      requestAnimationFrame(() => closeBtn?.focus());
    } else if (returnFocus) {
      burger.focus();
    }
  }

  toggles.forEach((el) => {
    el.addEventListener('click', () => {
      const isOpen = panel?.dataset.open === 'true';
      setMenu(!isOpen, true);
    });
  });

  backdrop?.addEventListener('click', () => setMenu(false, true));

  links.forEach((link) => {
    link.addEventListener('click', () => setMenu(false));
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && panel?.dataset.open === 'true') {
      setMenu(false, true);
    }
  });

  // ============================================================
  // Barra de progreso de lectura
  // ------------------------------------------------------------
  // Escala la línea coral del nav según cuánto se recorrió la página.
  // Usamos transform (no width) + requestAnimationFrame: rendimiento
  // fluido sin recalcular layout en cada scroll.
  // ============================================================
  const progreso = document.querySelector<HTMLElement>('[data-nav-progreso]');
  if (progreso) {
    let pedido = false;
    const pintar = () => {
      pedido = false;
      const total = document.documentElement.scrollHeight - window.innerHeight;
      const avance = total > 0 ? Math.min(window.scrollY / total, 1) : 0;
      progreso.style.transform = `scaleX(${avance})`;
    };
    window.addEventListener('scroll', () => {
      if (!pedido) { pedido = true; requestAnimationFrame(pintar); }
    }, { passive: true });
    pintar();
  }

  // ============================================================
  // Sección activa en el nav (scrollspy)
  // ------------------------------------------------------------
  // Cuando una sección linkeada desde el nav está en pantalla, su link
  // se marca con el subrayado coral. Ayuda a ubicarse en la página.
  // ============================================================
  const linksNav = Array.from(
    // href*="#" (no ^="#"): los links ahora son "/#seccion" para que
    // funcionen desde cualquier página; l.hash devuelve "#seccion" igual.
    document.querySelectorAll<HTMLAnchorElement>('.nav__links a[href*="#"]')
  );
  const secciones = linksNav
    .map((l) => document.querySelector<HTMLElement>(l.hash))
    .filter((s): s is HTMLElement => s !== null);

  if (secciones.length > 0) {
    const marcar = (id: string | null) => {
      linksNav.forEach((l) => l.classList.toggle('is-active', l.hash === `#${id}`));
    };
    const spy = new IntersectionObserver(
      (entradas) => {
        // De las secciones visibles, gana la más cercana al tope.
        const visibles = entradas.filter((e) => e.isIntersecting);
        if (visibles.length > 0) {
          marcar(visibles[0].target.id);
        }
      },
      // Banda de detección: franja central-alta del viewport.
      { rootMargin: '-25% 0px -65% 0px' }
    );
    secciones.forEach((s) => spy.observe(s));
  }
</script>
