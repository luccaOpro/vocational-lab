---
/*
  SECCIÓN 1 · HERO
  Primer pantallazo. Frase potente + dos CTAs (uno principal, uno secundario).
  El subtítulo describe el programa en una bajada larga.
*/
---

<section id="hero" class="hero">
  <div class="hero__inner container">
    <p class="hero__eyebrow">Vocational Lab · Donde futuro y vocación se encuentran</p>

    <h1 class="hero__title">
      Tu futuro no se elige.<br />
      <em>Se construye.</em>
    </h1>

    <p class="hero__lead">
      Un programa para jóvenes que tienen la pregunta activa y quieren
      explorar de verdad — con método, con otros, y desde el rol
      protagonista de su propia historia.
    </p>

    <div class="hero__ctas">
      <a href="#programa" class="btn btn-primary">Conocé el programa</a>
      <a href="#contacto" class="btn btn-secondary">Hablemos</a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(5rem, 11vw, 9rem);
    padding-bottom: clamp(5rem, 10vw, 8rem);
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-surface) 100%);
  }

  .hero__inner {
    max-width: 880px;
    text-align: center;
  }

  .hero__eyebrow {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin: 0 0 1.8rem;
  }

  .hero__title {
    font-size: clamp(2.6rem, 6.5vw, 5rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 1.8rem;
  }
  .hero__title em {
    font-style: italic;
    color: var(--color-accent);
  }

  .hero__lead {
    font-size: clamp(1.1rem, 1.7vw, 1.35rem);
    color: var(--color-ink-soft);
    max-width: 60ch;
    margin: 0 auto 2.5rem;
    line-height: 1.55;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    justify-content: center;
  }
</style>
