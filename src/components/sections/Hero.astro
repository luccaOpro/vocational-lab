  <div class="hero__inner container">
    <p class="hero__eyebrow">Vocational Lab · Donde futuro y vocación se encuentran</p>

    <h1 class="hero__title">
      Tu futuro <em>se construye</em>
    </h1>

    <p class="hero__lead">
      Un programa para personas que tienen la pregunta activa y quieren
      explorar de verdad — con método, con otros, y desde el rol
      protagonista de su propia historia.
    </p>

    <div class="hero__ctas">
      <a href="#programa" class="btn btn-primary">Conoce el programa</a>
      <a href="/inscripcion" class="btn btn-secondary">Quiero anotarme</a>
    </div>

    {/* Pista de scroll: invita a seguir bajando. */}
    <a href="#proposito" class="hero__scroll" aria-label="Bajar a la siguiente sección">
      <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
        <path d="M6 9 L12 15 L18 9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none" />
      </svg>
    </a>
  </div>
</section>

<style>
  /* --- Animación de entrada del hero (al cargar la página) ---
     Cada elemento aparece con un leve fade + slide-up, con delays
     escalonados para que se lean en orden natural. Solo si el sistema
     no tiene prefers-reduced-motion activado. */
  @keyframes heroFade {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: none; }
  }

  /* Flotación de las estrellas: sube/baja apenas, con leve rotación. */
  @keyframes flotar {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50%      { transform: translateY(-14px) rotate(4deg); }
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero__eyebrow {
      animation: heroFade 0.7s cubic-bezier(0.16, 1, 0.3, 1) 100ms both;
    }
    .hero__title {
      animation: heroFade 0.8s cubic-bezier(0.16, 1, 0.3, 1) 260ms both;
    }
    .hero__lead {
      animation: heroFade 0.75s cubic-bezier(0.16, 1, 0.3, 1) 430ms both;
    }
    .hero__ctas {
      animation: heroFade 0.7s cubic-bezier(0.16, 1, 0.3, 1) 570ms both;
    }
    .hero__scroll {
      animation: heroFade 0.7s cubic-bezier(0.16, 1, 0.3, 1) 900ms both;
    }
    .hero__estrella--1 { animation: flotar 7s ease-in-out infinite; }
    .hero__estrella--2 { animation: flotar 9s ease-in-out 1.2s infinite; }
  }

  /* --- Estilos de layout --- */
  .hero {
    position: relative;
    overflow: hidden;
    padding-top: clamp(5rem, 11vw, 9rem);
    padding-bottom: clamp(4rem, 8vw, 6rem);
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-surface) 100%);
  }

  /* Marca de agua del logo: gigante, casi invisible, asomando por la
     derecha. Da identidad sin competir con el texto. */
  .hero__marca {
    position: absolute;
    top: 50%;
    right: -6%;
    width: clamp(320px, 38vw, 540px);
    height: auto;
    transform: translateY(-50%) rotate(6deg);
    color: var(--color-ink);
    opacity: 0.045;
    pointer-events: none;
  }

  /* Estrellas decorativas sueltas. */
  .hero__estrella {
    position: absolute;
    pointer-events: none;
  }
  .hero__estrella--1 {
    top: 16%;
    right: 12%;
    width: clamp(30px, 3.5vw, 46px);
    color: var(--color-accent);
    opacity: 0.85;
  }
  .hero__estrella--2 {
    bottom: 22%;
    left: 7%;
    width: clamp(20px, 2.2vw, 30px);
    color: var(--color-deep);
    opacity: 0.35;
    transform: scaleX(-1);
  }

  /* En pantallas chicas los ornamentos laterales molestan más de lo que
     suman: dejamos solo la estrella coral, más chica y arriba. */
  @media (max-width: 720px) {
    .hero__marca { display: none; }
    .hero__estrella--2 { display: none; }
    .hero__estrella--1 { top: 9%; right: 8%; }
  }

  .hero__inner {
    position: relative; /* por encima de los ornamentos */
    max-width: 880px;
    text-align: center;
  }

  .hero__eyebrow {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin: 0 0 1.8rem;
  }

  .hero__title {
    font-size: clamp(2.6rem, 6.5vw, 5rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 1.8rem;
  }
  .hero__title em {
    font-style: italic;
    color: var(--color-accent);
  }

  .hero__lead {
    font-size: clamp(1.1rem, 1.7vw, 1.35rem);
    color: var(--color-ink-soft);
    max-width: 60ch;
    margin: 0 auto 2.5rem;
    line-height: 1.55;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    justify-content: center;
  }

  /* Pista de scroll: chevron sutil que invita a bajar. */
  .hero__scroll {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    margin-top: clamp(2.2rem, 5vw, 3.5rem);
    border: 1px solid var(--color-line);
    border-radius: 50%;
    color: var(--color-ink-muted);
    background: rgba(255, 255, 255, 0.4);
    transition: color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }
  .hero__scroll:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    transform: translateY(3px);
  }
</style>
