---
/*
  SECCIÓN 5 · EL PROGRAMA
  El núcleo: las 5 etapas del viaje.
  Más arriba: título + bajada + placeholder del mapa.
  Más abajo: las 5 etapas en línea + resumen de qué te llevás.
*/

const etapas = [
  {
    n: "01",
    nombre: "El llamado",
    cuerpo:
      "Entras al viaje. Te sumas al grupo. Abres el proceso desde donde estás.",
  },
  {
    n: "02",
    nombre: "El origen",
    cuerpo:
      "Descubres de dónde vienes: tus talentos, tus intereses, tus creencias heredadas. El árbol vocacional que construyes aquí es el suelo de todo lo que sigue.",
  },
  {
    n: "03",
    nombre: "La búsqueda",
    cuerpo:
      "Trazas tu mapa personal de posibilidades. Aprendes a explorar el mundo del trabajo y del estudio sin sesgos, con método propio.",
  },
  {
    n: "04",
    nombre: "Lanzar la flecha",
    cuerpo:
      "Tomas decisiones concretas. Construyes tu plan A y tu plan B. Armas tu portfolio: estudios, prácticas, intereses, todo cuenta.",
  },
  {
    n: "05",
    nombre: "Volver con tesoros",
    cuerpo:
      "Integras el recorrido, recibes tu informe personalizado en vivo y, si quieres, compartes el espacio con tu familia.",
  },
];

const llevas = [
  "Mapa personal de exploración",
  "Tests psicométricos integrados a tus propios hallazgos",
  "Tu portfolio en construcción",
  "Plan de acción concreto",
  "Informe final personalizado",
  "Comunidad de pares",
];
---

<section id="programa" class="programa section">
  <div class="container">
    <header class="programa__head" data-animate>
      <h2 class="programa__title">
        Un viaje de <em><span class="counter" data-target="8">8</span> encuentros</em> en 5 etapas
      </h2>
      <p class="programa__lead">
        Un proceso con estructura, con método y un mapa claro — donde
        cada etapa tiene un propósito y tú eres el protagonista de
        principio a fin.
      </p>
    </header>

    <!-- Cuando llegue la imagen final del mapa del viaje, agregar acá:
         <figure class="programa__mapa">
           <Image src={mapaImg} alt="Mapa visual del viaje" />
         </figure>
    -->

    <ol class="etapas" data-stagger>
      {etapas.map((e) => (
        <li class="etapa">
          <span class="etapa__n">{e.n}</span>
          <h3 class="etapa__nombre">{e.nombre}</h3>
          <p class="etapa__cuerpo">{e.cuerpo}</p>
        </li>
      ))}
    </ol>

    <div class="programa__cierre" data-animate data-delay="200">
      <h3 class="programa__cierre-title">Al terminar, tienes:</h3>
      <ul class="programa__llevas">
        {llevas.map((l) => <li>{l}</li>)}
      </ul>
      <p class="programa__formato">
        6 encuentros grupales + 2 sesiones individuales
        · 100% online · Grupos reducidos
      </p>
      <div class="programa__ctas">
        <a href="#contacto" class="btn btn-primary">Quiero anotarme</a>
        <a href="#contacto" class="btn btn-secondary">Quiero conocer todos los detalles</a>
      </div>
    </div>
  </div>
</section>

<style>
  .programa__head {
    max-width: 760px;
    margin-bottom: 3rem;
  }
  .programa__title em {
    font-style: italic;
    color: var(--color-accent);
  }
  .programa__lead {
    margin-top: 1.25rem;
    color: var(--color-ink-soft);
    font-size: 1.1rem;
    max-width: 60ch;
  }

  /* Lista de etapas */
  .etapas {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 1024px) {
    .etapas { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .etapas { grid-template-columns: 1fr; }
  }

  .etapa {
    border-top: 2px solid var(--color-accent);
    padding: 1rem 0.9rem 1.1rem;
    border-radius: 0 0 var(--radius-sm) var(--radius-sm);
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .etapa:hover {
    background: #fff;
    transform: translateY(-3px);
    box-shadow: 0 16px 36px -26px rgba(19, 27, 61, 0.4);
  }
  .etapa__n {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }
  .etapa__nombre {
    font-size: 1.25rem;
    margin: 0 0 0.5rem;
  }
  .etapa__cuerpo {
    margin: 0;
    color: var(--color-ink-soft);
    font-size: 0.97rem;
    line-height: 1.55;
  }

  /* Cierre con resumen */
  .programa__cierre {
    margin-top: 4rem;
    padding: 2.5rem;
    background: var(--color-surface);
    border-radius: var(--radius-lg);
  }
  .programa__cierre-title {
    font-size: 1.25rem;
    margin: 0 0 1rem;
  }
  .programa__llevas {
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1rem;
    font-size: 1rem;
  }
  .programa__llevas li {
    padding: 0.5rem 0.9rem;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: 999px;
  }
  .programa__formato {
    color: var(--color-ink-soft);
    margin: 0 0 1.5rem;
  }
  .programa__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  /* El número del contador hereda el color del <em> que lo envuelve */
  .counter { font-variant-numeric: tabular-nums; }
</style>

<script>
  /*
    Contador animado — efecto 4.
    Anima el "8" de "8 encuentros" de 0 → 8 cuando la sección
    entra al viewport. Solo si el usuario no prefiere menos movimiento.
  */
  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    const counter = document.querySelector<HTMLElement>(".counter[data-target]");
    if (counter) {
      const target = parseInt(counter.dataset.target ?? "0", 10);

      const obs = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            obs.unobserve(entry.target);

            const duration = 900; // ms
            const startTime = performance.now();

            function tick(now: number) {
              const elapsed = now - startTime;
              const progress = Math.min(elapsed / duration, 1);
              // Ease-out cúbico
              const eased = 1 - Math.pow(1 - progress, 3);
              counter.textContent = String(Math.round(eased * target));
              if (progress < 1) requestAnimationFrame(tick);
              else counter.textContent = String(target);
            }

            requestAnimationFrame(tick);
          }
        },
        { threshold: 0.5 }
      );

      obs.observe(counter);
    }
  }
</script>
