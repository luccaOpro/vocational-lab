---
/*
  Barra de navegación del AULA (área privada).
  ---
  · Logo "VL" linkeado a la "home" según el rol.
  · Links cambian según rol (alumno / profe / admin).
  · En mobile colapsa a hamburguesa con panel lateral.

  Por ahora "Cerrar sesión" redirige a /aula/login.
  Cuando integremos Supabase, ese link va a llamar al signOut() de verdad.
*/

interface Props {
  /** Define qué links mostrar. Default: "alumno". */
  rol?: "alumno" | "profe" | "admin";
}

const { rol = "alumno" } = Astro.props;
const ruta = Astro.url.pathname;

// Marcamos el link activo según la ruta actual.
function activo(...targets: string[]) {
  return targets.some((t) => ruta.startsWith(t)) ? "is-active" : "";
}

// Definimos los links según el rol.
const homePorRol = {
  alumno: "/aula/mis-cursos",
  profe: "/aula/profe",
  admin: "/aula/admin",
};

const etiquetaPorRol = {
  alumno: "Vocational Lab · Aula",
  profe: "Vocational Lab · Profe",
  admin: "Vocational Lab · Admin",
};

// "Mi perfil" ya no va como link de texto en desktop: lo reemplaza el
// avatar circular de la derecha (ver .navaula__perfil). En el panel
// mobile sigue como item de texto, agregado a mano abajo.
const linksPorRol = {
  alumno: [
    { href: "/aula/mis-cursos", label: "Mis cursos", match: ["/aula/mis-cursos", "/aula/curso"] },
  ],
  profe: [
    { href: "/aula/profe", label: "Dashboard", match: ["/aula/profe"] },
    { href: "/aula/profe/entregas", label: "Entregas", match: ["/aula/profe/entregas"] },
  ],
  admin: [
    { href: "/aula/admin", label: "Dashboard", match: ["/aula/admin"] },
    { href: "/aula/admin/cursos", label: "Cursos", match: ["/aula/admin/cursos"] },
    { href: "/aula/admin/solicitudes", label: "Solicitudes", match: ["/aula/admin/solicitudes"] },
    { href: "/aula/admin/transferencias", label: "Pagos", match: ["/aula/admin/transferencias"] },
    { href: "/aula/admin/usuarios", label: "Usuarios", match: ["/aula/admin/usuarios"] },
    { href: "/aula/admin/configuracion", label: "Ajustes", match: ["/aula/admin/configuracion"] },
  ],
};

const links = linksPorRol[rol];
const home = homePorRol[rol];
const etiqueta = etiquetaPorRol[rol];
---

<header class={`navaula navaula--${rol}`} data-rol={rol}>
  <div class="navaula__inner container">
    <a href={home} class="navaula__brand" aria-label={etiqueta}>
      {/* Logo completo (ícono + texto), versión clara para nav del aula.
          ViewBox recortado para eliminar el whitespace inferior del SVG
          original (que dejaba más margen abajo que arriba en el contenedor). */}
      <svg class="navaula__brand-logo" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 697.431 460" aria-label="Vocational Lab" role="img">
        <path fill="#ffffff" d="M0,443.73l.03-45.407c23.216.636,45.683-4.407,66.324-14.637,36.23-18.152,63.593-50.904,74.253-90.112,10.187-37.467,4.874-77.408-15.454-110.56-6.952-11.393-15.189-21.809-25.037-30.712C72.82,127.121,37.263,113.652,0,114.496l.037-46.499c44.551-.826,87.825,14.16,122.067,42.496,13.748,11.427,25.844,24.486,35.722,39.444,8.994,13.102,16.167,27.094,21.57,42.023,12.435,34.36,14.355,70.023,6.359,105.724-8.974,40.066-30.991,76.227-62.228,102.842-22.961,19.111-50.003,32.569-79.197,39.003-14.634,3.128-29.245,4.514-44.329,4.2Z"/>
        <path fill="#d85527" d="M26.34,305.497l-.613-1.82c-.122-.361-.996-.54-1.611-.716l.476-1.582-19.161.152,10.251-10.602,13.716,1.059-.058-1.175-12.423-1.026,6.091-6.282,13.612,1.104-.034-1.185-12.454-1.038,6.18-6.275,13.336,1.094.131-1.185-12.437-1.034,3.919-3.942c3.487-3.508,12.645-.401,18.901-1.622L217.149,100.94c-3.31-1.789-6.564-2.322-9.947-2.602l-11.392-.355,15.203-7.816,29.993-15.686c3.798-1.847,7.134-3.708,11.428-5.274l-22.756,50.442-3.415,6.55-2.236-15.178c-.229-1.554-.973-3.126-1.887-4.554L59.04,275.068l.589,10.139c.36,6.203-.746,7.708-5.857,12.288l-1.477-13.103c-.048-.076-.922-.053-1.189.021l1.603,14.354-6.078,6.182-1.514-13.294-1.183.053,1.629,14.478-6.088,6.301-1.474-13.253c-.017-.073-.587-.473-.717-.338l-.494.515,1.634,14.233-9.718,10.161-.463-19.249-1.902.943Z"/>
        <path fill="#ffffff" d="M298.919,59.572c.276,3.224,1.168,6.074,2.204,9.026,2.16,6.156,4.711,11.974,7.4,17.959,6.086,13.543,12.882,26.533,19.526,39.841l-23.439-38.61c-4.11-6.442-8.219-12.707-12.752-18.811-1.875-2.524-3.751-4.794-5.971-6.944-4.892-4.739-13.586,2.872-17.91,7.246,3.126-5.608,8.67-14.951,3.291-19.349-3.952-3.231-9.751-4.655-14.659-5.984,4.837.167,14.61-.004,16.446-3.913,2.574-5.479-11.443-32.405-14.854-40.032,4.469,6.811,8.531,13.575,13.323,20.097,3.24,4.318,7.109,9.638,11.451,12.579,1.286.871,2.775.931,4.205.328,5.04-2.126,10.72-7.591,14.833-11.63,6.152-6.041,11.61-12.426,17.388-18.918-4.544,6.896-9.014,13.503-12.92,20.714-2.467,4.671-5.647,10.714-5.955,15.79-.099,1.628.557,2.988,1.887,3.893,1.342.913,2.811,1.678,4.364,2.294,9.163,3.639,19.708,5.764,29.429,7.928l30.791,5.675c-13-1.19-25.692-2.499-38.701-3.088-6.689-.303-13.097-.497-19.708-.122-2.697.153-5.285.46-7.791,1.277-1.195.389-2.002,1.319-1.879,2.757Z"/>
        <text font-family="Fraunces, Georgia, serif" font-size="70.622" fill="#ffffff" transform="translate(217.294 274.919)">
          <tspan x="0" y="0">VOCATIONAL</tspan>
          <tspan font-weight="700" x="0" y="68.482">LAB</tspan>
        </text>
      </svg>
    </a>

    {/* Links de desktop */}
    <nav class="navaula__links" aria-label="Navegación del aula">
      {links.map((l) => (
        <a href={l.href} class={activo(...l.match)}>{l.label}</a>
      ))}
      <a href="/aula/login" class="navaula__logout" data-aula-logout>Cerrar sesión</a>
      {/* Avatar → Mi perfil. El JS de abajo lo llena con la foto del
          usuario (o sus iniciales). Arranca vacío para no mostrar datos
          de un rol equivocado mientras carga. */}
      <a
        href="/aula/perfil"
        class={`navaula__perfil ${activo("/aula/perfil")}`}
        id="navaula-perfil"
        aria-label="Mi perfil"
        title="Mi perfil"
      ></a>
    </nav>

    {/* Hamburguesa para mobile */}
    <button
      class="navaula__burger"
      type="button"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="aula-menu"
      data-aula-toggle
    >
      <span class="navaula__burger-bar"></span>
      <span class="navaula__burger-bar"></span>
      <span class="navaula__burger-bar"></span>
    </button>
  </div>
</header>

{/* Backdrop oscurecido para el panel mobile */}
<div class="navaula__backdrop" data-aula-backdrop hidden></div>

{/* Panel lateral mobile */}
<aside
  id="aula-menu"
  class="navaula__panel"
  aria-label="Menú del aula"
  aria-hidden="true"
>
  <div class="navaula__panel-head">
    <span class="navaula__panel-brand">Aula</span>
    <button
      class="navaula__close"
      type="button"
      aria-label="Cerrar menú"
      data-aula-toggle
    >
      <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
        <path d="M6 6 L18 18 M18 6 L6 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" fill="none" />
      </svg>
    </button>
  </div>

  <nav class="navaula__panel-links" aria-label="Navegación mobile del aula">
    {links.map((l) => (
      <a href={l.href} data-aula-link>{l.label}</a>
    ))}
    <a href="/aula/perfil" data-aula-link>Mi perfil</a>
    <a href="/aula/login" data-aula-link data-aula-logout class="navaula__panel-logout">Cerrar sesión</a>
  </nav>
</aside>

<style>
  /* ===== Barra superior ===== */
  .navaula {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-ink);
    color: var(--color-bg);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .navaula__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.85rem;
    padding-bottom: 0.85rem;
  }

  /* Marca a la izquierda */
  .navaula__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-bg);
    line-height: 0;
  }

  /* Logo completo (texto + ícono), versión light, para el fondo oscuro del aula.
     Mismo alto que el nav del sitio público: la barra ocupa menos pantalla
     y el contenido del aula respira más. */
  .navaula__brand-logo {
    width: auto;
    height: 64px;
    display: block;
  }

  /* Links desktop */
  .navaula__links {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    font-size: 0.95rem;
  }

  .navaula__links a {
    color: rgba(242, 234, 215, 0.78);
    transition: color 0.15s ease;
  }
  .navaula__links a:hover,
  .navaula__links a.is-active {
    color: var(--color-bg);
  }

  /* Subrayado coral en la sección activa (mismo lenguaje que el nav
     del sitio público). Solo en los links de texto, no en el botón de
     logout ni en el avatar. */
  .navaula__links a:not(.navaula__logout):not(.navaula__perfil) {
    position: relative;
    padding-bottom: 2px;
  }
  .navaula__links a:not(.navaula__logout):not(.navaula__perfil)::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -3px;
    height: 2px;
    background: var(--color-accent);
    border-radius: 2px;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.22s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .navaula__links a.is-active:not(.navaula__logout):not(.navaula__perfil)::after {
    transform: scaleX(1);
  }

  /* "Cerrar sesión" se ve más sutil */
  .navaula__logout {
    padding: 0.4rem 0.85rem;
    border: 1px solid rgba(242, 234, 215, 0.35);
    border-radius: var(--radius-sm);
    color: rgba(242, 234, 215, 0.78) !important;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .navaula__logout:hover {
    background: rgba(242, 234, 215, 0.1);
    border-color: rgba(242, 234, 215, 0.6);
    color: var(--color-bg) !important;
  }

  /* ===== Avatar → Mi perfil (solo desktop) ===== */
  /* Círculo con la foto del usuario o sus iniciales. Arranca invisible
     (sin --listo) para que no haya un circulito vacío mientras carga. */
  .navaula__perfil {
    display: none;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-gold);
    color: var(--color-ink) !important;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    overflow: hidden;
    flex-shrink: 0;
    border: 2px solid transparent;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .navaula__perfil--listo { display: grid; }
  .navaula__perfil:hover { transform: scale(1.06); border-color: rgba(242, 234, 215, 0.6); }
  .navaula__perfil.is-active { border-color: var(--color-bg); }
  .navaula__perfil--con-foto { background: transparent; }
  .navaula__perfil img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  /* En mobile el nav de links está oculto (menú hamburguesa) — el avatar
     se oculta junto con su contenedor, "Mi perfil" vive en el panel. */

  /* ===== Hamburguesa ===== */
  .navaula__burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 42px;
    height: 42px;
    padding: 0;
    background: transparent;
    border: 0;
    cursor: pointer;
    color: var(--color-bg);
  }
  .navaula__burger-bar {
    display: block;
    width: 22px;
    height: 1.6px;
    margin: 0 auto;
    background: currentColor;
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }
  .navaula__burger[aria-expanded="true"] .navaula__burger-bar:nth-child(1) {
    transform: translateY(6.6px) rotate(45deg);
  }
  .navaula__burger[aria-expanded="true"] .navaula__burger-bar:nth-child(2) {
    opacity: 0;
  }
  .navaula__burger[aria-expanded="true"] .navaula__burger-bar:nth-child(3) {
    transform: translateY(-6.6px) rotate(-45deg);
  }

  /* ===== Backdrop oscurecido ===== */
  .navaula__backdrop {
    position: fixed;
    inset: 0;
    background: rgba(19, 27, 61, 0.55);
    backdrop-filter: blur(2px);
    opacity: 0;
    transition: opacity 0.25s ease;
    z-index: 60;
  }
  .navaula__backdrop[data-open="true"] {
    opacity: 1;
  }

  /* ===== Panel lateral mobile ===== */
  .navaula__panel {
    position: fixed;
    top: 0;
    right: 0;
    height: 100dvh;
    width: min(82vw, 360px);
    background: var(--color-bg);
    border-left: 1px solid var(--color-line);
    box-shadow: -20px 0 60px rgba(19, 27, 61, 0.18);
    transform: translateX(100%);
    transition: transform 0.32s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 70;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
  }
  .navaula__panel[data-open="true"] {
    transform: translateX(0);
  }

  .navaula__panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem 1.5rem;
    border-bottom: 1px solid var(--color-line);
  }

  .navaula__panel-brand {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--color-ink);
  }

  .navaula__close {
    display: inline-grid;
    place-items: center;
    width: 38px;
    height: 38px;
    padding: 0;
    background: transparent;
    border: 0;
    cursor: pointer;
    color: var(--color-ink);
    border-radius: var(--radius-sm);
  }
  .navaula__close:hover { background: var(--color-surface); }

  .navaula__panel-links {
    display: flex;
    flex-direction: column;
    padding: 1.5rem 1.5rem 2rem;
    gap: 0.25rem;
  }
  .navaula__panel-links a {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    color: var(--color-ink);
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--color-line);
  }
  .navaula__panel-logout {
    margin-top: 1.2rem;
    border-bottom: 0 !important;
    background: var(--color-ink);
    color: var(--color-bg) !important;
    text-align: center;
    border-radius: var(--radius-sm);
    padding: 0.95rem 1rem !important;
    font-family: var(--font-sans) !important;
    font-size: 1rem !important;
  }

  /* ===== Breakpoint mobile ===== */
  @media (max-width: 720px) {
    .navaula__links { display: none; }
    .navaula__burger { display: inline-flex; }
    .navaula__brand-logo { height: 56px; }
    .navaula__brand-rol { display: none; }
  }

  :global(body.aula-menu-open) { overflow: hidden; }
</style>

<script>
  /*
    Ajuste del logo + banner según el usuario REAL (no el rol que declara
    la página, que es estático de build-time). Quién está logueado se sabe
    recién en el cliente, así que:
      · El logo siempre lleva al panel del usuario real. Un admin que entra a
        una página de profe vuelve a /aula/admin, no a /aula/profe.
      · Si el usuario tiene más permisos que el área que está viendo (ej: un
        admin en páginas de profe), mostramos un banner con "Volver a tu panel"
        para que sepa que está actuando en otro panel y cómo volver.
  */
  (async () => {
    const { supabase } = await import("../../lib/supabase");
    const { data: sesion } = await supabase.auth.getSession();
    const uid = sesion.session?.user?.id;
    if (!uid) return;

    const { data: perfil } = await supabase
      .from("profiles").select("rol, nombre, avatar_url").eq("id", uid).single();
    const rolReal = perfil?.rol as "alumno" | "profe" | "admin" | undefined;
    if (!rolReal) return;

    // 0) Avatar del nav (desktop): foto si subió una, iniciales si no.
    //    El <a> arranca vacío para no mostrar datos incorrectos en el flash
    //    de carga; recién acá sabemos quién es de verdad.
    const $perfil = document.getElementById("navaula-perfil");
    if ($perfil && perfil) {
      if (perfil.avatar_url) {
        const img = document.createElement("img");
        img.src = perfil.avatar_url;
        img.alt = "";
        $perfil.appendChild(img);
        $perfil.classList.add("navaula__perfil--con-foto");
      } else {
        $perfil.textContent = (perfil.nombre ?? "?")
          .split(" ").map((n: string) => n[0]).join("").slice(0, 2).toUpperCase();
      }
      $perfil.classList.add("navaula__perfil--listo");
    }

    const homePorRol = {
      alumno: "/aula/mis-cursos",
      profe: "/aula/profe",
      admin: "/aula/admin",
    } as const;

    // 1) El logo siempre lleva al panel del usuario real.
    const brand = document.querySelector<HTMLAnchorElement>(".navaula__brand");
    if (brand) brand.href = homePorRol[rolReal];

    // 2) Banner de "vista previa" cuando el usuario baja a un área de menor
    //    permiso (admin viendo profe/alumno, o profe viendo alumno).
    const orden = { alumno: 0, profe: 1, admin: 2 };
    const areaPagina = (document.querySelector(".navaula")?.getAttribute("data-rol")
      ?? "alumno") as "alumno" | "profe" | "admin";

    // "Mi perfil" es una página compartida por todos los roles (declara
    // alumno solo para mostrar un nav), no es una vista previa de otro panel:
    // ahí no mostramos el banner.
    const esPaginaCompartida = location.pathname.startsWith("/aula/perfil");

    if (orden[rolReal] > orden[areaPagina] && !esPaginaCompartida && !document.querySelector(".preview-banner")) {
      const labelRol = rolReal === "admin" ? "Administrador" : "Profesor";
      const texto = areaPagina === "alumno"
        ? `Estás viendo el aula como protagonista · sos <strong>${labelRol}</strong>.`
        : `Estás viendo el panel de profe · sos <strong>${labelRol}</strong>.`;
      const banner = document.createElement("div");
      banner.className = "preview-banner";
      banner.innerHTML = `
        <span class="preview-banner__icono" aria-hidden="true">&#128065;</span>
        <span class="preview-banner__texto">${texto}</span>
        <a href="${homePorRol[rolReal]}" class="preview-banner__link">Volver a tu panel &rarr;</a>`;
      document.body.insertBefore(banner, document.body.firstChild);
    }
  })();

  // Lógica del menú mobile del aula (mismo patrón que el nav público).
  const toggles = document.querySelectorAll<HTMLElement>('[data-aula-toggle]');
  const panel = document.getElementById('aula-menu');
  const backdrop = document.querySelector<HTMLElement>('[data-aula-backdrop]');
  const burger = document.querySelector<HTMLElement>('.navaula__burger');
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-aula-link]');

  function setMenu(open: boolean) {
    if (!panel || !backdrop || !burger) return;
    panel.dataset.open = String(open);
    panel.setAttribute('aria-hidden', String(!open));
    if (open) {
      backdrop.hidden = false;
      void backdrop.offsetWidth;
      backdrop.dataset.open = 'true';
    } else {
      backdrop.dataset.open = 'false';
      setTimeout(() => { if (backdrop.dataset.open !== 'true') backdrop.hidden = true; }, 280);
    }
    burger.setAttribute('aria-expanded', String(open));
    burger.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
    document.body.classList.toggle('aula-menu-open', open);
  }

  toggles.forEach((el) => el.addEventListener('click', () => {
    const isOpen = panel?.dataset.open === 'true';
    setMenu(!isOpen);
  }));
  backdrop?.addEventListener('click', () => setMenu(false));
  links.forEach((l) => l.addEventListener('click', () => setMenu(false)));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && panel?.dataset.open === 'true') setMenu(false);
  });

  // Cerrar sesión real: pide confirmación y después signOut.
  Promise.all([
    import("../../lib/supabase"),
    import("../../lib/ui"),
  ]).then(([{ supabase }, { confirmModal }]) => {
    document.querySelectorAll<HTMLAnchorElement>('[data-aula-logout]').forEach((el) => {
      el.addEventListener('click', async (e) => {
        e.preventDefault();
        // Si el panel mobile estaba abierto, cerramos primero.
        document.body.classList.remove('aula-menu-open');
        const ok = await confirmModal({
          titulo: 'Cerrar sesión',
          mensaje: '¿Querés salir del aula?',
          confirmLabel: 'Cerrar sesión',
        });
        if (!ok) return;
        await supabase.auth.signOut();
        window.location.href = '/aula/login';
      });
    });
  });
</script>
