    border-radius: var(--radius-sm);
    color: var(--color-accent);
    font-size: 0.92rem;
  }

  .prot__h2 {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    margin: 1.8rem 0 0.5rem;
