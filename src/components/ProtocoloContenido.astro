  }
  .prot__h2:first-of-type {
    margin-top: 0.5rem;
  }

  .prot p {
    margin: 0 0 0.9rem;
  }

  .prot ul {
    margin: 0 0 0.9rem;
    padding-left: 1.4rem;
  }
  .prot li {
    margin-bottom: 0.35rem;
  }

  .prot a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
