---
/*
  Layout principal del sitio.
  ---
  Toda página del sitio se envuelve en este layout. Acá viven:
    · el <head> con meta tags, fuentes, favicon y SEO completo
    · los estilos globales (importados desde src/styles/global.css)
    · el <slot /> donde se inserta el contenido de cada página

  PENDIENTES antes del lanzamiento:
    · Reemplazar SITE_URL con el dominio real una vez comprado.
    · Agregar public/og-image.png (1200×630px) para el preview en redes.
*/

import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Vocational Lab · Donde futuro y vocación se encuentran",
  description = "Programa de orientación vocacional para jóvenes que quieren explorar su futuro con método, con pares y desde el rol protagonista de su propia historia.",
} = Astro.props;

// ⚠️ Reemplazar con el dominio real antes de lanzar
const SITE_URL = "https://vocationallab.com";
const canonicalURL = new URL(Astro.url.pathname, SITE_URL).toString();
const ogImage = `${SITE_URL}/og-image.png`;

// Datos estructurados JSON-LD — le dice a Google qué es este sitio
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  "name": "Vocational Lab",
  "description": description,
  "url": SITE_URL,
  "inLanguage": "es",
  "areaServed": {
    "@type": "Country",
    "name": "Argentina"
  },
  "founders": [
    { "@type": "Person", "name": "Julia Vargas" },
    { "@type": "Person", "name": "Laura Pires" }
  ],
  "knowsAbout": [
    "orientación vocacional",
    "coaching ontológico",
    "desarrollo profesional",
    "futuro del trabajo"
  ]
};
---

<!doctype html>
<html lang="es-AR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- ===== SEO básico ===== -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <!-- ===== Open Graph — preview al compartir en redes ===== -->
    <!-- ⚠️ og:image requiere public/og-image.png (1200×630px) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Vocational Lab" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Vocational Lab — Orientación vocacional" />
    <meta property="og:locale" content="es_AR" />

    <!-- ===== Twitter / X Card ===== -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- ===== Favicon e íconos ===== -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/favicon.ico" />

    <!-- ===== Color de la barra del navegador en mobile ===== -->
    <meta name="theme-color" content="#131B3D" />

    <!-- ===== Datos estructurados para Google (JSON-LD) ===== -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- ===== Fuentes: Fraunces (serif) e Inter (sans) ===== -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600&display=swap"
    />
  </head>

  <body>
    <slot />
  </body>

  <script>
    /*
      IntersectionObserver global — activa las clases .visible en los
      elementos con [data-animate] y [data-stagger] cuando entran al
      viewport. Se dispara una sola vez por elemento y luego se desconecta.
      Ver src/styles/global.css para las reglas CSS que hacen el efecto.
    */
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            observer.unobserve(entry.target);
          }
        }
      },
      {
        threshold: 0.12,
        rootMargin: "0px 0px -50px 0px",
      }
    );

    document
      .querySelectorAll("[data-animate], [data-stagger]")
      .forEach((el) => observer.observe(el));
  </script>
</html>
