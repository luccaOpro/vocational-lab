---
/*
  /inscripcion — formulario único de embudo para los 3 canales.
  ---
  Esta es la URL a la que apuntan TODOS los caminos de "Quiero
  más info / Quiero anotarme / Prefiero hablar primero",
  vengan desde el sitio web, desde WhatsApp o desde Instagram.

  El form arranca con un selector de intención. Si el usuario
  elige "Quiero anotarme", aparece el bloque de firma del
  protocolo (checkbox obligatorio + link al PDF).

  Para menores: el form pregunta primero "Soy mayor de 18 / Soy
  responsable de un menor". Si es responsable, pide datos del
  menor también. El adulto es quien firma.

  Al enviar, INSERT en public.solicitudes_inscripcion con todos
  los datos + la versión del protocolo aceptado + user-agent.

  Query param soportado: ?canal=whatsapp|instagram|web|otro
  (default = web). Lo usamos para trackear de dónde vienen.

  Constante a editar cuando suban una nueva versión del PDF:
  PROTOCOLO_VERSION_ACTUAL en el <script> de abajo.
*/

import Layout from "../layouts/Layout.astro";
import Nav from "../components/sections/Nav.astro";
import Footer from "../components/sections/Footer.astro";
import ProtocoloContenido from "../components/ProtocoloContenido.astro";
---

<Layout title="Inscripción · Vocational Lab" description="Reserva tu lugar en Vocational Lab. Programa de orientación vocacional para jóvenes.">
  <Nav />

  <main id="contenido" tabindex="-1" class="inscripcion section">
    <div class="container inscripcion__inner">

      {/* ============ HEADER ============ */}
      <header class="inscripcion__head" data-animate>
        <p class="eyebrow">Inscripción y contacto</p>
        <h1>Reserva tu lugar</h1>
        <p class="inscripcion__sub">
          Próxima edición — Agosto 2026 · Grupos reducidos · 100% online
        </p>
      </header>

      {/* ============ FORM ============ */}
      <form id="inscripcion-form" class="ins-form" novalidate>

        {/* Honeypot anti-bot: invisible para personas (queda fuera de pantalla
            y sin tab). Si llega con texto, es un bot → descartamos el envío.
            No usar display:none: algunos bots ignoran esos campos. */}
        <div class="ins-form__hp" aria-hidden="true">
          <label>No completes este campo
            <input type="text" name="sitio_web" tabindex="-1" autocomplete="off" />
          </label>
        </div>

        {/* ─── PASO 1 · Intención ─── */}
        <fieldset class="ins-form__fieldset">
          <legend class="ins-form__legend">¿Qué te trae aquí? <span class="ins-form__required" aria-hidden="true">*</span></legend>

          <div class="ins-form__radios" role="radiogroup">
            <label class="ins-form__radio">
              <input type="radio" name="intencion" value="info" required />
              <span class="ins-form__radio-label">
                <strong>Quiero más información</strong>
                <small>Te enviamos toda la info del programa por mail.</small>
              </span>
            </label>

            <label class="ins-form__radio">
              <input type="radio" name="intencion" value="inscripcion" required />
              <span class="ins-form__radio-label">
                <strong>Quiero anotarme</strong>
                <small>Reservas tu lugar y coordinamos el pago.</small>
              </span>
            </label>
          </div>
        </fieldset>

        {/* ─── PASO 2 · Datos de contacto (siempre visibles) ─── */}
        <fieldset class="ins-form__fieldset">
          <legend class="ins-form__legend">Tus datos</legend>

          <div class="ins-form__grid">
            <label class="ins-form__field">
              <span class="ins-form__label">Nombre y apellido <span class="ins-form__required" aria-hidden="true">*</span></span>
              <input type="text" name="nombre" required autocomplete="name" minlength="3" maxlength="60" />
            </label>

            <label class="ins-form__field">
              <span class="ins-form__label">Email <span class="ins-form__required" aria-hidden="true">*</span></span>
              <input type="email" name="email" required autocomplete="email" maxlength="80" />
            </label>

            {/* Teléfono internacional: select de país (código) + input numérico.
                El código y el número se concatenan al enviar el form para
                guardarlo como un solo string formateado en la base.
                El asterisco "*" se muestra/oculta por JS según el canal
                preferido elegido (obligatorio solo si eligen WhatsApp). */}
            <div class="ins-form__field">
              <span class="ins-form__label">Teléfono <span class="ins-form__required" id="tel-asterisco" aria-hidden="true" hidden>*</span></span>
              <div class="ins-form__tel-grid">
                <select name="telefono_codigo" class="ins-form__tel-codigo" aria-label="Código de país">
                  <option value="+54">🇦🇷 Argentina (+54)</option>
                  <option value="+591">🇧🇴 Bolivia (+591)</option>
                  <option value="+55">🇧🇷 Brasil (+55)</option>
                  <option value="+56">🇨🇱 Chile (+56)</option>
                  <option value="+57">🇨🇴 Colombia (+57)</option>
                  <option value="+506">🇨🇷 Costa Rica (+506)</option>
                  <option value="+593">🇪🇨 Ecuador (+593)</option>
                  <option value="+503">🇸🇻 El Salvador (+503)</option>
                  <option value="+34">🇪🇸 España (+34)</option>
                  <option value="+1">🇺🇸 Estados Unidos (+1)</option>
                  <option value="+502">🇬🇹 Guatemala (+502)</option>
                  <option value="+504">🇭🇳 Honduras (+504)</option>
                  <option value="+52">🇲🇽 México (+52)</option>
                  <option value="+505">🇳🇮 Nicaragua (+505)</option>
                  <option value="+507">🇵🇦 Panamá (+507)</option>
                  <option value="+595">🇵🇾 Paraguay (+595)</option>
                  <option value="+51">🇵🇪 Perú (+51)</option>
                  <option value="+1809">🇩🇴 Rep. Dominicana (+1)</option>
                  <option value="+598">🇺🇾 Uruguay (+598)</option>
                  <option value="+58">🇻🇪 Venezuela (+58)</option>
                </select>
                <input
                  type="tel"
                  name="telefono_numero"
                  class="ins-form__tel-numero"
                  inputmode="numeric"
                  autocomplete="tel-national"
                  placeholder="11 5555 5555"
                  maxlength="20"
                  aria-label="Número de teléfono"
                />
              </div>
            </div>

            <label class="ins-form__field">
              <span class="ins-form__label">País</span>
              <input type="text" name="pais" autocomplete="country-name" maxlength="40" />
            </label>

            <label class="ins-form__field ins-form__field--full">
              <span class="ins-form__label">¿Cómo nos encontraste?</span>
              <input type="text" name="origen" placeholder="Instagram, una amiga, búsqueda en Google…" />
            </label>
          </div>
        </fieldset>

        {/* ─── PASO 3 · Canal preferido para recibir respuesta ─── */}
        <fieldset class="ins-form__fieldset">
          <legend class="ins-form__legend">¿Cómo prefieres que te contactemos? <span class="ins-form__required" aria-hidden="true">*</span></legend>

          <div class="ins-form__radios" role="radiogroup">
            <label class="ins-form__radio">
              <input type="radio" name="canal_preferido_respuesta" value="mail" required />
              <span class="ins-form__radio-label">
                <strong>Por mail</strong>
                <small>Recibes la información en tu casilla de email.</small>
              </span>
            </label>

            <label class="ins-form__radio">
              <input type="radio" name="canal_preferido_respuesta" value="whatsapp" required />
              <span class="ins-form__radio-label">
                <strong>Por WhatsApp</strong>
                <small>Te escribimos directamente. Hace falta el teléfono completo.</small>
              </span>
            </label>
          </div>
        </fieldset>

        {/* ─── PASO 4 · Bloque condicional (solo cuando intencion = inscripcion) ─── */}
        <div id="bloque-inscripcion" hidden>
          <fieldset class="ins-form__fieldset">
            <legend class="ins-form__legend">¿Quién se inscribe? <span class="ins-form__required" aria-hidden="true">*</span></legend>

            <div class="ins-form__radios" role="radiogroup">
              <label class="ins-form__radio">
                <input type="radio" name="rol_solicitante" value="mayor" />
                <span class="ins-form__radio-label">
                  <strong>Soy mayor de edad</strong>
                  <small>Me inscribo a mí mismo/a.</small>
                </span>
              </label>

              <label class="ins-form__radio">
                <input type="radio" name="rol_solicitante" value="responsable_menor" />
                <span class="ins-form__radio-label">
                  <strong>Soy responsable de un menor</strong>
                  <small>Inscribo a mi hijo/a o a un menor a mi cargo.</small>
                </span>
              </label>
            </div>
          </fieldset>

          {/* Sub-bloque para el participante mayor de edad (rol = mayor).
              El nombre/email/teléfono/país ya se pidieron arriba; acá
              solo falta la edad que exige el protocolo (sección 11). */}
          <fieldset id="bloque-mayor" class="ins-form__fieldset" hidden>
            <legend class="ins-form__legend">Tu edad</legend>

            <div class="ins-form__grid">
              <label class="ins-form__field">
                <span class="ins-form__label">Edad <span class="ins-form__required" aria-hidden="true">*</span></span>
                <input type="text" name="edad" inputmode="numeric" maxlength="3" autocomplete="off" />
              </label>
            </div>
          </fieldset>

          {/* Sub-bloque para datos del menor + del tutor (rol = responsable_menor).
              El nombre/email/teléfono de arriba corresponden al adulto
              responsable; acá pedimos los datos del menor y los del tutor
              que faltan según el protocolo (sección 12). */}
          <fieldset id="bloque-menor" class="ins-form__fieldset" hidden>
            <legend class="ins-form__legend">Datos del menor</legend>

            <div class="ins-form__grid">
              <label class="ins-form__field">
                <span class="ins-form__label">Nombre completo del menor <span class="ins-form__required" aria-hidden="true">*</span></span>
                <input type="text" name="nombre_menor" autocomplete="off" maxlength="60" />
              </label>

              <label class="ins-form__field">
                <span class="ins-form__label">Fecha de nacimiento <span class="ins-form__required" aria-hidden="true">*</span></span>
                <input type="date" name="fecha_nacimiento_menor" />
              </label>

              {/* Email propio del/la participante: lo usamos para enviarle
                  las indicaciones de acceso al campus virtual (pedido
                  Julia y Laura, 2026-06-11). */}
              <label class="ins-form__field ins-form__field--full">
                <span class="ins-form__label">Email del/de la participante <span class="ins-form__required" aria-hidden="true">*</span></span>
                <input type="email" name="email_menor" autocomplete="off" maxlength="80" />
                <small class="ins-form__ayuda">A esta casilla le enviaremos las indicaciones de acceso al campus virtual.</small>
              </label>
            </div>

            <p class="ins-form__nota">Tus datos como representante legal:</p>

            <div class="ins-form__grid">
              <label class="ins-form__field">
                <span class="ins-form__label">Tu vínculo con el menor <span class="ins-form__required" aria-hidden="true">*</span></span>
                <input type="text" name="vinculo_menor" placeholder="Madre, padre, tutor/a…" autocomplete="off" maxlength="30" />
              </label>

              <label class="ins-form__field">
                <span class="ins-form__label">Tu DNI / documento <span class="ins-form__required" aria-hidden="true">*</span></span>
                <input type="text" name="dni_tutor" inputmode="text" autocomplete="off" maxlength="15" placeholder="Sin puntos ni espacios" />
              </label>
            </div>
          </fieldset>

          {/* Contacto de emergencia. Para mayores es obligatorio (protocolo
              sección 11). Para menores el tutor ya es el contacto principal,
              así que este es un contacto ADICIONAL y opcional (sección 12).
              El texto del legend y la nota se ajustan por JS según el rol. */}
          {/* Las clases de los asteriscos del contacto de emergencia
              se togglean por JS según el rol: para mayor son obligatorios,
              para responsable_menor son opcionales (el tutor ya es el
              contacto principal). */}
          <fieldset id="bloque-emergencia" class="ins-form__fieldset" hidden>
            <legend class="ins-form__legend" id="emergencia-legend">Contacto de familiar o persona cercana que te acompañará en el proceso</legend>
            <p class="ins-form__nota" id="emergencia-nota">
              Una persona a la que podamos contactar si hiciera falta durante el programa.
            </p>

            <div class="ins-form__grid">
              <label class="ins-form__field">
                <span class="ins-form__label">Nombre y apellido <span class="ins-form__required" data-emergencia-asterisco aria-hidden="true">*</span></span>
                <input type="text" name="contacto_emergencia_nombre" autocomplete="off" maxlength="60" />
              </label>

              <label class="ins-form__field">
                <span class="ins-form__label">Teléfono <span class="ins-form__required" data-emergencia-asterisco aria-hidden="true">*</span></span>
                <input type="tel" name="contacto_emergencia_telefono" inputmode="tel" autocomplete="off" placeholder="+54 11 5555 5555" maxlength="20" />
              </label>

              <label class="ins-form__field ins-form__field--full">
                <span class="ins-form__label">Vínculo <span class="ins-form__required" data-emergencia-asterisco aria-hidden="true">*</span></span>
                <input type="text" name="contacto_emergencia_vinculo" placeholder="Madre, pareja, amigo/a…" autocomplete="off" maxlength="30" />
              </label>
            </div>
          </fieldset>

          {/* Protocolo + checkbox.
              Usamos un h3 en vez de <legend> porque este fieldset tiene fondo
              y borde, y el <legend> nativo se renderiza cortando el borde
              superior — quedaba sobresaliendo del cuadro. El fieldset usa
              aria-labelledby para mantener la accesibilidad. */}
          <fieldset class="ins-form__fieldset ins-form__fieldset--protocolo" aria-labelledby="protocolo-titulo">
            <h3 id="protocolo-titulo" class="ins-form__legend">Protocolo <span class="ins-form__required" aria-hidden="true">*</span></h3>

            <p class="ins-form__nota">
              Lee el protocolo del programa. Cubre la modalidad, cómo
              cuidamos tus datos, la confidencialidad y los compromisos
              mutuos. El checkbox se habilita cuando termines de leerlo.
            </p>

            {/* Panel scrolleable con el contenido del protocolo.
                JS detecta cuando llegás al final y recién ahí habilita
                el checkbox de abajo. */}
            <div id="protocolo-panel" class="ins-form__protocolo-panel">
              <div id="protocolo-scroll" class="ins-form__protocolo-scroll">
                <ProtocoloContenido />
              </div>
              <div class="ins-form__protocolo-fade" aria-hidden="true"></div>
            </div>

            <p id="protocolo-hint" class="ins-form__protocolo-hint">
              ↓ Haz scroll hasta el final para habilitar el checkbox.
              <a href="/protocolo" target="_blank" rel="noopener">Abrir en otra pestaña</a>
            </p>

            <label class="ins-form__checkbox" id="protocolo-checkbox-label">
              <input type="checkbox" name="protocolo_aceptado" disabled />
              <span>He leído y acepto el Protocolo del programa.</span>
            </label>
          </fieldset>
        </div>

        {/* ─── Mensajes y submit ─── */}
        <p id="ins-error" class="ins-form__msg ins-form__msg--error" hidden></p>

        <button type="submit" id="ins-submit" class="btn btn-primary ins-form__submit">
          Enviar →
        </button>
      </form>

      {/* ============ CONFIRMACIÓN (oculta al inicio) ============ */}
      <div id="ins-confirmacion" class="ins-confirm" hidden>
        <h2>¡Listo!</h2>
        <p id="ins-confirm-texto"></p>
        <a href="/" class="ins-confirm__back">← Volver al inicio</a>
      </div>

    </div>
  </main>

  <Footer />
</Layout>


<script>
  import { supabase } from "../lib/supabase";

  /*
    Versión del protocolo que se guarda en la base junto con
    la aceptación. Cambiar cuando se edite el texto del protocolo
    en src/components/ProtocoloContenido.astro (ej: "v1" → "v2").
    El contenido histórico de cada versión queda en git log.
  */
  const PROTOCOLO_VERSION_ACTUAL = "v1";

  // Momento en que cargó el formulario. Sirve para el chequeo anti-bot:
  // un envío hecho en menos de ~1.5s es casi seguro automático.
  const formCargadoEn = Date.now();

  // ============ Referencias DOM ============
  const $form = document.getElementById("inscripcion-form") as HTMLFormElement;
  const $submit = document.getElementById("ins-submit") as HTMLButtonElement;
  const $error = document.getElementById("ins-error") as HTMLElement;
  const $confirm = document.getElementById("ins-confirmacion") as HTMLElement;
  const $confirmTexto = document.getElementById("ins-confirm-texto") as HTMLElement;
  const $bloqueInscripcion = document.getElementById("bloque-inscripcion") as HTMLElement;
  const $bloqueMayor = document.getElementById("bloque-mayor") as HTMLElement;
  const $bloqueMenor = document.getElementById("bloque-menor") as HTMLElement;
  const $bloqueEmergencia = document.getElementById("bloque-emergencia") as HTMLElement;
  const $emergenciaLegend = document.getElementById("emergencia-legend") as HTMLElement;
  const $emergenciaNota = document.getElementById("emergencia-nota") as HTMLElement;

  // ============ Filtrado de caracteres por campo ============
  /*
    Cada campo solo acepta lo que corresponde, filtrando en vivo lo que se
    escribe (sin esperar al submit): el teléfono solo números, los nombres
    solo letras, el documento solo letras y números, etc. Mantenemos la
    posición del cursor para poder editar en el medio sin saltos molestos.
  */
  function filtrarCampo(name: string, limpiar: (v: string) => string) {
    const el = $form.querySelector(`[name="${name}"]`) as HTMLInputElement | null;
    if (!el) return;
    el.addEventListener("input", () => {
      const pos = el.selectionStart ?? el.value.length;
      const antes = el.value;
      const despues = limpiar(antes);
      if (antes !== despues) {
        el.value = despues;
        const nuevaPos = Math.max(0, pos - (antes.length - despues.length));
        try { el.setSelectionRange(nuevaPos, nuevaPos); } catch { /* inputs sin selección */ }
      }
    });
  }

  // Limpiadores reutilizables (usan \p{L} para aceptar acentos y ñ).
  const soloLetras = (v: string) => v.replace(/[^\p{L}\s'.\-]/gu, "");        // nombres
  const soloVinculo = (v: string) => v.replace(/[^\p{L}\s/\-]/gu, "");        // vínculos (permite "/")
  const soloPais = (v: string) => v.replace(/[^\p{L}\s.\-]/gu, "");           // país
  const soloTel = (v: string) => v.replace(/[^\d\s]/g, "");                   // teléfono nacional
  const soloTelIntl = (v: string) => v.replace(/[^\d\s+]/g, "");             // teléfono con prefijo
  const soloDoc = (v: string) => v.replace(/[^\p{L}\d]/gu, "").toUpperCase(); // DNI / pasaporte
  const soloEdad = (v: string) => v.replace(/\D/g, "").slice(0, 3);          // edad

  filtrarCampo("nombre", soloLetras);
  filtrarCampo("pais", soloPais);
  filtrarCampo("telefono_numero", soloTel);
  filtrarCampo("edad", soloEdad);
  filtrarCampo("nombre_menor", soloLetras);
  filtrarCampo("vinculo_menor", soloVinculo);
  filtrarCampo("dni_tutor", soloDoc);
  filtrarCampo("contacto_emergencia_nombre", soloLetras);
  filtrarCampo("contacto_emergencia_telefono", soloTelIntl);
  filtrarCampo("contacto_emergencia_vinculo", soloVinculo);

  // ============ País autocompletado desde el prefijo telefónico ============
  // El selector de prefijo ya dice el país: cuando el usuario lo cambia,
  // copiamos el nombre al campo "País" para que no lo tipee dos veces.
  // Solo si el campo está vacío o si lo llenamos nosotros antes (si la
  // persona escribió su país a mano, no se lo pisamos).
  {
    const $codigo = $form.querySelector<HTMLSelectElement>('[name="telefono_codigo"]');
    const $pais = $form.querySelector<HTMLInputElement>('[name="pais"]');
    if ($codigo && $pais) {
      $codigo.addEventListener("change", () => {
        const escribioAMano = $pais.value.trim() !== "" && $pais.dataset.autocompletado !== "true";
        if (escribioAMano) return;
        // El texto de la opción es "🇦🇷 Argentina (+54)": sacamos bandera y código.
        const texto = $codigo.options[$codigo.selectedIndex]?.text ?? "";
        const nombre = texto.replace(/\s*\(\+[\d\s]+\)\s*$/, "").replace(/^[^\p{L}]+/u, "").trim();
        if (nombre) {
          $pais.value = nombre;
          $pais.dataset.autocompletado = "true";
        }
      });
      // Si después edita el campo a mano, dejamos de autocompletar.
      $pais.addEventListener("input", () => {
        delete $pais.dataset.autocompletado;
      });
    }
  }

  // Fecha de nacimiento del menor: no puede ser futura ni absurdamente vieja.
  const $fechaMenor = $form.querySelector('[name="fecha_nacimiento_menor"]') as HTMLInputElement | null;
  if ($fechaMenor) {
    const hoy = new Date();
    const piso = new Date(hoy);
    piso.setFullYear(piso.getFullYear() - 25);
    $fechaMenor.max = hoy.toISOString().split("T")[0];
    $fechaMenor.min = piso.toISOString().split("T")[0];
  }

  // Cuenta solo los dígitos de un string (para validar largos de teléfono).
  function contarDigitos(s: string) {
    return (s.match(/\d/g) || []).length;
  }

  // Protocolo: panel scrolleable + checkbox que arranca disabled
  const $protocoloScroll = document.getElementById("protocolo-scroll") as HTMLElement;
  const $protocoloPanel = document.getElementById("protocolo-panel") as HTMLElement;
  const $protocoloHint = document.getElementById("protocolo-hint") as HTMLElement;
  const $protocoloCheckboxLabel = document.getElementById("protocolo-checkbox-label") as HTMLElement;
  const $protocoloCheckbox = $protocoloCheckboxLabel.querySelector(
    'input[name="protocolo_aceptado"]'
  ) as HTMLInputElement;

  /*
    Cuando el usuario hace scroll dentro del panel del protocolo
    y llega al final (o se acerca lo suficiente), habilitamos el
    checkbox. Una vez habilitado, queda habilitado para siempre
    en esa sesión.
  */
  let protocoloLeido = false;
  function chequearProtocoloLeido() {
    if (protocoloLeido) return;
    const dist = $protocoloScroll.scrollHeight - $protocoloScroll.scrollTop - $protocoloScroll.clientHeight;
    if (dist <= 10) {
      protocoloLeido = true;
      $protocoloCheckbox.disabled = false;
      $protocoloPanel.classList.add("ins-form__protocolo-panel--leido");
      $protocoloHint.textContent = "✓ Listo. Ya puedes marcar el checkbox.";
      $protocoloHint.classList.add("ins-form__protocolo-hint--leido");
    }
  }
  $protocoloScroll.addEventListener("scroll", chequearProtocoloLeido);

  /*
    Edge case: si el panel del protocolo arranca con su contenido
    completamente visible (sin scroll necesario), igual habilitamos
    el checkbox al momento de mostrarlo por primera vez.
  */
  function chequearProtocoloSinScroll() {
    if (protocoloLeido) return;
    if ($protocoloScroll.scrollHeight <= $protocoloScroll.clientHeight + 10) {
      chequearProtocoloLeido();
    }
  }

  // ============ Canal (query param) ============
  function detectarCanal(): "web" | "whatsapp" | "instagram" | "otro" {
    const param = new URLSearchParams(window.location.search).get("canal");
    if (param === "whatsapp" || param === "instagram" || param === "otro") return param;
    return "web";
  }

  // ============ Mostrar/ocultar bloques según selección ============
  function actualizarVisibilidad() {
    const intencion = ($form.elements.namedItem("intencion") as RadioNodeList)?.value;
    const rol = ($form.elements.namedItem("rol_solicitante") as RadioNodeList)?.value;
    const canalPreferido = ($form.elements.namedItem("canal_preferido_respuesta") as RadioNodeList)?.value;

    // Bloque grande de inscripción solo si la intención es "inscripcion"
    const inscripcionVisible = intencion === "inscripcion";
    $bloqueInscripcion.hidden = !inscripcionVisible;

    const esMayor = inscripcionVisible && rol === "mayor";
    const esMenor = inscripcionVisible && rol === "responsable_menor";

    // "Tu edad" solo para mayores; "datos del menor" solo para responsables.
    $bloqueMayor.hidden = !esMayor;
    $bloqueMenor.hidden = !esMenor;

    // Contacto de emergencia: visible apenas se elige un rol. El texto y la
    // obligatoriedad cambian según quién se inscribe.
    //  - Mayor: contacto obligatorio → asteriscos visibles.
    //  - Menor: el tutor ya es el contacto principal → este es adicional y opcional → asteriscos ocultos.
    $bloqueEmergencia.hidden = !(esMayor || esMenor);
    if (esMenor) {
      $emergenciaLegend.textContent = "Contacto adicional de familiar o persona cercana (opcional)";
      $emergenciaNota.textContent =
        "Como representante legal eres el contacto principal. Si quieres sumar un segundo contacto, complétalo aquí.";
    } else {
      $emergenciaLegend.textContent = "Contacto de familiar o persona cercana que te acompañará en el proceso";
      $emergenciaNota.textContent =
        "Un familiar o persona cercana que te acompañará durante el programa y a quien podamos contactar si hiciera falta.";
    }
    document.querySelectorAll<HTMLElement>("[data-emergencia-asterisco]").forEach((a) => {
      a.hidden = !esMayor;
    });

    // Asterisco del teléfono: solo obligatorio si canal preferido = whatsapp.
    const $telAst = document.getElementById("tel-asterisco");
    if ($telAst) $telAst.hidden = canalPreferido !== "whatsapp";

    // Si recién se hizo visible el bloque, chequeamos si el panel
    // del protocolo entra entero en pantalla sin necesidad de scroll.
    if (inscripcionVisible) {
      requestAnimationFrame(chequearProtocoloSinScroll);
    }
  }

  $form.addEventListener("change", actualizarVisibilidad);

  // ============ Validadores ============
  /** Email: regex pragmático que cubre 99% de los casos reales. */
  const EMAIL_REGEX = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;

  /**
   * Nombre completo: al menos 2 palabras separadas por espacio,
   * cada una con al menos 2 caracteres. Solo acepta letras (incluye
   * acentos y ñ), apóstrofo y guión.
   */
  const NOMBRE_COMPLETO_REGEX = /^[\p{L}][\p{L}'\-]+(\s+[\p{L}][\p{L}'\-]+)+$/u;

  // ============ Helpers de mensaje ============
  /**
   * Muestra el mensaje de error y, si se pasa el `campoName`, scrollea
   * hasta el campo problemático y le da focus.
   *
   * @param msg        texto a mostrar
   * @param campoName  atributo name del input/select/checkbox/radio
   */
  function mostrarError(msg: string, campoName?: string) {
    $error.textContent = msg;
    $error.hidden = false;

    if (campoName) {
      const el = $form.querySelector<HTMLElement>(`[name="${campoName}"]`);
      if (el) {
        const contenedor =
          el.closest(".ins-form__field, .ins-form__fieldset, .ins-form__fieldset--protocolo, .ins-form__radio") ?? el;
        contenedor.scrollIntoView({ behavior: "smooth", block: "center" });
        // Focus después del scroll para que el browser no nos recentre.
        setTimeout(() => {
          try {
            (el as HTMLInputElement).focus({ preventScroll: true });
          } catch { /* algunos elementos no aceptan focus */ }
        }, 350);
        return;
      }
    }
    $error.scrollIntoView({ behavior: "smooth", block: "center" });
  }
  function ocultarError() {
    $error.hidden = true;
    $error.textContent = "";
  }

  // ============ Submit ============
  $form.addEventListener("submit", async (e) => {
    e.preventDefault();
    ocultarError();

    const fd = new FormData($form);

    // ── Anti-spam (honeypot + tiempo mínimo) ──
    // Si el honeypot vino con texto, o el form se envió demasiado rápido,
    // es casi seguro un bot: simulamos éxito sin guardar nada (no le damos
    // ninguna pista de que lo detectamos, así no reintenta).
    const honeypot = String(fd.get("sitio_web") ?? "").trim();
    if (honeypot !== "" || Date.now() - formCargadoEn < 1500) {
      $confirmTexto.textContent = "Recibimos tu mensaje. Te contactamos pronto.";
      $form.hidden = true;
      $confirm.hidden = false;
      window.scrollTo({ top: 0, behavior: "smooth" });
      return;
    }

    const intencion = String(fd.get("intencion") ?? "");
    const nombre = String(fd.get("nombre") ?? "").trim();
    const email = String(fd.get("email") ?? "").trim().toLowerCase();

    // Teléfono internacional: armamos el string "+CC NUMERO".
    // Si el usuario no escribió ningún dígito en el número, dejamos
    // todo como null (para no guardar solo el código suelto).
    const telCodigo = String(fd.get("telefono_codigo") ?? "+54").trim();
    const telNumero = String(fd.get("telefono_numero") ?? "").trim();
    const telefono = telNumero ? `${telCodigo} ${telNumero}` : null;

    const pais = String(fd.get("pais") ?? "").trim() || null;
    const origen = String(fd.get("origen") ?? "").trim() || null;
    const canalPreferido = String(fd.get("canal_preferido_respuesta") ?? "");

    // Validaciones básicas — cada error scrollea al campo problemático.
    if (!intencion) return mostrarError("Elige qué te trae aquí.", "intencion");
    if (!nombre) return mostrarError("Necesitamos tu nombre.", "nombre");
    if (!NOMBRE_COMPLETO_REGEX.test(nombre)) {
      return mostrarError("Completa tu nombre y apellido (al menos 2 palabras).", "nombre");
    }
    if (!email) return mostrarError("Necesitamos tu mail para contactarte.", "email");
    if (!EMAIL_REGEX.test(email)) {
      return mostrarError("El mail no parece válido. Revisa si te falta algo.", "email");
    }
    if (canalPreferido !== "mail" && canalPreferido !== "whatsapp") {
      return mostrarError("Indícanos por dónde prefieres que te contactemos.", "canal_preferido_respuesta");
    }
    if (canalPreferido === "whatsapp" && !telefono) {
      return mostrarError("Si elegiste WhatsApp, necesitamos tu número de teléfono.", "telefono_numero");
    }
    // Si cargó teléfono, validamos que tenga una cantidad razonable de dígitos.
    if (telNumero && (contarDigitos(telNumero) < 6 || contarDigitos(telNumero) > 15)) {
      return mostrarError("El teléfono no parece válido. Escribe solo el número, sin el código de país.", "telefono_numero");
    }

    // Si es inscripción: validar los campos extra del consentimiento.
    let rolSolicitante: string | null = null;
    let edad: number | null = null;
    let nombreMenor: string | null = null;
    let emailMenor: string | null = null;
    let fechaNacimientoMenor: string | null = null;
    let vinculoMenor: string | null = null;
    let dniTutor: string | null = null;
    let contactoEmergenciaNombre: string | null = null;
    let contactoEmergenciaTelefono: string | null = null;
    let contactoEmergenciaVinculo: string | null = null;
    let protocoloAceptado: boolean | null = null;
    let protocoloVersion: string | null = null;
    let protocoloAceptadoEn: string | null = null;

    if (intencion === "inscripcion") {
      rolSolicitante = String(fd.get("rol_solicitante") ?? "");
      if (rolSolicitante !== "mayor" && rolSolicitante !== "responsable_menor") {
        return mostrarError("Indica si te inscribes tú o si eres responsable de un menor.", "rol_solicitante");
      }

      // Contacto de emergencia (se completa en ambos roles, con distinta
      // obligatoriedad). Lo leemos siempre y validamos según el rol más abajo.
      contactoEmergenciaNombre = String(fd.get("contacto_emergencia_nombre") ?? "").trim() || null;
      contactoEmergenciaTelefono = String(fd.get("contacto_emergencia_telefono") ?? "").trim() || null;
      contactoEmergenciaVinculo = String(fd.get("contacto_emergencia_vinculo") ?? "").trim() || null;

      if (rolSolicitante === "mayor") {
        const edadStr = String(fd.get("edad") ?? "").trim();
        edad = edadStr ? parseInt(edadStr, 10) : null;
        if (edad === null || Number.isNaN(edad) || edad < 18 || edad > 100) {
          return mostrarError("Para inscribirte tú mismo/a necesitamos una edad válida (entre 18 y 100).", "edad");
        }
        // Para mayores el contacto que acompaña es obligatorio.
        if (!contactoEmergenciaNombre) {
          return mostrarError("Completa el nombre del familiar o persona cercana que te acompañará.", "contacto_emergencia_nombre");
        }
        if (!NOMBRE_COMPLETO_REGEX.test(contactoEmergenciaNombre)) {
          return mostrarError("El contacto que te acompaña necesita nombre y apellido.", "contacto_emergencia_nombre");
        }
        if (!contactoEmergenciaTelefono) {
          return mostrarError("Completa el teléfono del familiar o persona cercana que te acompañará.", "contacto_emergencia_telefono");
        }
        if (contarDigitos(contactoEmergenciaTelefono) < 6 || contarDigitos(contactoEmergenciaTelefono) > 16) {
          return mostrarError("El teléfono del contacto que te acompaña no parece válido.", "contacto_emergencia_telefono");
        }
        if (!contactoEmergenciaVinculo) {
          return mostrarError("Indica tu vínculo con la persona que te acompañará.", "contacto_emergencia_vinculo");
        }
      }

      if (rolSolicitante === "responsable_menor") {
        nombreMenor = String(fd.get("nombre_menor") ?? "").trim() || null;
        emailMenor = String(fd.get("email_menor") ?? "").trim().toLowerCase() || null;
        fechaNacimientoMenor = String(fd.get("fecha_nacimiento_menor") ?? "").trim() || null;
        vinculoMenor = String(fd.get("vinculo_menor") ?? "").trim() || null;
        dniTutor = String(fd.get("dni_tutor") ?? "").trim() || null;

        if (!nombreMenor) {
          return mostrarError("Necesitamos el nombre completo del menor que se inscribe.", "nombre_menor");
        }
        if (!NOMBRE_COMPLETO_REGEX.test(nombreMenor)) {
          return mostrarError("Completa el nombre y apellido del menor.", "nombre_menor");
        }
        if (!fechaNacimientoMenor) {
          return mostrarError("Necesitamos la fecha de nacimiento del menor.", "fecha_nacimiento_menor");
        }
        // Email propio del participante: ahí le mandamos el acceso al campus.
        if (!emailMenor) {
          return mostrarError("Necesitamos el email del/de la participante para enviarle el acceso al campus.", "email_menor");
        }
        if (!EMAIL_REGEX.test(emailMenor)) {
          return mostrarError("El email del/de la participante no parece válido.", "email_menor");
        }
        if (emailMenor === email) {
          return mostrarError("El email del/de la participante tiene que ser distinto del tuyo: ahí le enviaremos su acceso al campus.", "email_menor");
        }
        if (!vinculoMenor) {
          return mostrarError("Indica tu vínculo con el menor (madre, padre, tutor/a…).", "vinculo_menor");
        }
        if (!dniTutor) {
          return mostrarError("Necesitamos tu DNI o documento como representante legal.", "dni_tutor");
        }
        if (dniTutor.length < 6) {
          return mostrarError("El DNI o documento parece incompleto.", "dni_tutor");
        }
      }

      const checkbox = $form.elements.namedItem("protocolo_aceptado") as HTMLInputElement;
      if (!checkbox.checked) {
        return mostrarError("Tienes que leer y aceptar el Protocolo para anotarte.", "protocolo_aceptado");
      }
      protocoloAceptado = true;
      protocoloVersion = PROTOCOLO_VERSION_ACTUAL;
      protocoloAceptadoEn = new Date().toISOString();
    }

    // INSERT
    $submit.disabled = true;
    $submit.textContent = "Enviando…";

    const { error: dbError } = await supabase
      .from("solicitudes_inscripcion")
      .insert({
        canal: detectarCanal(),
        intencion,
        nombre,
        email,
        telefono,
        pais,
        como_nos_encontraste: origen,
        canal_preferido_respuesta: canalPreferido,
        rol_solicitante: rolSolicitante,
        edad: edad,
        nombre_menor: nombreMenor,
        // Solo mandamos la columna cuando hay dato: así, si la migración 14
        // todavía no corrió, los flujos de info/mayor siguen funcionando.
        ...(emailMenor ? { email_menor: emailMenor } : {}),
        fecha_nacimiento_menor: fechaNacimientoMenor,
        vinculo_menor: vinculoMenor,
        dni_tutor: dniTutor,
        contacto_emergencia_nombre: contactoEmergenciaNombre,
        contacto_emergencia_telefono: contactoEmergenciaTelefono,
        contacto_emergencia_vinculo: contactoEmergenciaVinculo,
        protocolo_aceptado: protocoloAceptado,
        protocolo_version: protocoloVersion,
        protocolo_aceptado_en: protocoloAceptadoEn,
        user_agent: navigator.userAgent,
      });

    if (dbError) {
      console.error("[inscripcion]", dbError);
      mostrarError("Hubo un problema al guardar tu solicitud. Prueba de nuevo en un momento.");
      $submit.disabled = false;
      $submit.textContent = "Enviar →";
      return;
    }

    // Confirmación adaptada a la intención + canal preferido.
    const canalTexto = canalPreferido === "whatsapp" ? "por WhatsApp" : "por mail";
    const textosConfirmacion: Record<string, string> = {
      info: `Recibimos tu interés en Vocational Lab. En las próximas 24hs te enviamos toda la información del programa ${canalTexto}.`,
      inscripcion: `Recibimos tu solicitud de inscripción. Te contactamos ${canalTexto} para coordinar el pago y confirmar tu lugar.`,
    };
    $confirmTexto.textContent = textosConfirmacion[intencion] ?? `Recibimos tu mensaje. Te contactamos ${canalTexto} pronto.`;

    $form.hidden = true;
    $confirm.hidden = false;
    window.scrollTo({ top: 0, behavior: "smooth" });
  });
</script>


<style>
  .inscripcion {
    background: var(--color-bg);
  }

  .inscripcion__inner {
    max-width: 760px;
  }

  .inscripcion__head {
    margin-bottom: 3rem;
  }
  .inscripcion__sub {
    margin: 1rem 0 0;
    color: var(--color-ink-soft);
    font-size: 1.1rem;
  }

  /* ============ Form ============ */
  .ins-form {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Honeypot anti-bot: fuera de pantalla, invisible y no enfocable. */
  .ins-form__hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  /* El atributo `hidden` tiene que ganar siempre. Sin esto, los fieldsets
     con la clase .ins-form__fieldset (que define display:flex) quedan
     visibles aunque tengan hidden, porque Astro le sube la especificidad
     a la clase y le gana al estilo por defecto de [hidden]. */
  [hidden] {
    display: none !important;
  }

  /* Bloque condicional de inscripción: lo hacemos columna con gap para que
     sus fieldsets internos (rol, edad/menor, emergencia, protocolo) tengan
     el mismo aire que los del formulario principal. Antes quedaban pegados
     porque el gap del form solo aplica a sus hijos directos. */
  #bloque-inscripcion {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .ins-form__fieldset {
    border: 0;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .ins-form__legend {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    color: var(--color-ink);
    margin: 0 0 0.5rem;
    padding: 0;
  }

  /* Radios — usados en intención y rol_solicitante */
  .ins-form__radios {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .ins-form__radio {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 1rem 1.2rem;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .ins-form__radio:hover {
    border-color: var(--color-accent);
  }
  .ins-form__radio input[type="radio"] {
    margin-top: 0.25rem;
    accent-color: var(--color-accent);
    flex-shrink: 0;
  }
  .ins-form__radio:has(input:checked) {
    border-color: var(--color-accent);
    background: rgba(216, 85, 42, 0.05);
  }
  .ins-form__radio-label {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .ins-form__radio-label strong {
    font-weight: 500;
    color: var(--color-ink);
  }
  .ins-form__radio-label small {
    font-size: 0.88rem;
    color: var(--color-ink-soft);
  }

  /* Campos de texto */
  .ins-form__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem 1.1rem;
  }
  @media (max-width: 560px) {
    .ins-form__grid { grid-template-columns: 1fr; }
  }
  .ins-form__field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .ins-form__field--full { grid-column: 1 / -1; }
  .ins-form__label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-ink-soft);
  }

  /* Asterisco "*" rojo que marca un campo obligatorio. Se usa en labels
     de inputs y en legends de fieldsets de radios. Aria-hidden porque
     el campo ya tiene atributo `required` o se valida vía JS. */
  .ins-form__required {
    color: var(--color-accent);
    font-weight: 600;
    margin-left: 0.15em;
  }
  .ins-form input[type="text"],
  .ins-form input[type="email"],
  .ins-form input[type="tel"],
  .ins-form input[type="number"],
  .ins-form select {
    font: inherit;
    color: var(--color-ink);
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    padding: 0.75rem 0.9rem;
    transition: border-color 0.15s ease;
  }
  .ins-form input:focus,
  .ins-form select:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  /* Teléfono internacional: select de país + input de número en
     dos columnas (select más angosto, input ancho). En mobile
     pasa a apilarse. */
  .ins-form__tel-grid {
    display: grid;
    grid-template-columns: minmax(0, 12rem) 1fr;
    gap: 0.6rem;
  }
  @media (max-width: 480px) {
    .ins-form__tel-grid { grid-template-columns: 1fr; }
  }
  .ins-form__tel-codigo {
    min-width: 0;
  }
  .ins-form__tel-numero {
    min-width: 0;
  }

  /* Bloque protocolo destacado */
  .ins-form__fieldset--protocolo {
    background: var(--color-surface);
    padding: 1.5rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-line);
  }
  .ins-form__nota {
    margin: 0;
    color: var(--color-ink-soft);
    font-size: 0.95rem;
    line-height: 1.5;
  }
  /* Texto de ayuda chiquito debajo de un campo. */
  .ins-form__ayuda {
    margin-top: 0.3rem;
    font-size: 0.8rem;
    color: var(--color-ink-muted);
    line-height: 1.4;
  }

  /* Panel scrolleable con el contenido del protocolo */
  .ins-form__protocolo-panel {
    position: relative;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    transition: border-color 0.2s ease;
  }
  .ins-form__protocolo-panel--leido {
    border-color: var(--color-accent);
  }
  .ins-form__protocolo-scroll {
    max-height: 280px;
    overflow-y: auto;
    padding: 1.25rem 1.5rem;
  }
  /* Fade visual abajo del panel para insinuar que hay más contenido */
  .ins-form__protocolo-fade {
    position: absolute;
    inset: auto 1px 1px 1px;
    height: 40px;
    pointer-events: none;
    background: linear-gradient(to bottom, transparent, #fff 85%);
    border-radius: 0 0 var(--radius-sm) var(--radius-sm);
    transition: opacity 0.2s ease;
  }
  .ins-form__protocolo-panel--leido .ins-form__protocolo-fade {
    opacity: 0;
  }

  .ins-form__protocolo-hint {
    margin: 0;
    font-size: 0.88rem;
    color: var(--color-ink-soft);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
    align-items: center;
  }
  .ins-form__protocolo-hint a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .ins-form__protocolo-hint--leido {
    color: var(--color-deep);
    font-weight: 500;
  }

  .ins-form__checkbox {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    cursor: pointer;
    font-size: 0.95rem;
    line-height: 1.45;
    transition: opacity 0.2s ease;
  }
  /* Checkbox deshabilitado: visualmente "apagado" hasta que se lea el protocolo */
  .ins-form__checkbox:has(input:disabled) {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .ins-form__checkbox input[type="checkbox"] {
    margin-top: 0.2rem;
    accent-color: var(--color-accent);
    flex-shrink: 0;
    width: 1.1rem;
    height: 1.1rem;
  }
  .ins-form__checkbox input[type="checkbox"]:disabled {
    cursor: not-allowed;
  }

  /* Mensaje de error */
  .ins-form__msg {
    margin: 0;
    padding: 0.8rem 1rem;
    border-radius: var(--radius-sm);
    font-size: 0.95rem;
    line-height: 1.4;
  }
  .ins-form__msg--error {
    background: rgba(216, 85, 42, 0.1);
    border-left: 3px solid var(--color-accent);
    color: var(--color-accent);
  }

  .ins-form__submit {
    align-self: flex-start;
    margin-top: 0.5rem;
  }
  .ins-form__submit:disabled {
    opacity: 0.7;
    cursor: wait;
  }

  /* ============ Confirmación ============ */
  .ins-confirm {
    text-align: center;
    padding: 4rem 2rem;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
  }
  .ins-confirm h2 {
    margin: 0 0 1rem;
  }
  .ins-confirm p {
    color: var(--color-ink-soft);
    font-size: 1.1rem;
    line-height: 1.55;
    max-width: 50ch;
    margin: 0 auto 2rem;
  }
  .ins-confirm__back {
    color: var(--color-accent);
    font-weight: 500;
  }
</style>
