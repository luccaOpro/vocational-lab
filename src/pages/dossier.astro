<script>
  /*
    Barra de progreso de lectura del dossier (mismo patrón que el nav
    del sitio: transform scaleX + requestAnimationFrame).
  */
  const barra = document.querySelector<HTMLElement>("[data-dossier-progreso]");
  if (barra && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    let pedido = false;
    function pintar() {
      pedido = false;
      const total = document.documentElement.scrollHeight - window.innerHeight;
      const avance = total > 0 ? window.scrollY / total : 0;
      barra!.style.transform = `scaleX(${Math.min(Math.max(avance, 0), 1)})`;
    }
    window.addEventListener("scroll", () => {
      if (!pedido) { pedido = true; requestAnimationFrame(pintar); }
    }, { passive: true });
    pintar();
  }

  /*
    Contadores animados de "8 semanas · 5 etapas · 8 encuentros"
    (mismo efecto que el "8 encuentros" de la home).
  */
  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    const counters = document.querySelectorAll<HTMLElement>(".counter[data-target]");
    const obs = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;
        obs.unobserve(entry.target);
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.target ?? "0", 10);
        const inicio = performance.now();
        const dur = 900;
        function tick(ahora: number) {
          const p = Math.min((ahora - inicio) / dur, 1);
          el.textContent = String(Math.round((1 - Math.pow(1 - p, 3)) * target));
          if (p < 1) requestAnimationFrame(tick);
          else el.textContent = String(target);
        }
        requestAnimationFrame(tick);
      }
    }, { threshold: 0.5 });
    counters.forEach((c) => obs.observe(c));
  }

  /*
    Mapa del viaje: cuando entra al viewport le ponemos .visible y el CSS
    dispara la entrada por capas (etapas → línea → nodos → filas → bandas).
    Con prefers-reduced-motion todo se ve directo, sin animación.
  */
  const mapa = document.querySelector<HTMLElement>("[data-mapa]");
  if (mapa) {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      mapa.classList.add("visible");
    } else {
      const obsMapa = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          obsMapa.unobserve(entry.target);
          entry.target.classList.add("visible");
        }
      }, { threshold: 0.3 });
      obsMapa.observe(mapa);
    }

    /*
      Foco por columna: al pasar el mouse por un nodo, se encienden las
      celdas de ese encuentro (mundo interno + externo + emoción) y el
      resto del mapa se atenúa. Hace legible la lectura vertical:
      "¿qué pasa en el encuentro 3?".
    */
    const celdas = mapa.querySelectorAll<HTMLElement>(".mw-celda[data-col]");
    mapa.querySelectorAll<HTMLElement>(".mw-nodo[data-col]").forEach((nodo) => {
      const col = nodo.dataset.col;
      nodo.addEventListener("mouseenter", () => {
        mapa.classList.add("mapaweb--foco");
        celdas.forEach((c) => c.classList.toggle("is-foco", c.dataset.col === col));
      });
      nodo.addEventListener("mouseleave", () => {
        mapa.classList.remove("mapaweb--foco");
        celdas.forEach((c) => c.classList.remove("is-foco"));
      });
    });
  }
</script>

