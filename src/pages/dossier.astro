    background: rgba(242, 234, 215, 0.92);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-line);
  }
  .dtop__inner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.7rem;
    padding-bottom: 0.7rem;
  }
  .dtop__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-ink);
  }
  .dtop__logo { height: 40px; width: auto; }
  .dtop__nombre {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    letter-spacing: 0.02em;
  }
  .dtop__cta {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-accent);
  }
  .dtop__cta:hover { color: var(--color-accent-dark); }
  /* Barra de progreso de lectura */
  .dtop__progreso {
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 3px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left center;
    pointer-events: none;
  }

  /* ═══════ Portada ═══════ */
  .portada {
    position: relative;
    overflow: hidden;
    /* Azul noche con un resplandor sutil arriba: profundidad sin ruido. */
    background:
      radial-gradient(ellipse 90% 60% at 50% -10%, rgba(36, 58, 130, 0.55) 0%, transparent 65%),
      var(--color-ink);
    color: var(--color-bg);
    padding: clamp(5rem, 12vw, 9rem) 0 clamp(4rem, 9vw, 7rem);
    text-align: center;
  }
  /* Marca de agua del logo completo, asomando por la derecha. */
  .portada__marca {
    position: absolute;
    top: 50%;
    right: -7%;
    width: clamp(300px, 36vw, 520px);
    height: auto;
    transform: translateY(-50%) rotate(6deg);
    color: var(--color-bg);
    opacity: 0.05;
    pointer-events: none;
  }
  .portada__estrella {
    position: absolute;
    top: 14%;
    right: 10%;
    width: clamp(30px, 4vw, 52px);
    color: var(--color-accent);
    opacity: 0.9;
  }
  .portada__estrella--2 {
    top: auto;
    bottom: 16%;
    left: 8%;
    right: auto;
    width: clamp(20px, 2.4vw, 32px);
    color: var(--color-bg);
    opacity: 0.3;
    transform: scaleX(-1);
  }
  @keyframes dossier-flotar {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50%      { transform: translateY(-14px) rotate(4deg); }
  }
  @media (prefers-reduced-motion: no-preference) {
    .portada__estrella { animation: dossier-flotar 8s ease-in-out infinite; }
    .portada__estrella--2 { animation: dossier-flotar 10s ease-in-out 1.4s infinite; }
    .portada__eyebrow  { animation: dossier-entra 0.7s cubic-bezier(0.16, 1, 0.3, 1) 100ms both; }
    .portada__titulo   { animation: dossier-entra 0.8s cubic-bezier(0.16, 1, 0.3, 1) 250ms both; }
    .portada__sub      { animation: dossier-entra 0.75s cubic-bezier(0.16, 1, 0.3, 1) 400ms both; }
    .portada__lead     { animation: dossier-entra 0.75s cubic-bezier(0.16, 1, 0.3, 1) 520ms both; }
    .portada__badge    { animation: dossier-entra 0.7s cubic-bezier(0.16, 1, 0.3, 1) 650ms both; }
    .portada__scroll   { animation: dossier-entra 0.7s cubic-bezier(0.16, 1, 0.3, 1) 900ms both; }
  }
  @keyframes dossier-entra {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: none; }
  }
  .portada__inner {
    max-width: 860px;
    position: relative; /* por encima de los ornamentos */
  }
  .portada__eyebrow {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(242, 234, 215, 0.6);
    margin: 0 0 1.6rem;
  }
  /* El título es la promesa de la marca, no el nombre: grande,
     con el remate en cursiva coral (mismo gesto que la home). */
  .portada__titulo {
    color: var(--color-bg);
    font-size: clamp(2.6rem, 6.5vw, 4.8rem);
    line-height: 1.06;
    letter-spacing: -0.02em;
    margin: 0 0 1.4rem;
  }
  .portada__titulo em {
    display: block;
    font-style: italic;
    color: var(--color-accent);
    font-weight: 400;
  }
  .portada__sub {
    font-size: 1.02rem;
    color: rgba(242, 234, 215, 0.75);
    margin: 0 0 1.6rem;
  }
  .portada__lead {
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    color: rgba(242, 234, 215, 0.9);
    max-width: 56ch;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }
  .portada__badge {
    display: inline-block;
    padding: 0.5rem 1.1rem;
    border: 1px solid rgba(242, 234, 215, 0.3);
    border-radius: 999px;
    font-size: 0.85rem;
    color: rgba(242, 234, 215, 0.85);
  }
  .portada__scroll {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    margin-top: 2.6rem;
    border: 1px solid rgba(242, 234, 215, 0.3);
    border-radius: 50%;
    color: rgba(242, 234, 215, 0.7);
    transition: color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }
  .portada__scroll:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    transform: translateY(3px);
  }

  /* ═══════ Una nueva forma ═══════ */
  .nf { max-width: 880px; }
  .nf h2 em { font-style: italic; color: var(--color-accent); }
  .nf__lead { margin-top: 1.2rem; }
  .nf__diferencial {
    margin-top: 2.5rem;
    padding: 2rem 2.2rem;
    background: #fff;
    border-left: 3px solid var(--color-accent);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }
  .nf__diferencial h3 { margin: 0 0 0.9rem; font-size: 1.25rem; }
  .nf__diferencial p { margin: 0 0 1em; color: var(--color-ink-soft); }
  .nf__diferencial p:last-child { margin-bottom: 0; }

  /* ═══════ Lo que nos distingue ═══════ */
  .distingue { background: var(--color-surface); }
  .distingue__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  @media (max-width: 760px) { .distingue__grid { grid-template-columns: 1fr; } }
  .distingue__item {
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    padding: 1.8rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .distingue__item:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 40px -28px rgba(19, 27, 61, 0.45);
  }
  .distingue__item h3 { font-size: 1.3rem; margin: 0 0 0.6rem; }
  .distingue__item p { margin: 0; color: var(--color-ink-soft); }

  /* ═══════ El programa: números ═══════ */
  .programa-nums__titulo {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.6rem 1rem;
    margin: 0 0 1.4rem;
  }
  .num-grande { white-space: nowrap; }
  .num-grande .counter {
    color: var(--color-accent);
    font-variant-numeric: tabular-nums;
  }
  .num-sep { color: var(--color-ink-muted); }

  /* Cinta de etapas */
  .cinta {
    list-style: none;
    margin: 3rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
  }
  @media (max-width: 1024px) { .cinta { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .cinta { grid-template-columns: 1fr; } }
  .cinta__etapa {
    border-top: 2px solid var(--color-accent);
    padding: 0.9rem 0.8rem 1rem;
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    border-radius: 0 0 var(--radius-sm) var(--radius-sm);
  }
  .cinta__etapa:hover {
    background: #fff;
    transform: translateY(-3px);
    box-shadow: 0 16px 36px -26px rgba(19, 27, 61, 0.4);
  }
  .cinta__n {
    display: block;
    font-family: var(--font-serif);
    color: var(--color-accent);
    margin-bottom: 0.35rem;
  }
  .cinta__nombre {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.15rem;
    margin-bottom: 0.25rem;
  }
  .cinta__enc {
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    color: var(--color-ink-muted);
  }

  /* ═══════ Los 8 encuentros ═══════ */
  .encuentros { background: var(--color-surface); }
  .encuentros__leyenda {
    display: flex;
    align-items: center;
    gap: 0.5rem 0.6rem;
    flex-wrap: wrap;
    margin: 1.2rem 0 0;
    font-size: 0.85rem;
    color: var(--color-ink-soft);
  }
  .leyenda__punto {
    display: inline-block;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    margin-left: 1rem;
  }
  .leyenda__punto:first-of-type { margin-left: 0; }
  .leyenda__punto--grupal { background: var(--color-ink); }
  .leyenda__punto--individual { background: transparent; border: 2px solid var(--color-deep); }

  .enc-lista {
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .enc {
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    padding: 1.3rem 1.5rem;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }
  .enc:hover {
    transform: translateX(4px);
    border-color: var(--color-deep);
    box-shadow: 0 14px 34px -26px rgba(19, 27, 61, 0.5);
  }
  /* Número del encuentro: relleno = grupal, contorno = individual
     (mismo código visual que el mapa del programa). */
  .enc__n {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    border-radius: 50%;
    background: var(--color-ink);
    color: var(--color-bg);
    font-family: var(--font-serif);
    font-size: 1.05rem;
  }
  .enc--individual .enc__n {
    background: transparent;
    border: 2px solid var(--color-deep);
    color: var(--color-deep);
  }
  .enc__cuerpo { flex: 1; min-width: 0; }
  .enc__head {
    display: flex;
    align-items: baseline;
    gap: 0.8rem;
    flex-wrap: wrap;
  }
  .enc__nombre { font-size: 1.25rem; margin: 0; }
  .enc__tipo {
    font-size: 0.78rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }
  .enc__foco { margin: 0.4rem 0 0.6rem; color: var(--color-ink-soft); }
  .enc__etapa {
    display: inline-block;
    font-size: 0.78rem;
    padding: 0.22rem 0.65rem;
    border-radius: 999px;
    background: rgba(36, 58, 130, 0.09);
    color: var(--color-deep);
    font-weight: 500;
  }
  @media (max-width: 560px) {
    .enc { padding: 1.1rem 1.1rem; gap: 0.9rem; }
  }

  /* ═══════ Mapa del viaje (versión web nativa) ═══════ */
  /* Pista de scroll horizontal: solo visible cuando el mapa no entra. */
  .mapaweb-hint {
    display: none;
    margin: 2rem 0 0.6rem;
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    font-style: italic;
  }
  @media (max-width: 1100px) {
    .mapaweb-hint { display: block; }
  }
  /* En desktop el mapa se ensancha más allá de la columna de texto
     (hasta 1320px) para verse completo sin scroll; en pantallas chicas
     vuelve al ancho normal y scrollea horizontal. */
  .mapa-breakout {
    width: min(1320px, calc(100vw - 2.4rem));
    position: relative;
    left: 50%;
    transform: translateX(-50%);
  }
  .mapaweb-scroll {
    margin-top: 2.5rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: var(--radius-md);
  }
  @media (max-width: 1100px) {
    .mapaweb-scroll { margin-top: 0; }
  }

  .mapaweb {
    display: grid;
    grid-template-columns: 108px repeat(8, minmax(112px, 1fr));
    gap: 0.9rem 0.7rem;
    align-items: start;
    /* min-content: el panel nunca puede ser más angosto de lo que piden
       sus columnas — así el fondo siempre contiene TODO el contenido.
       (Antes era un número fijo en px que quedó corto y en mobile las
       celdas se salían del panel.) */
    min-width: min-content;
    padding: clamp(1.4rem, 3vw, 2.4rem);
    background: #faf6ee;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    box-shadow: 0 24px 60px -38px rgba(19, 27, 61, 0.5);
  }

  /* Bandas de etapas */
  .mw-etapa {
    display: grid;
    place-items: center;
    padding: 0.55rem 0.6rem;
    border-radius: var(--radius-sm);
    color: #fff;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-align: center;
    line-height: 1.25;
  }
  .mw-etapa--llamado  { background: #3F4870; }
  .mw-etapa--origen   { background: var(--color-ink); }
  .mw-etapa--busqueda { background: var(--color-deep); }
  .mw-etapa--flecha   { background: var(--color-accent); }
  .mw-etapa--tesoros  { background: #56608C; }
  .mw-etapa { transition: transform 0.2s ease, filter 0.2s ease; }
  .mw-etapa:hover { transform: translateY(-2px); filter: brightness(1.15); }

  /* La línea del viaje, detrás de los nodos. Se dibuja al aparecer. */
  .mw-linea {
    position: relative;
    height: 44px;
    pointer-events: none;
  }
  .mw-linea::before {
    content: "";
    position: absolute;
    left: 2%;
    right: 2%;
    top: 21px;
    height: 2px;
    background: var(--color-ink-muted);
    opacity: 0.5;
  }
  @media (prefers-reduced-motion: no-preference) {
    .mw-linea::before {
      transform: scaleX(0);
      transform-origin: left center;
      transition: transform 1.1s cubic-bezier(0.16, 1, 0.3, 1) 0.35s;
    }
    .mapaweb.visible .mw-linea::before { transform: scaleX(1); }
  }

  /* Nodos de encuentro: relleno = grupal · contorno = individual ·
     coral = hito clave · contorno coral = integración (como el mapa). */
  .mw-nodo {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.4rem;
    transition: opacity 0.25s ease;
  }
  .mw-nodo__circulo {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    font-family: var(--font-serif);
    font-size: 1.15rem;
    background: var(--color-ink);
    color: var(--color-bg);
    box-shadow: 0 0 0 5px #faf6ee; /* recorta la línea alrededor */
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.2s ease;
  }
  /* Hover del nodo: el círculo crece con un anillo coral y el nombre
     se enciende. El JS además resalta la columna de ese encuentro. */
  .mw-nodo:hover .mw-nodo__circulo {
    transform: scale(1.16);
    box-shadow: 0 0 0 5px #faf6ee, 0 0 0 8px rgba(216, 85, 42, 0.3);
  }
  .mw-nodo__nombre { transition: color 0.2s ease; }
  .mw-nodo:hover .mw-nodo__nombre { color: var(--color-accent); }
  /* Los hitos clave laten suave, invitan a mirar. */
  @media (prefers-reduced-motion: no-preference) {
    .mw-nodo--hito .mw-nodo__circulo {
      animation: mw-latido 3.2s ease-in-out 3s infinite;
    }
  }
  @keyframes mw-latido {
    0%, 100% { box-shadow: 0 0 0 5px #faf6ee, 0 0 0 6px rgba(216, 85, 42, 0); }
    50%      { box-shadow: 0 0 0 5px #faf6ee, 0 0 0 13px rgba(216, 85, 42, 0.18); }
  }
  .mw-nodo--individual .mw-nodo__circulo {
    background: #faf6ee;
    border: 2px solid var(--color-deep);
    color: var(--color-deep);
  }
  .mw-nodo--hito .mw-nodo__circulo {
    background: var(--color-accent);
    color: #fff;
  }
  .mw-nodo--integracion .mw-nodo__circulo {
    background: rgba(216, 85, 42, 0.1);
    border: 2px solid var(--color-accent);
    color: var(--color-accent);
  }
  .mw-nodo__chip {
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    line-height: 1.3;
  }
  .mw-nodo__nombre {
    font-family: var(--font-serif);
    font-size: 0.98rem;
    color: var(--color-ink);
    line-height: 1.2;
  }

  /* Etiquetas de fila (mundo interno / externo / emoción) */
  .mw-label {
    align-self: center;
    justify-self: end;
    text-align: right;
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    line-height: 1.4;
    padding-right: 0.3rem;
  }

  /* Celdas de contenido */
  .mw-celda {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    padding: 0.75rem 0.8rem;
    text-align: center;
    min-height: 100%;
    transition: transform 0.2s ease, box-shadow 0.2s ease,
      border-color 0.2s ease, opacity 0.25s ease;
  }
  .mw-celda:hover {
    transform: translateY(-3px);
    border-color: var(--color-accent);
    box-shadow: 0 14px 30px -22px rgba(216, 85, 42, 0.45);
  }
  /* Foco por columna (lo activa el JS al pasar por un nodo): la columna
     del encuentro se enciende y el resto se atenúa. */
  .mapaweb--foco .mw-celda:not(.is-foco) { opacity: 0.3; }
  .mapaweb--foco .mw-nodo:not(:hover) { opacity: 0.45; }
  .mw-celda.is-foco {
    transform: translateY(-3px);
    border-color: var(--color-accent);
    box-shadow: 0 14px 30px -22px rgba(216, 85, 42, 0.5);
  }
  .mw-celda.is-foco .mw-celda__titulo { color: var(--color-accent); }
  .mw-celda--pausa.is-foco,
  .mw-celda--emocion.is-foco {
    transform: scale(1.07);
    border: 0;
    box-shadow: none;
  }
  .mw-celda__titulo {
    font-size: 0.88rem;
    color: var(--color-ink);
    transition: color 0.2s ease;
  }
  .mw-celda__detalle {
    font-size: 0.74rem;
    color: var(--color-ink-soft);
    line-height: 1.4;
  }
  .mw-celda--pausa {
    background: transparent;
    border: 0;
    justify-content: center;
  }
  .mw-celda--pausa:hover { transform: none; box-shadow: none; }
  .mw-celda__pausa {
    font-size: 0.74rem;
    color: var(--color-ink-muted);
    font-style: italic;
    line-height: 1.4;
  }
  .mw-celda--emocion {
    background: transparent;
    border: 0;
    justify-content: center;
  }
  .mw-celda--emocion:hover { transform: none; box-shadow: none; }
  .mw-celda__palabra {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.05rem;
    color: var(--color-accent);
  }

  /* Banda "entre encuentros" */
  .mw-banda {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-align: center;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    padding: 0.85rem 1rem;
  }
  .mw-banda strong { font-size: 0.9rem; color: var(--color-ink); }
  .mw-banda em { font-size: 0.78rem; color: var(--color-ink-soft); }

  /* Canal de atajos */
  .mw-atajos {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    border-top: 2px dashed rgba(216, 85, 42, 0.5);
    padding-top: 0.55rem;
  }
  .mw-atajos em {
    font-size: 0.78rem;
    color: var(--color-accent);
    font-style: italic;
  }
  .mw-atajos__nota {
    font-size: 0.72rem;
    font-style: italic;
    color: var(--color-ink-muted);
  }

  /* Leyenda */
  .mw-leyenda {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1.6rem;
    margin: 1.2rem 0 0;
    font-size: 0.82rem;
    color: var(--color-ink-soft);
  }
  .mw-leyenda__item { display: inline-flex; align-items: center; gap: 0.45rem; }
  .mw-punto {
    display: inline-block;
    width: 13px;
    height: 13px;
    border-radius: 50%;
  }
  .mw-punto--grupal { background: var(--color-ink); }
  .mw-punto--individual { border: 2px solid var(--color-deep); }
  .mw-punto--hito { background: var(--color-accent); }
