      <path fill="currentColor" d="M298.919,59.572c.276,3.224,1.168,6.074,2.204,9.026,2.16,6.156,4.711,11.974,7.4,17.959,6.086,13.543,12.882,26.533,19.526,39.841l-23.439-38.61c-4.11-6.442-8.219-12.707-12.752-18.811-1.875-2.524-3.751-4.794-5.971-6.944-4.892-4.739-13.586,2.872-17.91,7.246,3.126-5.608,8.67-14.951,3.291-19.349-3.952-3.231-9.751-4.655-14.659-5.984,4.837.167,14.61-.004,16.446-3.913,2.574-5.479-11.443-32.405-14.854-40.032,4.469,6.811,8.531,13.575,13.323,20.097,3.24,4.318,7.109,9.638,11.451,12.579,1.286.871,2.775.931,4.205.328,5.04-2.126,10.72-7.591,14.833-11.63,6.152-6.041,11.61-12.426,17.388-18.918-4.544,6.896-9.014,13.503-12.92,20.714-2.467,4.671-5.647,10.714-5.955,15.79-.099,1.628.557,2.988,1.887,3.893,1.342.913,2.811,1.678,4.364,2.294,9.163,3.639,19.708,5.764,29.429,7.928l30.791,5.675c-13-1.19-25.692-2.499-38.701-3.088-6.689-.303-13.097-.497-19.708-.122-2.697.153-5.285.46-7.791,1.277-1.195.389-2.002,1.319-1.879,2.757Z"/>
    </svg>

    {/* Estrellas de marca flotando — el "tesoro" del viaje, igual que en el hero. */}
    <svg class="login__estrella" viewBox="235 -5 135 138" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path fill="currentColor" d="M298.919,59.572c.276,3.224,1.168,6.074,2.204,9.026,2.16,6.156,4.711,11.974,7.4,17.959,6.086,13.543,12.882,26.533,19.526,39.841l-23.439-38.61c-4.11-6.442-8.219-12.707-12.752-18.811-1.875-2.524-3.751-4.794-5.971-6.944-4.892-4.739-13.586,2.872-17.91,7.246,3.126-5.608,8.67-14.951,3.291-19.349-3.952-3.231-9.751-4.655-14.659-5.984,4.837.167,14.61-.004,16.446-3.913,2.574-5.479-11.443-32.405-14.854-40.032,4.469,6.811,8.531,13.575,13.323,20.097,3.24,4.318,7.109,9.638,11.451,12.579,1.286.871,2.775.931,4.205.328,5.04-2.126,10.72-7.591,14.833-11.63,6.152-6.041,11.61-12.426,17.388-18.918-4.544,6.896-9.014,13.503-12.92,20.714-2.467,4.671-5.647,10.714-5.955,15.79-.099,1.628.557,2.988,1.887,3.893,1.342.913,2.811,1.678,4.364,2.294,9.163,3.639,19.708,5.764,29.429,7.928l30.791,5.675c-13-1.19-25.692-2.499-38.701-3.088-6.689-.303-13.097-.497-19.708-.122-2.697.153-5.285.46-7.791,1.277-1.195.389-2.002,1.319-1.879,2.757Z"/>
    </svg>
    <svg class="login__estrella login__estrella--2" viewBox="235 -5 135 138" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path fill="currentColor" d="M298.919,59.572c.276,3.224,1.168,6.074,2.204,9.026,2.16,6.156,4.711,11.974,7.4,17.959,6.086,13.543,12.882,26.533,19.526,39.841l-23.439-38.61c-4.11-6.442-8.219-12.707-12.752-18.811-1.875-2.524-3.751-4.794-5.971-6.944-4.892-4.739-13.586,2.872-17.91,7.246,3.126-5.608,8.67-14.951,3.291-19.349-3.952-3.231-9.751-4.655-14.659-5.984,4.837.167,14.61-.004,16.446-3.913,2.574-5.479-11.443-32.405-14.854-40.032,4.469,6.811,8.531,13.575,13.323,20.097,3.24,4.318,7.109,9.638,11.451,12.579,1.286.871,2.775.931,4.205.328,5.04-2.126,10.72-7.591,14.833-11.63,6.152-6.041,11.61-12.426,17.388-18.918-4.544,6.896-9.014,13.503-12.92,20.714-2.467,4.671-5.647,10.714-5.955,15.79-.099,1.628.557,2.988,1.887,3.893,1.342.913,2.811,1.678,4.364,2.294,9.163,3.639,19.708,5.764,29.429,7.928l30.791,5.675c-13-1.19-25.692-2.499-38.701-3.088-6.689-.303-13.097-.497-19.708-.122-2.697.153-5.285.46-7.791,1.277-1.195.389-2.002,1.319-1.879,2.757Z"/>
    </svg>
    <div class="login__card">
      <a href="/" class="login__brand" aria-label="Vocational Lab — Inicio">
        {/* Ícono COMPLETO de marca: arco + flecha + estrella. La estrella
            es parte del logo, nunca usar la versión sin ella. */}
        <svg class="login__brand-logo" xmlns="http://www.w3.org/2000/svg" viewBox="0 -5 371 465" aria-label="Vocational Lab" role="img">
          <path fill="#1b1f3b" d="M0,443.73l.03-45.407c23.216.636,45.683-4.407,66.324-14.637,36.23-18.152,63.593-50.904,74.253-90.112,10.187-37.467,4.874-77.408-15.454-110.56-6.952-11.393-15.189-21.809-25.037-30.712C72.82,127.121,37.263,113.652,0,114.496l.037-46.499c44.551-.826,87.825,14.16,122.067,42.496,13.748,11.427,25.844,24.486,35.722,39.444,8.994,13.102,16.167,27.094,21.57,42.023,12.435,34.36,14.355,70.023,6.359,105.724-8.974,40.066-30.991,76.227-62.228,102.842-22.961,19.111-50.003,32.569-79.197,39.003-14.634,3.128-29.245,4.514-44.329,4.2Z"/>
          <path fill="#d85527" d="M26.34,305.497l-.613-1.82c-.122-.361-.996-.54-1.611-.716l.476-1.582-19.161.152,10.251-10.602,13.716,1.059-.058-1.175-12.423-1.026,6.091-6.282,13.612,1.104-.034-1.185-12.454-1.038,6.18-6.275,13.336,1.094.131-1.185-12.437-1.034,3.919-3.942c3.487-3.508,12.645-.401,18.901-1.622L217.149,100.94c-3.31-1.789-6.564-2.322-9.947-2.602l-11.392-.355,15.203-7.816,29.993-15.686c3.798-1.847,7.134-3.708,11.428-5.274l-22.756,50.442-3.415,6.55-2.236-15.178c-.229-1.554-.973-3.126-1.887-4.554L59.04,275.068l.589,10.139c.36,6.203-.746,7.708-5.857,12.288l-1.477-13.103c-.048-.076-.922-.053-1.189.021l1.603,14.354-6.078,6.182-1.514-13.294-1.183.053,1.629,14.478-6.088,6.301-1.474-13.253c-.017-.073-.587-.473-.717-.338l-.494.515,1.634,14.233-9.718,10.161-.463-19.249-1.902.943Z"/>
          <path fill="#1b1f3b" d="M298.919,59.572c.276,3.224,1.168,6.074,2.204,9.026,2.16,6.156,4.711,11.974,7.4,17.959,6.086,13.543,12.882,26.533,19.526,39.841l-23.439-38.61c-4.11-6.442-8.219-12.707-12.752-18.811-1.875-2.524-3.751-4.794-5.971-6.944-4.892-4.739-13.586,2.872-17.91,7.246,3.126-5.608,8.67-14.951,3.291-19.349-3.952-3.231-9.751-4.655-14.659-5.984,4.837.167,14.61-.004,16.446-3.913,2.574-5.479-11.443-32.405-14.854-40.032,4.469,6.811,8.531,13.575,13.323,20.097,3.24,4.318,7.109,9.638,11.451,12.579,1.286.871,2.775.931,4.205.328,5.04-2.126,10.72-7.591,14.833-11.63,6.152-6.041,11.61-12.426,17.388-18.918-4.544,6.896-9.014,13.503-12.92,20.714-2.467,4.671-5.647,10.714-5.955,15.79-.099,1.628.557,2.988,1.887,3.893,1.342.913,2.811,1.678,4.364,2.294,9.163,3.639,19.708,5.764,29.429,7.928l30.791,5.675c-13-1.19-25.692-2.499-38.701-3.088-6.689-.303-13.097-.497-19.708-.122-2.697.153-5.285.46-7.791,1.277-1.195.389-2.002,1.319-1.879,2.757Z"/>
        </svg>
      </a>

      {/* ============ MODO LOGIN ============ */}
      <div id="modo-login">
        <h1 class="login__titulo">Entra al aula</h1>
        <p class="login__bajada">
          Si ya tienes acceso, ingresa con tu mail y contraseña.
        </p>

        <form id="login-form" class="login__form">
          <label class="login__label">
            <span>Mail</span>
            <input type="email" name="mail" placeholder="tu@mail.com" required autocomplete="email" />
          </label>
          <label class="login__label">
            <span>Contraseña</span>
            <div class="login__pass-wrap">
              <input type="password" name="pass" placeholder="••••••••" required autocomplete="current-password" />
              <button type="button" class="login__pass-toggle" data-toggle-pass aria-label="Mostrar contraseña" aria-pressed="false">
                {/* Ojo abierto — visible cuando la contraseña está oculta */}
                <svg class="icono-ojo" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
                {/* Ojo tachado — visible cuando la contraseña está visible */}
                <svg class="icono-ojo-tachado" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" hidden>
                  <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/>
                  <path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/>
                  <path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/>
                  <line x1="2" y1="2" x2="22" y2="22"/>
                </svg>
              </button>
            </div>
          </label>
          {/* Recordar sesión: desmarcado, la sesión muere al cerrar el
              navegador (para computadoras compartidas). */}
          <label class="login__recordar">
            <input type="checkbox" name="recordar" checked />
            <span>Mantener la sesión iniciada en este dispositivo</span>
          </label>
          <p id="login-error" class="login__msg-error" hidden></p>
          <button type="submit" id="login-submit" class="login__submit">Entrar</button>
          <a href="#" class="login__olvido" id="login-recover">Olvidé mi contraseña</a>
        </form>

        <p class="login__ayuda">
          ¿Todavía no tienes cuenta?
          <a href="#" id="ir-a-registro">Crear una nueva</a>
        </p>
      </div>

      {/* ============ MODO REGISTRO ============ */}
      <div id="modo-registro" hidden>
        <h1 class="login__titulo">Crear cuenta</h1>
        <p class="login__bajada">
          Completa tus datos. Te activamos el acceso cuando confirmemos tu inscripción.
        </p>

        <form id="signup-form" class="login__form">
          <label class="login__label">
            <span>Nombre y apellido</span>
            <input type="text" name="nombre" placeholder="María Pérez" required autocomplete="name" minlength="2" />
          </label>
          <label class="login__label">
            <span>Mail</span>
            <input type="email" name="mail" placeholder="tu@mail.com" required autocomplete="email" />
          </label>
          <label class="login__label">
            <span>Contraseña</span>
            <div class="login__pass-wrap">
              <input type="password" name="pass" placeholder="Mínimo 8 caracteres" required autocomplete="new-password" minlength="8" />
              <button type="button" class="login__pass-toggle" data-toggle-pass aria-label="Mostrar contraseña" aria-pressed="false">
                <svg class="icono-ojo" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
                <svg class="icono-ojo-tachado" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" hidden>
                  <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/>
                  <path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/>
                  <path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/>
                  <line x1="2" y1="2" x2="22" y2="22"/>
                </svg>
              </button>
            </div>
          </label>
          <p id="signup-error" class="login__msg-error" hidden></p>
          <p id="signup-ok" class="login__msg-ok" hidden></p>
          <button type="submit" id="signup-submit" class="login__submit">Crear cuenta</button>
        </form>

        <p class="login__ayuda">
          ¿Ya tienes cuenta?
          <a href="#" id="ir-a-login">Inicia sesión</a>
        </p>
      </div>

      {/* ============ MODO RECUPERAR — pedir el enlace ============ */}
      <div id="modo-recuperar" hidden>
        <h1 class="login__titulo">Recuperar contraseña</h1>
        <p class="login__bajada">
          Ingresa tu mail y te enviamos un enlace para crear una contraseña nueva.
        </p>

        <form id="recover-form" class="login__form">
          <label class="login__label">
            <span>Mail</span>
            <input type="email" name="mail" placeholder="tu@mail.com" required autocomplete="email" />
          </label>
          <p id="recover-error" class="login__msg-error" hidden></p>
          <p id="recover-ok" class="login__msg-ok" hidden></p>
          <button type="submit" id="recover-submit" class="login__submit">Enviar enlace</button>
        </form>

        <p class="login__ayuda">
          <a href="#" id="volver-a-login">Volver a iniciar sesión</a>
        </p>
      </div>

      {/* ============ MODO NUEVA CONTRASEÑA — vuelta desde el mail ============ */}
      <div id="modo-nueva-pass" hidden>
        <h1 class="login__titulo">Crea tu contraseña nueva</h1>
        <p class="login__bajada">
          Elige una contraseña nueva para tu cuenta. Después entras directo al aula.
        </p>

        <form id="nuevapass-form" class="login__form">
          <label class="login__label">
            <span>Contraseña nueva</span>
            <div class="login__pass-wrap">
              <input type="password" name="pass" placeholder="Mínimo 8 caracteres" required autocomplete="new-password" minlength="8" />
              <button type="button" class="login__pass-toggle" data-toggle-pass aria-label="Mostrar contraseña" aria-pressed="false">
                <svg class="icono-ojo" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
                <svg class="icono-ojo-tachado" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" hidden>
                  <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/>
                  <path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/>
                  <path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/>
                  <line x1="2" y1="2" x2="22" y2="22"/>
                </svg>
              </button>
            </div>
          </label>
          <label class="login__label">
            <span>Repetir contraseña</span>
            <div class="login__pass-wrap">
              <input type="password" name="pass2" placeholder="Repite la contraseña" required autocomplete="new-password" minlength="8" />
              <button type="button" class="login__pass-toggle" data-toggle-pass aria-label="Mostrar contraseña" aria-pressed="false">
                <svg class="icono-ojo" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
                <svg class="icono-ojo-tachado" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" hidden>
                  <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/>
                  <path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/>
                  <path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/>
                  <line x1="2" y1="2" x2="22" y2="22"/>
                </svg>
              </button>
            </div>
          </label>
          <p id="nuevapass-error" class="login__msg-error" hidden></p>
          <p id="nuevapass-ok" class="login__msg-ok" hidden></p>
          <button type="submit" id="nuevapass-submit" class="login__submit">Guardar contraseña</button>
        </form>
      </div>
    </div>
  </main>
</AulaLayout>

<script>
  import { supabase, PERSISTENCIA_KEY } from "../../lib/supabase";
  import { homePorRol, type Rol } from "../../lib/auth-guard";
  import { traducirError } from "../../lib/ui";

  // Si llegamos desde el enlace del mail de recuperación, la URL trae
  // "type=recovery" en el hash. Lo leemos AHORA, antes de que el cliente de
  // Supabase procese y borre el hash: nos sirve para saber que NO hay que
  // auto-redirigir al aula, sino mostrar la pantalla de "nueva contraseña".
  const veniaDeRecovery = window.location.hash.includes("type=recovery");

  // ============ Referencias DOM ============
  const $modoLogin = document.getElementById("modo-login") as HTMLElement;
  const $modoRegistro = document.getElementById("modo-registro") as HTMLElement;
  const $modoRecuperar = document.getElementById("modo-recuperar") as HTMLElement;
  const $modoNuevaPass = document.getElementById("modo-nueva-pass") as HTMLElement;

  // Login
  const $loginForm = document.getElementById("login-form") as HTMLFormElement;
  const $loginError = document.getElementById("login-error") as HTMLElement;
  const $loginSubmit = document.getElementById("login-submit") as HTMLButtonElement;
  const $loginRecover = document.getElementById("login-recover") as HTMLAnchorElement;

  // Registro
  const $signupForm = document.getElementById("signup-form") as HTMLFormElement;
  const $signupError = document.getElementById("signup-error") as HTMLElement;
  const $signupOk = document.getElementById("signup-ok") as HTMLElement;
  const $signupSubmit = document.getElementById("signup-submit") as HTMLButtonElement;

  // Recuperar contraseña (pedir el enlace)
  const $recoverForm = document.getElementById("recover-form") as HTMLFormElement;
  const $recoverError = document.getElementById("recover-error") as HTMLElement;
  const $recoverOk = document.getElementById("recover-ok") as HTMLElement;
  const $recoverSubmit = document.getElementById("recover-submit") as HTMLButtonElement;

  // Nueva contraseña (vuelta desde el mail)
  const $nuevaPassForm = document.getElementById("nuevapass-form") as HTMLFormElement;
  const $nuevaPassError = document.getElementById("nuevapass-error") as HTMLElement;
  const $nuevaPassOk = document.getElementById("nuevapass-ok") as HTMLElement;
  const $nuevaPassSubmit = document.getElementById("nuevapass-submit") as HTMLButtonElement;

  // Toggles
  const $irARegistro = document.getElementById("ir-a-registro") as HTMLAnchorElement;
  const $irALogin = document.getElementById("ir-a-login") as HTMLAnchorElement;
  const $volverALogin = document.getElementById("volver-a-login") as HTMLAnchorElement;

  // ============ Ojito mostrar/ocultar contraseña ============
  // Cada botón [data-toggle-pass] está al lado de un <input type="password">.
  // Al cliquearlo cambia el type del input y el icono visible (ojo / ojo tachado).
  // Usamos toggleAttribute en lugar de .hidden porque en <svg> la propiedad
  // hidden no siempre refleja el atributo, y el selector CSS [hidden] no
  // engancha si no está el atributo.
  document.querySelectorAll<HTMLButtonElement>("[data-toggle-pass]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const wrap = btn.closest(".login__pass-wrap");
      const input = wrap?.querySelector("input") as HTMLInputElement | null;
      if (!input) return;
      const yaVisible = input.type === "text";
      input.type = yaVisible ? "password" : "text";
      const ahoraVisible = !yaVisible;
      btn.setAttribute("aria-pressed", String(ahoraVisible));
      btn.setAttribute("aria-label", ahoraVisible ? "Ocultar contraseña" : "Mostrar contraseña");
      // Cuando la pass está visible, muestro el ojo tachado (sugiere "ocultar").
      btn.querySelector(".icono-ojo")?.toggleAttribute("hidden", ahoraVisible);
      btn.querySelector(".icono-ojo-tachado")?.toggleAttribute("hidden", !ahoraVisible);
    });
  });

  // ============ Cambiar entre vistas ============
  // Hay 4 vistas en la misma página; mostramos una y ocultamos el resto.
  type Vista = "login" | "registro" | "recuperar" | "nueva-pass";
  function mostrarVista(cual: Vista) {
    $modoLogin.hidden = cual !== "login";
    $modoRegistro.hidden = cual !== "registro";
    $modoRecuperar.hidden = cual !== "recuperar";
    $modoNuevaPass.hidden = cual !== "nueva-pass";
  }

  $irARegistro.addEventListener("click", (e) => {
    e.preventDefault();
    mostrarVista("registro");
    history.replaceState(null, "", "#registro");
  });

  $irALogin.addEventListener("click", (e) => {
    e.preventDefault();
    mostrarVista("login");
    history.replaceState(null, "", window.location.pathname);
  });

  // "Olvidé mi contraseña" → pantalla para pedir el enlace.
  $loginRecover.addEventListener("click", (e) => {
    e.preventDefault();
    // Arrastramos el mail que ya hubiera escrito en el login, así no lo retipea.
    const mailLogin = ((new FormData($loginForm).get("mail") as string) ?? "").trim();
    const inputRecover = $recoverForm.elements.namedItem("mail") as HTMLInputElement;
    if (mailLogin) inputRecover.value = mailLogin;
    ocultarMensaje($recoverError);
    ocultarMensaje($recoverOk);
    mostrarVista("recuperar");
    inputRecover.focus();
  });

  // "Volver a iniciar sesión" desde la pantalla de recuperar.
  $volverALogin.addEventListener("click", (e) => {
    e.preventDefault();
    mostrarVista("login");
  });

  // Si la URL tiene #registro, arrancamos en esa vista.
  if (window.location.hash === "#registro") {
    mostrarVista("registro");
  }

  // ============ Helpers ============
  async function redirigirSegunRol(userId: string) {
    const { data: profile, error } = await supabase
      .from("profiles")
      .select("rol")
      .eq("id", userId)
      .single();

    if (error || !profile) {
      console.error("[login] No se pudo leer el rol, fallback a mis-cursos:", error);
      window.location.href = "/aula/mis-cursos";
      return;
    }
    const destino = homePorRol[profile.rol as Rol] ?? "/aula/mis-cursos";
    window.location.href = destino;
  }

  function mostrarMensaje(el: HTMLElement, msg: string) {
    el.textContent = msg;
    el.hidden = false;
  }

  function ocultarMensaje(el: HTMLElement) {
    el.hidden = true;
    el.textContent = "";
  }

  // ============ Sesión existente / vuelta del mail de recuperación ============
  // Al procesar el enlace de recuperación, el cliente fija una sesión y dispara
  // el evento PASSWORD_RECOVERY. En ese caso NO entramos al aula: mostramos la
  // pantalla para elegir una contraseña nueva.
  supabase.auth.onAuthStateChange((event) => {
    if (event === "PASSWORD_RECOVERY") {
      mostrarVista("nueva-pass");
    }
  });

  if (veniaDeRecovery) {
    // Mostramos ya la pantalla de nueva contraseña (por si el evento de arriba
    // se disparó antes de que engancháramos el listener).
    mostrarVista("nueva-pass");
  } else {
    // Flujo normal: si ya hay sesión activa, derecho al aula.
    (async () => {
      const { data } = await supabase.auth.getSession();
      if (data.session) {
        await redirigirSegunRol(data.session.user.id);
      }
    })();
  }

  // ============ LOGIN ============
  $loginForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    ocultarMensaje($loginError);
    $loginSubmit.disabled = true;
    $loginSubmit.textContent = "Entrando…";

    const formData = new FormData($loginForm);
    const email = String(formData.get("mail"));
    const password = String(formData.get("pass"));

    // Guardar la preferencia ANTES del signIn: el adaptador de storage de
    // lib/supabase.ts la lee para decidir dónde persistir los tokens
    // (localStorage = recordar / sessionStorage = solo esta sesión).
    const recordar = formData.get("recordar") !== null;
    window.localStorage.setItem(PERSISTENCIA_KEY, recordar ? "local" : "session");

    const { data, error } = await supabase.auth.signInWithPassword({ email, password });

    if (error) {
      mostrarMensaje($loginError, traducirError(error));
      $loginSubmit.disabled = false;
      $loginSubmit.textContent = "Entrar";
      return;
    }

    if (data.user) {
      await redirigirSegunRol(data.user.id);
    } else {
      window.location.href = "/aula/mis-cursos";
    }
  });

  // ============ RECUPERAR — pedir el enlace por mail ============
  $recoverForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    ocultarMensaje($recoverError);
    ocultarMensaje($recoverOk);
    const mail = ((new FormData($recoverForm).get("mail") as string) ?? "").trim();
    if (!mail) {
      mostrarMensaje($recoverError, "Escribe tu mail para enviarte el enlace.");
      return;
    }

    $recoverSubmit.disabled = true;
    $recoverSubmit.textContent = "Enviando…";

    const { error } = await supabase.auth.resetPasswordForEmail(mail, {
      redirectTo: `${window.location.origin}/aula/login`,
    });

    $recoverSubmit.disabled = false;
    $recoverSubmit.textContent = "Enviar enlace";

    if (error) {
      mostrarMensaje($recoverError, traducirError(error));
      return;
    }

    // Mensaje a propósito genérico: no revelamos si el mail tiene cuenta o no.
    mostrarMensaje(
      $recoverOk,
      `Si ${mail} tiene una cuenta, te enviamos un enlace para crear una contraseña nueva. Revisa tu casilla (y la carpeta de spam). El enlace vence en una hora.`
    );
  });

  // ============ NUEVA CONTRASEÑA — al volver del enlace del mail ============
  $nuevaPassForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    ocultarMensaje($nuevaPassError);
    ocultarMensaje($nuevaPassOk);

    const fd = new FormData($nuevaPassForm);
    const pass = String(fd.get("pass"));
    const pass2 = String(fd.get("pass2"));

    if (pass.length < 8) {
      mostrarMensaje($nuevaPassError, "La contraseña tiene que tener al menos 8 caracteres.");
      return;
    }
    if (pass !== pass2) {
      mostrarMensaje($nuevaPassError, "Las dos contraseñas no coinciden.");
      return;
    }

    $nuevaPassSubmit.disabled = true;
    $nuevaPassSubmit.textContent = "Guardando…";

    const { data, error } = await supabase.auth.updateUser({ password: pass });

    if (error) {
      mostrarMensaje($nuevaPassError, traducirError(error));
      $nuevaPassSubmit.disabled = false;
      $nuevaPassSubmit.textContent = "Guardar contraseña";
      return;
    }

    mostrarMensaje($nuevaPassOk, "¡Listo! Tu contraseña quedó actualizada. Entrando al aula…");
    const userId = data.user?.id;
    setTimeout(() => {
      if (userId) redirigirSegunRol(userId);
      else window.location.href = "/aula/mis-cursos";
    }, 1200);
  });

  // ============ REGISTRO ============
  $signupForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    ocultarMensaje($signupError);
    ocultarMensaje($signupOk);
    $signupSubmit.disabled = true;
    $signupSubmit.textContent = "Creando cuenta…";

    const formData = new FormData($signupForm);
    const nombre = String(formData.get("nombre")).trim();
    const email = String(formData.get("mail")).trim().toLowerCase();
    const password = String(formData.get("pass"));

    const { data, error } = await supabase.auth.signUp({
      email,
      password,
      options: {
        // El trigger handle_new_user usa este metadata para el nombre del profile.
        data: { nombre },
        emailRedirectTo: `${window.location.origin}/aula/login`,
      },
    });

    if (error) {
      mostrarMensaje($signupError, traducirError(error));
      $signupSubmit.disabled = false;
      $signupSubmit.textContent = "Crear cuenta";
      return;
    }

    // Dos escenarios según la configuración de Supabase:
    //  · "Confirm email" activado → necesitan confirmar antes de loguearse.
    //  · "Confirm email" desactivado → se loguean directo.
    if (data.session) {
      // Auto-loguead@ ya. Redirigimos según rol (será 'alumno' por default).
      await redirigirSegunRol(data.session.user.id);
    } else {
      // Esperando confirmación de mail.
      mostrarMensaje(
        $signupOk,
        `¡Cuenta creada! Te enviamos un mail a ${email} para confirmarla. Revisá tu casilla y volvé a iniciar sesión.`
      );
      $signupForm.reset();
      $signupSubmit.disabled = false;
      $signupSubmit.textContent = "Crear cuenta";
    }
  });
</script>

<style>
  .login {
    flex: 1;
    display: grid;
    place-items: center;
    padding: 3rem 1.5rem;
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(ellipse at top, rgba(36, 58, 130, 0.06) 0%, transparent 60%),
      linear-gradient(180deg, var(--color-bg) 0%, var(--color-surface) 100%);
  }

  /* Marca de agua del logo completo, asomando por la derecha (como en
     el hero de la home). Se queda también en mobile, más chica.
     Sin rotación: el logo va derecho (pedido 2026-06-12). */
  .login__marca {
    position: absolute;
    top: 50%;
    right: -8%;
    width: clamp(280px, 34vw, 480px);
    height: auto;
    transform: translateY(-50%);
    color: var(--color-ink);
    opacity: 0.05;
    pointer-events: none;
  }

  /* Estrellas flotando: coral arriba a la derecha, azul tenue abajo
     a la izquierda — como en el hero del sitio. */
  .login__estrella {
    position: absolute;
    top: 12%;
    right: 10%;
    width: clamp(28px, 3.5vw, 42px);
    color: var(--color-accent);
    opacity: 0.75;
    pointer-events: none;
  }
  .login__estrella--2 {
    top: auto;
    bottom: 14%;
    left: 8%;
    right: auto;
    width: clamp(20px, 2.2vw, 30px);
    color: var(--color-deep);
    opacity: 0.35;
    transform: scaleX(-1);
  }
  @keyframes login-flotar {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50%      { transform: translateY(-12px) rotate(4deg); }
  }
  @media (prefers-reduced-motion: no-preference) {
    .login__estrella { animation: login-flotar 8s ease-in-out infinite; }
    .login__estrella--2 { animation: login-flotar 10s ease-in-out 1.3s infinite; }
  }
  @media (max-width: 720px) {
    .login__estrella { top: 6%; right: 7%; }
    .login__estrella--2 { display: none; }
    /* La marca de agua grande se oculta en mobile: asomaba cortada por
       el costado (pedido 2026-06-13). Se queda solo la estrella coral. */
    .login__marca { display: none; }
  }

  .login__card {
    width: 100%;
    max-width: 440px;
    background: #fff;
    border: 1px solid var(--color-line);
    /* Filo coral de marca: mismo detalle que llevan los mails y el footer. */
    border-top: 3px solid var(--color-accent);
    border-radius: var(--radius-md);
    padding: 2.5rem 2rem;
    box-shadow: 0 18px 60px rgba(19, 27, 61, 0.08);
    position: relative; /* por encima de los ornamentos */
  }
  /* Entrada suave del card al cargar la página. */
  @keyframes login-entra {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: none; }
  }
  @media (prefers-reduced-motion: no-preference) {
    .login__card {
      animation: login-entra 0.55s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
  }

  /* Ícono del logo, alineado a la izquierda del card. */
  .login__brand {
    display: flex;
    justify-content: flex-start;
    margin-bottom: 1.5rem;
    line-height: 0;
  }
  .login__brand-logo {
    width: auto;
    height: 72px;
    display: block;
  }

  .login__titulo { font-size: 1.9rem; margin: 0 0 0.5rem; }
  .login__bajada {
    color: var(--color-ink-soft);
    margin: 0 0 2rem;
    font-size: 0.98rem;
  }

  .login__form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .login__label {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.85rem;
    color: var(--color-ink-soft);
    font-weight: 500;
  }
  .login__label input {
    font-family: inherit;
    font-size: 1rem;
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    color: var(--color-ink);
    transition: border-color 0.15s ease, background 0.15s ease;
    width: 100%;
  }
  .login__label input:focus {
    outline: none;
    border-color: var(--color-deep);
    background: #fff;
  }

  /* Wrap para el input de contraseña + botón de mostrar/ocultar. */
  .login__pass-wrap {
    position: relative;
    display: flex;
    align-items: stretch;
  }
  .login__pass-wrap input {
    padding-right: 2.6rem; /* hace espacio para el ojito */
  }
  .login__pass-toggle {
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    display: grid;
    place-items: center;
    width: 2.4rem;
    background: transparent;
    border: 0;
    color: var(--color-ink-muted);
    cursor: pointer;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .login__pass-toggle:hover { color: var(--color-ink); background: rgba(19, 27, 61, 0.04); }
  .login__pass-toggle:focus-visible {
    outline: 2px solid var(--color-deep);
    outline-offset: -2px;
  }
  /* El atributo `hidden` no siempre oculta los <svg> en todos los navegadores —
     forzamos con CSS para que solo se vea el icono activo (ojo / ojo tachado). */
  .login__pass-toggle svg[hidden] { display: none; }

  /* Checkbox "mantener sesión iniciada" */
  .login__recordar {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    font-size: 0.88rem;
    color: var(--color-ink-soft);
    cursor: pointer;
    line-height: 1.35;
  }
  .login__recordar input[type="checkbox"] {
    margin-top: 0.15rem;
    accent-color: var(--color-accent);
    flex-shrink: 0;
    width: 1rem;
    height: 1rem;
  }

  .login__msg-error,
  .login__msg-ok {
    margin: 0;
    padding: 0.7rem 0.9rem;
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    line-height: 1.4;
  }
  .login__msg-error {
    background: rgba(216, 85, 42, 0.1);
    border-left: 3px solid var(--color-accent);
    color: var(--color-accent);
  }
  .login__msg-ok {
    background: rgba(36, 58, 130, 0.08);
    border-left: 3px solid var(--color-deep);
    color: var(--color-deep);
  }

  .login__submit {
    margin-top: 0.5rem;
    padding: 0.9rem 1rem;
    border: 0;
    border-radius: var(--radius-sm);
    background: var(--color-accent);
    color: #fff;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .login__submit:hover:not(:disabled) { background: var(--color-accent-dark); }
  .login__submit:disabled { opacity: 0.7; cursor: wait; }

  .login__olvido {
    margin-top: 0.25rem;
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-ink-soft);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .login__olvido:hover { color: var(--color-ink); }

  .login__ayuda {
    margin: 2rem 0 0;
    text-align: center;
    color: var(--color-ink-muted);
    font-size: 0.88rem;
    line-height: 1.5;
  }
  .login__ayuda a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
  }
</style>
