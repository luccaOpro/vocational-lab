---
/*
  /aula/login — login + registro contra Supabase.
  ---
  Dos vistas en una sola página, alternables con un toggle:
    1. Login (default): mail + contraseña → signInWithPassword.
    2. Registro: nombre + mail + contraseña → signUp.
       El trigger handle_new_user crea automáticamente el profile
       con rol = 'alumno'. Admin después puede promover el rol.
*/

import AulaLayout from "../../layouts/AulaLayout.astro";
---

<AulaLayout title="Ingresar al aula · Vocational Lab" nav={false}>
  <main class="login">
    <div class="login__card">
      <a href="/" class="login__brand">
        <span class="login__brand-mark">VL</span>
        <span>Vocational Lab</span>
      </a>

      {/* ============ MODO LOGIN ============ */}
      <div id="modo-login">
        <h1 class="login__titulo">Entrá al aula.</h1>
        <p class="login__bajada">
          Si ya tenés acceso, ingresá con tu mail y contraseña.
        </p>

        <form id="login-form" class="login__form">
          <label class="login__label">
            <span>Mail</span>
            <input type="email" name="mail" placeholder="tu@mail.com" required autocomplete="email" />
          </label>
          <label class="login__label">
            <span>Contraseña</span>
            <input type="password" name="pass" placeholder="••••••••" required autocomplete="current-password" />
          </label>
          <p id="login-error" class="login__msg-error" hidden></p>
          <button type="submit" id="login-submit" class="login__submit">Entrar</button>
          <a href="#" class="login__olvido" id="login-recover">Olvidé mi contraseña</a>
        </form>

        <p class="login__ayuda">
          ¿Todavía no tenés cuenta?
          <a href="#" id="ir-a-registro">Crear una nueva</a>
        </p>
      </div>

      {/* ============ MODO REGISTRO ============ */}
      <div id="modo-registro" hidden>
        <h1 class="login__titulo">Crear cuenta.</h1>
        <p class="login__bajada">
          Completá tus datos. Te activamos el acceso cuando confirmemos tu inscripción.
        </p>

        <form id="signup-form" class="login__form">
          <label class="login__label">
            <span>Nombre y apellido</span>
            <input type="text" name="nombre" placeholder="María Pérez" required autocomplete="name" minlength="2" />
          </label>
          <label class="login__label">
            <span>Mail</span>
            <input type="email" name="mail" placeholder="tu@mail.com" required autocomplete="email" />
          </label>
          <label class="login__label">
            <span>Contraseña</span>
            <input type="password" name="pass" placeholder="Mínimo 8 caracteres" required autocomplete="new-password" minlength="8" />
          </label>
          <p id="signup-error" class="login__msg-error" hidden></p>
          <p id="signup-ok" class="login__msg-ok" hidden></p>
          <button type="submit" id="signup-submit" class="login__submit">Crear cuenta</button>
        </form>

        <p class="login__ayuda">
          ¿Ya tenés cuenta?
          <a href="#" id="ir-a-login">Iniciá sesión</a>
        </p>
      </div>
    </div>
  </main>
</AulaLayout>

<script>
  import { supabase } from "../../lib/supabase";
  import { homePorRol, type Rol } from "../../lib/auth-guard";

  // ============ Referencias DOM ============
  const $modoLogin = document.getElementById("modo-login") as HTMLElement;
  const $modoRegistro = document.getElementById("modo-registro") as HTMLElement;

  // Login
  const $loginForm = document.getElementById("login-form") as HTMLFormElement;
  const $loginError = document.getElementById("login-error") as HTMLElement;
  const $loginSubmit = document.getElementById("login-submit") as HTMLButtonElement;
  const $loginRecover = document.getElementById("login-recover") as HTMLAnchorElement;

  // Registro
  const $signupForm = document.getElementById("signup-form") as HTMLFormElement;
  const $signupError = document.getElementById("signup-error") as HTMLElement;
  const $signupOk = document.getElementById("signup-ok") as HTMLElement;
  const $signupSubmit = document.getElementById("signup-submit") as HTMLButtonElement;

  // Toggles
  const $irARegistro = document.getElementById("ir-a-registro") as HTMLAnchorElement;
  const $irALogin = document.getElementById("ir-a-login") as HTMLAnchorElement;

  // ============ Toggle entre vistas ============
  $irARegistro.addEventListener("click", (e) => {
    e.preventDefault();
    $modoLogin.hidden = true;
    $modoRegistro.hidden = false;
    history.replaceState(null, "", "#registro");
  });

  $irALogin.addEventListener("click", (e) => {
    e.preventDefault();
    $modoLogin.hidden = false;
    $modoRegistro.hidden = true;
    history.replaceState(null, "", window.location.pathname);
  });

  // Si la URL tiene #registro, arrancamos en esa vista.
  if (window.location.hash === "#registro") {
    $modoLogin.hidden = true;
    $modoRegistro.hidden = false;
  }

  // ============ Helpers ============
  async function redirigirSegunRol(userId: string) {
    const { data: profile, error } = await supabase
      .from("profiles")
      .select("rol")
      .eq("id", userId)
      .single();

    if (error || !profile) {
      console.error("[login] No se pudo leer el rol, fallback a mis-cursos:", error);
      window.location.href = "/aula/mis-cursos";
      return;
    }
    const destino = homePorRol[profile.rol as Rol] ?? "/aula/mis-cursos";
    window.location.href = destino;
  }

  function mostrarMensaje(el: HTMLElement, msg: string) {
    el.textContent = msg;
    el.hidden = false;
  }

  function ocultarMensaje(el: HTMLElement) {
    el.hidden = true;
    el.textContent = "";
  }

  // ============ Si ya hay sesión, redirigimos ============
  (async () => {
    const { data } = await supabase.auth.getSession();
    if (data.session) {
      await redirigirSegunRol(data.session.user.id);
    }
  })();

  // ============ LOGIN ============
  $loginForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    ocultarMensaje($loginError);
    $loginSubmit.disabled = true;
    $loginSubmit.textContent = "Entrando…";

    const formData = new FormData($loginForm);
    const email = String(formData.get("mail"));
    const password = String(formData.get("pass"));

    const { data, error } = await supabase.auth.signInWithPassword({ email, password });

    if (error) {
      const msg = error.message.includes("Invalid login credentials")
        ? "Mail o contraseña incorrectos."
        : error.message.includes("Email not confirmed")
        ? "Tu mail todavía no está confirmado. Revisá tu casilla."
        : `No pudimos entrar: ${error.message}`;
      mostrarMensaje($loginError, msg);
      $loginSubmit.disabled = false;
      $loginSubmit.textContent = "Entrar";
      return;
    }

    if (data.user) {
      await redirigirSegunRol(data.user.id);
    } else {
      window.location.href = "/aula/mis-cursos";
    }
  });

  // "Olvidé mi contraseña" — envía mail de recuperación.
  $loginRecover.addEventListener("click", async (e) => {
    e.preventDefault();
    ocultarMensaje($loginError);
    const mail = (new FormData($loginForm).get("mail") as string)?.trim();
    if (!mail) {
      mostrarMensaje($loginError, "Escribí tu mail arriba y volvé a apretar 'Olvidé mi contraseña'.");
      return;
    }
    const { error } = await supabase.auth.resetPasswordForEmail(mail, {
      redirectTo: `${window.location.origin}/aula/login`,
    });
    if (error) {
      mostrarMensaje($loginError, `No pudimos enviar el mail: ${error.message}`);
      return;
    }
    $loginError.style.color = "var(--color-deep)";
    mostrarMensaje($loginError, `Te enviamos un mail a ${mail} para resetear la contraseña.`);
  });

  // ============ REGISTRO ============
  $signupForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    ocultarMensaje($signupError);
    ocultarMensaje($signupOk);
    $signupSubmit.disabled = true;
    $signupSubmit.textContent = "Creando cuenta…";

    const formData = new FormData($signupForm);
    const nombre = String(formData.get("nombre")).trim();
    const email = String(formData.get("mail")).trim().toLowerCase();
    const password = String(formData.get("pass"));

    const { data, error } = await supabase.auth.signUp({
      email,
      password,
      options: {
        // El trigger handle_new_user usa este metadata para el nombre del profile.
        data: { nombre },
        emailRedirectTo: `${window.location.origin}/aula/login`,
      },
    });

    if (error) {
      const msg = error.message.includes("already registered") || error.message.includes("already been registered")
        ? "Ese mail ya está registrado. Probá iniciar sesión."
        : error.message.includes("Password should be")
        ? "La contraseña tiene que tener al menos 8 caracteres."
        : `No pudimos crear la cuenta: ${error.message}`;
      mostrarMensaje($signupError, msg);
      $signupSubmit.disabled = false;
      $signupSubmit.textContent = "Crear cuenta";
      return;
    }

    // Dos escenarios según la configuración de Supabase:
    //  · "Confirm email" activado → necesitan confirmar antes de loguearse.
    //  · "Confirm email" desactivado → se loguean directo.
    if (data.session) {
      // Auto-loguead@ ya. Redirigimos según rol (será 'alumno' por default).
      await redirigirSegunRol(data.session.user.id);
    } else {
      // Esperando confirmación de mail.
      mostrarMensaje(
        $signupOk,
        `¡Cuenta creada! Te enviamos un mail a ${email} para confirmarla. Revisá tu casilla y volvé a iniciar sesión.`
      );
      $signupForm.reset();
      $signupSubmit.disabled = false;
      $signupSubmit.textContent = "Crear cuenta";
    }
  });
</script>

<style>
  .login {
    flex: 1;
    display: grid;
    place-items: center;
    padding: 3rem 1.5rem;
    background:
      radial-gradient(ellipse at top, rgba(36, 58, 130, 0.06) 0%, transparent 60%),
      linear-gradient(180deg, var(--color-bg) 0%, var(--color-surface) 100%);
  }

  .login__card {
    width: 100%;
    max-width: 440px;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    padding: 2.5rem 2rem;
    box-shadow: 0 18px 60px rgba(19, 27, 61, 0.08);
  }

  .login__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-serif);
    font-size: 0.95rem;
    color: var(--color-ink-soft);
    margin-bottom: 1.8rem;
  }
  .login__brand-mark {
    display: inline-grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--color-ink);
    color: var(--color-bg);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .login__titulo { font-size: 1.9rem; margin: 0 0 0.5rem; }
  .login__bajada {
    color: var(--color-ink-soft);
    margin: 0 0 2rem;
    font-size: 0.98rem;
  }

  .login__form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .login__label {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.85rem;
    color: var(--color-ink-soft);
    font-weight: 500;
  }
  .login__label input {
    font-family: inherit;
    font-size: 1rem;
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    color: var(--color-ink);
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .login__label input:focus {
    outline: none;
    border-color: var(--color-deep);
    background: #fff;
  }

  .login__msg-error,
  .login__msg-ok {
    margin: 0;
    padding: 0.7rem 0.9rem;
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    line-height: 1.4;
  }
  .login__msg-error {
    background: rgba(216, 85, 42, 0.1);
    border-left: 3px solid var(--color-accent);
    color: var(--color-accent);
  }
  .login__msg-ok {
    background: rgba(36, 58, 130, 0.08);
    border-left: 3px solid var(--color-deep);
    color: var(--color-deep);
  }

  .login__submit {
    margin-top: 0.5rem;
    padding: 0.9rem 1rem;
    border: 0;
    border-radius: var(--radius-sm);
    background: var(--color-accent);
    color: #fff;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .login__submit:hover:not(:disabled) { background: var(--color-accent-dark); }
  .login__submit:disabled { opacity: 0.7; cursor: wait; }

  .login__olvido {
    margin-top: 0.25rem;
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-ink-soft);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .login__olvido:hover { color: var(--color-ink); }

  .login__ayuda {
    margin: 2rem 0 0;
    text-align: center;
    color: var(--color-ink-muted);
    font-size: 0.88rem;
    line-height: 1.5;
  }
  .login__ayuda a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
  }
</style>
