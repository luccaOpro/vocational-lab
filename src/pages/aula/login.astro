---
/*
  /aula/login — login + registro contra Supabase.
  ---
  Dos vistas en una sola página, alternables con un toggle:
    1. Login (default): mail + contraseña → signInWithPassword.
    2. Registro: nombre + mail + contraseña → signUp.
       El trigger handle_new_user crea automáticamente el profile
       con rol = 'alumno'. Admin después puede promover el rol.
*/

import AulaLayout from "../../layouts/AulaLayout.astro";
---

<AulaLayout title="Ingresar al aula · Vocational Lab" nav={false}>
  <main class="login">
    {/* Marca de agua: el ícono COMPLETO del logo (arco + flecha + estrella),
        gigante y casi invisible, asomando por la derecha — como en el hero. */}
    <svg class="login__marca" viewBox="0 -5 371 465" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path fill="currentColor" d="M0,443.73l.03-45.407c23.216.636,45.683-4.407,66.324-14.637,36.23-18.152,63.593-50.904,74.253-90.112,10.187-37.467,4.874-77.408-15.454-110.56-6.952-11.393-15.189-21.809-25.037-30.712C72.82,127.121,37.263,113.652,0,114.496l.037-46.499c44.551-.826,87.825,14.16,122.067,42.496,13.748,11.427,25.844,24.486,35.722,39.444,8.994,13.102,16.167,27.094,21.57,42.023,12.435,34.36,14.355,70.023,6.359,105.724-8.974,40.066-30.991,76.227-62.228,102.842-22.961,19.111-50.003,32.569-79.197,39.003-14.634,3.128-29.245,4.514-44.329,4.2Z"/>
