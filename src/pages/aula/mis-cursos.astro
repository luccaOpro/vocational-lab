---
/*
  /aula/mis-cursos — pantalla principal del alumno una vez que entró.
  Muestra la lista de cursos donde está inscripto, cada uno con un
  resumen, profesor, período y barra de progreso. Click → al curso.
*/

import AulaLayout from "../../layouts/AulaLayout.astro";
import { alumnoDemo, cursosDemo } from "../../data/cursos-demo";
---

<AulaLayout title="Mis cursos · Aula Vocational Lab">
  <main class="cursos">
    <div class="container">
      <header class="cursos__head">
        <p class="cursos__eyebrow">Aula · Hola de nuevo</p>
        <h1 class="cursos__titulo">Hola, {alumnoDemo.nombre.split(" ")[0]}.</h1>
        <p class="cursos__bajada">Estos son tus cursos activos.</p>
      </header>

      <div class="cursos__grid">
        {cursosDemo.map((c) => (
          <a href={`/aula/curso/${c.slug}`} class="curso-card">
            <div class="curso-card__head">
              <span class="curso-card__periodo">{c.periodo}</span>
              <span class={`curso-card__estado ${c.progreso === 100 ? "is-completo" : ""}`}>
                {c.progreso === 100 ? "Completo" : "En curso"}
              </span>
            </div>

            <h2 class="curso-card__titulo">{c.titulo}</h2>
            <p class="curso-card__resumen">{c.resumen}</p>

            <div class="curso-card__profe">
              Con <strong>{c.profesor}</strong>
            </div>

            <div class="curso-card__progreso" aria-label={`Progreso ${c.progreso}%`}>
              <div class="curso-card__barra">
                <span style={`width: ${c.progreso}%`}></span>
              </div>
              <span class="curso-card__porcentaje">{c.progreso}%</span>
            </div>

            <span class="curso-card__entrar">Entrar al curso →</span>
          </a>
        ))}
      </div>
    </div>
  </main>
</AulaLayout>

<style>
  .cursos {
    flex: 1;
    padding: clamp(2.5rem, 6vw, 4rem) 0 5rem;
  }

  .cursos__head {
    max-width: 720px;
    margin-bottom: 3rem;
  }
  .cursos__eyebrow {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin: 0 0 0.9rem;
  }
  .cursos__titulo {
    font-size: clamp(2rem, 4.5vw, 2.8rem);
    margin: 0 0 0.6rem;
  }
  .cursos__bajada {
    color: var(--color-ink-soft);
    font-size: 1.05rem;
    margin: 0;
  }

  /* ===== Grid de cursos ===== */
  .cursos__grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  }

  .curso-card {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding: 1.6rem 1.6rem 1.4rem;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    color: var(--color-ink);
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }
  .curso-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 40px rgba(19, 27, 61, 0.08);
    border-color: var(--color-deep);
  }

  .curso-card__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }
  .curso-card__estado {
    padding: 0.25rem 0.55rem;
    border-radius: 99px;
    background: rgba(36, 58, 130, 0.1);
    color: var(--color-deep);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: none;
  }
  .curso-card__estado.is-completo {
    background: rgba(201, 162, 76, 0.18);
    color: #7a5f1f;
  }

  .curso-card__titulo {
    font-size: 1.35rem;
    margin: 0;
    line-height: 1.2;
  }
  .curso-card__resumen {
    margin: 0;
    color: var(--color-ink-soft);
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .curso-card__profe {
    font-size: 0.9rem;
    color: var(--color-ink-soft);
  }
  .curso-card__profe strong {
    color: var(--color-ink);
    font-weight: 500;
  }

  /* Barra de progreso */
  .curso-card__progreso {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.3rem;
  }
  .curso-card__barra {
    flex: 1;
    height: 6px;
    background: var(--color-line);
    border-radius: 99px;
    overflow: hidden;
  }
  .curso-card__barra span {
    display: block;
    height: 100%;
    background: var(--color-accent);
    border-radius: 99px;
    transition: width 0.4s ease;
  }
  .curso-card__porcentaje {
    font-size: 0.85rem;
    color: var(--color-ink-soft);
    min-width: 36px;
    text-align: right;
  }

  .curso-card__entrar {
    margin-top: 0.4rem;
    color: var(--color-accent);
    font-weight: 500;
    font-size: 0.95rem;
  }
</style>
