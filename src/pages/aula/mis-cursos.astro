---
/*
  /aula/mis-cursos — pantalla principal del alumno una vez logueado.
  ---
  La página renderiza un "esqueleto" estático (loader + estructura) y
  un script del cliente que:
    1. Chequea sesión. Si no hay → redirige a /aula/login.
    2. Trae el profile del user para saber nombre y rol.
    3. Trae los cursos visibles (filtrados por RLS).
    4. Pinta las cards.
*/

import AulaLayout from "../../layouts/AulaLayout.astro";
---

<AulaLayout title="Mis cursos · Aula Vocational Lab">
  <main class="cursos">
    <div class="container">
      {/* Loader inicial — se oculta cuando llegan los datos. */}
      <div id="cursos-loader" class="cursos__loader">
        <div class="loader" role="status">
          <span class="loader__spinner" aria-hidden="true"></span>
          <span class="loader__label">Cargando tus cursos…</span>
        </div>
      </div>

      {/* Contenido real — empieza oculto, se muestra cuando hay datos. */}
      <div id="cursos-contenido" hidden>
        <header class="cursos__head">
          <p class="cursos__eyebrow">Aula · Hola de nuevo</p>
          <h1 class="cursos__titulo" id="saludo">Hola</h1>
          <p class="cursos__bajada" id="bajada">Estos son tus cursos activos.</p>
        </header>

        {/* Estado: sin cursos. */}
        <div id="cursos-vacio" hidden>
          <div class="empty-state">
            <span class="empty-state__icono" aria-hidden="true">📚</span>
            <h3 class="empty-state__titulo">Todavía no tienes cursos</h3>
            <p class="empty-state__bajada">
              Si recién pagaste, espera a que activemos tu acceso —
              te avisamos por mail cuando esté listo.
            </p>
          </div>
        </div>

        {/* Grid de cursos — lo llenamos desde JS. */}
        <div id="cursos-grid" class="cursos__grid"></div>
      </div>
    </div>
  </main>
</AulaLayout>

<script>
  import { supabase } from "../../lib/supabase";
  import { requireSession } from "../../lib/auth-guard";
  import { traducirError } from "../../lib/ui";

  const $loader = document.getElementById("cursos-loader")!;
  const $contenido = document.getElementById("cursos-contenido") as HTMLElement;
  const $saludo = document.getElementById("saludo")!;
  const $grid = document.getElementById("cursos-grid")!;
  const $vacio = document.getElementById("cursos-vacio") as HTMLElement;

  function saludoSegunHora(nombre: string): string {
    const h = new Date().getHours();
    const momento = h < 13 ? "Buen día" : h < 20 ? "Buenas tardes" : "Buenas noches";
    return `${momento}, ${nombre}`;
  }

  async function cargar() {
    const auth = await requireSession();
    if (!auth) return;

    const { profile } = auth;

    // Cursos visibles (RLS filtra por inscripción).
    const { data: cursos, error: errCursos } = await supabase
      .from("cursos")
      .select("id, slug, titulo, resumen, periodo, publicado")
      .eq("publicado", true)
      .order("creado_en", { ascending: false });

    if (errCursos) {
      $loader.textContent = `Error al cargar cursos: ${traducirError(errCursos)}`;
      return;
    }

    const primerNombre = profile.nombre.split(" ")[0];
    $saludo.textContent = saludoSegunHora(primerNombre);
    $loader.hidden = true;
    $contenido.hidden = false;

    if (!cursos || cursos.length === 0) {
      $vacio.hidden = false;
      return;
    }

    // Cantidad de cursos en la bajada.
    const $bajada = document.getElementById("bajada")!;
    $bajada.textContent = cursos.length === 1
      ? "Este es tu curso activo."
      : `Tenés ${cursos.length} cursos activos.`;

    // Progreso por curso: tareas totales y entregadas.
    const cursoIds = cursos.map((c: any) => c.id);
    const progresoPorCurso: Record<string, { total: number; entregadas: number }> = {};
    cursoIds.forEach((id: string) => { progresoPorCurso[id] = { total: 0, entregadas: 0 }; });

    try {
      // Todas las tareas de todos los cursos en una sola query.
      const { data: tareasData } = await supabase
        .from("tareas")
        .select("id, modulos!inner(curso_id)")
        .in("modulos.curso_id", cursoIds);

      const tareasPorCurso: Record<string, string[]> = {};
      (tareasData ?? []).forEach((t: any) => {
        const cid = t.modulos?.curso_id;
        if (cid) {
          if (!tareasPorCurso[cid]) tareasPorCurso[cid] = [];
          tareasPorCurso[cid].push(t.id);
        }
      });

      const allIds = Object.values(tareasPorCurso).flat();
      const entregadasSet = new Set<string>();

      if (allIds.length > 0) {
        const { data: entregasData } = await supabase
          .from("entregas")
          .select("tarea_id")
          .eq("alumno_id", profile.id)
          .in("tarea_id", allIds);
        (entregasData ?? []).forEach((e: any) => entregadasSet.add(e.tarea_id));
      }

      for (const cid of cursoIds) {
        const ids = tareasPorCurso[cid] ?? [];
        progresoPorCurso[cid] = {
          total: ids.length,
          entregadas: ids.filter((id) => entregadasSet.has(id)).length,
        };
      }
    } catch { /* progreso no crítico — las cards se muestran igual */ }

    $grid.innerHTML = cursos
      .map((c: any) => {
        const p = progresoPorCurso[c.id] ?? { total: 0, entregadas: 0 };
        const pct = p.total > 0 ? Math.round((p.entregadas / p.total) * 100) : 0;
        const completo = p.total > 0 && p.entregadas === p.total;

        const estadoBadge = completo
          ? `<span class="curso-card__estado curso-card__estado--completo">Completado ✓</span>`
          : `<span class="curso-card__estado">En curso</span>`;

        const progresoHTML = p.total > 0 ? `
          <div class="curso-card__progreso">
            <div class="curso-card__progreso-barra-wrap">
              <div class="curso-card__progreso-barra" style="width:${pct}%"></div>
            </div>
            <span class="curso-card__progreso-texto">
              ${p.entregadas} de ${p.total} tarea${p.total === 1 ? "" : "s"}
            </span>
          </div>
        ` : "";

        return `
          <a href="/aula/curso?slug=${encodeURIComponent(c.slug)}" class="curso-card">
            <div class="curso-card__head">
              <span class="curso-card__periodo">${escape(c.periodo ?? "")}</span>
              ${estadoBadge}
            </div>
            <h2 class="curso-card__titulo">${escape(c.titulo)}</h2>
            <p class="curso-card__resumen">${escape(c.resumen ?? "")}</p>
            ${progresoHTML}
            <span class="curso-card__entrar">Entrar al curso →</span>
          </a>
        `;
      })
      .join("");
  }

  // Mini helper para evitar inyección de HTML.
  function escape(str: string): string {
    return String(str)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }

  cargar();
</script>

<style>
  .cursos {
    flex: 1;
    padding: clamp(2.5rem, 6vw, 4rem) 0 5rem;
  }

  .cursos__loader {
    color: var(--color-ink-soft);
    font-style: italic;
    padding: 2rem 0;
  }

  .cursos__head { max-width: 720px; margin-bottom: 3rem; }
  .cursos__eyebrow {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin: 0 0 0.9rem;
  }
  .cursos__titulo {
    font-size: clamp(2rem, 4.5vw, 2.8rem);
    margin: 0 0 0.6rem;
  }
  .cursos__bajada {
    color: var(--color-ink-soft);
    font-size: 1.05rem;
    margin: 0;
  }

  .cursos__vacio {
    background: #fff;
    border: 1px dashed var(--color-line);
    border-radius: var(--radius-md);
    padding: 2rem;
    text-align: center;
    color: var(--color-ink-soft);
  }
  .cursos__vacio p { margin: 0 0 0.5rem; }
  .cursos__vacio-hint { font-size: 0.9rem; color: var(--color-ink-muted); }

  /* ===== Grid de cursos ===== */
  .cursos__grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  }

  :global(.curso-card) {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding: 1.6rem 1.6rem 1.4rem;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    color: var(--color-ink);
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }
  :global(.curso-card:hover) {
    transform: translateY(-3px);
    box-shadow: 0 18px 40px rgba(19, 27, 61, 0.08);
    border-color: var(--color-deep);
  }

  :global(.curso-card__head) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }
  :global(.curso-card__estado) {
    padding: 0.25rem 0.55rem;
    border-radius: 99px;
    background: rgba(36, 58, 130, 0.1);
    color: var(--color-deep);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: none;
  }
  :global(.curso-card__titulo) {
    font-size: 1.35rem;
    margin: 0;
    line-height: 1.2;
  }
  :global(.curso-card__resumen) {
    margin: 0;
    color: var(--color-ink-soft);
    font-size: 0.95rem;
    line-height: 1.5;
  }
  :global(.curso-card__estado--completo) {
    background: rgba(36, 130, 80, 0.12);
    color: #1a6b3e;
  }

  :global(.curso-card__progreso) {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-top: 0.2rem;
  }
  :global(.curso-card__progreso-barra-wrap) {
    flex: 1;
    height: 4px;
    background: var(--color-line);
    border-radius: 99px;
    overflow: hidden;
  }
  :global(.curso-card__progreso-barra) {
    height: 100%;
    background: var(--color-deep);
    border-radius: 99px;
    transition: width 0.4s ease;
  }
  :global(.curso-card__progreso-texto) {
    font-size: 0.78rem;
    color: var(--color-ink-muted);
    white-space: nowrap;
  }

  :global(.curso-card__entrar) {
    margin-top: 0.4rem;
    color: var(--color-accent);
    font-weight: 500;
    font-size: 0.95rem;
  }
</style>
