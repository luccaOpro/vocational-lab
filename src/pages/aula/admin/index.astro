---
/*
  /aula/admin — dashboard del admin.
  ---
  KPIs reales del estado del aula:
   · usuarios totales (alumnos / profes / admins)
   · cursos publicados
   · entregas pendientes
   · transferencias pendientes (cuando se implemente la carga)
*/

import AulaLayout from "../../../layouts/AulaLayout.astro";
---

<AulaLayout title="Admin · Aula Vocational Lab" rol="admin">
  <main class="admin">
    <div class="container">
      <header class="admin__head">
        <p class="admin__eyebrow">Admin</p>
        <h1 class="admin__titulo" id="admin-titulo">Panel general</h1>
        <p class="admin__bajada" id="admin-bajada">Cargando…</p>
      </header>

      <div id="admin-loader" class="admin__loader">
        <div class="loader" role="status">
          <span class="loader__spinner" aria-hidden="true"></span>
          <span class="loader__label">Cargando datos…</span>
        </div>
      </div>

      <div id="admin-contenido" hidden>
        <section class="kpis">
          <article class="kpi">
            <span class="kpi__numero" id="kpi-alumnos">0</span>
            <span class="kpi__label">Alumnos</span>
          </article>
          <article class="kpi">
            <span class="kpi__numero" id="kpi-profes">0</span>
            <span class="kpi__label">Profes</span>
          </article>
          <article class="kpi">
            <span class="kpi__numero" id="kpi-admins">0</span>
            <span class="kpi__label">Admins</span>
          </article>
          <article class="kpi">
            <span class="kpi__numero" id="kpi-cursos">0</span>
            <span class="kpi__label">Cursos publicados</span>
          </article>
          <a href="/aula/admin/transferencias" class="kpi kpi--alerta kpi--link" id="kpi-sin-curso-wrap">
            <span class="kpi__numero" id="kpi-sin-curso">0</span>
            <span class="kpi__label">Alumnos sin curso</span>
            <span class="kpi__cta">Ver pagos →</span>
          </a>
          <article class="kpi kpi--alerta">
            <span class="kpi__numero" id="kpi-pendientes">0</span>
            <span class="kpi__label">Entregas a corregir</span>
          </article>
        </section>

        <section class="admin__seccion">
          <div class="admin__seccion-head">
            <h2 class="admin__seccion-titulo">Accesos rápidos</h2>
          </div>
          <div class="acciones">
            <a href="/aula/admin/cursos" class="accion">
              <span class="accion__icono">📚</span>
              <div>
                <span class="accion__titulo">Gestionar cursos</span>
                <span class="accion__bajada">Crear, editar y publicar cursos del aula.</span>
              </div>
            </a>
            <a href="/aula/admin/transferencias" class="accion">
              <span class="accion__icono">💸</span>
              <div>
                <span class="accion__titulo">Pagos y accesos</span>
                <span class="accion__bajada">Confirmar transferencias y dar acceso a alumnos nuevos.</span>
              </div>
            </a>
            <a href="/aula/admin/usuarios" class="accion">
              <span class="accion__icono">👥</span>
              <div>
                <span class="accion__titulo">Gestionar usuarios</span>
                <span class="accion__bajada">Promover a profe/admin, ver mails, controlar roles.</span>
              </div>
            </a>
            <a href="/aula/profe/entregas" class="accion">
              <span class="accion__icono">📝</span>
              <div>
                <span class="accion__titulo">Ver entregas</span>
                <span class="accion__bajada">Repasar lo entregado por los alumnos y las correcciones.</span>
              </div>
            </a>
          </div>
        </section>
      </div>

      <p id="admin-error" class="admin__error" hidden></p>
    </div>
  </main>
</AulaLayout>

<script>
  import { supabase } from "../../../lib/supabase";
  import { requireRol } from "../../../lib/auth-guard";
  import { traducirError } from "../../../lib/ui";

  const $loader = document.getElementById("admin-loader") as HTMLElement;
  const $contenido = document.getElementById("admin-contenido") as HTMLElement;
  const $errorBox = document.getElementById("admin-error") as HTMLElement;
  const $titulo = document.getElementById("admin-titulo")!;
  const $bajada = document.getElementById("admin-bajada")!;

  async function cargar() {
    const auth = await requireRol(["admin"]);
    if (!auth) return;

    $titulo.textContent = `Hola, ${auth.profile.nombre.split(" ")[0]}.`;

    // Consultas en paralelo para acelerar.
    const [profilesRes, cursosRes, entregasRes, sinCursoRes] = await Promise.all([
      supabase.from("profiles").select("rol"),
      supabase.from("cursos").select("id").eq("publicado", true),
      supabase.from("entregas").select("id").is("corregida_en", null),
      // Alumnos sin ninguna inscripción activa.
      supabase.rpc("alumnos_sin_inscripcion_count").maybeSingle(),
    ]);

    if (profilesRes.error) return mostrarError(profilesRes.error.message);
    if (cursosRes.error) return mostrarError(cursosRes.error.message);
    if (entregasRes.error) return mostrarError(entregasRes.error.message);

    const profiles = profilesRes.data ?? [];
    const cursos = cursosRes.data ?? [];
    const entregas = entregasRes.data ?? [];

    const conteo = { alumno: 0, profe: 0, admin: 0 };
    for (const p of profiles) {
      conteo[p.rol as keyof typeof conteo] = (conteo[p.rol as keyof typeof conteo] ?? 0) + 1;
    }

    // Fallback: si la RPC no existe todavía, lo calculamos manualmente.
    let sinCurso = 0;
    if (sinCursoRes.error || sinCursoRes.data == null) {
      const { data } = await supabase
        .from("profiles")
        .select("id, inscripciones!inner(activo)", { count: "exact" })
        .eq("rol", "alumno");
      // Workaround: traemos todos los alumnos y filtramos en cliente.
      const { data: todosAlumnos } = await supabase
        .from("profiles")
        .select("id, inscripciones(activo)")
        .eq("rol", "alumno");
      sinCurso = (todosAlumnos ?? []).filter(
        (a: any) => !(a.inscripciones ?? []).some((i: any) => i.activo)
      ).length;
      void data;
    } else {
      sinCurso = Number(sinCursoRes.data) || 0;
    }

    document.getElementById("kpi-alumnos")!.textContent = String(conteo.alumno);
    document.getElementById("kpi-profes")!.textContent = String(conteo.profe);
    document.getElementById("kpi-admins")!.textContent = String(conteo.admin);
    document.getElementById("kpi-cursos")!.textContent = String(cursos.length);
    document.getElementById("kpi-pendientes")!.textContent = String(entregas.length);
    document.getElementById("kpi-sin-curso")!.textContent = String(sinCurso);

    // Ocultamos el KPI si está vacío (no es prioritario verlo).
    const $sinCursoWrap = document.getElementById("kpi-sin-curso-wrap")!;
    if (sinCurso === 0) $sinCursoWrap.hidden = true;

    // Bajada: priorizamos el aviso más urgente.
    if (sinCurso > 0) {
      $bajada.textContent = `Tenés ${sinCurso} alumno${sinCurso === 1 ? "" : "s"} registrado${sinCurso === 1 ? "" : "s"} sin curso asignado.`;
    } else if (entregas.length > 0) {
      $bajada.textContent = `Hay ${entregas.length} entrega${entregas.length === 1 ? "" : "s"} esperando corrección.`;
    } else {
      $bajada.textContent = "Sin avisos pendientes. Todo al día.";
    }

    $loader.hidden = true;
    $contenido.hidden = false;
  }

  function mostrarError(msg: string) {
    $loader.hidden = true;
    $errorBox.hidden = false;
    $errorBox.textContent = `Error: ${traducirError(msg)}`;
  }

  cargar().catch((err) => {
    console.error("[admin]", err);
    mostrarError(err instanceof Error ? err.message : String(err));
  });
</script>

<style>
  .admin { flex: 1; padding: clamp(2.5rem, 6vw, 4rem) 0 5rem; }

  .admin__head { max-width: 720px; margin-bottom: 2.5rem; }
  .admin__eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 500;
    margin: 0 0 0.9rem;
  }
  .admin__titulo {
    font-size: clamp(2rem, 4.5vw, 2.6rem);
    margin: 0 0 0.6rem;
  }
  .admin__bajada { color: var(--color-ink-soft); margin: 0; font-size: 1.05rem; }

  .admin__loader {
    color: var(--color-ink-soft);
    font-style: italic;
    padding: 2rem 0;
  }
  .admin__error {
    color: var(--color-accent);
    padding: 1rem 0;
  }

  .kpis {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1rem;
    margin-bottom: 3rem;
  }
  .kpi {
    padding: 1.3rem;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .kpi--alerta { border-left: 3px solid var(--color-accent); }

  /* KPI clickeable (queremos que actúe como acción + se note). */
  .kpi--link {
    color: var(--color-ink);
    text-decoration: none;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
    position: relative;
  }
  .kpi--link:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 30px rgba(216, 85, 42, 0.12);
  }
  .kpi__cta {
    margin-top: 0.4rem;
    font-size: 0.8rem;
    color: var(--color-accent);
    font-weight: 500;
  }
  .kpi__numero {
    font-family: var(--font-serif);
    font-size: 2.4rem;
    line-height: 1;
    color: var(--color-ink);
  }
  .kpi--alerta .kpi__numero { color: var(--color-accent); }
  .kpi__label {
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }

  .admin__seccion { margin-bottom: 3rem; }
  .admin__seccion-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.2rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-line);
    flex-wrap: wrap;
  }
  .admin__seccion-titulo { font-size: 1.3rem; margin: 0; }

  /* Accesos rápidos */
  .acciones {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  .accion {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1.3rem;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    color: var(--color-ink);
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }
  .accion:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 40px rgba(19, 27, 61, 0.08);
    border-color: var(--color-accent);
  }
  .accion__icono {
    font-size: 1.5rem;
    line-height: 1;
    flex-shrink: 0;
  }
  .accion__titulo {
    display: block;
    font-weight: 500;
    margin-bottom: 0.2rem;
  }
  .accion__bajada {
    display: block;
    font-size: 0.88rem;
    color: var(--color-ink-soft);
    line-height: 1.4;
  }
</style>
