---
/*
  /aula/admin/cursos/editor — crear o editar un curso.
  Sin ?id: crea uno nuevo.
  Con ?id=UUID: carga el curso y permite editar / borrar.
*/

import AulaLayout from "../../../../layouts/AulaLayout.astro";
---

<AulaLayout title="Editor de curso · Admin · Vocational Lab" rol="admin">
  <main class="editor">
    <div class="container">
      <a href="/aula/admin/cursos" class="editor__volver">← Volver a cursos</a>

      <div id="editor-loader" class="editor__loader">
        <div class="loader" role="status">
          <span class="loader__spinner" aria-hidden="true"></span>
          <span class="loader__label">Cargando…</span>
        </div>
      </div>

      <div id="editor-contenido" hidden>
        <header class="editor__head">
          <p class="editor__eyebrow" id="editor-eyebrow">Cursos</p>
          <h1 class="editor__titulo" id="editor-titulo">Nuevo curso</h1>
        </header>

        <form id="curso-form" class="form-curso">
          <label class="form-curso__label">
            <span>Título del curso *</span>
            <input
              type="text"
              name="titulo"
              required
              minlength="3"
              placeholder="Ej: Coaching Vocacional · Edición Agosto 2026"
            />
          </label>

          {/* El slug (URL interna del curso) se genera automáticamente
              del título al crear. No se cambia al editar para no romper
              URLs ya compartidas. Lo manejamos del lado del JS. */}

          <label class="form-curso__label">
            <span>Resumen *</span>
            <textarea
              name="resumen"
              rows="3"
              required
              placeholder="Una bajada corta para mostrar en la card del curso."
            ></textarea>
          </label>

          <label class="form-curso__label">
            <span>Período</span>
            <input
              type="text"
              name="periodo"
              placeholder="Ej: Agosto – Octubre 2026"
            />
          </label>

          <label class="form-curso__label form-curso__label--check">
            <input type="checkbox" name="publicado" />
            <span>
              <strong>Publicar el curso</strong>
              <small class="form-curso__hint">Si está sin tildar, queda como borrador y los protagonistas no lo ven.</small>
            </span>
          </label>

          <div class="form-curso__acciones">
            <button type="submit" id="submit-curso" class="form-curso__submit">Crear curso</button>
            <button type="button" id="borrar-curso" class="form-curso__danger" hidden>Borrar curso</button>
          </div>
        </form>

        {/* ── Solo en modo edición: gestión de profes + acceso a contenido ── */}
        <section id="seccion-profes" class="seccion-extra" hidden>
          <div class="seccion-extra__head">
            <div>
              <h2 class="seccion-extra__titulo">Profesores asignados</h2>
              <p class="seccion-extra__bajada" id="profes-bajada">Quiénes pueden corregir entregas y subir material.</p>
            </div>
            <button type="button" id="abrir-asignar-profe-btn" class="agregar-profe__btn">+ Asignar profe</button>
          </div>

          <div id="profes-grid" class="profes-grid"></div>
        </section>

        <section id="seccion-alumnos" class="seccion-extra" hidden>
          <div class="seccion-extra__head">
            <div>
              <h2 class="seccion-extra__titulo">Protagonistas inscriptos</h2>
              <p class="seccion-extra__bajada" id="alumnos-bajada">Quiénes tienen acceso al curso.</p>
            </div>
            <button type="button" id="abrir-inscribir-btn" class="agregar-profe__btn">+ Inscribir protagonistas</button>
          </div>

          <div id="alumnos-grid" class="alumnos-grid"></div>

        </section>

        <section id="seccion-contenido" class="seccion-extra" hidden>
          <h2 class="seccion-extra__titulo">Contenido del curso</h2>
          <p class="seccion-extra__bajada">Acá administrás los módulos, archivos y tareas.</p>
          <a id="link-contenido" href="#" class="contenido-link">Ir a gestionar contenido →</a>
        </section>
      </div>

      <p id="editor-error" class="editor__error" hidden></p>
    </div>
  </main>
</AulaLayout>

<script>
  import { supabase } from "../../../../lib/supabase";
  import { requireRol } from "../../../../lib/auth-guard";
  import { showToast, confirmModal, traducirError } from "../../../../lib/ui";

  const $loader = document.getElementById("editor-loader") as HTMLElement;
  const $contenido = document.getElementById("editor-contenido") as HTMLElement;
  const $errorBox = document.getElementById("editor-error") as HTMLElement;
  const $titulo = document.getElementById("editor-titulo")!;
  const $form = document.getElementById("curso-form") as HTMLFormElement;
  const $submit = document.getElementById("submit-curso") as HTMLButtonElement;
  const $borrar = document.getElementById("borrar-curso") as HTMLButtonElement;

  let modoEdicion = false;
  let cursoId: string | null = null;
  // Slug del curso en modo edición — no se modifica al editar el título
  // para no romper URLs ya compartidas con los alumnos.
  let slugActual: string | null = null;

  /** Convierte "Hola Mundo · Edición 2026!" → "hola-mundo-edicion-2026". */
  function slugify(s: string): string {
    return s
      .toLowerCase()
      .normalize("NFD")
      .replace(/[̀-ͯ]/g, "")     // saca acentos
      .replace(/[^a-z0-9\s-]/g, "")        // saca caracteres especiales
      .trim()
      .replace(/\s+/g, "-")                // espacios → guiones
      .replace(/-+/g, "-");                // guiones múltiples → uno
  }

  /** Garantiza que el slug sea único agregando -2, -3, ... si hace falta. */
  async function generarSlugUnico(base: string): Promise<string> {
    let slug = base;
    let n = 1;
    while (true) {
      const { data } = await supabase
        .from("cursos")
        .select("id")
        .eq("slug", slug)
        .maybeSingle();
      if (!data) return slug;
      n += 1;
      slug = `${base}-${n}`;
    }
  }

  async function cargar() {
    const auth = await requireRol(["admin"]);
    if (!auth) return;

    cursoId = new URLSearchParams(window.location.search).get("id");
    modoEdicion = !!cursoId;

    if (modoEdicion) {
      $titulo.textContent = "Editar curso";
      $submit.textContent = "Guardar cambios";
      $borrar.hidden = false;

      const { data: curso, error } = await supabase
        .from("cursos")
        .select("titulo, slug, resumen, periodo, publicado")
        .eq("id", cursoId!)
        .maybeSingle();

      if (error || !curso) {
        $loader.hidden = true;
        $errorBox.hidden = false;
        $errorBox.textContent = error
          ? `Error al cargar el curso: ${traducirError(error)}`
          : "No encontramos ese curso.";
        return;
      }

      ($form.elements.namedItem("titulo") as HTMLInputElement).value = curso.titulo;
      ($form.elements.namedItem("resumen") as HTMLTextAreaElement).value = curso.resumen ?? "";
      ($form.elements.namedItem("periodo") as HTMLInputElement).value = curso.periodo ?? "";
      ($form.elements.namedItem("publicado") as HTMLInputElement).checked = !!curso.publicado;
      slugActual = curso.slug;
    }

    enchufarSubmit();
    enchufarBorrar();

    if (modoEdicion) {
      // Mostramos secciones extra que solo aplican a cursos existentes.
      document.getElementById("seccion-profes")!.hidden = false;
      document.getElementById("seccion-alumnos")!.hidden = false;
      document.getElementById("seccion-contenido")!.hidden = false;
      (document.getElementById("link-contenido") as HTMLAnchorElement).href =
        `/aula/admin/cursos/contenido?id=${encodeURIComponent(cursoId!)}`;
      await Promise.all([cargarProfes(), cargarAlumnos()]);
    }

    $loader.hidden = true;
    $contenido.hidden = false;
  }

  // ============ Gestión de profes ============
  type ProfileMini = { id: string; nombre: string; email: string; rol: string; avatar_url: string | null };

  /** Render del avatar (img si tiene foto, iniciales si no). Usa la clase
   *  base que reciba (alumno-card__avatar, profe-card__avatar, etc.).
   *  La variante --con-foto pone background transparente. */
  function avatarHtml(p: ProfileMini, baseClass: string, modificadorRol?: string): string {
    if (p.avatar_url) {
      return `<div class="${baseClass} ${baseClass}--con-foto"><img src="${esc(p.avatar_url)}" alt="" /></div>`;
    }
    const mod = modificadorRol ? ` ${baseClass}--${esc(modificadorRol)}` : "";
    return `<div class="${baseClass}${mod}">${esc(iniciales(p.nombre))}</div>`;
  }

  async function cargarProfes() {
    const $grid = document.getElementById("profes-grid")!;
    const $bajada = document.getElementById("profes-bajada")!;

    const [resPosibles, resAsignados] = await Promise.all([
      supabase
        .from("profiles")
        .select("id, nombre, email, rol, avatar_url")
        .in("rol", ["profe", "admin"])
        .order("nombre"),
      supabase
        .from("cursos_profesores")
        .select("profesor_id, profiles!cursos_profesores_profesor_id_fkey(id, nombre, email, rol, avatar_url)")
        .eq("curso_id", cursoId!),
    ]);

    if (resPosibles.error || resAsignados.error) {
      $grid.innerHTML = `<p class="profes-grid__error">Error al cargar profes: ${
        traducirError(resPosibles.error ?? resAsignados.error)
      }</p>`;
      return;
    }

    const asignados = (resAsignados.data ?? []).map(
      (r: any) => r.profiles as ProfileMini
    ).filter(Boolean);
    const asignadosIds = new Set(asignados.map((p) => p.id));
    const posibles = (resPosibles.data ?? []) as ProfileMini[];
    const disponibles = posibles.filter((p) => !asignadosIds.has(p.id));

    $bajada.textContent = asignados.length === 0
      ? "Todavía no hay profes asignados."
      : `${asignados.length} profe${asignados.length === 1 ? "" : "s"} asignado${asignados.length === 1 ? "" : "s"}.`;

    $grid.innerHTML = asignados.length === 0
      ? `<p class="profes-grid__vacio">Ningún profe asignado todavía.</p>`
      : asignados.map((p) => `
          <article class="profe-card">
            ${avatarHtml(p, "profe-card__avatar", p.rol)}
            <div class="profe-card__cuerpo">
              <span class="profe-card__nombre">${esc(p.nombre)}</span>
              <span class="profe-card__mail">${esc(p.email)}</span>
            </div>
            <button type="button" class="profe-card__quitar" data-profe-id="${esc(p.id)}" aria-label="Quitar a ${esc(p.nombre)}">×</button>
          </article>
        `).join("");

    $grid.querySelectorAll<HTMLButtonElement>(".profe-card__quitar").forEach((btn) => {
      btn.addEventListener("click", () => quitarProfe(btn.dataset.profeId!));
    });

    const $btnAbrir = document.getElementById("abrir-asignar-profe-btn") as HTMLButtonElement;
    $btnAbrir.disabled = disponibles.length === 0;
    $btnAbrir.title = disponibles.length === 0 ? "No hay más profes disponibles" : "";
    $btnAbrir.onclick = () => abrirModalAsignarProfe(disponibles);
  }

  async function quitarProfe(profeId: string) {
    const ok = await confirmModal({
      titulo: "Quitar profe",
      mensaje: "¿Sacarlo como profe de este curso? No se borra del sistema, solo se desvincula.",
      confirmLabel: "Quitar",
      danger: true,
    });
    if (!ok) return;
    const { error } = await supabase
      .from("cursos_profesores")
      .delete()
      .eq("curso_id", cursoId!)
      .eq("profesor_id", profeId);
    if (error) {
      showToast(traducirError(error), "error");
      return;
    }
    showToast("Profe quitado del curso.");
    await cargarProfes();
  }

  /** Modal con búsqueda + checkboxes para asignar varios profes a la vez. */
  function abrirModalAsignarProfe(disponibles: ProfileMini[]) {
    const modal = document.getElementById("modal-confirm")!;
    const $titulo = document.getElementById("modal-confirm-titulo")!;
    const $mensaje = document.getElementById("modal-confirm-mensaje") as HTMLElement;
    const $btnOk = document.getElementById("modal-confirm-ok") as HTMLButtonElement;
    const $btnCancel = document.getElementById("modal-confirm-cancel") as HTMLButtonElement;
    const $backdrop = modal.querySelector("[data-modal-backdrop]") as HTMLElement;

    $titulo.textContent = "Asignar profes";
    $mensaje.hidden = false;
    $mensaje.innerHTML = `
      <input type="search" id="asignar-buscar" placeholder="Buscar por nombre o mail…" class="multi-buscar" autocomplete="off" />
      <div id="asignar-lista" class="multi-lista">
        ${disponibles.map((p) => `
          <label class="multi-item">
            <input type="checkbox" value="${esc(p.id)}" />
            ${avatarHtml(p, "multi-item__avatar", "profe")}
            <div class="multi-item__cuerpo">
              <span class="multi-item__nombre">${esc(p.nombre)}</span>
              <span class="multi-item__mail">${esc(p.email)}</span>
            </div>
          </label>
        `).join("")}
      </div>
      <p id="asignar-conteo" class="multi-conteo">0 seleccionado/s</p>
    `;
    $btnCancel.textContent = "Cancelar";
    $btnOk.textContent = "Asignar";
    $btnOk.className = "modal__btn modal__btn--primary";
    $btnOk.disabled = true;

    modal.hidden = false;
    document.body.classList.add("modal-open");
    void modal.offsetWidth;
    modal.classList.add("modal--visible");

    const $buscar = document.getElementById("asignar-buscar") as HTMLInputElement;
    const $lista = document.getElementById("asignar-lista") as HTMLElement;
    const $conteo = document.getElementById("asignar-conteo") as HTMLElement;

    requestAnimationFrame(() => $buscar.focus());

    $buscar.addEventListener("input", () => {
      const q = $buscar.value.trim().toLowerCase();
      $lista.querySelectorAll<HTMLLabelElement>(".multi-item").forEach((item) => {
        const text = item.textContent?.toLowerCase() ?? "";
        item.style.display = text.includes(q) ? "" : "none";
      });
    });

    function actualizarConteo() {
      const checked = $lista.querySelectorAll<HTMLInputElement>('input[type="checkbox"]:checked');
      $conteo.textContent = `${checked.length} seleccionado${checked.length === 1 ? "" : "s"}`;
      $btnOk.disabled = checked.length === 0;
      $btnOk.textContent = checked.length === 0 ? "Asignar" : `Asignar ${checked.length}`;
    }
    $lista.addEventListener("change", actualizarConteo);

    function cleanup() {
      modal.classList.remove("modal--visible");
      setTimeout(() => {
        modal.hidden = true;
        document.body.classList.remove("modal-open");
        $mensaje.innerHTML = "";
        $btnOk.disabled = false;
      }, 200);
      $btnOk.removeEventListener("click", onOk);
      $btnCancel.removeEventListener("click", onCancel);
      $backdrop.removeEventListener("click", onCancel);
      document.removeEventListener("keydown", onEsc);
    }

    async function onOk() {
      const ids = Array.from($lista.querySelectorAll<HTMLInputElement>('input[type="checkbox"]:checked')).map((c) => c.value);
      if (ids.length === 0) return;

      $btnOk.disabled = true;
      $btnOk.textContent = "Asignando…";

      const rows = ids.map((id) => ({ curso_id: cursoId!, profesor_id: id }));
      const { error } = await supabase.from("cursos_profesores").insert(rows);

      if (error) {
        showToast(traducirError(error), "error");
        $btnOk.disabled = false;
        return;
      }

      cleanup();
      showToast(`${ids.length} profe${ids.length === 1 ? "" : "s"} asignado${ids.length === 1 ? "" : "s"}.`);
      await cargarProfes();
    }
    function onCancel() { cleanup(); }
    function onEsc(e: KeyboardEvent) { if (e.key === "Escape") cleanup(); }

    $btnOk.addEventListener("click", onOk);
    $btnCancel.addEventListener("click", onCancel);
    $backdrop.addEventListener("click", onCancel);
    document.addEventListener("keydown", onEsc);
  }

  // ============ Gestión de alumnos inscriptos ============
  type InscripcionRow = {
    id: string;
    activo: boolean;
    profiles: ProfileMini | null;
  };

  async function cargarAlumnos() {
    const $grid = document.getElementById("alumnos-grid")!;
    const $bajada = document.getElementById("alumnos-bajada")!;

    const [resTodos, resInscriptos] = await Promise.all([
      supabase
        .from("profiles")
        .select("id, nombre, email, rol, avatar_url")
        .eq("rol", "alumno")
        .order("nombre"),
      supabase
        .from("inscripciones")
        .select("id, activo, profiles!inscripciones_alumno_id_fkey(id, nombre, email, rol, avatar_url)")
        .eq("curso_id", cursoId!),
    ]);

    if (resTodos.error || resInscriptos.error) {
      $grid.innerHTML = `<p class="alumnos-grid__error">Error al cargar protagonistas: ${
        traducirError(resTodos.error ?? resInscriptos.error)
      }</p>`;
      return;
    }

    const inscripciones = ((resInscriptos.data ?? []) as unknown as InscripcionRow[])
      .filter((i) => !!i.profiles);
    const inscriptosIds = new Set(inscripciones.map((i) => i.profiles!.id));
    const todosAlumnos = (resTodos.data ?? []) as ProfileMini[];
    const disponibles = todosAlumnos.filter((a) => !inscriptosIds.has(a.id));

    // Bajada con conteo.
    $bajada.textContent = inscripciones.length === 0
      ? "Todavía no hay protagonistas inscriptos."
      : `${inscripciones.length} protagonista${inscripciones.length === 1 ? "" : "s"} inscripto${inscripciones.length === 1 ? "" : "s"}.`;

    // Grid de cards de inscriptos.
    $grid.innerHTML = inscripciones.length === 0
      ? `<p class="alumnos-grid__vacio">Aún no hay protagonistas en este curso.</p>`
      : inscripciones.map((i) => {
          const a = i.profiles!;
          return `
            <article class="alumno-card">
              ${avatarHtml(a, "alumno-card__avatar")}
              <div class="alumno-card__cuerpo">
                <span class="alumno-card__nombre">${esc(a.nombre)}</span>
                <span class="alumno-card__mail">${esc(a.email)}</span>
              </div>
              <button type="button" class="alumno-card__quitar" data-inscripcion-id="${esc(i.id)}" data-nombre="${esc(a.nombre)}" aria-label="Desinscribir a ${esc(a.nombre)}">×</button>
            </article>
          `;
        }).join("");

    $grid.querySelectorAll<HTMLButtonElement>(".alumno-card__quitar").forEach((btn) => {
      btn.addEventListener("click", () => desinscribirAlumno(btn.dataset.inscripcionId!, btn.dataset.nombre!));
    });

    // Botón de abrir modal de inscripción múltiple.
    const $btnAbrir = document.getElementById("abrir-inscribir-btn") as HTMLButtonElement;
    $btnAbrir.disabled = disponibles.length === 0;
    $btnAbrir.title = disponibles.length === 0 ? "No hay más protagonistas para inscribir" : "";
    $btnAbrir.onclick = () => abrirModalInscribir(disponibles);
  }

  /** Modal con búsqueda + lista con checkboxes para inscribir varios alumnos a la vez. */
  function abrirModalInscribir(disponibles: ProfileMini[]) {
    const modal = document.getElementById("modal-confirm")!;
    const $titulo = document.getElementById("modal-confirm-titulo")!;
    const $mensaje = document.getElementById("modal-confirm-mensaje") as HTMLElement;
    const $btnOk = document.getElementById("modal-confirm-ok") as HTMLButtonElement;
    const $btnCancel = document.getElementById("modal-confirm-cancel") as HTMLButtonElement;
    const $backdrop = modal.querySelector("[data-modal-backdrop]") as HTMLElement;

    $titulo.textContent = "Inscribir protagonistas";
    $mensaje.hidden = false;
    $mensaje.innerHTML = `
      <input type="search" id="inscribir-buscar" placeholder="Buscar por nombre o mail…" class="multi-buscar" autocomplete="off" />
      <div id="inscribir-lista" class="multi-lista">
        ${disponibles.map((a) => `
          <label class="multi-item">
            <input type="checkbox" value="${esc(a.id)}" />
            ${avatarHtml(a, "multi-item__avatar")}
            <div class="multi-item__cuerpo">
              <span class="multi-item__nombre">${esc(a.nombre)}</span>
              <span class="multi-item__mail">${esc(a.email)}</span>
            </div>
          </label>
        `).join("")}
      </div>
      <p id="inscribir-conteo" class="multi-conteo">0 seleccionado/s</p>
    `;
    $btnCancel.textContent = "Cancelar";
    $btnOk.textContent = "Inscribir";
    $btnOk.className = "modal__btn modal__btn--primary";
    $btnOk.disabled = true;

    modal.hidden = false;
    document.body.classList.add("modal-open");
    void modal.offsetWidth;
    modal.classList.add("modal--visible");

    const $buscar = document.getElementById("inscribir-buscar") as HTMLInputElement;
    const $lista = document.getElementById("inscribir-lista") as HTMLElement;
    const $conteo = document.getElementById("inscribir-conteo") as HTMLElement;

    requestAnimationFrame(() => $buscar.focus());

    // Filtro de búsqueda.
    $buscar.addEventListener("input", () => {
      const q = $buscar.value.trim().toLowerCase();
      $lista.querySelectorAll<HTMLLabelElement>(".multi-item").forEach((item) => {
        const text = item.textContent?.toLowerCase() ?? "";
        item.style.display = text.includes(q) ? "" : "none";
      });
    });

    // Actualizar conteo cuando se marcan checkboxes.
    function actualizarConteo() {
      const checked = $lista.querySelectorAll<HTMLInputElement>('input[type="checkbox"]:checked');
      $conteo.textContent = `${checked.length} seleccionado${checked.length === 1 ? "" : "s"}`;
      $btnOk.disabled = checked.length === 0;
      $btnOk.textContent = checked.length === 0
        ? "Inscribir"
        : `Inscribir ${checked.length}`;
    }
    $lista.addEventListener("change", actualizarConteo);

    function cleanup() {
      modal.classList.remove("modal--visible");
      setTimeout(() => {
        modal.hidden = true;
        document.body.classList.remove("modal-open");
        $mensaje.innerHTML = "";
        $btnOk.disabled = false;
      }, 200);
      $btnOk.removeEventListener("click", onOk);
      $btnCancel.removeEventListener("click", onCancel);
      $backdrop.removeEventListener("click", onCancel);
      document.removeEventListener("keydown", onEsc);
    }

    async function onOk() {
      const ids = Array.from($lista.querySelectorAll<HTMLInputElement>('input[type="checkbox"]:checked')).map((c) => c.value);
      if (ids.length === 0) return;

      $btnOk.disabled = true;
      $btnOk.textContent = "Inscribiendo…";

      const rows = ids.map((id) => ({ curso_id: cursoId!, alumno_id: id, activo: true }));
      const { error } = await supabase.from("inscripciones").insert(rows);

      if (error) {
        showToast(traducirError(error), "error");
        $btnOk.disabled = false;
        return;
      }

      cleanup();
      showToast(`${ids.length} protagonista${ids.length === 1 ? "" : "s"} inscripto${ids.length === 1 ? "" : "s"}.`);
      await cargarAlumnos();
    }
    function onCancel() { cleanup(); }
    function onEsc(e: KeyboardEvent) { if (e.key === "Escape") cleanup(); }

    $btnOk.addEventListener("click", onOk);
    $btnCancel.addEventListener("click", onCancel);
    $backdrop.addEventListener("click", onCancel);
    document.addEventListener("keydown", onEsc);
  }

  async function desinscribirAlumno(inscripcionId: string, nombre: string) {
    const ok = await confirmModal({
      titulo: "Desinscribir protagonista",
      mensaje: `${nombre} va a perder el acceso a este curso y sus entregas. Esta acción no se puede deshacer. ¿Continuar?`,
      confirmLabel: "Desinscribir",
      danger: true,
    });
    if (!ok) return;
    const { error } = await supabase
      .from("inscripciones")
      .delete()
      .eq("id", inscripcionId);
    if (error) {
      showToast(traducirError(error), "error");
      return;
    }
    showToast("Protagonista desinscripto");
    await cargarAlumnos();
  }

  function esc(s: string | null | undefined) {
    return String(s ?? "")
      .replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;").replace(/'/g, "&#039;");
  }

  function iniciales(nombre: string) {
    return nombre.split(" ").map((n) => n[0]).join("").slice(0, 2).toUpperCase();
  }

  function enchufarSubmit() {
    $form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const fd = new FormData($form);
      const titulo = String(fd.get("titulo")).trim();
      const resumen = String(fd.get("resumen")).trim();
      const periodo = String(fd.get("periodo")).trim();
      const publicado = fd.get("publicado") === "on";

      $submit.disabled = true;
      $submit.textContent = modoEdicion ? "Guardando…" : "Creando…";

      // Al editar: NO cambiamos el slug (preservamos las URLs ya compartidas).
      // Al crear: lo generamos del título y agregamos sufijo si hay colisión.
      let slug: string;
      if (modoEdicion) {
        slug = slugActual ?? slugify(titulo);
      } else {
        const base = slugify(titulo) || "curso";
        slug = await generarSlugUnico(base);
      }

      const payload = { titulo, slug, resumen, periodo: periodo || null, publicado };

      const { error } = modoEdicion
        ? await supabase.from("cursos").update(payload).eq("id", cursoId!)
        : await supabase.from("cursos").insert(payload);

      $submit.disabled = false;
      $submit.textContent = modoEdicion ? "Guardar cambios" : "Crear curso";

      if (error) {
        showToast(traducirError(error), "error");
        return;
      }

      showToast(modoEdicion ? "Curso actualizado." : "Curso creado.");
      window.location.href = "/aula/admin/cursos";
    });
  }

  function enchufarBorrar() {
    $borrar.addEventListener("click", async () => {
      const tituloActual = ($form.elements.namedItem("titulo") as HTMLInputElement).value;
      const ok = await confirmModal({
        titulo: "Borrar curso",
        mensaje: `¿Seguro que quieres borrar "${tituloActual}"? También se borran sus módulos, tareas e inscripciones. Esta acción no se puede deshacer.`,
        confirmLabel: "Borrar definitivamente",
        danger: true,
      });
      if (!ok) return;

      $borrar.disabled = true;
      $borrar.textContent = "Borrando…";

      const { error } = await supabase.from("cursos").delete().eq("id", cursoId!);

      if (error) {
        showToast(traducirError(error), "error");
        $borrar.disabled = false;
        $borrar.textContent = "Borrar curso";
        return;
      }

      showToast("Curso borrado.");
      window.location.href = "/aula/admin/cursos";
    });
  }

  cargar().catch((err) => {
    console.error("[editor-curso]", err);
    $loader.hidden = true;
    $errorBox.hidden = false;
    $errorBox.textContent = `Error inesperado: ${err instanceof Error ? err.message : String(err)}`;
  });
</script>

