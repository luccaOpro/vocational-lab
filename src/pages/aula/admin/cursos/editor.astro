---
/*
  /aula/admin/cursos/editor — crear o editar un curso.
  Sin ?id: crea uno nuevo.
  Con ?id=UUID: carga el curso y permite editar / borrar.
*/

import AulaLayout from "../../../../layouts/AulaLayout.astro";
---

<AulaLayout title="Editor de curso · Admin · Vocational Lab" rol="admin">
  <main class="editor">
    <div class="container">
      <a href="/aula/admin/cursos" class="editor__volver">← Volver a cursos</a>

      <div id="editor-loader" class="editor__loader">
        <div class="loader" role="status">
          <span class="loader__spinner" aria-hidden="true"></span>
          <span class="loader__label">Cargando…</span>
        </div>
      </div>

      <div id="editor-contenido" hidden>
        <header class="editor__head">
          <p class="editor__eyebrow" id="editor-eyebrow">Cursos</p>
          <h1 class="editor__titulo" id="editor-titulo">Nuevo curso</h1>
        </header>

        <form id="curso-form" class="form-curso">
          <label class="form-curso__label">
            <span>Título del curso *</span>
            <input
              type="text"
              name="titulo"
              required
              minlength="3"
              placeholder="Ej: Coaching Vocacional · Edición Agosto 2026"
            />
          </label>

          <label class="form-curso__label">
            <span>
              URL del curso (slug)
              <small class="form-curso__hint">— se autogenera del título; podés ajustarlo</small>
            </span>
            <div class="form-curso__slug">
              <span class="form-curso__slug-prefix">/aula/curso?slug=</span>
              <input
                type="text"
                name="slug"
                required
                pattern="[a-z0-9\-]+"
                placeholder="coaching-vocacional-agosto-2026"
              />
            </div>
            <small class="form-curso__error" id="slug-error" hidden></small>
          </label>

          <label class="form-curso__label">
            <span>Resumen *</span>
            <textarea
              name="resumen"
              rows="3"
              required
              placeholder="Una bajada corta para mostrar en la card del curso."
            ></textarea>
          </label>

          <label class="form-curso__label">
            <span>Período</span>
            <input
              type="text"
              name="periodo"
              placeholder="Ej: Agosto – Octubre 2026"
            />
          </label>

          <label class="form-curso__label form-curso__label--check">
            <input type="checkbox" name="publicado" />
            <span>
              <strong>Publicar el curso</strong>
              <small class="form-curso__hint">Si está sin tildar, queda como borrador y los alumnos no lo ven.</small>
            </span>
          </label>

          <div class="form-curso__acciones">
            <button type="submit" id="submit-curso" class="form-curso__submit">Crear curso</button>
            <button type="button" id="borrar-curso" class="form-curso__danger" hidden>Borrar curso</button>
          </div>
        </form>

        {/* ── Solo en modo edición: gestión de profes + acceso a contenido ── */}
        <section id="seccion-profes" class="seccion-extra" hidden>
          <h2 class="seccion-extra__titulo">Profesores asignados</h2>
          <p class="seccion-extra__bajada">Quiénes pueden corregir entregas y subir material en este curso.</p>

          <ul id="profes-lista" class="profes-lista"></ul>

          <div class="agregar-profe">
            <label for="profe-disponible" class="agregar-profe__label">Agregar profe:</label>
            <select id="profe-disponible" class="agregar-profe__select">
              <option value="">— Elegí un profe —</option>
            </select>
            <button type="button" id="agregar-profe-btn" class="agregar-profe__btn">+ Agregar</button>
          </div>
        </section>

        <section id="seccion-alumnos" class="seccion-extra" hidden>
          <h2 class="seccion-extra__titulo">Alumnos inscriptos</h2>
          <p class="seccion-extra__bajada">Quiénes tienen acceso al curso y aparecen en "Mis cursos".</p>

          <ul id="alumnos-lista" class="profes-lista"></ul>

          <div class="agregar-profe">
            <label for="alumno-disponible" class="agregar-profe__label">Inscribir alumno:</label>
            <select id="alumno-disponible" class="agregar-profe__select">
              <option value="">— Elegí un alumno —</option>
            </select>
            <button type="button" id="agregar-alumno-btn" class="agregar-profe__btn">+ Inscribir</button>
          </div>
          <p class="seccion-extra__nota">
            Si el alumno todavía no se registró en el aula, decile que entre a
            <code>/aula/login</code> y use "Crear cuenta". Después aparece acá para inscribirlo.
          </p>
        </section>

        <section id="seccion-contenido" class="seccion-extra" hidden>
          <h2 class="seccion-extra__titulo">Contenido del curso</h2>
          <p class="seccion-extra__bajada">Acá administrás los módulos, archivos y tareas.</p>
          <a id="link-contenido" href="#" class="contenido-link">Ir a gestionar contenido →</a>
        </section>
      </div>

      <p id="editor-error" class="editor__error" hidden></p>
    </div>
  </main>
</AulaLayout>

<script>
  import { supabase } from "../../../../lib/supabase";
  import { requireRol } from "../../../../lib/auth-guard";
  import { showToast, confirmModal, traducirError } from "../../../../lib/ui";

  const $loader = document.getElementById("editor-loader") as HTMLElement;
  const $contenido = document.getElementById("editor-contenido") as HTMLElement;
  const $errorBox = document.getElementById("editor-error") as HTMLElement;
  const $titulo = document.getElementById("editor-titulo")!;
  const $form = document.getElementById("curso-form") as HTMLFormElement;
  const $submit = document.getElementById("submit-curso") as HTMLButtonElement;
  const $borrar = document.getElementById("borrar-curso") as HTMLButtonElement;
  const $slugError = document.getElementById("slug-error") as HTMLElement;

  let modoEdicion = false;
  let cursoId: string | null = null;

  /** Convierte "Hola Mundo · Edición 2026!" → "hola-mundo-edicion-2026". */
  function slugify(s: string): string {
    return s
      .toLowerCase()
      .normalize("NFD")
      .replace(/[̀-ͯ]/g, "")     // saca acentos
      .replace(/[^a-z0-9\s-]/g, "")        // saca caracteres especiales
      .trim()
      .replace(/\s+/g, "-")                // espacios → guiones
      .replace(/-+/g, "-");                // guiones múltiples → uno
  }

  async function cargar() {
    const auth = await requireRol(["admin"]);
    if (!auth) return;

    cursoId = new URLSearchParams(window.location.search).get("id");
    modoEdicion = !!cursoId;

    if (modoEdicion) {
      $titulo.textContent = "Editar curso";
      $submit.textContent = "Guardar cambios";
      $borrar.hidden = false;

      const { data: curso, error } = await supabase
        .from("cursos")
        .select("titulo, slug, resumen, periodo, publicado")
        .eq("id", cursoId!)
        .maybeSingle();

      if (error || !curso) {
        $loader.hidden = true;
        $errorBox.hidden = false;
        $errorBox.textContent = error
          ? `Error al cargar el curso: ${traducirError(error)}`
          : "No encontramos ese curso.";
        return;
      }

      ($form.elements.namedItem("titulo") as HTMLInputElement).value = curso.titulo;
      ($form.elements.namedItem("slug") as HTMLInputElement).value = curso.slug;
      ($form.elements.namedItem("resumen") as HTMLTextAreaElement).value = curso.resumen ?? "";
      ($form.elements.namedItem("periodo") as HTMLInputElement).value = curso.periodo ?? "";
      ($form.elements.namedItem("publicado") as HTMLInputElement).checked = !!curso.publicado;
    }

    enchufarSlugAuto();
    enchufarSubmit();
    enchufarBorrar();

    if (modoEdicion) {
      // Mostramos secciones extra que solo aplican a cursos existentes.
      document.getElementById("seccion-profes")!.hidden = false;
      document.getElementById("seccion-alumnos")!.hidden = false;
      document.getElementById("seccion-contenido")!.hidden = false;
      (document.getElementById("link-contenido") as HTMLAnchorElement).href =
        `/aula/admin/cursos/contenido?id=${encodeURIComponent(cursoId!)}`;
      await Promise.all([cargarProfes(), cargarAlumnos()]);
    }

    $loader.hidden = true;
    $contenido.hidden = false;
  }

  // ============ Gestión de profes ============
  type ProfileMini = { id: string; nombre: string; email: string; rol: string };

  async function cargarProfes() {
    const $lista = document.getElementById("profes-lista")!;
    const $select = document.getElementById("profe-disponible") as HTMLSelectElement;

    // Profes/admins disponibles + los ya asignados al curso.
    const [resPosibles, resAsignados] = await Promise.all([
      supabase
        .from("profiles")
        .select("id, nombre, email, rol")
        .in("rol", ["profe", "admin"])
        .order("nombre"),
      supabase
        .from("cursos_profesores")
        .select("profesor_id, profiles!cursos_profesores_profesor_id_fkey(id, nombre, email, rol)")
        .eq("curso_id", cursoId!),
    ]);

    if (resPosibles.error || resAsignados.error) {
      $lista.innerHTML = `<li class="profes-lista__error">Error al cargar profes: ${
        traducirError(resPosibles.error ?? resAsignados.error)
      }</li>`;
      return;
    }

    const asignados = (resAsignados.data ?? []).map(
      (r: any) => r.profiles as ProfileMini
    ).filter(Boolean);
    const asignadosIds = new Set(asignados.map((p) => p.id));
    const posibles = (resPosibles.data ?? []) as ProfileMini[];

    // Render lista de asignados.
    if (asignados.length === 0) {
      $lista.innerHTML = `<li class="profes-lista__vacio">Ningún profe asignado todavía.</li>`;
    } else {
      $lista.innerHTML = asignados.map((p) => `
        <li class="profe-item">
          <div class="profe-item__avatar profe-item__avatar--${esc(p.rol)}">${esc(iniciales(p.nombre))}</div>
          <div class="profe-item__cuerpo">
            <span class="profe-item__nombre">${esc(p.nombre)}</span>
            <span class="profe-item__mail">${esc(p.email)}</span>
          </div>
          <button type="button" class="profe-item__quitar" data-profe-id="${esc(p.id)}" aria-label="Quitar a ${esc(p.nombre)}">×</button>
        </li>
      `).join("");
      $lista.querySelectorAll<HTMLButtonElement>(".profe-item__quitar").forEach((btn) => {
        btn.addEventListener("click", () => quitarProfe(btn.dataset.profeId!));
      });
    }

    // Render select con los NO asignados.
    const disponibles = posibles.filter((p) => !asignadosIds.has(p.id));
    $select.innerHTML = disponibles.length === 0
      ? `<option value="">— Sin más profes disponibles —</option>`
      : `<option value="">— Elegí un profe —</option>` +
        disponibles.map((p) => `<option value="${esc(p.id)}">${esc(p.nombre)} (${esc(p.email)})</option>`).join("");
    $select.disabled = disponibles.length === 0;

    const $btn = document.getElementById("agregar-profe-btn") as HTMLButtonElement;
    $btn.onclick = async () => {
      const pid = $select.value;
      if (!pid) {
        showToast("Elegí un profe primero.", "info");
        return;
      }
      $btn.disabled = true;
      $btn.textContent = "Agregando…";
      const { error } = await supabase
        .from("cursos_profesores")
        .insert({ curso_id: cursoId!, profesor_id: pid });
      $btn.disabled = false;
      $btn.textContent = "+ Agregar";
      if (error) {
        showToast(traducirError(error), "error");
        return;
      }
      showToast("Profe agregado.");
      await cargarProfes();
    };
  }

  async function quitarProfe(profeId: string) {
    const ok = await confirmModal({
      titulo: "Quitar profe",
      mensaje: "¿Sacarlo como profe de este curso? No se borra del sistema, solo se desvincula.",
      confirmLabel: "Quitar",
      danger: true,
    });
    if (!ok) return;
    const { error } = await supabase
      .from("cursos_profesores")
      .delete()
      .eq("curso_id", cursoId!)
      .eq("profesor_id", profeId);
    if (error) {
      showToast(traducirError(error), "error");
      return;
    }
    showToast("Profe quitado del curso.");
    await cargarProfes();
  }

  // ============ Gestión de alumnos inscriptos ============
  type InscripcionRow = {
    id: string;
    activo: boolean;
    profiles: ProfileMini | null;
  };

  async function cargarAlumnos() {
    const $lista = document.getElementById("alumnos-lista")!;
    const $select = document.getElementById("alumno-disponible") as HTMLSelectElement;

    const [resTodos, resInscriptos] = await Promise.all([
      supabase
        .from("profiles")
        .select("id, nombre, email, rol")
        .eq("rol", "alumno")
        .order("nombre"),
      supabase
        .from("inscripciones")
        .select("id, activo, profiles!inscripciones_alumno_id_fkey(id, nombre, email, rol)")
        .eq("curso_id", cursoId!),
    ]);

    if (resTodos.error || resInscriptos.error) {
      $lista.innerHTML = `<li class="profes-lista__error">Error al cargar alumnos: ${
        traducirError(resTodos.error ?? resInscriptos.error)
      }</li>`;
      return;
    }

    const inscripciones = ((resInscriptos.data ?? []) as unknown as InscripcionRow[])
      .filter((i) => !!i.profiles);
    const inscriptosIds = new Set(inscripciones.map((i) => i.profiles!.id));
    const todosAlumnos = (resTodos.data ?? []) as ProfileMini[];

    if (inscripciones.length === 0) {
      $lista.innerHTML = `<li class="profes-lista__vacio">Ningún alumno inscripto todavía.</li>`;
    } else {
      $lista.innerHTML = inscripciones.map((i) => {
        const a = i.profiles!;
        const badgeClase = i.activo ? "estado-badge--activo" : "estado-badge--pendiente";
        const badgeTexto = i.activo ? "Activo" : "Pendiente";
        return `
          <li class="profe-item">
            <div class="profe-item__avatar profe-item__avatar--alumno">${esc(iniciales(a.nombre))}</div>
            <div class="profe-item__cuerpo">
              <span class="profe-item__nombre">
                ${esc(a.nombre)}
                <span class="estado-badge ${badgeClase}">${badgeTexto}</span>
              </span>
              <span class="profe-item__mail">${esc(a.email)}</span>
            </div>
            <button type="button" class="profe-item__quitar" data-inscripcion-id="${esc(i.id)}" data-nombre="${esc(a.nombre)}" aria-label="Desinscribir a ${esc(a.nombre)}">×</button>
          </li>
        `;
      }).join("");

      $lista.querySelectorAll<HTMLButtonElement>(".profe-item__quitar").forEach((btn) => {
        btn.addEventListener("click", () => desinscribirAlumno(btn.dataset.inscripcionId!, btn.dataset.nombre!));
      });
    }

    // Select de alumnos no inscriptos.
    const disponibles = todosAlumnos.filter((a) => !inscriptosIds.has(a.id));
    $select.innerHTML = disponibles.length === 0
      ? `<option value="">— No hay más alumnos para inscribir —</option>`
      : `<option value="">— Elegí un alumno —</option>` +
        disponibles.map((a) => `<option value="${esc(a.id)}">${esc(a.nombre)} (${esc(a.email)})</option>`).join("");
    $select.disabled = disponibles.length === 0;

    const $btn = document.getElementById("agregar-alumno-btn") as HTMLButtonElement;
    $btn.onclick = async () => {
      const aid = $select.value;
      if (!aid) {
        showToast("Elegí un alumno primero.", "info");
        return;
      }
      $btn.disabled = true;
      $btn.textContent = "Inscribiendo…";
      const { error } = await supabase
        .from("inscripciones")
        .insert({ curso_id: cursoId!, alumno_id: aid, activo: true });
      $btn.disabled = false;
      $btn.textContent = "+ Inscribir";
      if (error) {
        showToast(traducirError(error), "error");
        return;
      }
      showToast("Alumno inscripto.");
      await cargarAlumnos();
    };
  }

  async function desinscribirAlumno(inscripcionId: string, nombre: string) {
    const ok = await confirmModal({
      titulo: "Desinscribir alumno",
      mensaje: `${nombre} va a perder el acceso a este curso y sus entregas. Esta acción no se puede deshacer. ¿Continuar?`,
      confirmLabel: "Desinscribir",
      danger: true,
    });
    if (!ok) return;
    const { error } = await supabase
      .from("inscripciones")
      .delete()
      .eq("id", inscripcionId);
    if (error) {
      showToast(traducirError(error), "error");
      return;
    }
    showToast("Alumno desinscripto.");
    await cargarAlumnos();
  }

  function esc(s: string | null | undefined) {
    return String(s ?? "")
      .replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;").replace(/'/g, "&#039;");
  }

  function iniciales(nombre: string) {
    return nombre.split(" ").map((n) => n[0]).join("").slice(0, 2).toUpperCase();
  }

  /** Auto-llena el slug a medida que el usuario escribe el título, salvo
   *  que el usuario haya editado el slug manualmente. */
  function enchufarSlugAuto() {
    const $tit = $form.elements.namedItem("titulo") as HTMLInputElement;
    const $slug = $form.elements.namedItem("slug") as HTMLInputElement;
    let slugEditado = modoEdicion; // si estamos editando, no piso el slug

    $slug.addEventListener("input", () => { slugEditado = true; });

    $tit.addEventListener("input", () => {
      if (!slugEditado) $slug.value = slugify($tit.value);
    });
  }

  function enchufarSubmit() {
    $form.addEventListener("submit", async (e) => {
      e.preventDefault();
      $slugError.hidden = true;

      const fd = new FormData($form);
      const titulo = String(fd.get("titulo")).trim();
      const slug = String(fd.get("slug")).trim();
      const resumen = String(fd.get("resumen")).trim();
      const periodo = String(fd.get("periodo")).trim();
      const publicado = fd.get("publicado") === "on";

      if (!/^[a-z0-9-]+$/.test(slug)) {
        $slugError.textContent = "El slug solo puede tener letras minúsculas, números y guiones.";
        $slugError.hidden = false;
        return;
      }

      $submit.disabled = true;
      $submit.textContent = modoEdicion ? "Guardando…" : "Creando…";

      const payload = { titulo, slug, resumen, periodo: periodo || null, publicado };

      const { error } = modoEdicion
        ? await supabase.from("cursos").update(payload).eq("id", cursoId!)
        : await supabase.from("cursos").insert(payload);

      $submit.disabled = false;
      $submit.textContent = modoEdicion ? "Guardar cambios" : "Crear curso";

      if (error) {
        showToast(traducirError(error), "error");
        return;
      }

      showToast(modoEdicion ? "Curso actualizado." : "Curso creado.");
      window.location.href = "/aula/admin/cursos";
    });
  }

  function enchufarBorrar() {
    $borrar.addEventListener("click", async () => {
      const tituloActual = ($form.elements.namedItem("titulo") as HTMLInputElement).value;
      const ok = await confirmModal({
        titulo: "Borrar curso",
        mensaje: `¿Seguro que querés borrar "${tituloActual}"? También se borran sus módulos, tareas e inscripciones. Esta acción no se puede deshacer.`,
        confirmLabel: "Borrar definitivamente",
        danger: true,
      });
      if (!ok) return;

      $borrar.disabled = true;
      $borrar.textContent = "Borrando…";

      const { error } = await supabase.from("cursos").delete().eq("id", cursoId!);

      if (error) {
        showToast(traducirError(error), "error");
        $borrar.disabled = false;
        $borrar.textContent = "Borrar curso";
        return;
      }

      showToast("Curso borrado.");
      window.location.href = "/aula/admin/cursos";
    });
  }

  cargar().catch((err) => {
    console.error("[editor-curso]", err);
    $loader.hidden = true;
    $errorBox.hidden = false;
    $errorBox.textContent = `Error inesperado: ${err instanceof Error ? err.message : String(err)}`;
  });
</script>

<style>
  .editor { flex: 1; padding: clamp(2rem, 5vw, 3rem) 0 5rem; }

  .editor__volver {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--color-ink-soft);
    margin-bottom: 1.5rem;
  }
  .editor__volver:hover { color: var(--color-ink); }

  .editor__loader { padding: 1.5rem 0; color: var(--color-ink-soft); }
  .editor__error { color: var(--color-accent); padding: 1rem 0; }

  .editor__head { margin-bottom: 2rem; }
  .editor__eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 500;
    margin: 0 0 0.9rem;
  }
  .editor__titulo {
    font-size: clamp(1.8rem, 4vw, 2.2rem);
    margin: 0;
  }

  .form-curso {
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    padding: 2rem;
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-curso__label {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.88rem;
    color: var(--color-ink-soft);
    font-weight: 500;
  }
  .form-curso__hint {
    color: var(--color-ink-muted);
    font-weight: 400;
    font-size: 0.78rem;
  }
  .form-curso__error {
    color: var(--color-accent);
    font-weight: 400;
    font-size: 0.82rem;
  }

  .form-curso__label input[type="text"],
  .form-curso__label textarea {
    font-family: inherit;
    font-size: 1rem;
    padding: 0.7rem 0.9rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    color: var(--color-ink);
    resize: vertical;
    width: 100%;
  }
  .form-curso__label input:focus,
  .form-curso__label textarea:focus {
    outline: none;
    border-color: var(--color-deep);
    background: #fff;
  }

  /* Slug con prefijo gris */
  .form-curso__slug {
    display: flex;
    align-items: stretch;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    overflow: hidden;
  }
  .form-curso__slug:focus-within {
    border-color: var(--color-deep);
    background: #fff;
  }
  .form-curso__slug-prefix {
    padding: 0.7rem 0.7rem 0.7rem 0.9rem;
    background: var(--color-surface);
    border-right: 1px solid var(--color-line);
    color: var(--color-ink-muted);
    font-family: ui-monospace, "Cascadia Code", Menlo, monospace;
