---
/*
  /aula/admin/cursos/contenido?id=X — gestión completa del contenido
  de un curso: módulos, archivos y tareas.

  Solo admin (las RLS también permiten al profe que enseña, pero la
  UI por ahora está bajo /aula/admin).
*/

import AulaLayout from "../../../../layouts/AulaLayout.astro";
---

<AulaLayout title="Contenido del curso · Admin · Vocational Lab" rol="admin">
  <main class="contenido">
    <div class="container">
      <a id="volver-link" href="/aula/admin/cursos" class="contenido__volver">← Volver a cursos</a>

      <div id="contenido-loader" class="contenido__loader">
        <div class="loader" role="status">
          <span class="loader__spinner" aria-hidden="true"></span>
          <span class="loader__label">Cargando…</span>
        </div>
      </div>

      <div id="contenido-wrap" hidden>
        <header class="contenido__head">
          <p class="contenido__eyebrow">Contenido del curso</p>
          <h1 class="contenido__titulo" id="curso-titulo"></h1>
          <p class="contenido__meta" id="curso-meta"></p>
          <div class="contenido__acciones">
            <a id="ver-alumno-link" href="#" class="boton-ghost" target="_blank">Ver como protagonista ↗</a>
            <a id="editar-curso-link" href="#" class="boton-ghost">Editar datos del curso</a>
          </div>
        </header>

        <section>
          <header class="contenido__seccion-head">
            <h2 class="contenido__seccion-titulo">Módulos</h2>
            <span class="contenido__seccion-meta" id="modulos-count"></span>
          </header>

          <div id="modulos-lista" class="modulos-lista"></div>

          <button type="button" id="agregar-modulo-btn" class="boton-primario boton-primario--full">
            + Agregar módulo
          </button>
        </section>
      </div>

      <p id="contenido-error" class="contenido__error" hidden></p>
    </div>
  </main>
</AulaLayout>

<script>
  import { supabase } from "../../../../lib/supabase";
  import { requireRol } from "../../../../lib/auth-guard";
  import { showToast, confirmModal, formModal, traducirError, setupDropzone } from "../../../../lib/ui";
  import { iconHtml } from "../../../../lib/icons";

  const MAX_FILE_SIZE = 25 * 1024 * 1024; // 25 MB para material del profe

  const $loader = document.getElementById("contenido-loader") as HTMLElement;
  const $wrap = document.getElementById("contenido-wrap") as HTMLElement;
  const $errorBox = document.getElementById("contenido-error") as HTMLElement;
  const $titulo = document.getElementById("curso-titulo")!;
  const $meta = document.getElementById("curso-meta")!;
  const $modulos = document.getElementById("modulos-lista")!;
  const $count = document.getElementById("modulos-count")!;

  let cursoId: string = "";
  let cursoSlug: string = "";

  function esc(s: string | null | undefined) {
    return String(s ?? "")
      .replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;").replace(/'/g, "&#039;");
  }

  function formatoFecha(iso: string | null) {
    if (!iso) return "—";
    try {
      const d = new Date(iso);
      return d.toLocaleDateString("es-AR", { day: "numeric", month: "long", year: "numeric" });
    } catch {
      return iso;
    }
  }

  function formatoTamano(kb: number | null) {
    if (!kb) return "";
    if (kb >= 1024) return `${(kb / 1024).toFixed(1)} MB`;
    return `${kb} KB`;
  }

  function iconoTipo(tipo: string) {
    return tipo === "pdf" ? "📄" : tipo === "video" ? "▶︎" : tipo === "audio" ? "♪" : tipo === "youtube" ? "▶" : "↗";
  }

  function mostrarError(msg: string) {
    $loader.hidden = true;
    $errorBox.hidden = false;
    $errorBox.textContent = msg;
  }

  type Archivo = { id: string; nombre: string; tipo: string; storage_path: string; peso_kb: number | null };
  type Tarea = {
    id: string;
    titulo: string;
    consigna: string;
    fecha_entrega: string | null;
    video_url: string | null;
    adjunto_path: string | null;
    adjunto_nombre: string | null;
  };
  type Modulo = {
    id: string;
    numero: number;
    titulo: string;
    descripcion: string | null;
    archivos_modulo: Archivo[] | null;
    tareas: Tarea | Tarea[] | null;
  };

  async function cargar() {
    const auth = await requireRol(["admin"]);
    if (!auth) return;

    cursoId = new URLSearchParams(window.location.search).get("id") ?? "";
    if (!cursoId) {
      mostrarError("Falta el parámetro 'id' en la URL.");
      return;
    }

    // 1. Curso + módulos en una sola query.
    const { data: curso, error: errCurso } = await supabase
      .from("cursos")
      .select("id, slug, titulo, periodo, publicado")
      .eq("id", cursoId)
      .maybeSingle();
    if (errCurso || !curso) {
      mostrarError(errCurso ? `Error: ${traducirError(errCurso)}` : "No encontramos ese curso.");
      return;
    }
    cursoSlug = curso.slug;

    const { data: modulos, error: errMods } = await supabase
      .from("modulos")
      .select(`
        id, numero, titulo, descripcion,
        archivos_modulo (id, nombre, tipo, storage_path, peso_kb),
        tareas (id, titulo, consigna, fecha_entrega, video_url, adjunto_path, adjunto_nombre)
      `)
      .eq("curso_id", cursoId)
      .order("numero");
    if (errMods) {
      mostrarError(`Error al cargar módulos: ${traducirError(errMods)}`);
      return;
    }

    // 2. Render.
    $titulo.textContent = curso.titulo;
    $meta.textContent = `${curso.periodo ?? "Sin periodo"} · ${curso.publicado ? "Publicado" : "Borrador"}`;
    (document.getElementById("ver-alumno-link") as HTMLAnchorElement).href = `/aula/curso?slug=${encodeURIComponent(curso.slug)}`;
    (document.getElementById("editar-curso-link") as HTMLAnchorElement).href = `/aula/admin/cursos/editor?id=${encodeURIComponent(curso.id)}`;

    const mods = (modulos ?? []) as Modulo[];
    $count.textContent = `${mods.length} módulo${mods.length === 1 ? "" : "s"}`;
    $modulos.innerHTML = mods.length === 0
      ? `<div class="empty-state">
          <span class="empty-state__icono" aria-hidden="true">${iconHtml("package", 28)}</span>
          <h3 class="empty-state__titulo">Sin módulos todavía</h3>
          <p class="empty-state__bajada">Empezá agregando el primer módulo del curso.</p>
        </div>`
      : mods.map(renderModulo).join("");

    enchufarAcciones(mods);
    enchufarAgregarModulo(mods.length);

    $loader.hidden = true;
    $wrap.hidden = false;
  }

  // ============ Render ============
  function renderModulo(m: Modulo): string {
    const tarea: Tarea | undefined = Array.isArray(m.tareas) ? m.tareas[0] : m.tareas ?? undefined;
    const archivos = m.archivos_modulo ?? [];
    return `
      <article class="modulo-card" data-modulo-id="${esc(m.id)}">
        <details class="modulo-card__details">
          <summary class="modulo-card__summary">
            <span class="modulo-card__numero">${m.numero}</span>
            <span class="modulo-card__titulo">${esc(m.titulo)}</span>
            <span class="modulo-card__resumen">
              ${archivos.length} archivo${archivos.length === 1 ? "" : "s"}${tarea ? " · 1 tarea" : ""}
            </span>
            <span class="modulo-card__chevron" aria-hidden="true">▾</span>
          </summary>

          <div class="modulo-card__cuerpo">
            ${m.descripcion ? `<p class="modulo-card__descripcion">${esc(m.descripcion)}</p>` : ""}

            <div class="bloque">
              <h4 class="bloque__titulo">Material</h4>
              <ul class="archivos-lista">
                ${archivos.length === 0
                  ? `<li class="archivos-vacio">Sin archivos ni videos cargados.</li>`
                  : archivos.map((a) => a.tipo === "youtube"
                    ? `
                      <li class="archivo archivo--link">
                        <span class="archivo__icono archivo__icono--yt">${iconoTipo(a.tipo)}</span>
                        <div class="archivo__cuerpo">
                          <a href="${esc(a.storage_path)}" target="_blank" rel="noopener" class="archivo__nombre archivo__nombre--link">${esc(a.nombre)}</a>
                          <span class="archivo__meta">Video externo</span>
                        </div>
                        <button type="button" class="archivo__borrar" data-archivo-id="${esc(a.id)}" data-storage-path="${esc(a.storage_path)}" data-tipo="youtube" aria-label="Quitar ${esc(a.nombre)}">×</button>
                      </li>
                    `
                    : `
                      <li class="archivo">
                        <span class="archivo__icono">${iconoTipo(a.tipo)}</span>
                        <div class="archivo__cuerpo">
                          <span class="archivo__nombre">${esc(a.nombre)}</span>
                          <span class="archivo__meta">${esc(formatoTamano(a.peso_kb))}</span>
                        </div>
                        <button type="button" class="archivo__borrar" data-archivo-id="${esc(a.id)}" data-storage-path="${esc(a.storage_path)}" aria-label="Borrar ${esc(a.nombre)}">×</button>
                      </li>
                    `
                  ).join("")}
              </ul>
              <div class="bloque__acciones">
                <label class="bloque__upload" data-dropzone>
                  <input type="file" data-modulo-id="${esc(m.id)}" />
                  <span class="bloque__upload-btn">+ Subir archivo</span>
                  <span class="bloque__upload-hint">Hasta 25 MB · o arrastra el archivo aquí</span>
                </label>
                <button type="button" class="bloque__link-btn" data-agregar-video="${esc(m.id)}">+ Agregar video</button>
              </div>
            </div>

            <div class="bloque">
              <h4 class="bloque__titulo">Tarea</h4>
              ${tarea
                ? `
                  <div class="tarea-mini">
                    <span class="tarea-mini__titulo">${esc(tarea.titulo)}</span>
                    <p class="tarea-mini__consigna">${esc(tarea.consigna)}</p>
                    <span class="tarea-mini__fecha">Entrega: ${esc(formatoFecha(tarea.fecha_entrega))}</span>

                    ${tarea.video_url ? `
                      <a href="${esc(tarea.video_url)}" target="_blank" rel="noopener" class="tarea-mini__video">
                        <span class="tarea-mini__video-icono">▶</span>
                        <span class="tarea-mini__video-label">Ver video de referencia</span>
                      </a>
                    ` : ""}

                    ${tarea.adjunto_path ? `
                      <div class="tarea-mini__adjunto">
                        <span class="tarea-mini__adjunto-icono">📎</span>
                        <span class="tarea-mini__adjunto-nombre">${esc(tarea.adjunto_nombre ?? "Adjunto")}</span>
                        <button type="button" class="archivo__borrar" data-borrar-adjunto-tarea="${esc(tarea.id)}" data-adjunto-path="${esc(tarea.adjunto_path)}" aria-label="Borrar adjunto">×</button>
                      </div>
                    ` : `
                      <label class="bloque__upload bloque__upload--mini" data-dropzone>
                        <input type="file" data-adjunto-tarea-id="${esc(tarea.id)}" />
                        <span class="bloque__upload-btn">+ Adjunto</span>
                      </label>
                    `}

                    <div class="tarea-mini__acciones">
                      <button type="button" class="boton-ghost-mini" data-editar-tarea="${esc(tarea.id)}">Editar</button>
                      <button type="button" class="boton-danger-mini" data-borrar-tarea="${esc(tarea.id)}">Borrar tarea</button>
                    </div>
                  </div>
                `
                : `
                  <button type="button" class="boton-primario-mini" data-agregar-tarea="${esc(m.id)}">+ Agregar tarea</button>
                `}
            </div>

            <div class="modulo-card__pie">
              <button type="button" class="boton-ghost-mini" data-editar-modulo="${esc(m.id)}">Editar módulo</button>
              <button type="button" class="boton-danger-mini" data-borrar-modulo="${esc(m.id)}">Borrar módulo</button>
            </div>
          </div>
        </details>
      </article>
    `;
  }

  // ============ Acciones ============
  function enchufarAcciones(mods: Modulo[]) {
    // Editar módulo
    $modulos.querySelectorAll<HTMLButtonElement>("[data-editar-modulo]").forEach((btn) => {
      btn.addEventListener("click", () => editarModulo(btn.dataset.editarModulo!, mods));
    });
    // Borrar módulo
    $modulos.querySelectorAll<HTMLButtonElement>("[data-borrar-modulo]").forEach((btn) => {
      btn.addEventListener("click", () => borrarModulo(btn.dataset.borrarModulo!));
    });
    // Subir archivo (clic o drag & drop sobre el label)
    $modulos.querySelectorAll<HTMLInputElement>('input[type="file"][data-modulo-id]').forEach((input) => {
      input.addEventListener("change", () => subirArchivo(input));
      setupDropzone(input);
    });
    // Borrar archivo
    $modulos.querySelectorAll<HTMLButtonElement>("[data-archivo-id]").forEach((btn) => {
      btn.addEventListener("click", () => borrarArchivo(btn.dataset.archivoId!, btn.dataset.storagePath!));
    });
    // Agregar tarea
    $modulos.querySelectorAll<HTMLButtonElement>("[data-agregar-tarea]").forEach((btn) => {
      btn.addEventListener("click", () => editarTarea(null, btn.dataset.agregarTarea!));
    });
    // Editar tarea
    $modulos.querySelectorAll<HTMLButtonElement>("[data-editar-tarea]").forEach((btn) => {
      btn.addEventListener("click", () => editarTarea(btn.dataset.editarTarea!, null));
    });
    // Borrar tarea
    $modulos.querySelectorAll<HTMLButtonElement>("[data-borrar-tarea]").forEach((btn) => {
      btn.addEventListener("click", () => borrarTarea(btn.dataset.borrarTarea!));
    });
    // Agregar video a módulo
    $modulos.querySelectorAll<HTMLButtonElement>("[data-agregar-video]").forEach((btn) => {
      btn.addEventListener("click", () => agregarVideoModulo(btn.dataset.agregarVideo!));
    });
    // Subir adjunto a tarea (clic o drag & drop sobre el label)
    $modulos.querySelectorAll<HTMLInputElement>('input[type="file"][data-adjunto-tarea-id]').forEach((input) => {
      input.addEventListener("change", () => subirAdjuntoTarea(input));
      setupDropzone(input);
    });
    // Borrar adjunto de tarea
    $modulos.querySelectorAll<HTMLButtonElement>("[data-borrar-adjunto-tarea]").forEach((btn) => {
      btn.addEventListener("click", () => borrarAdjuntoTarea(btn.dataset.borrarAdjuntoTarea!, btn.dataset.adjuntoPath!));
    });
  }

  function enchufarAgregarModulo(cantActual: number) {
    const $btn = document.getElementById("agregar-modulo-btn") as HTMLButtonElement;
    $btn.onclick = () => editarModulo(null, [], cantActual + 1);
  }

  // ============ Módulos ============
  async function editarModulo(id: string | null, mods: Modulo[], numeroSugerido?: number) {
    const existente = id ? mods.find((m) => m.id === id) : null;
    const numero = existente?.numero ?? numeroSugerido ?? 1;

    const result = await formModal({
      titulo: existente ? `Editar módulo ${numero}` : `Nuevo módulo ${numero}`,
      campos: [
        {
          name: "titulo",
          label: "Título del módulo",
          type: "text",
          required: true,
          minLength: 2,
          value: existente?.titulo ?? "",
          placeholder: "Ej: Bienvenida — el viaje empieza acá",
        },
        {
          name: "descripcion",
          label: "Descripción",
          type: "textarea",
          rows: 3,
          value: existente?.descripcion ?? "",
          placeholder: "Una bajada que orienta al protagonista sobre el módulo.",
          hint: "Opcional. Se muestra al protagonista cuando abre el curso.",
        },
      ],
      confirmLabel: existente ? "Guardar cambios" : "Crear módulo",
    });

    if (!result) return;

    const payload = {
      titulo: result.titulo,
      descripcion: result.descripcion || null,
    };

    const { error } = existente
      ? await supabase.from("modulos").update(payload).eq("id", existente.id)
      : await supabase.from("modulos").insert({
          ...payload,
          curso_id: cursoId,
          numero,
        });

    if (error) {
      showToast(traducirError(error), "error");
      return;
    }
    showToast(existente ? "Módulo actualizado." : "Módulo creado.");
    await cargar();
  }

  async function borrarModulo(id: string) {
    const ok = await confirmModal({
      titulo: "Borrar módulo",
      mensaje: "Esto borra el módulo y todos sus archivos y tareas. Las entregas de los protagonistas también se pierden. ¿Continuar?",
      confirmLabel: "Borrar módulo",
      danger: true,
    });
    if (!ok) return;
    const { error } = await supabase.from("modulos").delete().eq("id", id);
    if (error) {
      showToast(traducirError(error), "error");
      return;
    }
    showToast("Módulo borrado.");
    await cargar();
  }

  // ============ Archivos ============
  async function subirArchivo(input: HTMLInputElement) {
    const moduloId = input.dataset.moduloId!;
    const file = input.files?.[0];
    if (!file) return;

    if (file.size > MAX_FILE_SIZE) {
      showToast(`El archivo supera los 25 MB.`, "error");
      input.value = "";
      return;
    }

    // Detectamos tipo simple.
    const tipo = file.type.startsWith("video/") ? "video"
      : file.type.startsWith("audio/") ? "audio"
      : file.type === "application/pdf" ? "pdf"
      : "link";

    const pesoKb = Math.round(file.size / 1024);
    const path = `${cursoId}/${moduloId}/${file.name}`;

    const $btn = input.parentElement?.querySelector(".bloque__upload-btn") as HTMLElement | null;
    const labelOrig = $btn?.textContent ?? "+ Subir archivo";
    if ($btn) $btn.textContent = "Subiendo…";

    const { error: errUpload } = await supabase.storage
      .from("material-cursos")
      .upload(path, file, { upsert: true, contentType: file.type || "application/octet-stream" });
    if (errUpload) {
      if ($btn) $btn.textContent = labelOrig;
      showToast(`No se pudo subir: ${traducirError(errUpload)}`, "error");
      input.value = "";
      return;
    }

    const { error: errInsert } = await supabase
      .from("archivos_modulo")
      .insert({
        modulo_id: moduloId,
        nombre: file.name,
        tipo,
        storage_path: path,
        peso_kb: pesoKb,
      });

    if ($btn) $btn.textContent = labelOrig;

    if (errInsert) {
      showToast(`Subido pero no registrado: ${traducirError(errInsert)}`, "error");
      return;
    }

    showToast("Archivo subido.");
    await cargar();
  }

  async function borrarArchivo(id: string, storagePath: string) {
    const ok = await confirmModal({
      titulo: "Borrar archivo",
      mensaje: "¿Borrar este archivo del material? Esta acción no se puede deshacer.",
      confirmLabel: "Borrar",
      danger: true,
    });
    if (!ok) return;
    // Los videos externos (YouTube, etc.) no tienen archivo en Storage.
    if (!storagePath.startsWith("http")) {
      await supabase.storage.from("material-cursos").remove([storagePath]);
    }
    const { error } = await supabase.from("archivos_modulo").delete().eq("id", id);
    if (error) {
      showToast(traducirError(error), "error");
      return;
    }
    showToast("Archivo borrado.");
    await cargar();
  }

  // ============ Tareas ============
  async function editarTarea(tareaId: string | null, moduloId: string | null) {
    let existente: { titulo: string; consigna: string; fecha_entrega: string | null; modulo_id: string } | null = null;
    if (tareaId) {
      const { data } = await supabase
        .from("tareas")
        .select("titulo, consigna, fecha_entrega, modulo_id")
        .eq("id", tareaId)
        .maybeSingle();
      existente = data ?? null;
      moduloId = data?.modulo_id ?? null;
    }
    if (!moduloId) {
      showToast("No se pudo identificar el módulo.", "error");
      return;
    }

    const fechaActual = existente?.fecha_entrega
      ? new Date(existente.fecha_entrega).toISOString().slice(0, 10)
      : "";

    const result = await formModal({
      titulo: existente ? "Editar tarea" : "Nueva tarea",
      campos: [
        {
          name: "titulo",
          label: "Título de la tarea",
          type: "text",
          required: true,
          minLength: 2,
          value: existente?.titulo ?? "",
          placeholder: "Ej: Carta a tu yo del futuro",
        },
        {
          name: "consigna",
          label: "Consigna",
          type: "textarea",
          required: true,
          rows: 5,
          value: existente?.consigna ?? "",
          placeholder: "Lo que el protagonista tiene que hacer, con detalle.",
        },
        {
          name: "fecha_entrega",
          label: "Fecha de entrega",
          type: "date",
          value: fechaActual,
          hint: "Opcional. Si no la ponés, la tarea no tiene fecha límite.",
        },
        {
          name: "video_url",
          label: "Video de referencia",
          type: "text",
          value: existente?.video_url ?? "",
          placeholder: "https://www.youtube.com/watch?v=… (opcional)",
          hint: "YouTube, Vimeo o cualquier URL de video. Se muestra al protagonista junto a la consigna.",
        },
      ],
      confirmLabel: existente ? "Guardar cambios" : "Crear tarea",
    });

    if (!result) return;

    const payload = {
      titulo: result.titulo,
      consigna: result.consigna,
      fecha_entrega: result.fecha_entrega || null,
      video_url: result.video_url?.trim() || null,
    };

    const { error } = tareaId
      ? await supabase.from("tareas").update(payload).eq("id", tareaId)
      : await supabase.from("tareas").insert({ ...payload, modulo_id: moduloId });

    if (error) {
      showToast(traducirError(error), "error");
      return;
    }
    showToast(tareaId ? "Tarea actualizada." : "Tarea creada.");
    await cargar();
  }

  async function borrarTarea(tareaId: string) {
    const ok = await confirmModal({
      titulo: "Borrar tarea",
      mensaje: "También se borran las entregas de los protagonistas. ¿Continuar?",
      confirmLabel: "Borrar tarea",
      danger: true,
    });
    if (!ok) return;
    const { error } = await supabase.from("tareas").delete().eq("id", tareaId);
    if (error) {
      showToast(traducirError(error), "error");
      return;
    }
    showToast("Tarea borrada.");
    await cargar();
  }

  // ============ Video externo en módulo ============
  async function agregarVideoModulo(moduloId: string) {
    const result = await formModal({
      titulo: "Agregar video",
      campos: [
        {
          name: "nombre",
          label: "Nombre del video",
          type: "text",
          required: true,
          placeholder: "Ej: Clase 1 — Introducción a la orientación vocacional",
        },
        {
          name: "url",
          label: "URL del video",
          type: "text",
          required: true,
          placeholder: "https://www.youtube.com/watch?v=…",
          hint: "YouTube, Vimeo o cualquier enlace de video.",
        },
      ],
      confirmLabel: "Agregar",
    });
    if (!result) return;

    const url = result.url.trim();
    if (!url.startsWith("http")) {
      showToast("La URL debe empezar con https://.", "error");
      return;
    }

    const { error } = await supabase.from("archivos_modulo").insert({
      modulo_id: moduloId,
      nombre: result.nombre,
      tipo: "youtube",
      storage_path: url,
      peso_kb: null,
    });

    if (error) { showToast(traducirError(error), "error"); return; }
    showToast("Video agregado.");
    await cargar();
  }

  // ============ Adjunto de tarea ============
  async function subirAdjuntoTarea(input: HTMLInputElement) {
    const tareaId = input.dataset.adjuntoTareaId!;
    const file = input.files?.[0];
    if (!file) return;

    if (file.size > MAX_FILE_SIZE) {
      showToast("El archivo supera los 25 MB.", "error");
      input.value = "";
      return;
    }

    const path = `${cursoId}/tareas/${tareaId}/${file.name}`;
    const $btn = input.parentElement?.querySelector(".bloque__upload-btn") as HTMLElement | null;
    const orig = $btn?.textContent ?? "+ Adjunto";
    if ($btn) $btn.textContent = "Subiendo…";

    const { error: errUpload } = await supabase.storage
      .from("material-cursos")
      .upload(path, file, { upsert: true, contentType: file.type || "application/octet-stream" });

    if (errUpload) {
      if ($btn) $btn.textContent = orig;
      showToast(`No se pudo subir: ${traducirError(errUpload)}`, "error");
      input.value = "";
      return;
    }

    const { error: errUpdate } = await supabase
      .from("tareas")
      .update({ adjunto_path: path, adjunto_nombre: file.name })
      .eq("id", tareaId);

    if ($btn) $btn.textContent = orig;
    if (errUpdate) { showToast(`Subido pero no registrado: ${traducirError(errUpdate)}`, "error"); return; }
    showToast("Adjunto subido.");
    await cargar();
  }

  async function borrarAdjuntoTarea(tareaId: string, storagePath: string) {
    const ok = await confirmModal({
      titulo: "Borrar adjunto",
      mensaje: "¿Borrar el adjunto de esta tarea? No se puede deshacer.",
      confirmLabel: "Borrar",
      danger: true,
    });
    if (!ok) return;

    await supabase.storage.from("material-cursos").remove([storagePath]);
    const { error } = await supabase
      .from("tareas")
      .update({ adjunto_path: null, adjunto_nombre: null })
      .eq("id", tareaId);

    if (error) { showToast(traducirError(error), "error"); return; }
    showToast("Adjunto borrado.");
    await cargar();
  }

  cargar().catch((err) => {
    console.error("[contenido-curso]", err);
    mostrarError(`Error inesperado: ${err instanceof Error ? err.message : String(err)}`);
  });
</script>

