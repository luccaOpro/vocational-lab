---
/*
  /aula/admin/alumnos — lista de TODOS los alumnos para el admin.
  Permite ver estado de pago e ir a una vista de detalle (a futuro).
*/

import AulaLayout from "../../../layouts/AulaLayout.astro";
import { alumnosDemo, cursosDemo } from "../../../data/cursos-demo";

function cursosLegibles(slugs: string[]) {
  return slugs
    .map((s) => cursosDemo.find((c) => c.slug === s)?.titulo ?? s)
    .join(", ");
}
---

<AulaLayout title="Alumnos · Admin · Vocational Lab" rol="admin">
  <main class="alumnos-admin">
    <div class="container">
      <a href="/aula/admin" class="alumnos-admin__volver">← Volver al panel</a>

      <header class="alumnos-admin__head">
        <p class="alumnos-admin__eyebrow">Admin</p>
        <h1 class="alumnos-admin__titulo">Alumnos</h1>
        <p class="alumnos-admin__bajada">{alumnosDemo.length} en total</p>
      </header>

      <div class="tabla-wrap">
        <table class="tabla">
          <thead>
            <tr>
              <th scope="col">Alumno</th>
              <th scope="col">Inscripto</th>
              <th scope="col">Cursos</th>
              <th scope="col">Estado</th>
              <th scope="col"></th>
            </tr>
          </thead>
          <tbody>
            {alumnosDemo.map((a) => (
              <tr>
                <td>
                  <div class="celda-alumno">
                    <div class="celda-alumno__avatar">
                      {a.nombre.split(" ").map((n) => n[0]).join("").slice(0, 2)}
                    </div>
                    <div>
                      <span class="celda-alumno__nombre">{a.nombre}</span>
                      <span class="celda-alumno__mail">{a.email}</span>
                    </div>
                  </div>
                </td>
                <td class="celda-meta">{a.inscripto}</td>
                <td class="celda-meta">
                  {a.cursos.length === 0 ? <em class="sin-cursos">Ningún curso aún</em> : cursosLegibles(a.cursos)}
                </td>
                <td>
                  <span class={`badge badge--${a.pago}`}>
                    {a.pago === "pagado" ? "Pagó" : "Pendiente"}
                  </span>
                </td>
                <td class="celda-accion">
                  {a.pago === "pendiente" && (
                    <button type="button" class="btn-mini">Activar</button>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </main>
</AulaLayout>

<style>
  .alumnos-admin { flex: 1; padding: clamp(2rem, 5vw, 3rem) 0 5rem; }

  .alumnos-admin__volver {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--color-ink-soft);
    margin-bottom: 1.5rem;
  }
  .alumnos-admin__volver:hover { color: var(--color-ink); }

  .alumnos-admin__head {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-line);
  }
  .alumnos-admin__eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 500;
    margin: 0 0 0.9rem;
  }
  .alumnos-admin__titulo { font-size: clamp(2rem, 4.5vw, 2.6rem); margin: 0 0 0.4rem; }
  .alumnos-admin__bajada { color: var(--color-ink-soft); margin: 0; }

  /* Tabla — usamos overflow-x para que scrollee en mobile. */
  .tabla-wrap {
    overflow-x: auto;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
  }
  .tabla {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }
  .tabla th, .tabla td {
    padding: 0.85rem 1.1rem;
    text-align: left;
    border-bottom: 1px solid var(--color-line);
    white-space: nowrap;
  }
  .tabla th {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    font-weight: 500;
    background: var(--color-bg);
  }
  .tabla tbody tr:last-child td { border-bottom: 0; }
  .tabla tbody tr:hover { background: var(--color-bg); }

  .celda-alumno {
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }
  .celda-alumno__avatar {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.04em;
  }
  .celda-alumno__nombre { display: block; font-weight: 500; }
  .celda-alumno__mail { display: block; font-size: 0.82rem; color: var(--color-ink-muted); }

  .celda-meta { color: var(--color-ink-soft); }
  .sin-cursos { color: var(--color-ink-muted); font-style: italic; }
  .celda-accion { text-align: right; }

  .badge {
    display: inline-block;
    padding: 0.25rem 0.6rem;
    border-radius: 99px;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.04em;
  }
  .badge--pagado {
    background: rgba(36, 58, 130, 0.1);
    color: var(--color-deep);
  }
  .badge--pendiente {
    background: rgba(216, 85, 42, 0.12);
    color: var(--color-accent);
  }

  .btn-mini {
    padding: 0.4rem 0.85rem;
    background: var(--color-accent);
    color: #fff;
    border: 0;
    border-radius: var(--radius-sm);
    font-family: inherit;
    font-size: 0.82rem;
    font-weight: 500;
    cursor: pointer;
  }
  .btn-mini:hover { background: var(--color-accent-dark); }
</style>
