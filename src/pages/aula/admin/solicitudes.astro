---
/*
  /aula/admin/solicitudes — bandeja de solicitudes de inscripción.
  ---
  Muestra todo lo que entra por los forms públicos: /inscripcion
  (intenciones "info" e "inscripcion") y el form "Hablemos" de la
  landing (intencion "charla", con mensaje libre).

  El seguimiento lo hacen Julia y Laura A MANO (sin automatización),
  así que el panel es su herramienta de trabajo diaria:
    · Avisos arriba de todo: solicitudes nuevas sin responder,
      seguimientos de 48 hs pendientes y recordatorios vencidos.
    · Buscador (nombre, mail, teléfono, mensaje, notas) + orden.
    · Filtros por estado, por intención y por canal de contacto
      (¿ya le escribimos por mail? ¿por WhatsApp?).
    · Por cada solicitud: marcar por dónde se la contactó, notas
      internas con fecha, recordatorio manual ("avisarme el día X"),
      WhatsApp y mail pre-redactados, copiar mails para CCO.

  Las reglas de seguridad (RLS) están en docs/sql/04. Las columnas
  de seguimiento (contacto, recordatorios, notas con fecha, mensaje
  del form "Hablemos") las agrega docs/sql/15.
*/

import AulaLayout from "../../../layouts/AulaLayout.astro";
---

<AulaLayout title="Solicitudes · Admin · Vocational Lab" rol="admin">
  <main class="sols">
    <div class="container">
      <a href="/aula/admin" class="sols__volver">← Volver al panel</a>

      <header class="sols__head">
        <div>
          <p class="sols__eyebrow">Admin</p>
          <h1 class="sols__titulo">Solicitudes</h1>
          <p class="sols__bajada" id="sols-bajada">Cargando…</p>
        </div>
      </header>

      {/* Avisos: lo que necesita acción hoy (se arma por JS) */}
      <div class="sols__avisos" id="sols-avisos" hidden></div>

      {/* Buscador + orden */}
      <div class="sols__buscador" id="sols-buscador" hidden>
        <input
          type="search"
          id="sols-buscar"
          placeholder="Buscar por nombre, mail, teléfono, mensaje o nota…"
          aria-label="Buscar solicitudes"
        />
        <select id="sols-orden" aria-label="Ordenar solicitudes">
          <option value="recientes">Más recientes primero</option>
          <option value="antiguas">Más antiguas primero</option>
        </select>
      </div>

      {/* Filtros por estado */}
      <div class="sols__filtros" id="sols-filtros" role="tablist" aria-label="Filtrar por estado" hidden>
        <button type="button" class="sols__filtro is-activo" data-filtro="todas">Todas</button>
        <button type="button" class="sols__filtro" data-filtro="nueva">Nuevas</button>
        <button type="button" class="sols__filtro" data-filtro="contactada">Contactadas</button>
        <button type="button" class="sols__filtro" data-filtro="convertida">Convertidas</button>
        <button type="button" class="sols__filtro" data-filtro="descartada">Descartadas</button>
      </div>

      {/* Filtro por canal de contacto (qué se usó para escribirles) */}
      <div class="sols__filtros sols__filtros--contacto" id="sols-fcontacto" role="group" aria-label="Filtrar por canal de contacto" hidden>
        <span class="sols__filtros-label">Contacto:</span>
        <button type="button" class="sols__filtro is-activo" data-fcontacto="todas">Todas</button>
        <button type="button" class="sols__filtro" data-fcontacto="mail">Les escribimos por mail</button>
        <button type="button" class="sols__filtro" data-fcontacto="whatsapp">Les escribimos por WhatsApp</button>
        <button type="button" class="sols__filtro" data-fcontacto="sin">Sin contactar</button>
      </div>

      {/* Envío manual: filtro por intención + copiar los mails de lo visible.
          Pensado para que Julia/Laura armen un mail grupal en su correo:
          filtran acá, copian las direcciones y las pegan en CCO. */}
      <div class="sols__envio" id="sols-envio" hidden>
        <div class="sols__filtros sols__envio-filtros" role="group" aria-label="Filtrar por intención">
          <button type="button" class="sols__filtro is-activo" data-intencion="todas">Todas las intenciones</button>
          <button type="button" class="sols__filtro" data-intencion="info">Quieren info</button>
          <button type="button" class="sols__filtro" data-intencion="inscripcion">Quieren anotarse</button>
          <button type="button" class="sols__filtro" data-intencion="charla">Quieren hablar</button>
        </div>
        <div class="sols__envio-acciones">
          <span class="sols__envio-resumen" id="envio-resumen"></span>
          <button type="button" class="sols__envio-btn" id="envio-copiar">Copiar mails</button>
          <a class="sols__envio-btn sols__envio-btn--sec" id="envio-mailto" href="#" hidden>Abrir en el correo (CCO)</a>
        </div>
        <p class="sols__envio-hint">Se copian los mails de las solicitudes visibles según los filtros y la búsqueda, sin repetidos. Pégalos en <strong>CCO</strong> para no exponer las direcciones entre sí.</p>
      </div>

      {/* Resumen de origen (de qué canal vino cada solicitud) */}
      <p class="sols__canales" id="sols-canales" hidden></p>

      <div id="sols-loader" class="sols__loader">
        <div class="loader" role="status">
          <span class="loader__spinner" aria-hidden="true"></span>
          <span class="loader__label">Cargando solicitudes…</span>
        </div>
      </div>

      <div id="sols-lista"></div>

      <p id="sols-error" class="sols__error" hidden></p>
    </div>
  </main>
</AulaLayout>

<script>
  import { supabase } from "../../../lib/supabase";
  import { requireRol } from "../../../lib/auth-guard";
  import { showToast, confirmModal, formModal, traducirError } from "../../../lib/ui";
  import { iconHtml } from "../../../lib/icons";

  const $loader = document.getElementById("sols-loader") as HTMLElement;
  const $lista = document.getElementById("sols-lista") as HTMLElement;
  const $bajada = document.getElementById("sols-bajada")!;
  const $errorBox = document.getElementById("sols-error") as HTMLElement;
  const $avisos = document.getElementById("sols-avisos") as HTMLElement;
  const $buscador = document.getElementById("sols-buscador") as HTMLElement;
  const $buscar = document.getElementById("sols-buscar") as HTMLInputElement;
  const $orden = document.getElementById("sols-orden") as HTMLSelectElement;
  const $filtros = document.getElementById("sols-filtros") as HTMLElement;
  const $fcontacto = document.getElementById("sols-fcontacto") as HTMLElement;
  const $canales = document.getElementById("sols-canales") as HTMLElement;
  const $envio = document.getElementById("sols-envio") as HTMLElement;
  const $envioResumen = document.getElementById("envio-resumen") as HTMLElement;
  const $envioCopiar = document.getElementById("envio-copiar") as HTMLButtonElement;
  const $envioMailto = document.getElementById("envio-mailto") as HTMLAnchorElement;

  // ============ Reglas de los avisos (editables) ============
  // Una solicitud "nueva" sin tocar durante más de estas horas → aviso.
  const HORAS_SIN_RESPUESTA = 24;
  // Pidió info/charla, fue contactada, y pasaron estas horas sin que se
  // anote → aviso de seguimiento (decisión doc 11-jun: seguimiento 48 hs).
  const HORAS_SEGUIMIENTO = 48;

  // ============ Tipos ============
  type Estado = "nueva" | "contactada" | "convertida" | "descartada";
  type Intencion = "info" | "inscripcion" | "charla";
  type Nota = { en: string | null; texto: string };
  type Solicitud = {
    id: string;
    creado_en: string;
    canal: string;
    intencion: Intencion;
    nombre: string;
    email: string;
    telefono: string | null;
    pais: string | null;
    como_nos_encontraste: string | null;
    canal_preferido_respuesta: "mail" | "whatsapp" | null;
    rol_solicitante: "mayor" | "responsable_menor" | null;
    edad: number | null;
    nombre_menor: string | null;
    email_menor: string | null;
    fecha_nacimiento_menor: string | null;
    vinculo_menor: string | null;
    dni_tutor: string | null;
    contacto_emergencia_nombre: string | null;
    contacto_emergencia_telefono: string | null;
    contacto_emergencia_vinculo: string | null;
    protocolo_aceptado: boolean | null;
    protocolo_version: string | null;
    protocolo_aceptado_en: string | null;
    estado: Estado;
    notas_admin: string | null;
    // Migración 15 — form "Hablemos" + seguimiento manual
    mensaje: string | null;
    contactada_por_mail: boolean;
    contactada_por_whatsapp: boolean;
    contactada_en: string | null;
    seguimiento_hecho_en: string | null;
    recordatorio_en: string | null;
    recordatorio_nota: string | null;
    notas: Nota[];
  };

  const ESTADOS: Record<Estado, { label: string }> = {
    nueva: { label: "Nueva" },
    contactada: { label: "Contactada" },
    convertida: { label: "Convertida" },
    descartada: { label: "Descartada" },
  };

  const INTENCION_LABEL: Record<Intencion, string> = {
    info: "Quiere info",
    inscripcion: "Quiere anotarse",
    charla: "Quiere hablar",
  };

  const CANAL_LABEL: Record<string, string> = {
    web: "Web", whatsapp: "WhatsApp", instagram: "Instagram", otro: "Otro",
  };

  let solicitudes: Solicitud[] = [];
  let filtroActivo: "todas" | Estado = "todas";
  let filtroIntencion: "todas" | Intencion = "todas";
  let filtroContacto: "todas" | "mail" | "whatsapp" | "sin" = "todas";
  let busqueda = "";
  let orden: "recientes" | "antiguas" = "recientes";
  let emailsVisibles: string[] = [];

  // ============ Helpers ============
  function esc(s: string | null | undefined) {
    return String(s ?? "")
      .replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;").replace(/'/g, "&#039;");
  }

  function formatoFechaHora(iso: string | null) {
    if (!iso) return "—";
    try {
      return new Date(iso).toLocaleString("es-AR", {
        day: "numeric", month: "long", year: "numeric", hour: "2-digit", minute: "2-digit",
      });
    } catch { return iso; }
  }

  function formatoFecha(iso: string | null) {
    if (!iso) return "—";
    try {
      return new Date(iso + "T00:00:00").toLocaleDateString("es-AR", {
        day: "numeric", month: "long", year: "numeric",
      });
    } catch { return iso; }
  }

  // Fecha corta para las notas y recordatorios: "12/6 14:30".
  function formatoFechaCorta(iso: string | null) {
    if (!iso) return "";
    try {
      const d = new Date(iso);
      return d.toLocaleDateString("es-AR", { day: "numeric", month: "numeric" }) +
        " " + d.toLocaleTimeString("es-AR", { hour: "2-digit", minute: "2-digit" });
    } catch { return ""; }
  }

  // "hace 3 h" / "hace 2 días" — para los avisos.
  function tiempoRelativo(iso: string): string {
    const ms = Date.now() - new Date(iso).getTime();
    const horas = Math.floor(ms / 3_600_000);
    if (horas < 1) return "hace menos de 1 hora";
    if (horas < 48) return `hace ${horas} h`;
    return `hace ${Math.floor(horas / 24)} días`;
  }

  // Para la búsqueda: minúsculas y sin acentos ("Maria" encuentra "María").
  function normalizar(s: string): string {
    return s.toLowerCase().normalize("NFD").replace(/[̀-ͯ]/g, "");
  }

  // Edad a partir de una fecha de nacimiento (YYYY-MM-DD).
  function calcularEdad(fecha: string | null): number | null {
    if (!fecha) return null;
    const nac = new Date(fecha + "T00:00:00");
    if (Number.isNaN(nac.getTime())) return null;
    const hoy = new Date();
    let edad = hoy.getFullYear() - nac.getFullYear();
    const m = hoy.getMonth() - nac.getMonth();
    if (m < 0 || (m === 0 && hoy.getDate() < nac.getDate())) edad--;
    return edad;
  }

  function iniciales(nombre: string) {
    return nombre.split(" ").map((n) => n[0]).join("").slice(0, 2).toUpperCase();
  }

  // Link de WhatsApp a partir de un teléfono (deja solo dígitos).
  function waLink(tel: string | null): string | null {
    if (!tel) return null;
    const soloDigitos = tel.replace(/\D/g, "");
    return soloDigitos.length >= 8 ? `https://wa.me/${soloDigitos}` : null;
  }

  // Mensaje pre-cargado para iniciar el chat de WhatsApp, según la intención.
  // Se abre escrito; Julia/Laura lo revisan y mandan. Tuteo neutro, sin emojis.
  function mensajeWpp(s: Solicitud): string {
    const nom = (s.nombre || "").trim().split(/\s+/)[0] || "";
    const hola = nom ? `Hola ${nom}, ` : "Hola, ";
    if (s.intencion === "inscripcion") {
      return `${hola}somos Julia y Laura de Vocational Lab. Recibimos tu inscripción al próximo grupo, ¡qué alegría! Para confirmar tu lugar coordinamos el pago por transferencia. ¿Te enviamos los datos?`;
    }
    if (s.intencion === "info") {
      return `${hola}somos Julia y Laura de Vocational Lab. Recibimos tu consulta desde la web y te escribimos por aquí como pediste. ¿Quieres que te contemos más sobre el programa o prefieres que coordinemos una charla?`;
    }
    return `${hola}somos Julia y Laura de Vocational Lab. Recibimos tu mensaje desde la web. ¿En qué te podemos ayudar?`;
  }

  // waLink + el mensaje pre-cargado (?text=...).
  function waLinkMsg(s: Solicitud): string | null {
    const base = waLink(s.telefono);
    if (!base) return null;
    return `${base}?text=${encodeURIComponent(mensajeWpp(s))}`;
  }

  // Mail pre-redactado (mailto con asunto + cuerpo según la intención).
  // Igual que el de WhatsApp: se abre escrito en el cliente de correo
  // y Julia/Laura lo completan antes de mandar.
  function mailtoMsg(s: Solicitud): string {
    const nom = (s.nombre || "").trim().split(/\s+/)[0] || "";
    const hola = nom ? `Hola ${nom}:` : "Hola:";
    let asunto: string;
    let cuerpo: string;
    if (s.intencion === "inscripcion") {
      asunto = "Tu lugar en Vocational Lab";
      cuerpo = `${hola}\n\nSomos Julia y Laura de Vocational Lab. Recibimos tu inscripción al próximo grupo, ¡qué alegría!\n\nPara confirmar tu lugar coordinamos el pago por transferencia. Te dejamos los datos:\n\n[completar datos de la transferencia]\n\nCualquier duda, respondes este mail y te ayudamos.\n\nJulia y Laura · Vocational Lab`;
    } else if (s.intencion === "info") {
      asunto = "Información sobre Vocational Lab";
      cuerpo = `${hola}\n\nSomos Julia y Laura de Vocational Lab. Recibimos tu consulta desde la web, ¡gracias por escribirnos!\n\n[completar]\n\nJulia y Laura · Vocational Lab`;
    } else {
      asunto = "Tu mensaje a Vocational Lab";
      cuerpo = `${hola}\n\nSomos Julia y Laura de Vocational Lab. Leímos tu mensaje, ¡gracias por escribirnos!\n\n[completar respuesta]\n\nJulia y Laura · Vocational Lab`;
    }
    return `mailto:${s.email}?subject=${encodeURIComponent(asunto)}&body=${encodeURIComponent(cuerpo)}`;
  }

  // ============ Carga ============
  async function cargar() {
    const auth = await requireRol(["admin"]);
    if (!auth) return;

    const { data, error } = await supabase
      .from("solicitudes_inscripcion")
      .select("*")
      .order("creado_en", { ascending: false });

    if (error) {
      $loader.hidden = true;
      $errorBox.hidden = false;
      $errorBox.textContent = `Error: ${traducirError(error)}`;
      return;
    }

    // Defaults defensivos: si la migración 15 todavía no corrió, las columnas
    // nuevas vienen undefined y el panel igual tiene que poder mostrar la lista.
    solicitudes = ((data ?? []) as Record<string, unknown>[]).map((raw) => {
      const s = raw as unknown as Solicitud;
      if (!Array.isArray(s.notas)) {
        s.notas = s.notas_admin ? [{ en: null, texto: s.notas_admin }] : [];
      }
      s.contactada_por_mail = !!s.contactada_por_mail;
      s.contactada_por_whatsapp = !!s.contactada_por_whatsapp;
      return s;
    });

    $loader.hidden = true;
    $buscador.hidden = false;
    $filtros.hidden = false;
    $fcontacto.hidden = false;
    $envio.hidden = false;
    render();
  }

  // ============ Avisos (lo que necesita acción hoy) ============
  type Aviso = {
    tipo: "recordatorio" | "sin_respuesta" | "seguimiento";
    sol: Solicitud;
    texto: string;
    accionLabel: string | null; // botón "listo" del aviso (null = solo "Ver")
  };

  function calcularAvisos(): Aviso[] {
    const ahora = Date.now();
    const avisos: Aviso[] = [];

    for (const s of solicitudes) {
      // 1 · Recordatorio manual vencido.
      if (s.recordatorio_en && new Date(s.recordatorio_en).getTime() <= ahora
        && s.estado !== "descartada") {
        avisos.push({
          tipo: "recordatorio",
          sol: s,
          texto: `Aviso programado · ${s.nombre}${s.recordatorio_nota ? `: ${s.recordatorio_nota}` : ""}`,
          accionLabel: "Listo, quitar aviso",
        });
        continue; // si hay recordatorio vencido, no apilamos más avisos de la misma persona
      }

      // 2 · Nueva sin responder hace más de HORAS_SIN_RESPUESTA.
      if (s.estado === "nueva"
        && ahora - new Date(s.creado_en).getTime() > HORAS_SIN_RESPUESTA * 3_600_000) {
        avisos.push({
          tipo: "sin_respuesta",
          sol: s,
          texto: `${s.nombre} (${INTENCION_LABEL[s.intencion].toLowerCase()}) entró ${tiempoRelativo(s.creado_en)} y todavía nadie le respondió.`,
          accionLabel: null,
        });
        continue;
      }

      // 3 · Seguimiento de 48 hs: pidió info o quería hablar, fue contactada,
      //     y no se anotó ni se le hizo el seguimiento todavía.
      if ((s.intencion === "info" || s.intencion === "charla")
        && s.estado === "contactada"
        && !s.seguimiento_hecho_en
        && s.contactada_en
        && ahora - new Date(s.contactada_en).getTime() > HORAS_SEGUIMIENTO * 3_600_000) {
        avisos.push({
          tipo: "seguimiento",
          sol: s,
          texto: `${s.nombre} recibió respuesta ${tiempoRelativo(s.contactada_en)} y no se anotó. Puede ser momento de un mensaje de seguimiento (charla, beneficio, recordatorio de cupos).`,
          accionLabel: "Seguimiento hecho",
        });
      }
    }

    // Recordatorios primero, después sin respuesta, después seguimientos.
    const peso = { recordatorio: 0, sin_respuesta: 1, seguimiento: 2 };
    return avisos.sort((a, b) => peso[a.tipo] - peso[b.tipo]);
  }

  function renderAvisos() {
    const avisos = calcularAvisos();
    if (avisos.length === 0) {
      $avisos.hidden = true;
      $avisos.innerHTML = "";
      return avisos.length;
    }

    $avisos.innerHTML = `
      <p class="sols__avisos-titulo">${iconHtml("bell", 16)} Necesitan atención (${avisos.length})</p>
      <ul class="sols__avisos-lista">
        ${avisos.map((a) => `
          <li class="sols-aviso sols-aviso--${a.tipo}">
            <span class="sols-aviso__texto">${esc(a.texto)}</span>
            <span class="sols-aviso__acciones">
              <button type="button" class="sols-aviso__btn" data-aviso-ver="${esc(a.sol.id)}">Ver</button>
              ${a.accionLabel ? `<button type="button" class="sols-aviso__btn sols-aviso__btn--ok" data-aviso-listo="${a.tipo}:${esc(a.sol.id)}">${esc(a.accionLabel)}</button>` : ""}
            </span>
          </li>`).join("")}
      </ul>`;
    $avisos.hidden = false;
    return avisos.length;
  }

  // ============ Render ============
  function render() {
    const q = normalizar(busqueda.trim());

    const visibles = solicitudes.filter((s) => {
      if (filtroActivo !== "todas" && s.estado !== filtroActivo) return false;
      if (filtroIntencion !== "todas" && s.intencion !== filtroIntencion) return false;
      if (filtroContacto === "mail" && !s.contactada_por_mail) return false;
      if (filtroContacto === "whatsapp" && !s.contactada_por_whatsapp) return false;
      if (filtroContacto === "sin" && (s.contactada_por_mail || s.contactada_por_whatsapp)) return false;
      if (q) {
        const texto = normalizar([
          s.nombre, s.email, s.telefono ?? "", s.pais ?? "", s.nombre_menor ?? "",
          s.email_menor ?? "", s.mensaje ?? "", s.como_nos_encontraste ?? "",
          s.recordatorio_nota ?? "", ...s.notas.map((n) => n.texto),
        ].join(" "));
        if (!texto.includes(q)) return false;
      }
      return true;
    }).sort((a, b) => orden === "recientes"
      ? b.creado_en.localeCompare(a.creado_en)
      : a.creado_en.localeCompare(b.creado_en));

    const cantAvisos = renderAvisos();

    // Resumen en la bajada.
    const nuevas = solicitudes.filter((s) => s.estado === "nueva").length;
    const total = solicitudes.length;
    $bajada.textContent = total === 0
      ? "Todavía no entró ninguna solicitud."
      : `${total} en total · ${nuevas} sin revisar${cantAvisos ? ` · ${cantAvisos} con aviso pendiente` : ""}`;

    // Resumen por canal (de dónde vino cada solicitud).
    if (total === 0) {
      $canales.hidden = true;
    } else {
      const porCanal: Record<string, number> = {};
      for (const s of solicitudes) porCanal[s.canal] = (porCanal[s.canal] ?? 0) + 1;
      const partes = ["web", "whatsapp", "instagram", "otro"]
        .filter((c) => porCanal[c])
        .map((c) => `${CANAL_LABEL[c] ?? c}: ${porCanal[c]}`);
      $canales.textContent = `Por canal — ${partes.join(" · ")}`;
      $canales.hidden = false;
    }

    // Contadores en los filtros de estado (ojo: scopeado a #sols-filtros para
    // no pisar los botones de intención/contacto, que comparten la clase visual).
    document.querySelectorAll<HTMLButtonElement>("#sols-filtros .sols__filtro").forEach((btn) => {
      const f = btn.dataset.filtro as "todas" | Estado;
      const n = f === "todas" ? total : solicitudes.filter((s) => s.estado === f).length;
      const base = btn.textContent?.replace(/\s*\(\d+\)$/, "") ?? "";
      btn.textContent = `${base} (${n})`;
      btn.classList.toggle("is-activo", f === filtroActivo);
    });

    // Botones de contacto e intención: solo marcamos el activo.
    document.querySelectorAll<HTMLButtonElement>("[data-fcontacto]").forEach((btn) => {
      btn.classList.toggle("is-activo", btn.dataset.fcontacto === filtroContacto);
    });
    document.querySelectorAll<HTMLButtonElement>("[data-intencion]").forEach((btn) => {
      btn.classList.toggle("is-activo", btn.dataset.intencion === filtroIntencion);
    });

    // Barra de envío manual: mails únicos de lo visible.
    const emails = [...new Set(visibles.map((s) => s.email.trim().toLowerCase()).filter(Boolean))];
    $envioResumen.textContent = emails.length === 0
      ? "Sin destinatarios con estos filtros."
      : `${emails.length} destinatario${emails.length === 1 ? "" : "s"}`;
    $envioCopiar.disabled = emails.length === 0;
    // mailto con CCO pre-cargado. Si la lista es muy larga el mailto se rompe
    // (límite de URL de los clientes de correo), así que lo ocultamos y queda
    // solo "Copiar mails".
    const mailtoHref = `mailto:hola@vlab.com.ar?bcc=${encodeURIComponent(emails.join(","))}`;
    const mailtoUsable = emails.length > 0 && mailtoHref.length <= 1800;
    $envioMailto.hidden = !mailtoUsable;
    if (mailtoUsable) $envioMailto.href = mailtoHref;
    emailsVisibles = emails;

    if (visibles.length === 0) {
      $lista.innerHTML = `
        <div class="empty-state">
          <span class="empty-state__icono" aria-hidden="true">${iconHtml("inbox", 28)}</span>
          <h3 class="empty-state__titulo">Nada por acá</h3>
          <p class="empty-state__bajada">${q ? "Ninguna solicitud coincide con la búsqueda." : "No hay solicitudes con este filtro."}</p>
        </div>`;
      return;
    }

    $lista.innerHTML = `<ul class="sols-cards">${visibles.map(renderCard).join("")}</ul>`;
    enchufarAcciones();
  }

  function renderCard(s: Solicitud): string {
    const esInscripcion = s.intencion === "inscripcion";
    const waMsg = waLinkMsg(s);
    const prefiereWpp = s.canal_preferido_respuesta === "whatsapp";
    const prefiereMail = s.canal_preferido_respuesta === "mail";
    const prefiere = prefiereWpp ? "Prefiere WhatsApp"
      : prefiereMail ? "Prefiere mail" : null;

    // Bloque de consentimiento (solo si es inscripción).
    let consentimiento = "";
    if (esInscripcion) {
      const filas: string[] = [];
      if (s.rol_solicitante === "mayor") {
        filas.push(fila("Se inscribe", "Mayor de edad" + (s.edad ? ` · ${s.edad} años` : "")));
      } else if (s.rol_solicitante === "responsable_menor") {
        const edadM = calcularEdad(s.fecha_nacimiento_menor);
        filas.push(fila("Se inscribe", "Menor de edad (lo anota un responsable)"));
        filas.push(fila("Menor", `${esc(s.nombre_menor ?? "—")}${edadM != null ? ` · ${edadM} años` : ""}`));
        filas.push(fila("Email del menor", esc(s.email_menor ?? "—")));
        filas.push(fila("Nacimiento", formatoFecha(s.fecha_nacimiento_menor)));
        filas.push(fila("Responsable", `${esc(s.nombre)} · ${esc(s.vinculo_menor ?? "—")}`));
        filas.push(fila("DNI responsable", esc(s.dni_tutor ?? "—")));
      }
      // Contacto de familiar/persona cercana que acompaña (si lo cargaron).
      if (s.contacto_emergencia_nombre || s.contacto_emergencia_telefono) {
        filas.push(fila(
          "Acompaña",
          `${esc(s.contacto_emergencia_nombre ?? "—")} · ${esc(s.contacto_emergencia_telefono ?? "—")}${s.contacto_emergencia_vinculo ? ` (${esc(s.contacto_emergencia_vinculo)})` : ""}`
        ));
      }
      // Protocolo.
      const protoOk = s.protocolo_aceptado
        ? `✓ Aceptado ${s.protocolo_version ? `(${esc(s.protocolo_version)})` : ""} · ${esc(formatoFechaHora(s.protocolo_aceptado_en))}`
        : "✗ No consta aceptación";
      filas.push(fila("Protocolo", protoOk));

      consentimiento = `
        <div class="sol-card__bloque">
          <span class="sol-card__bloque-titulo">Consentimiento</span>
          <dl class="sol-card__datos">${filas.join("")}</dl>
        </div>`;
    }

    // Mensaje libre (form "Hablemos").
    const mensaje = s.mensaje ? `
      <div class="sol-card__bloque">
        <span class="sol-card__bloque-titulo">Mensaje</span>
        <p class="sol-card__mensaje">${esc(s.mensaje)}</p>
      </div>` : "";

    // Seguimiento: por dónde se la contactó + recordatorio.
    const recVencido = s.recordatorio_en && new Date(s.recordatorio_en).getTime() <= Date.now();
    const seguimiento = `
      <div class="sol-card__bloque">
        <span class="sol-card__bloque-titulo">Seguimiento</span>
        <div class="sol-seguimiento">
          <span class="sol-seguimiento__label">Ya le escribimos por:</span>
          <button type="button" class="sol-toggle${s.contactada_por_mail ? " is-on" : ""}" data-contacto="mail" data-id="${esc(s.id)}" aria-pressed="${s.contactada_por_mail}">Mail</button>
          <button type="button" class="sol-toggle${s.contactada_por_whatsapp ? " is-on" : ""}" data-contacto="whatsapp" data-id="${esc(s.id)}" aria-pressed="${s.contactada_por_whatsapp}">WhatsApp</button>
          ${s.contactada_en ? `<span class="sol-seguimiento__fecha">Primer contacto: ${esc(formatoFechaCorta(s.contactada_en))}</span>` : ""}
        </div>
        ${s.recordatorio_en ? `
          <p class="sol-recordatorio${recVencido ? " sol-recordatorio--vencido" : ""}">
            ${iconHtml("bell", 14)} Aviso para el ${esc(formatoFecha(s.recordatorio_en.slice(0, 10)))}${s.recordatorio_nota ? `: ${esc(s.recordatorio_nota)}` : ""}
            <button type="button" class="sol-recordatorio__quitar" data-rec-quitar="${esc(s.id)}">quitar</button>
          </p>` : ""}
      </div>`;

    // Notas internas con fecha.
    const notas = s.notas.length > 0 ? `
      <div class="sol-card__bloque">
        <span class="sol-card__bloque-titulo">Notas internas (${s.notas.length})</span>
        <ul class="sol-notas">
          ${s.notas.map((n, i) => `
            <li class="sol-notas__item">
              ${n.en ? `<span class="sol-notas__fecha">${esc(formatoFechaCorta(n.en))}</span>` : ""}
              <span class="sol-notas__texto">${esc(n.texto)}</span>
              <button type="button" class="sol-notas__borrar" data-nota-borrar="${esc(s.id)}:${i}" aria-label="Borrar nota">×</button>
            </li>`).join("")}
        </ul>
      </div>` : "";

    // Selector de estado.
    const opcionesEstado = (Object.keys(ESTADOS) as Estado[]).map((e) =>
      `<option value="${e}" ${e === s.estado ? "selected" : ""}>${ESTADOS[e].label}</option>`
    ).join("");

    return `
      <li class="sol-card sol-card--${s.estado}" data-sol-id="${esc(s.id)}">
        <div class="sol-card__head">
          <div class="sol-card__id">
            <span class="sol-card__avatar">${esc(iniciales(s.nombre))}</span>
            <div>
              <span class="sol-card__nombre">${esc(s.nombre)}</span>
              <span class="sol-card__fecha">Entró el ${esc(formatoFechaHora(s.creado_en))}</span>
            </div>
          </div>
          <div class="sol-card__tags">
            <span class="sol-tag sol-tag--${s.intencion === "inscripcion" ? "insc" : s.intencion === "charla" ? "charla" : "info"}">${INTENCION_LABEL[s.intencion] ?? esc(s.intencion)}</span>
            <span class="sol-tag sol-tag--canal">vía ${esc(CANAL_LABEL[s.canal] ?? s.canal)}</span>
          </div>
        </div>

        <div class="sol-card__bloque">
          <span class="sol-card__bloque-titulo">Contacto</span>
          <dl class="sol-card__datos">
            ${fila("Mail", `<a href="mailto:${esc(s.email)}">${esc(s.email)}</a>`)}
            ${s.telefono ? fila("Teléfono", esc(s.telefono)) : ""}
            ${s.pais ? fila("País", esc(s.pais)) : ""}
            ${prefiere ? fila("Respuesta", esc(prefiere)) : ""}
            ${s.como_nos_encontraste ? fila("Nos encontró por", esc(s.como_nos_encontraste)) : ""}
          </dl>
        </div>

        ${mensaje}

        ${consentimiento}

        ${seguimiento}

        ${notas}

        <div class="sol-card__acciones">
          <label class="sol-card__estado">
            <span>Estado</span>
            <select data-estado="${esc(s.id)}">${opcionesEstado}</select>
          </label>
          <div class="sol-card__botones">
            ${waMsg ? `<a class="sol-wpp${prefiereWpp ? " sol-wpp--destacado" : ""}" href="${esc(waMsg)}" target="_blank" rel="noopener">Escribir por WhatsApp</a>` : ""}
            <a class="sol-mail${prefiereMail ? " sol-mail--destacado" : ""}" href="${esc(mailtoMsg(s))}">Escribir por mail</a>
            <button type="button" class="boton-ghost-mini" data-nota="${esc(s.id)}">Agregar nota</button>
            <button type="button" class="boton-ghost-mini" data-recordatorio="${esc(s.id)}">${s.recordatorio_en ? "Cambiar aviso" : "Crear aviso"}</button>
            <button type="button" class="sol-eliminar" data-eliminar="${esc(s.id)}">Eliminar</button>
          </div>
        </div>
      </li>`;
  }

  function fila(label: string, valorHTML: string): string {
    return `<div class="sol-fila"><dt>${esc(label)}</dt><dd>${valorHTML}</dd></div>`;
  }

  // ============ Persistencia (helper común de updates) ============
  // Aplica el update en Supabase y, si sale bien, copia los cambios al
  // objeto local y re-renderiza. Devuelve true/false según resultado.
  async function actualizarSolicitud(id: string, cambios: Partial<Solicitud>): Promise<boolean> {
    const sol = solicitudes.find((s) => s.id === id);
    if (!sol) return false;

    const { error } = await supabase
      .from("solicitudes_inscripcion")
      .update(cambios)
      .eq("id", id);

    if (error) {
      showToast(traducirError(error), "error");
      return false;
    }

    Object.assign(sol, cambios);
    return true;
  }

  // ============ Acciones ============
  function enchufarAcciones() {
    document.querySelectorAll<HTMLSelectElement>("[data-estado]").forEach((sel) => {
      sel.addEventListener("change", () => cambiarEstado(sel.dataset.estado!, sel.value as Estado, sel));
    });
    document.querySelectorAll<HTMLButtonElement>("[data-nota]").forEach((btn) => {
      btn.addEventListener("click", () => agregarNota(btn.dataset.nota!));
    });
    document.querySelectorAll<HTMLButtonElement>("[data-nota-borrar]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const [id, idx] = btn.dataset.notaBorrar!.split(":");
        borrarNota(id, parseInt(idx, 10));
      });
    });
    document.querySelectorAll<HTMLButtonElement>("[data-contacto]").forEach((btn) => {
      btn.addEventListener("click", () => toggleContacto(btn.dataset.id!, btn.dataset.contacto as "mail" | "whatsapp"));
    });
    document.querySelectorAll<HTMLButtonElement>("[data-recordatorio]").forEach((btn) => {
      btn.addEventListener("click", () => editarRecordatorio(btn.dataset.recordatorio!));
    });
    document.querySelectorAll<HTMLButtonElement>("[data-rec-quitar]").forEach((btn) => {
      btn.addEventListener("click", () => quitarRecordatorio(btn.dataset.recQuitar!));
    });
    document.querySelectorAll<HTMLButtonElement>("[data-eliminar]").forEach((btn) => {
      btn.addEventListener("click", () => eliminarSolicitud(btn.dataset.eliminar!, btn));
    });
  }

  async function eliminarSolicitud(id: string, btn: HTMLButtonElement) {
    const sol = solicitudes.find((s) => s.id === id);
    const ok = await confirmModal({
      titulo: "Eliminar solicitud",
      mensaje: `¿Eliminar la solicitud de ${sol?.nombre ?? "esta persona"} de forma permanente? Sirve para sacar pruebas o spam. No se puede deshacer.`,
      confirmLabel: "Eliminar",
      danger: true,
    });
    if (!ok) return;

    btn.disabled = true;
    const { error } = await supabase
      .from("solicitudes_inscripcion")
      .delete()
      .eq("id", id);

    if (error) {
      showToast(traducirError(error), "error");
      btn.disabled = false;
      return;
    }

    solicitudes = solicitudes.filter((s) => s.id !== id);
    showToast("Solicitud eliminada.");
    render();
  }

  async function cambiarEstado(id: string, nuevo: Estado, sel: HTMLSelectElement) {
    const sol = solicitudes.find((s) => s.id === id);
    if (!sol || sol.estado === nuevo) return;

    // Confirmamos solo el caso "descartada" (es el más definitivo).
    if (nuevo === "descartada") {
      const ok = await confirmModal({
        titulo: "Descartar solicitud",
        mensaje: `¿Marcar la solicitud de ${sol.nombre} como descartada?`,
        confirmLabel: "Descartar",
        danger: true,
      });
      if (!ok) { sel.value = sol.estado; return; }
    }

    // Al pasar a "contactada" por primera vez, registramos cuándo
    // (es la base del aviso de seguimiento a las 48 hs).
    const cambios: Partial<Solicitud> = { estado: nuevo };
    if (nuevo === "contactada" && !sol.contactada_en) {
      cambios.contactada_en = new Date().toISOString();
    }

    sel.disabled = true;
    const ok = await actualizarSolicitud(id, cambios);
    sel.disabled = false;

    if (!ok) { sel.value = sol.estado; return; }
    showToast(`Marcada como ${ESTADOS[nuevo].label.toLowerCase()}.`);
    render();
  }

  // Marca/desmarca por dónde se contactó a la persona. Si es el primer
  // contacto y la solicitud estaba "nueva", la pasamos a "contactada" sola.
  async function toggleContacto(id: string, canal: "mail" | "whatsapp") {
    const sol = solicitudes.find((s) => s.id === id);
    if (!sol) return;

    const campo = canal === "mail" ? "contactada_por_mail" : "contactada_por_whatsapp";
    const nuevoValor = !sol[campo];

    const cambios: Partial<Solicitud> = { [campo]: nuevoValor };
    if (nuevoValor && !sol.contactada_en) cambios.contactada_en = new Date().toISOString();
    if (nuevoValor && sol.estado === "nueva") cambios.estado = "contactada";

    if (!(await actualizarSolicitud(id, cambios))) return;

    if (nuevoValor && cambios.estado === "contactada") {
      showToast(`Contacto por ${canal === "mail" ? "mail" : "WhatsApp"} registrado. Pasó a "contactada".`);
    } else {
      showToast(nuevoValor ? `Contacto por ${canal === "mail" ? "mail" : "WhatsApp"} registrado.` : "Contacto desmarcado.");
    }
    render();
  }

  async function agregarNota(id: string) {
    const sol = solicitudes.find((s) => s.id === id);
    if (!sol) return;

    const result = await formModal({
      titulo: "Agregar nota",
      mensaje: `Sobre la solicitud de ${sol.nombre}. Solo la ven los admins. Queda guardada con fecha y hora.`,
      campos: [
        {
          name: "nota",
          label: "Nota",
          type: "textarea",
          rows: 4,
          required: true,
          placeholder: "Ej: la llamé hoy, coordina pago para la semana que viene.",
        },
      ],
      confirmLabel: "Guardar nota",
    });
    if (result === null) return;

    const texto = result.nota.trim();
    if (!texto) return;

    const notas = [...sol.notas, { en: new Date().toISOString(), texto }];
    if (!(await actualizarSolicitud(id, { notas }))) return;
    showToast("Nota guardada.");
    render();
  }

  async function borrarNota(id: string, idx: number) {
    const sol = solicitudes.find((s) => s.id === id);
    if (!sol || !sol.notas[idx]) return;

    const ok = await confirmModal({
      titulo: "Borrar nota",
      mensaje: `¿Borrar esta nota? "${sol.notas[idx].texto.slice(0, 80)}${sol.notas[idx].texto.length > 80 ? "…" : ""}"`,
      confirmLabel: "Borrar",
      danger: true,
    });
    if (!ok) return;

    const notas = sol.notas.filter((_, i) => i !== idx);
    if (!(await actualizarSolicitud(id, { notas }))) return;
    showToast("Nota borrada.");
    render();
  }

  async function editarRecordatorio(id: string) {
    const sol = solicitudes.find((s) => s.id === id);
    if (!sol) return;

    const result = await formModal({
      titulo: sol.recordatorio_en ? "Cambiar aviso" : "Crear aviso",
      mensaje: `El panel te va a avisar ese día, arriba de todo, sobre la solicitud de ${sol.nombre}.`,
      campos: [
        {
          name: "fecha",
          label: "Avisar el día",
          type: "date",
          required: true,
          value: sol.recordatorio_en ? sol.recordatorio_en.slice(0, 10) : "",
        },
        {
          name: "nota",
          label: "Qué hay que hacer",
          value: sol.recordatorio_nota ?? "",
          placeholder: "Ej: escribirle para ofrecerle la charla informativa.",
        },
      ],
      confirmLabel: "Guardar aviso",
    });
    if (result === null) return;

    const fecha = result.fecha.trim();
    if (!fecha) { showToast("Falta la fecha del aviso.", "error"); return; }

    // Guardamos el aviso a las 00:00 hora local de ese día: el panel lo
    // muestra como pendiente desde esa mañana.
    const cambios: Partial<Solicitud> = {
      recordatorio_en: new Date(fecha + "T00:00:00").toISOString(),
      recordatorio_nota: result.nota.trim() || null,
    };
    if (!(await actualizarSolicitud(id, cambios))) return;
    showToast("Aviso guardado.");
    render();
  }

  async function quitarRecordatorio(id: string) {
    if (!(await actualizarSolicitud(id, { recordatorio_en: null, recordatorio_nota: null }))) return;
    showToast("Aviso quitado.");
    render();
  }

  // Marca el seguimiento de 48 hs como hecho (apaga el aviso) y deja
  // una nota con fecha para que quede registro de quién/cuándo.
  async function marcarSeguimiento(id: string) {
    const sol = solicitudes.find((s) => s.id === id);
    if (!sol) return;

    const ahora = new Date().toISOString();
    const notas = [...sol.notas, { en: ahora, texto: "Se le envió mensaje de seguimiento." }];
    if (!(await actualizarSolicitud(id, { seguimiento_hecho_en: ahora, notas }))) return;
    showToast("Seguimiento registrado.");
    render();
  }

  // ============ Avisos: Ver / Listo ============
  $avisos.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;

    const verBtn = target.closest<HTMLButtonElement>("[data-aviso-ver]");
    if (verBtn) {
      // Limpiamos filtros y búsqueda para garantizar que la card esté visible.
      filtroActivo = "todas";
      filtroIntencion = "todas";
      filtroContacto = "todas";
      busqueda = "";
      $buscar.value = "";
      render();
      const card = document.querySelector<HTMLElement>(`[data-sol-id="${verBtn.dataset.avisoVer}"]`);
      if (card) {
        card.scrollIntoView({ behavior: "smooth", block: "center" });
        card.classList.add("sol-card--destacada");
        setTimeout(() => card.classList.remove("sol-card--destacada"), 2200);
      }
      return;
    }

    const listoBtn = target.closest<HTMLButtonElement>("[data-aviso-listo]");
    if (listoBtn) {
      const [tipo, id] = listoBtn.dataset.avisoListo!.split(":");
      listoBtn.disabled = true;
      if (tipo === "recordatorio") quitarRecordatorio(id);
      else if (tipo === "seguimiento") marcarSeguimiento(id);
    }
  });

  // ============ Filtros, búsqueda y orden ============
  $filtros.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(".sols__filtro");
    if (!btn) return;
    filtroActivo = btn.dataset.filtro as "todas" | Estado;
    render();
  });

  $fcontacto.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>("[data-fcontacto]");
    if (!btn) return;
    filtroContacto = btn.dataset.fcontacto as typeof filtroContacto;
    render();
  });

  $envio.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>("[data-intencion]");
    if (!btn) return;
    filtroIntencion = btn.dataset.intencion as "todas" | Intencion;
    render();
  });

  $buscar.addEventListener("input", () => {
    busqueda = $buscar.value;
    render();
  });

  $orden.addEventListener("change", () => {
    orden = $orden.value as "recientes" | "antiguas";
    render();
  });

  // Copiar los mails visibles al portapapeles (separados por coma, listos
  // para pegar en el campo CCO de cualquier cliente de correo).
  $envioCopiar.addEventListener("click", async () => {
    if (emailsVisibles.length === 0) return;
    const texto = emailsVisibles.join(", ");
    try {
      await navigator.clipboard.writeText(texto);
      showToast(`${emailsVisibles.length} mail${emailsVisibles.length === 1 ? "" : "s"} copiados. Pégalos en CCO.`);
    } catch {
      // Fallback para navegadores sin permiso de clipboard: prompt copiable.
      window.prompt("Copia los mails con Ctrl+C:", texto);
    }
  });

  cargar().catch((err) => {
    console.error("[solicitudes]", err);
    $loader.hidden = true;
    $errorBox.hidden = false;
    $errorBox.textContent = `Error inesperado: ${err instanceof Error ? err.message : String(err)}`;
  });
</script>

<style>
  .sols { flex: 1; padding: clamp(2rem, 5vw, 3rem) 0 5rem; }

  .sols__volver {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--color-ink-soft);
    margin-bottom: 1.5rem;
  }
  .sols__volver:hover { color: var(--color-ink); }

  .sols__head {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-line);
  }
  .sols__eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 500;
    margin: 0 0 0.9rem;
  }
  .sols__titulo { font-size: clamp(2rem, 4.5vw, 2.6rem); margin: 0 0 0.4rem; }
  .sols__bajada { color: var(--color-ink-soft); margin: 0; }

  .sols__canales {
    margin: -0.6rem 0 1.6rem;
    font-size: 0.85rem;
    color: var(--color-ink-muted);
  }

  .sols__loader { padding: 1.5rem 0; }
  .sols__error { color: var(--color-accent); padding: 1rem 0; }

  /* ===== Avisos (necesitan atención) ===== */
  .sols__avisos {
    background: rgba(216, 85, 42, 0.06);
    border: 1px solid rgba(216, 85, 42, 0.35);
    border-radius: var(--radius-md);
    padding: 1rem 1.2rem;
    margin-bottom: 1.6rem;
  }
  .sols__avisos-titulo {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0 0 0.7rem;
    font-size: 0.92rem;
