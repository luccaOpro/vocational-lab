  }
  .sols__filtros-flecha { transition: transform 0.2s ease; }
  .sols__filtros-toggle.is-abierto .sols__filtros-flecha { transform: rotate(180deg); }

  /* Panel desplegable con las filas de filtros */
  .sols__filtros-panel {
    display: flex;
    flex-direction: column;
