---
/*
  /aula/admin/solicitudes — bandeja de solicitudes de inscripción.
  ---
  Muestra todo lo que entra por el formulario público de /inscripcion
  (tabla solicitudes_inscripcion). El admin puede:
    · Ver todos los datos de cada solicitud (contacto + consentimiento).
    · Filtrar por estado (nueva / contactada / convertida / descartada).
    · Cambiar el estado de cada una.
    · Dejar una nota interna.

  Es la entrada del embudo: cuando una persona efectivamente paga, el
  admin la marca como "convertida" y carga el pago en /aula/admin/transferencias.

  Las reglas de seguridad (RLS) que permiten al admin leer/editar esta
  tabla ya están en docs/sql/04-solicitudes-inscripcion.sql.
*/

import AulaLayout from "../../../layouts/AulaLayout.astro";
---

<AulaLayout title="Solicitudes · Admin · Vocational Lab" rol="admin">
  <main class="sols">
    <div class="container">
      <a href="/aula/admin" class="sols__volver">← Volver al panel</a>

      <header class="sols__head">
        <div>
          <p class="sols__eyebrow">Admin</p>
          <h1 class="sols__titulo">Solicitudes</h1>
          <p class="sols__bajada" id="sols-bajada">Cargando…</p>
        </div>
      </header>

      {/* Filtros por estado */}
      <div class="sols__filtros" id="sols-filtros" role="tablist" aria-label="Filtrar por estado" hidden>
        <button type="button" class="sols__filtro is-activo" data-filtro="todas">Todas</button>
        <button type="button" class="sols__filtro" data-filtro="nueva">Nuevas</button>
        <button type="button" class="sols__filtro" data-filtro="contactada">Contactadas</button>
        <button type="button" class="sols__filtro" data-filtro="convertida">Convertidas</button>
        <button type="button" class="sols__filtro" data-filtro="descartada">Descartadas</button>
      </div>

      {/* Envío manual: filtro por intención + copiar los mails de lo visible.
          Pensado para que Julia/Laura armen un mail grupal en su correo:
          filtran acá, copian las direcciones y las pegan en CCO. */}
      <div class="sols__envio" id="sols-envio" hidden>
        <div class="sols__filtros sols__envio-filtros" role="group" aria-label="Filtrar por intención">
          <button type="button" class="sols__filtro is-activo" data-intencion="todas">Todas las intenciones</button>
          <button type="button" class="sols__filtro" data-intencion="info">Quieren info</button>
          <button type="button" class="sols__filtro" data-intencion="inscripcion">Quieren anotarse</button>
        </div>
        <div class="sols__envio-acciones">
          <span class="sols__envio-resumen" id="envio-resumen"></span>
          <button type="button" class="sols__envio-btn" id="envio-copiar">Copiar mails</button>
          <a class="sols__envio-btn sols__envio-btn--sec" id="envio-mailto" href="#" hidden>Abrir en el correo (CCO)</a>
        </div>
        <p class="sols__envio-hint">Se copian los mails de las solicitudes visibles según los filtros, sin repetidos. Pégalos en <strong>CCO</strong> para no exponer las direcciones entre sí.</p>
      </div>

      {/* Resumen de origen (de qué canal vino cada solicitud) */}
      <p class="sols__canales" id="sols-canales" hidden></p>

      <div id="sols-loader" class="sols__loader">
        <div class="loader" role="status">
          <span class="loader__spinner" aria-hidden="true"></span>
          <span class="loader__label">Cargando solicitudes…</span>
        </div>
      </div>

      <div id="sols-lista"></div>

      <p id="sols-error" class="sols__error" hidden></p>
    </div>
  </main>
</AulaLayout>

<script>
  import { supabase } from "../../../lib/supabase";
  import { requireRol } from "../../../lib/auth-guard";
  import { showToast, confirmModal, formModal, traducirError } from "../../../lib/ui";
  import { iconHtml } from "../../../lib/icons";

  const $loader = document.getElementById("sols-loader") as HTMLElement;
  const $lista = document.getElementById("sols-lista") as HTMLElement;
  const $bajada = document.getElementById("sols-bajada")!;
  const $errorBox = document.getElementById("sols-error") as HTMLElement;
  const $filtros = document.getElementById("sols-filtros") as HTMLElement;
  const $canales = document.getElementById("sols-canales") as HTMLElement;
  const $envio = document.getElementById("sols-envio") as HTMLElement;
  const $envioResumen = document.getElementById("envio-resumen") as HTMLElement;
  const $envioCopiar = document.getElementById("envio-copiar") as HTMLButtonElement;
  const $envioMailto = document.getElementById("envio-mailto") as HTMLAnchorElement;

  // ============ Tipos ============
  type Estado = "nueva" | "contactada" | "convertida" | "descartada";
  type Solicitud = {
    id: string;
    creado_en: string;
    canal: string;
    intencion: "info" | "inscripcion" | "charla";
    nombre: string;
    email: string;
    telefono: string | null;
    pais: string | null;
    como_nos_encontraste: string | null;
    canal_preferido_respuesta: "mail" | "whatsapp" | null;
    rol_solicitante: "mayor" | "responsable_menor" | null;
    edad: number | null;
    nombre_menor: string | null;
    fecha_nacimiento_menor: string | null;
    vinculo_menor: string | null;
    dni_tutor: string | null;
    contacto_emergencia_nombre: string | null;
    contacto_emergencia_telefono: string | null;
    contacto_emergencia_vinculo: string | null;
    protocolo_aceptado: boolean | null;
    protocolo_version: string | null;
    protocolo_aceptado_en: string | null;
    estado: Estado;
    notas_admin: string | null;
  };

  const ESTADOS: Record<Estado, { label: string }> = {
    nueva: { label: "Nueva" },
    contactada: { label: "Contactada" },
    convertida: { label: "Convertida" },
    descartada: { label: "Descartada" },
  };

  const CANAL_LABEL: Record<string, string> = {
    web: "Web", whatsapp: "WhatsApp", instagram: "Instagram", otro: "Otro",
  };

  let solicitudes: Solicitud[] = [];
  let filtroActivo: "todas" | Estado = "todas";
  let filtroIntencion: "todas" | "info" | "inscripcion" = "todas";
  let emailsVisibles: string[] = [];

  // ============ Helpers ============
  function esc(s: string | null | undefined) {
    return String(s ?? "")
      .replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;").replace(/'/g, "&#039;");
  }

  function formatoFechaHora(iso: string | null) {
    if (!iso) return "—";
    try {
      return new Date(iso).toLocaleString("es-AR", {
        day: "numeric", month: "long", year: "numeric", hour: "2-digit", minute: "2-digit",
      });
    } catch { return iso; }
  }

  function formatoFecha(iso: string | null) {
    if (!iso) return "—";
    try {
      return new Date(iso + "T00:00:00").toLocaleDateString("es-AR", {
        day: "numeric", month: "long", year: "numeric",
      });
    } catch { return iso; }
  }

  // Edad a partir de una fecha de nacimiento (YYYY-MM-DD).
  function calcularEdad(fecha: string | null): number | null {
    if (!fecha) return null;
    const nac = new Date(fecha + "T00:00:00");
    if (Number.isNaN(nac.getTime())) return null;
    const hoy = new Date();
    let edad = hoy.getFullYear() - nac.getFullYear();
    const m = hoy.getMonth() - nac.getMonth();
    if (m < 0 || (m === 0 && hoy.getDate() < nac.getDate())) edad--;
    return edad;
  }

  function iniciales(nombre: string) {
    return nombre.split(" ").map((n) => n[0]).join("").slice(0, 2).toUpperCase();
  }

  // Link de WhatsApp a partir de un teléfono (deja solo dígitos).
  function waLink(tel: string | null): string | null {
    if (!tel) return null;
    const soloDigitos = tel.replace(/\D/g, "");
    return soloDigitos.length >= 8 ? `https://wa.me/${soloDigitos}` : null;
  }

  // Mensaje pre-cargado para iniciar el chat de WhatsApp, según la intención.
  // Se abre escrito; Julia/Laura lo revisan y mandan. Tuteo neutro, sin emojis.
  function mensajeWpp(s: Solicitud): string {
    const nom = (s.nombre || "").trim().split(/\s+/)[0] || "";
    const hola = nom ? `Hola ${nom}, ` : "Hola, ";
    if (s.intencion === "inscripcion") {
      return `${hola}somos Julia y Laura de Vocational Lab. Recibimos tu inscripción al próximo grupo, ¡qué alegría! Para confirmar tu lugar coordinamos el pago por transferencia. ¿Te enviamos los datos?`;
    }
    if (s.intencion === "info") {
      return `${hola}somos Julia y Laura de Vocational Lab. Recibimos tu consulta desde la web y te escribimos por aquí como pediste. ¿Quieres que te contemos más sobre el programa o prefieres que coordinemos una charla?`;
    }
    return `${hola}somos Julia y Laura de Vocational Lab. Recibimos tu mensaje desde la web y te escribimos por aquí como pediste. ¿En qué te podemos ayudar?`;
  }

  // waLink + el mensaje pre-cargado (?text=...).
  function waLinkMsg(s: Solicitud): string | null {
    const base = waLink(s.telefono);
    if (!base) return null;
    return `${base}?text=${encodeURIComponent(mensajeWpp(s))}`;
  }

  // ============ Carga ============
  async function cargar() {
    const auth = await requireRol(["admin"]);
    if (!auth) return;

    const { data, error } = await supabase
      .from("solicitudes_inscripcion")
      .select("*")
      .order("creado_en", { ascending: false });

    if (error) {
      $loader.hidden = true;
      $errorBox.hidden = false;
      $errorBox.textContent = `Error: ${traducirError(error)}`;
      return;
    }

    solicitudes = (data ?? []) as Solicitud[];
    $loader.hidden = true;
    $filtros.hidden = false;
    $envio.hidden = false;
    render();
  }

  // ============ Render ============
  function render() {
    const visibles = solicitudes.filter((s) =>
      (filtroActivo === "todas" || s.estado === filtroActivo) &&
      (filtroIntencion === "todas" || s.intencion === filtroIntencion)
    );

    // Resumen en la bajada.
    const nuevas = solicitudes.filter((s) => s.estado === "nueva").length;
    const total = solicitudes.length;
    $bajada.textContent = total === 0
      ? "Todavía no entró ninguna solicitud."
      : `${total} en total · ${nuevas} sin revisar`;

    // Resumen por canal (de dónde vino cada solicitud).
    if (total === 0) {
      $canales.hidden = true;
    } else {
      const porCanal: Record<string, number> = {};
      for (const s of solicitudes) porCanal[s.canal] = (porCanal[s.canal] ?? 0) + 1;
      const partes = ["web", "whatsapp", "instagram", "otro"]
        .filter((c) => porCanal[c])
        .map((c) => `${CANAL_LABEL[c] ?? c}: ${porCanal[c]}`);
      $canales.textContent = `Por canal — ${partes.join(" · ")}`;
      $canales.hidden = false;
    }

    // Contadores en los filtros de estado (ojo: scopeado a #sols-filtros para
    // no pisar los botones de intención, que comparten la clase visual).
    document.querySelectorAll<HTMLButtonElement>("#sols-filtros .sols__filtro").forEach((btn) => {
      const f = btn.dataset.filtro as "todas" | Estado;
      const n = f === "todas" ? total : solicitudes.filter((s) => s.estado === f).length;
      const base = btn.textContent?.replace(/\s*\(\d+\)$/, "") ?? "";
      btn.textContent = `${base} (${n})`;
      btn.classList.toggle("is-activo", f === filtroActivo);
    });

    // Botones de intención: solo marcamos el activo.
    document.querySelectorAll<HTMLButtonElement>("[data-intencion]").forEach((btn) => {
      btn.classList.toggle("is-activo", btn.dataset.intencion === filtroIntencion);
    });

    // Barra de envío manual: mails únicos de lo visible.
    const emails = [...new Set(visibles.map((s) => s.email.trim().toLowerCase()).filter(Boolean))];
    $envioResumen.textContent = emails.length === 0
      ? "Sin destinatarios con estos filtros."
      : `${emails.length} destinatario${emails.length === 1 ? "" : "s"}`;
    $envioCopiar.disabled = emails.length === 0;
    // mailto con CCO pre-cargado. Si la lista es muy larga el mailto se rompe
    // (límite de URL de los clientes de correo), así que lo ocultamos y queda
    // solo "Copiar mails".
    const mailtoHref = `mailto:hola@vlab.com.ar?bcc=${encodeURIComponent(emails.join(","))}`;
    const mailtoUsable = emails.length > 0 && mailtoHref.length <= 1800;
    $envioMailto.hidden = !mailtoUsable;
    if (mailtoUsable) $envioMailto.href = mailtoHref;
    emailsVisibles = emails;

    if (visibles.length === 0) {
      $lista.innerHTML = `
        <div class="empty-state">
          <span class="empty-state__icono" aria-hidden="true">${iconHtml("inbox", 28)}</span>
          <h3 class="empty-state__titulo">Nada por acá</h3>
          <p class="empty-state__bajada">No hay solicitudes con este filtro.</p>
        </div>`;
      return;
    }

    $lista.innerHTML = `<ul class="sols-cards">${visibles.map(renderCard).join("")}</ul>`;
    enchufarAcciones();
  }

  function renderCard(s: Solicitud): string {
    const esInscripcion = s.intencion === "inscripcion";
    const intLabel = esInscripcion ? "Quiere anotarse" : "Quiere info";
    const waMsg = waLinkMsg(s);
    const prefiereWpp = s.canal_preferido_respuesta === "whatsapp";
    const prefiere = prefiereWpp ? "Prefiere WhatsApp"
      : s.canal_preferido_respuesta === "mail" ? "Prefiere mail" : null;

    // Bloque de consentimiento (solo si es inscripción).
    let consentimiento = "";
    if (esInscripcion) {
      const filas: string[] = [];
      if (s.rol_solicitante === "mayor") {
        filas.push(fila("Se inscribe", "Mayor de edad" + (s.edad ? ` · ${s.edad} años` : "")));
      } else if (s.rol_solicitante === "responsable_menor") {
        const edadM = calcularEdad(s.fecha_nacimiento_menor);
        filas.push(fila("Se inscribe", "Menor de edad (lo anota un responsable)"));
        filas.push(fila("Menor", `${esc(s.nombre_menor ?? "—")}${edadM != null ? ` · ${edadM} años` : ""}`));
        filas.push(fila("Nacimiento", formatoFecha(s.fecha_nacimiento_menor)));
        filas.push(fila("Responsable", `${esc(s.nombre)} · ${esc(s.vinculo_menor ?? "—")}`));
        filas.push(fila("DNI responsable", esc(s.dni_tutor ?? "—")));
      }
      // Contacto de emergencia (si lo cargaron).
      if (s.contacto_emergencia_nombre || s.contacto_emergencia_telefono) {
        filas.push(fila(
          "Emergencia",
          `${esc(s.contacto_emergencia_nombre ?? "—")} · ${esc(s.contacto_emergencia_telefono ?? "—")}${s.contacto_emergencia_vinculo ? ` (${esc(s.contacto_emergencia_vinculo)})` : ""}`
        ));
      }
      // Protocolo.
      const protoOk = s.protocolo_aceptado
        ? `✓ Aceptado ${s.protocolo_version ? `(${esc(s.protocolo_version)})` : ""} · ${esc(formatoFechaHora(s.protocolo_aceptado_en))}`
        : "✗ No consta aceptación";
      filas.push(fila("Protocolo", protoOk));

      consentimiento = `
        <div class="sol-card__bloque">
          <span class="sol-card__bloque-titulo">Consentimiento</span>
          <dl class="sol-card__datos">${filas.join("")}</dl>
        </div>`;
    }

    // Selector de estado.
    const opcionesEstado = (Object.keys(ESTADOS) as Estado[]).map((e) =>
      `<option value="${e}" ${e === s.estado ? "selected" : ""}>${ESTADOS[e].label}</option>`
    ).join("");

    return `
      <li class="sol-card sol-card--${s.estado}" data-sol-id="${esc(s.id)}">
        <div class="sol-card__head">
          <div class="sol-card__id">
            <span class="sol-card__avatar">${esc(iniciales(s.nombre))}</span>
            <div>
              <span class="sol-card__nombre">${esc(s.nombre)}</span>
              <span class="sol-card__fecha">Entró el ${esc(formatoFechaHora(s.creado_en))}</span>
            </div>
          </div>
          <div class="sol-card__tags">
            <span class="sol-tag sol-tag--${esInscripcion ? "insc" : "info"}">${intLabel}</span>
            <span class="sol-tag sol-tag--canal">vía ${esc(CANAL_LABEL[s.canal] ?? s.canal)}</span>
          </div>
        </div>

        <div class="sol-card__bloque">
          <span class="sol-card__bloque-titulo">Contacto</span>
          <dl class="sol-card__datos">
            ${fila("Mail", `<a href="mailto:${esc(s.email)}">${esc(s.email)}</a>`)}
            ${s.telefono ? fila("Teléfono", esc(s.telefono)) : ""}
            ${s.pais ? fila("País", esc(s.pais)) : ""}
            ${prefiere ? fila("Respuesta", esc(prefiere)) : ""}
            ${s.como_nos_encontraste ? fila("Nos encontró por", esc(s.como_nos_encontraste)) : ""}
          </dl>
        </div>

        ${consentimiento}

        ${s.notas_admin ? `<p class="sol-card__nota"><strong>Nota:</strong> ${esc(s.notas_admin)}</p>` : ""}

        <div class="sol-card__acciones">
          <label class="sol-card__estado">
            <span>Estado</span>
            <select data-estado="${esc(s.id)}">${opcionesEstado}</select>
          </label>
          <div class="sol-card__botones">
            ${waMsg ? `<a class="sol-wpp${prefiereWpp ? " sol-wpp--destacado" : ""}" href="${esc(waMsg)}" target="_blank" rel="noopener">Escribir por WhatsApp</a>` : ""}
            <button type="button" class="boton-ghost-mini" data-nota="${esc(s.id)}">
              ${s.notas_admin ? "Editar nota" : "Agregar nota"}
            </button>
            <button type="button" class="sol-eliminar" data-eliminar="${esc(s.id)}">Eliminar</button>
          </div>
        </div>
      </li>`;
  }

  function fila(label: string, valorHTML: string): string {
    return `<div class="sol-fila"><dt>${esc(label)}</dt><dd>${valorHTML}</dd></div>`;
  }

  // ============ Acciones ============
  function enchufarAcciones() {
    document.querySelectorAll<HTMLSelectElement>("[data-estado]").forEach((sel) => {
      sel.addEventListener("change", () => cambiarEstado(sel.dataset.estado!, sel.value as Estado, sel));
    });
    document.querySelectorAll<HTMLButtonElement>("[data-nota]").forEach((btn) => {
      btn.addEventListener("click", () => editarNota(btn.dataset.nota!));
    });
    document.querySelectorAll<HTMLButtonElement>("[data-eliminar]").forEach((btn) => {
      btn.addEventListener("click", () => eliminarSolicitud(btn.dataset.eliminar!, btn));
    });
  }

  async function eliminarSolicitud(id: string, btn: HTMLButtonElement) {
    const sol = solicitudes.find((s) => s.id === id);
    const ok = await confirmModal({
      titulo: "Eliminar solicitud",
      mensaje: `¿Eliminar la solicitud de ${sol?.nombre ?? "esta persona"} de forma permanente? Sirve para sacar pruebas o spam. No se puede deshacer.`,
      confirmLabel: "Eliminar",
      danger: true,
    });
    if (!ok) return;

    btn.disabled = true;
    const { error } = await supabase
      .from("solicitudes_inscripcion")
      .delete()
      .eq("id", id);

    if (error) {
      showToast(traducirError(error), "error");
      btn.disabled = false;
      return;
    }

    solicitudes = solicitudes.filter((s) => s.id !== id);
    showToast("Solicitud eliminada.");
    render();
  }

  async function cambiarEstado(id: string, nuevo: Estado, sel: HTMLSelectElement) {
    const sol = solicitudes.find((s) => s.id === id);
    if (!sol || sol.estado === nuevo) return;

    // Confirmamos solo el caso "descartada" (es el más definitivo).
    if (nuevo === "descartada") {
      const ok = await confirmModal({
        titulo: "Descartar solicitud",
        mensaje: `¿Marcar la solicitud de ${sol.nombre} como descartada?`,
        confirmLabel: "Descartar",
        danger: true,
      });
      if (!ok) { sel.value = sol.estado; return; }
    }

    sel.disabled = true;
    const { error } = await supabase
      .from("solicitudes_inscripcion")
      .update({ estado: nuevo })
      .eq("id", id);
    sel.disabled = false;

    if (error) {
      showToast(traducirError(error), "error");
      sel.value = sol.estado;
      return;
    }

    sol.estado = nuevo;
    showToast(`Marcada como ${ESTADOS[nuevo].label.toLowerCase()}.`);
    render();
  }

  async function editarNota(id: string) {
    const sol = solicitudes.find((s) => s.id === id);
    if (!sol) return;

    const result = await formModal({
      titulo: "Nota interna",
      mensaje: `Sobre la solicitud de ${sol.nombre}. Solo la ven los admins.`,
      campos: [
        {
          name: "nota",
          label: "Nota",
          type: "textarea",
          rows: 4,
          value: sol.notas_admin ?? "",
          placeholder: "Ej: la llamé el 7/6, coordina pago para la semana que viene.",
        },
      ],
      confirmLabel: "Guardar",
    });
    if (result === null) return;

    const nota = result.nota.trim() || null;
    const { error } = await supabase
      .from("solicitudes_inscripcion")
      .update({ notas_admin: nota })
      .eq("id", id);

    if (error) {
      showToast(traducirError(error), "error");
      return;
    }

    sol.notas_admin = nota;
    showToast("Nota guardada.");
    render();
  }

  // ============ Filtros ============
  $filtros.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(".sols__filtro");
    if (!btn) return;
    filtroActivo = btn.dataset.filtro as "todas" | Estado;
    render();
  });

  $envio.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>("[data-intencion]");
    if (!btn) return;
    filtroIntencion = btn.dataset.intencion as "todas" | "info" | "inscripcion";
    render();
  });

  // Copiar los mails visibles al portapapeles (separados por coma, listos
  // para pegar en el campo CCO de cualquier cliente de correo).
  $envioCopiar.addEventListener("click", async () => {
    if (emailsVisibles.length === 0) return;
    const texto = emailsVisibles.join(", ");
    try {
      await navigator.clipboard.writeText(texto);
      showToast(`${emailsVisibles.length} mail${emailsVisibles.length === 1 ? "" : "s"} copiados. Pégalos en CCO.`);
    } catch {
      // Fallback para navegadores sin permiso de clipboard: prompt copiable.
      window.prompt("Copia los mails con Ctrl+C:", texto);
    }
  });

  cargar().catch((err) => {
    console.error("[solicitudes]", err);
    $loader.hidden = true;
    $errorBox.hidden = false;
    $errorBox.textContent = `Error inesperado: ${err instanceof Error ? err.message : String(err)}`;
