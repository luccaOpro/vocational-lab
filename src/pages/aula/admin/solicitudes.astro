  }
  .sols__filtros-toggle-icono { line-height: 0; }
  .sols__filtros-badge {
    min-width: 1.25rem; height: 1.25rem;
    padding: 0 0.3rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 99px;
    background: var(--color-deep);
