---
/*
  /aula/perfil — perfil del usuario logueado.
  ---
  Muestra los datos del profile (nombre, mail, rol, fecha de alta) y
  permite editar el nombre y cambiar la contraseña.
*/

import AulaLayout from "../../layouts/AulaLayout.astro";
---

<AulaLayout title="Mi perfil · Aula Vocational Lab" rol="alumno">
  <main class="perfil">
    <div class="container">
      <a href="#" id="perfil-volver" class="perfil__volver">← Volver</a>

      <div id="perfil-loader" class="perfil__loader">
        <div class="loader" role="status">
          <span class="loader__spinner" aria-hidden="true"></span>
          <span class="loader__label">Cargando tu perfil…</span>
        </div>
      </div>

      <div id="perfil-contenido" hidden>
        <header class="perfil__head">
          {/* Avatar: al hacer click sobre la zona o sobre "Cambiar foto"
              se dispara el input file invisible. Si ya hay foto, muestra
              una opción extra "Quitar foto". */}
          <div class="perfil__avatar-wrap">
            <button type="button" class="perfil__avatar" id="p-avatar" aria-label="Cambiar foto de perfil"></button>
            <input type="file" id="p-avatar-input" accept="image/png,image/jpeg,image/webp" hidden />
            <div class="perfil__avatar-acciones">
              <button type="button" class="perfil__avatar-accion" id="btn-cambiar-foto">Cambiar foto</button>
              <button type="button" class="perfil__avatar-accion perfil__avatar-accion--quitar" id="btn-quitar-foto" hidden>Quitar foto</button>
            </div>
          </div>
          <div class="perfil__head-cuerpo">
            <h1 class="perfil__nombre" id="p-nombre"></h1>
            <p class="perfil__mail" id="p-mail"></p>
            <span class="perfil__rol-badge" id="p-rol-badge"></span>
          </div>
        </header>

        <p class="perfil__meta" id="p-creado-en"></p>

        {/* ── Editar nombre ── */}
        <section class="card">
          <h2 class="card__titulo">Editar perfil</h2>
          <form id="form-nombre" class="form">
            <label class="form__label">
              <span>Nombre y apellido</span>
              <input type="text" name="nombre" id="input-nombre" required minlength="2" />
            </label>
            <button type="submit" class="form__submit">Guardar</button>
            <p id="msg-nombre-ok" class="form__msg-ok" hidden></p>
            <p id="msg-nombre-error" class="form__msg-error" hidden></p>
          </form>
        </section>

        {/* ── Cambiar contraseña ── */}
        <section class="card">
          <h2 class="card__titulo">Cambiar contraseña</h2>
          <form id="form-password" class="form">
            <label class="form__label">
              <span>Nueva contraseña</span>
              <input type="password" name="pass" minlength="8" required autocomplete="new-password" placeholder="Mínimo 8 caracteres" />
            </label>
            <label class="form__label">
              <span>Confirmar nueva contraseña</span>
              <input type="password" name="pass2" minlength="8" required autocomplete="new-password" placeholder="Repetí la nueva contraseña" />
            </label>
            <button type="submit" class="form__submit">Cambiar contraseña</button>
            <p id="msg-pass-ok" class="form__msg-ok" hidden></p>
            <p id="msg-pass-error" class="form__msg-error" hidden></p>
          </form>
        </section>

        {/* ── Cerrar sesión ── */}
        <section class="card card--ghost">
          <h2 class="card__titulo">Sesión</h2>
          <p class="card__bajada">Cuando termines, cerrá sesión para que nadie use tu cuenta.</p>
          <button id="btn-logout" type="button" class="form__submit form__submit--ghost">Cerrar sesión</button>
        </section>
      </div>

      <p id="perfil-error" class="perfil__error" hidden></p>
    </div>
  </main>
</AulaLayout>

<script>
  import { supabase } from "../../lib/supabase";
  import { requireSession, homePorRol, type Rol } from "../../lib/auth-guard";
  import { showToast, confirmModal } from "../../lib/ui";

  const $loader = document.getElementById("perfil-loader") as HTMLElement;
  const $contenido = document.getElementById("perfil-contenido") as HTMLElement;
  const $errorBox = document.getElementById("perfil-error") as HTMLElement;
  const $volver = document.getElementById("perfil-volver") as HTMLAnchorElement;

  const $avatar = document.getElementById("p-avatar")!;
  const $avatarInput = document.getElementById("p-avatar-input") as HTMLInputElement;
  const $btnCambiarFoto = document.getElementById("btn-cambiar-foto")!;
  const $btnQuitarFoto = document.getElementById("btn-quitar-foto")!;
  const $nombre = document.getElementById("p-nombre")!;
  const $mail = document.getElementById("p-mail")!;
  const $rolBadge = document.getElementById("p-rol-badge")!;
  const $creadoEn = document.getElementById("p-creado-en")!;

  function esc(s: string | null | undefined) {
    return String(s ?? "")
      .replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;").replace(/'/g, "&#039;");
  }

  function iniciales(nombre: string) {
    return nombre.split(" ").map((n) => n[0]).join("").slice(0, 2).toUpperCase();
  }

  function formatoFechaLarga(iso: string) {
    try {
      return new Date(iso).toLocaleDateString("es-AR", { day: "numeric", month: "long", year: "numeric" });
    } catch {
      return iso;
    }
  }

  const labelRol: Record<Rol, string> = {
    alumno: "Protagonista",
    profe: "Profesor/a",
    admin: "Administrador/a",
  };

  // Mantiene los mensajes inline como fallback,
  // pero los principales ahora usan showToast() (mejor UX).
  function mostrarMsg(el: HTMLElement, mensaje: string) {
    el.textContent = mensaje;
    el.hidden = false;
    setTimeout(() => { el.hidden = true; }, 4000);
  }

  type ProfileFull = {
    id: string;
    nombre: string;
    email: string;
    rol: Rol;
    creado_en: string;
    avatar_url: string | null;
  };

  // Tamaño máximo del avatar antes de upload (en bytes).
  // Si la imagen es más grande, se redimensiona en el cliente a 512×512
  // (suficiente para un avatar) y se sube como JPEG.
  const AVATAR_MAX_LADO = 512;
  const AVATAR_MAX_BYTES = 5 * 1024 * 1024; // 5 MB de cota dura antes de procesar

  /**
   * Redimensiona y comprime la imagen del avatar en el cliente.
   * Sale como JPEG 0.85 — suficiente para foto de perfil chica.
   */
  async function procesarAvatar(file: File): Promise<Blob> {
    if (file.size > AVATAR_MAX_BYTES) {
      throw new Error("La imagen pesa más de 5 MB. Probá con una más liviana.");
    }
    const bitmap = await createImageBitmap(file);
    const escala = Math.min(1, AVATAR_MAX_LADO / Math.max(bitmap.width, bitmap.height));
    const w = Math.round(bitmap.width * escala);
    const h = Math.round(bitmap.height * escala);
    const canvas = document.createElement("canvas");
    canvas.width = w;
    canvas.height = h;
    const ctx = canvas.getContext("2d")!;
    ctx.drawImage(bitmap, 0, 0, w, h);
    bitmap.close?.();
    return new Promise<Blob>((resolve, reject) => {
      canvas.toBlob((b) => b ? resolve(b) : reject(new Error("No se pudo procesar la imagen.")), "image/jpeg", 0.85);
    });
  }

  /** Pinta el avatar: img si hay url, iniciales si no. */
  function renderAvatar(profile: ProfileFull) {
    if (profile.avatar_url) {
      $avatar.innerHTML = `<img src="${esc(profile.avatar_url)}" alt="Foto de perfil" class="perfil__avatar-img" />`;
      $avatar.classList.add("perfil__avatar--con-foto");
      ($btnQuitarFoto as HTMLElement).hidden = false;
    } else {
      $avatar.textContent = iniciales(profile.nombre);
      $avatar.classList.remove("perfil__avatar--con-foto");
      ($btnQuitarFoto as HTMLElement).hidden = true;
    }
  }

  async function cargar() {
    const auth = await requireSession();
    if (!auth) return;

    // Traemos profile completo (con email, creado_en y avatar).
    const { data: profile, error } = await supabase
      .from("profiles")
      .select("id, nombre, email, rol, creado_en, avatar_url")
      .eq("id", auth.session.user.id)
      .single<ProfileFull>();

    if (error || !profile) {
      $loader.hidden = true;
      $errorBox.hidden = false;
      $errorBox.textContent = `Error: ${error?.message ?? "no se pudo cargar el perfil"}`;
      return;
    }

    // Render del header.
    $avatar.classList.add(`perfil__avatar--${profile.rol}`);
    renderAvatar(profile);
    $nombre.textContent = profile.nombre;
    $mail.textContent = profile.email;
    $rolBadge.textContent = labelRol[profile.rol];
    $rolBadge.classList.add(`perfil__rol-badge--${profile.rol}`);
    $creadoEn.textContent = `Cuenta creada el ${formatoFechaLarga(profile.creado_en)}.`;

    // El "← Volver" lleva al home del rol del user.
    $volver.href = homePorRol[profile.rol];

    // Pre-rellenamos el input del nombre.
    const $inputNombre = document.getElementById("input-nombre") as HTMLInputElement;
    $inputNombre.value = profile.nombre;

    // Conectar handlers.
    enchufarFormNombre(profile);
    enchufarFormPassword();
    enchufarLogout();
    enchufarAvatar(profile);

    $loader.hidden = true;
    $contenido.hidden = false;
  }

  /**
   * Subida / borrado del avatar.
   *   · Click en el avatar o en "Cambiar foto" → abre el file picker.
   *   · Al elegir, procesa la imagen (resize + jpeg) y la sube al bucket
   *     "avatares" en la carpeta {userId}/.
   *   · Guarda la URL pública en profiles.avatar_url y refresca la UI.
   *   · "Quitar foto" borra el archivo y blanquea avatar_url.
   */
  function enchufarAvatar(profile: ProfileFull) {
    const elegirFoto = () => $avatarInput.click();
    $avatar.addEventListener("click", elegirFoto);
    $btnCambiarFoto.addEventListener("click", elegirFoto);

    $avatarInput.addEventListener("change", async () => {
      const file = $avatarInput.files?.[0];
      $avatarInput.value = "";
      if (!file) return;

      try {
        // Procesamos en cliente (resize + recompresión a JPEG).
        const blob = await procesarAvatar(file);

        // Path estable: siempre sobrescribimos avatar.jpg del usuario.
        // Le agregamos ?v=timestamp a la URL final para evitar cache.
        const path = `${profile.id}/avatar.jpg`;

        const { error: upErr } = await supabase.storage
          .from("avatares")
          .upload(path, blob, { upsert: true, contentType: "image/jpeg" });
        if (upErr) throw upErr;

        // URL pública + cache-buster.
        const { data: pub } = supabase.storage.from("avatares").getPublicUrl(path);
        const urlConVersion = `${pub.publicUrl}?v=${Date.now()}`;

        const { error: dbErr } = await supabase
          .from("profiles")
          .update({ avatar_url: urlConVersion })
          .eq("id", profile.id);
        if (dbErr) throw dbErr;

        profile.avatar_url = urlConVersion;
        renderAvatar(profile);
        showToast("Foto actualizada");
      } catch (err) {
        const msg = err instanceof Error ? err.message : String(err);
        showToast(`No se pudo actualizar la foto: ${msg}`, "error");
      }
    });

    $btnQuitarFoto.addEventListener("click", async () => {
      const ok = await confirmModal({
        titulo: "Quitar foto",
        mensaje: "¿Querés volver a mostrar tus iniciales en lugar de la foto?",
        confirmLabel: "Quitar foto",
      });
      if (!ok) return;

      try {
        // Borramos el archivo. Si falla por not-found lo ignoramos:
        // lo importante es blanquear la columna.
        await supabase.storage.from("avatares").remove([`${profile.id}/avatar.jpg`]);

        const { error: dbErr } = await supabase
          .from("profiles")
          .update({ avatar_url: null })
          .eq("id", profile.id);
        if (dbErr) throw dbErr;

        profile.avatar_url = null;
        renderAvatar(profile);
        showToast("Foto eliminada");
      } catch (err) {
        const msg = err instanceof Error ? err.message : String(err);
        showToast(`No se pudo quitar la foto: ${msg}`, "error");
      }
    });
  }

  function enchufarFormNombre(profile: ProfileFull) {
    const $form = document.getElementById("form-nombre") as HTMLFormElement;
    const $input = document.getElementById("input-nombre") as HTMLInputElement;
    const $btn = $form.querySelector("button") as HTMLButtonElement;
    const $ok = document.getElementById("msg-nombre-ok") as HTMLElement;
    const $err = document.getElementById("msg-nombre-error") as HTMLElement;

    $form.addEventListener("submit", async (e) => {
      e.preventDefault();
      $ok.hidden = true; $err.hidden = true;

      const nuevo = $input.value.trim();
      if (nuevo.length < 2) {
        showToast("El nombre tiene que tener al menos 2 caracteres.", "error");
        return;
      }
      if (nuevo === profile.nombre) {
        showToast("No hay cambios para guardar.", "info");
        return;
      }

      $btn.disabled = true;
      $btn.textContent = "Guardando…";

      const { error } = await supabase
        .from("profiles")
        .update({ nombre: nuevo })
        .eq("id", profile.id);

      $btn.disabled = false;
      $btn.textContent = "Guardar";

      if (error) {
        showToast(`No se pudo guardar: ${error.message}`, "error");
        return;
      }

      profile.nombre = nuevo;
      $nombre.textContent = nuevo;
      // Si no hay foto, las iniciales reflejan el nombre nuevo.
      if (!profile.avatar_url) $avatar.textContent = iniciales(nuevo);
      showToast("Nombre actualizado");
    });
  }

  function enchufarFormPassword() {
    const $form = document.getElementById("form-password") as HTMLFormElement;
    const $btn = $form.querySelector("button") as HTMLButtonElement;
    const $ok = document.getElementById("msg-pass-ok") as HTMLElement;
    const $err = document.getElementById("msg-pass-error") as HTMLElement;

    $form.addEventListener("submit", async (e) => {
      e.preventDefault();
      $ok.hidden = true; $err.hidden = true;

      const fd = new FormData($form);
      const pass = String(fd.get("pass"));
      const pass2 = String(fd.get("pass2"));

      if (pass.length < 8) {
        showToast("La contraseña tiene que tener al menos 8 caracteres.", "error");
        return;
      }
      if (pass !== pass2) {
        showToast("Las dos contraseñas no coinciden.", "error");
        return;
      }

      $btn.disabled = true;
      $btn.textContent = "Cambiando…";

      const { error } = await supabase.auth.updateUser({ password: pass });

      $btn.disabled = false;
      $btn.textContent = "Cambiar contraseña";

      if (error) {
        showToast(`No se pudo cambiar: ${error.message}`, "error");
        return;
      }

      showToast("Contraseña actualizada.");
      $form.reset();
    });
  }

  function enchufarLogout() {
    const $btn = document.getElementById("btn-logout") as HTMLButtonElement;
    $btn.addEventListener("click", async () => {
      const ok = await confirmModal({
        titulo: "Cerrar sesión",
        mensaje: "¿Querés salir del aula?",
        confirmLabel: "Cerrar sesión",
      });
      if (!ok) return;
      await supabase.auth.signOut();
      window.location.href = "/aula/login";
    });
  }

  cargar().catch((err) => {
    console.error("[perfil]", err);
    $loader.hidden = true;
    $errorBox.hidden = false;
    $errorBox.textContent = `Error inesperado: ${err instanceof Error ? err.message : String(err)}`;
  });
</script>

<style>
  .perfil { flex: 1; padding: clamp(2rem, 5vw, 3rem) 0 5rem; }

  .perfil__volver {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--color-ink-soft);
    margin-bottom: 1.5rem;
  }
  .perfil__volver:hover { color: var(--color-ink); }

  .perfil__loader { color: var(--color-ink-soft); font-style: italic; padding: 2rem 0; }
  .perfil__error { color: var(--color-accent); padding: 1rem 0; }

  /* ── Encabezado: avatar + nombre + mail + badge ── */
  .perfil__head {
    display: flex;
    align-items: center;
    gap: 1.4rem;
    margin-bottom: 0.8rem;
  }

  /* Wrap del avatar: contiene el botón circular + las acciones debajo. */
  .perfil__avatar-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  /* El avatar ahora es un <button> para abrir el file picker.
     Reseteamos los estilos default del button. */
  .perfil__avatar {
    display: grid;
    place-items: center;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--color-ink-muted);
    color: #fff;
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-weight: 500;
    border: 0;
    padding: 0;
    cursor: pointer;
    overflow: hidden;
    position: relative;
    transition: filter 0.15s ease, box-shadow 0.15s ease;
  }
  .perfil__avatar:hover {
    filter: brightness(0.95);
    box-shadow: 0 0 0 3px rgba(216, 85, 42, 0.18);
  }
  .perfil__avatar:focus-visible {
    outline: 3px solid var(--color-accent);
    outline-offset: 3px;
  }
  .perfil__avatar--alumno { background: var(--color-gold); color: var(--color-ink); }
  .perfil__avatar--profe { background: var(--color-deep); color: #fff; }
  .perfil__avatar--admin { background: var(--color-accent); color: #fff; }

  /* Si hay foto, la imagen llena el botón y tapa el color de fondo. */
  .perfil__avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .perfil__avatar--con-foto { background: transparent; }

  /* Acciones debajo del avatar (Cambiar foto / Quitar foto). */
  .perfil__avatar-acciones {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    align-items: center;
  }
  .perfil__avatar-accion {
    background: transparent;
    border: 0;
    padding: 0.2rem 0.4rem;
    font: inherit;
    font-size: 0.78rem;
    color: var(--color-ink-soft);
    cursor: pointer;
    border-radius: var(--radius-sm);
    line-height: 1.2;
  }
  .perfil__avatar-accion:hover {
    background: rgba(0, 0, 0, 0.04);
    color: var(--color-ink);
  }
  .perfil__avatar-accion--quitar:hover {
    color: var(--color-accent);
  }

  .perfil__head-cuerpo { display: flex; flex-direction: column; gap: 0.3rem; min-width: 0; }
  .perfil__nombre {
    font-size: clamp(1.6rem, 3vw, 2rem);
    margin: 0;
    line-height: 1.1;
  }
  .perfil__mail {
    margin: 0;
    color: var(--color-ink-soft);
    font-size: 0.95rem;
  }

  .perfil__rol-badge {
    display: inline-block;
    align-self: flex-start;
    padding: 0.25rem 0.65rem;
    border-radius: 99px;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    margin-top: 0.2rem;
    background: var(--color-bg);
    color: var(--color-ink-soft);
  }
  .perfil__rol-badge--alumno {
    background: rgba(201, 162, 76, 0.18);
    color: #7a5f1f;
  }
  .perfil__rol-badge--profe {
    background: rgba(36, 58, 130, 0.1);
    color: var(--color-deep);
  }
  .perfil__rol-badge--admin {
    background: rgba(216, 85, 42, 0.12);
    color: var(--color-accent);
  }

  .perfil__meta {
    color: var(--color-ink-muted);
    font-size: 0.88rem;
    margin: 0 0 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-line);
  }

  /* ── Cards de edición ── */
  .card {
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    padding: 1.8rem;
    margin-bottom: 1.5rem;
    max-width: 560px;
  }
  .card--ghost {
    background: transparent;
    border-style: dashed;
  }
  .card__titulo {
    font-size: 1.1rem;
    margin: 0 0 1.2rem;
  }
  .card__bajada {
    margin: 0 0 1rem;
    color: var(--color-ink-soft);
    font-size: 0.95rem;
  }

  .form { display: flex; flex-direction: column; gap: 1rem; }
  .form__label {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.85rem;
    color: var(--color-ink-soft);
    font-weight: 500;
  }
  .form__label input {
    font-family: inherit;
    font-size: 1rem;
    padding: 0.7rem 0.9rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    color: var(--color-ink);
  }
  .form__label input:focus {
    outline: none;
    border-color: var(--color-deep);
    background: #fff;
  }

  .form__submit {
    padding: 0.75rem 1.2rem;
    border: 0;
    border-radius: var(--radius-sm);
    background: var(--color-deep);
    color: #fff;
    font-family: inherit;
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    align-self: flex-start;
    transition: background 0.15s ease;
  }
  .form__submit:hover:not(:disabled) { background: #1a2c64; }
  .form__submit:disabled { opacity: 0.7; cursor: wait; }
  .form__submit--ghost {
    background: transparent;
    color: var(--color-ink);
    border: 1px solid var(--color-line);
  }
  .form__submit--ghost:hover:not(:disabled) {
    background: var(--color-bg);
  }

  .form__msg-ok,
  .form__msg-error {
    margin: 0;
    padding: 0.6rem 0.9rem;
    border-radius: var(--radius-sm);
    font-size: 0.88rem;
  }
  .form__msg-ok {
    background: rgba(36, 58, 130, 0.08);
    border-left: 3px solid var(--color-deep);
    color: var(--color-deep);
  }
  .form__msg-error {
    background: rgba(216, 85, 42, 0.1);
    border-left: 3px solid var(--color-accent);
    color: var(--color-accent);
  }

  @media (max-width: 540px) {
    .perfil__head { flex-direction: column; align-items: flex-start; gap: 1rem; }
    .perfil__avatar { width: 60px; height: 60px; font-size: 1.4rem; }
  }
</style>
