---
/*
  /aula/perfil — perfil del usuario logueado.
  ---
  Muestra los datos del profile (nombre, mail, rol, fecha de alta) y
  permite editar el nombre y cambiar la contraseña.
*/

import AulaLayout from "../../layouts/AulaLayout.astro";
---

<AulaLayout title="Mi perfil · Aula Vocational Lab" rol="alumno">
  <main class="perfil">
    <div class="container">
      <a href="#" id="perfil-volver" class="perfil__volver">← Volver</a>

      <div id="perfil-loader" class="perfil__loader">
        <div class="loader" role="status">
          <span class="loader__spinner" aria-hidden="true"></span>
          <span class="loader__label">Cargando tu perfil…</span>
        </div>
      </div>

      <div id="perfil-contenido" hidden>
        <header class="perfil__head">
          {/* Avatar: al hacer click sobre la zona o sobre "Cambiar foto"
              se dispara el input file invisible. Si ya hay foto, muestra
              una opción extra "Quitar foto". */}
          <div class="perfil__avatar-wrap">
            <button type="button" class="perfil__avatar" id="p-avatar" aria-label="Cambiar foto de perfil"></button>
            <input type="file" id="p-avatar-input" accept="image/png,image/jpeg,image/webp" hidden />
            <div class="perfil__avatar-acciones">
              <button type="button" class="perfil__avatar-accion" id="btn-cambiar-foto">Cambiar foto</button>
              <button type="button" class="perfil__avatar-accion perfil__avatar-accion--quitar" id="btn-quitar-foto" hidden>Quitar foto</button>
            </div>
          </div>
          <div class="perfil__head-cuerpo">
            <h1 class="perfil__nombre" id="p-nombre"></h1>
            <p class="perfil__mail" id="p-mail"></p>
            <span class="perfil__rol-badge" id="p-rol-badge"></span>
          </div>
        </header>

        <p class="perfil__meta" id="p-creado-en"></p>

        {/* ── Datos personales ── */}
        <section class="card">
          <h2 class="card__titulo">Datos personales</h2>
          <form id="form-datos" class="form">
            <label class="form__label">
              <span>Nombre y apellido</span>
              <input type="text" name="nombre" id="input-nombre" required minlength="2" maxlength="60" />
            </label>

            <div class="form__row">
              <label class="form__label">
                <span>País</span>
                <input type="text" name="pais" id="input-pais" maxlength="40" list="lista-paises" placeholder="Argentina" autocomplete="country-name" />
                {/* Sugerencias LATAM + países comunes — el usuario puede igualmente escribir libre. */}
                <datalist id="lista-paises">
                  <option value="Argentina"></option>
                  <option value="Bolivia"></option>
                  <option value="Brasil"></option>
                  <option value="Chile"></option>
                  <option value="Colombia"></option>
                  <option value="Costa Rica"></option>
                  <option value="Cuba"></option>
                  <option value="Ecuador"></option>
                  <option value="El Salvador"></option>
                  <option value="España"></option>
                  <option value="Estados Unidos"></option>
                  <option value="Guatemala"></option>
                  <option value="Honduras"></option>
                  <option value="México"></option>
                  <option value="Nicaragua"></option>
                  <option value="Panamá"></option>
                  <option value="Paraguay"></option>
                  <option value="Perú"></option>
                  <option value="Puerto Rico"></option>
                  <option value="República Dominicana"></option>
                  <option value="Uruguay"></option>
                  <option value="Venezuela"></option>
                </datalist>
              </label>
              <label class="form__label">
                <span>Ciudad</span>
                <input type="text" name="ciudad" id="input-ciudad" maxlength="60" placeholder="Buenos Aires" />
              </label>
            </div>

            <label class="form__label">
              <span>Sobre vos <small class="form__hint" id="bio-contador">0 / 280</small></span>
              <textarea name="bio" id="input-bio" maxlength="280" rows="3" placeholder="Una mini bio. Lo que quieras compartir con el grupo."></textarea>
            </label>

            <div class="form__label">
              <span>Tus intereses <small class="form__hint">Escribí y apretá Enter. Máximo 10.</small></span>
              <div class="chips" id="chips-intereses">
                <input type="text" id="input-interes" class="chips__input" maxlength="30" placeholder="Música, ciencia, diseño, lectura…" />
              </div>
            </div>

            <button type="submit" class="form__submit">Guardar cambios</button>
            <p id="msg-datos-ok" class="form__msg-ok" hidden></p>
            <p id="msg-datos-error" class="form__msg-error" hidden></p>
          </form>
        </section>

        {/* ── Cambiar contraseña ── */}
        <section class="card">
          <h2 class="card__titulo">Cambiar contraseña</h2>
          <form id="form-password" class="form">
            <label class="form__label">
              <span>Nueva contraseña</span>
              <div class="form__pass-wrap">
                <input type="password" name="pass" minlength="8" required autocomplete="new-password" placeholder="Mínimo 8 caracteres" />
                <button type="button" class="form__pass-toggle" data-toggle-pass aria-label="Mostrar contraseña" aria-pressed="false">
                  <svg class="icono-ojo" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/>
                    <circle cx="12" cy="12" r="3"/>
                  </svg>
                  <svg class="icono-ojo-tachado" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" hidden>
                    <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/>
                    <path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/>
                    <path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/>
                    <line x1="2" y1="2" x2="22" y2="22"/>
                  </svg>
                </button>
              </div>
            </label>
            <label class="form__label">
              <span>Confirmar nueva contraseña</span>
              <div class="form__pass-wrap">
                <input type="password" name="pass2" minlength="8" required autocomplete="new-password" placeholder="Repetí la nueva contraseña" />
                <button type="button" class="form__pass-toggle" data-toggle-pass aria-label="Mostrar contraseña" aria-pressed="false">
                  <svg class="icono-ojo" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/>
                    <circle cx="12" cy="12" r="3"/>
                  </svg>
                  <svg class="icono-ojo-tachado" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" hidden>
                    <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/>
                    <path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/>
                    <path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/>
                    <line x1="2" y1="2" x2="22" y2="22"/>
                  </svg>
                </button>
              </div>
            </label>
            <button type="submit" class="form__submit">Cambiar contraseña</button>
            <p id="msg-pass-ok" class="form__msg-ok" hidden></p>
            <p id="msg-pass-error" class="form__msg-error" hidden></p>
          </form>
        </section>

        {/* ── Cerrar sesión ── */}
        <section class="card card--ghost">
          <h2 class="card__titulo">Sesión</h2>
          <p class="card__bajada">Cuando termines, cerrá sesión para que nadie use tu cuenta.</p>
          <button id="btn-logout" type="button" class="form__submit form__submit--ghost">Cerrar sesión</button>
        </section>
      </div>

      <p id="perfil-error" class="perfil__error" hidden></p>

      {/* ── Modal de recorte de foto ──
          Aparece cuando el usuario elige una imagen para el avatar.
          Permite arrastrar y zoomear hasta dejar la porción que quiere
          dentro del círculo guía, antes de subirla al server. */}
      <dialog id="crop-modal" class="crop-modal" aria-label="Recortar foto de perfil">
        <div class="crop-modal__card">
          <h2 class="crop-modal__titulo">Recortá tu foto</h2>
          <p class="crop-modal__bajada">Arrastrá la imagen y ajustá el zoom hasta dejar la parte que querés mostrar.</p>

          <div id="crop-stage" class="crop-stage">
            <img id="crop-img" class="crop-img" alt="" />
            <svg class="crop-overlay" viewBox="0 0 320 320" aria-hidden="true">
              <defs>
                <mask id="crop-hole">
                  <rect width="320" height="320" fill="white" />
                  <circle cx="160" cy="160" r="140" fill="black" />
                </mask>
              </defs>
              <rect width="320" height="320" fill="rgba(19, 27, 61, 0.55)" mask="url(#crop-hole)" />
              <circle cx="160" cy="160" r="140" fill="none" stroke="#fff" stroke-width="2" />
            </svg>
          </div>

          <div class="crop-zoom">
            <span class="crop-zoom__icono" aria-hidden="true">−</span>
            <input type="range" id="crop-zoom" min="1" max="3" step="0.01" value="1" aria-label="Zoom" />
            <span class="crop-zoom__icono" aria-hidden="true">+</span>
          </div>

          <div class="crop-actions">
            <button type="button" id="crop-cancel" class="crop-btn crop-btn--ghost">Cancelar</button>
            <button type="button" id="crop-apply" class="crop-btn crop-btn--primary">Aplicar</button>
          </div>
        </div>
      </dialog>
    </div>
  </main>
</AulaLayout>

<script>
  import { supabase } from "../../lib/supabase";
  import { requireSession, homePorRol, type Rol } from "../../lib/auth-guard";
  import { showToast, confirmModal } from "../../lib/ui";

  const $loader = document.getElementById("perfil-loader") as HTMLElement;
  const $contenido = document.getElementById("perfil-contenido") as HTMLElement;
  const $errorBox = document.getElementById("perfil-error") as HTMLElement;
  const $volver = document.getElementById("perfil-volver") as HTMLAnchorElement;

  const $avatar = document.getElementById("p-avatar")!;
  const $avatarInput = document.getElementById("p-avatar-input") as HTMLInputElement;
  const $btnCambiarFoto = document.getElementById("btn-cambiar-foto")!;
  const $btnQuitarFoto = document.getElementById("btn-quitar-foto")!;
  const $nombre = document.getElementById("p-nombre")!;
  const $mail = document.getElementById("p-mail")!;
  const $rolBadge = document.getElementById("p-rol-badge")!;
  const $creadoEn = document.getElementById("p-creado-en")!;

  function esc(s: string | null | undefined) {
    return String(s ?? "")
      .replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;").replace(/'/g, "&#039;");
  }

  function iniciales(nombre: string) {
    return nombre.split(" ").map((n) => n[0]).join("").slice(0, 2).toUpperCase();
  }

  function formatoFechaLarga(iso: string) {
    try {
      return new Date(iso).toLocaleDateString("es-AR", { day: "numeric", month: "long", year: "numeric" });
    } catch {
      return iso;
    }
  }

  const labelRol: Record<Rol, string> = {
    alumno: "Protagonista",
    profe: "Profesor/a",
    admin: "Administrador/a",
  };

  // Mantiene los mensajes inline como fallback,
  // pero los principales ahora usan showToast() (mejor UX).
  function mostrarMsg(el: HTMLElement, mensaje: string) {
    el.textContent = mensaje;
    el.hidden = false;
    setTimeout(() => { el.hidden = true; }, 4000);
  }

  type ProfileFull = {
    id: string;
    nombre: string;
    email: string;
    rol: Rol;
    creado_en: string;
    avatar_url: string | null;
    bio: string | null;
    pais: string | null;
    ciudad: string | null;
    intereses: string[] | null;
  };

  // Lo que se permite por columna (mismos límites que el CHECK constraint de DB).
  const LIMITES = {
    bio: 280,
    pais: 40,
    ciudad: 60,
    interes: 30,
    cantidadIntereses: 10,
  };

  /** Limpia un string: trim + colapsa espacios + cap al máximo. */
  function limpiar(s: string, max: number): string {
    return s.replace(/\s+/g, " ").trim().slice(0, max);
  }

  // ===========================================================
  // ───── Cropper de avatar ─────────────────────────────────────
  // ===========================================================
  // Cuando el usuario elige una foto, abrimos un modal con la
  // imagen + un círculo guía. El usuario puede arrastrar la
  // imagen y zoomear con el slider hasta dejar la porción que
  // quiera dentro del círculo. Al aplicar, generamos un JPEG
  // 512×512 cuadrado con esa porción y la subimos a Storage.
  // El círculo del avatar lo hace después el CSS (border-radius:50%).
  //
  // Geometría del cropper:
  //   STAGE         = 320 px (lado del contenedor cuadrado).
  //   CROP_DIAMETER = 280 px (diámetro del círculo guía centrado).
  // ===========================================================
  const STAGE = 320;
  const CROP_DIAMETER = 280;
  const AVATAR_MAX_BYTES = 5 * 1024 * 1024; // 5 MB cota dura antes de procesar.

  const $cropModal = document.getElementById("crop-modal") as HTMLDialogElement;
  const $cropStage = document.getElementById("crop-stage") as HTMLElement;
  const $cropImg = document.getElementById("crop-img") as HTMLImageElement;
  const $cropZoom = document.getElementById("crop-zoom") as HTMLInputElement;
  const $cropApply = document.getElementById("crop-apply") as HTMLButtonElement;
  const $cropCancel = document.getElementById("crop-cancel") as HTMLButtonElement;

  interface CropState {
    imgW: number;
    imgH: number;
    /** Escala mínima que hace que la imagen cubra el círculo. */
    scaleMin: number;
    /** Escala efectiva = scaleMin * userScale (1..3). */
    scale: number;
    /** Offset desde el centro del stage. */
    tx: number;
    ty: number;
  }

  let cropState: CropState | null = null;
  let cropResolver: ((blob: Blob | null) => void) | null = null;

  /** Clampea tx/ty para que el círculo nunca caiga fuera de la imagen. */
  function clampOffset(s: CropState) {
    const W = s.imgW * s.scale;
    const H = s.imgH * s.scale;
    const xMax = Math.max(0, (W - CROP_DIAMETER) / 2);
    const yMax = Math.max(0, (H - CROP_DIAMETER) / 2);
    s.tx = Math.max(-xMax, Math.min(xMax, s.tx));
    s.ty = Math.max(-yMax, Math.min(yMax, s.ty));
  }

  /** Recalcula width/height/transform del img según el state. */
  function aplicarTransformCrop(s: CropState) {
    const W = s.imgW * s.scale;
    const H = s.imgH * s.scale;
    $cropImg.style.width = `${W}px`;
    $cropImg.style.height = `${H}px`;
    $cropImg.style.transform = `translate(${(STAGE - W) / 2 + s.tx}px, ${(STAGE - H) / 2 + s.ty}px)`;
  }

  /**
   * Abre el modal con la imagen cargada, devuelve un Blob recortado
   * al apretar Aplicar, o null si el usuario cancela / cierra con ESC.
   */
  function abrirCropper(file: File): Promise<Blob | null> {
    return new Promise(async (resolve) => {
      cropResolver = resolve;

      const url = URL.createObjectURL(file);
      // Esperamos que la imagen efectivamente cargue antes de mostrar el modal.
      await new Promise<void>((res, rej) => {
        $cropImg.onload = () => res();
        $cropImg.onerror = () => rej(new Error("No se pudo leer la imagen."));
        $cropImg.src = url;
      });

      const w = $cropImg.naturalWidth;
      const h = $cropImg.naturalHeight;
      const scaleMin = Math.max(CROP_DIAMETER / w, CROP_DIAMETER / h);

      cropState = { imgW: w, imgH: h, scaleMin, scale: scaleMin, tx: 0, ty: 0 };
      $cropZoom.value = "1";
      aplicarTransformCrop(cropState);
      $cropModal.showModal();
    });
  }

  /** Cierra el modal y resuelve la promesa (blob o null). */
  function cerrarCropper(blob: Blob | null) {
    if (cropResolver) {
      cropResolver(blob);
      cropResolver = null;
    }
    if ($cropModal.open) $cropModal.close();
    if ($cropImg.src.startsWith("blob:")) {
      URL.revokeObjectURL($cropImg.src);
    }
    $cropImg.removeAttribute("src");
    cropState = null;
  }

  /**
   * Genera el blob JPEG 512×512 con la porción de la imagen que está
   * dentro del círculo del cropper. El círculo lo aplica el CSS
   * cuando se renderiza el avatar (border-radius: 50%).
   */
  function generarBlobRecortado(): Promise<Blob> {
    const s = cropState;
    if (!s) return Promise.reject(new Error("No hay imagen cargada."));
    // Tamaño del crop en las coordenadas originales de la imagen.
    const sizeOrig = CROP_DIAMETER / s.scale;
    // Centro de la imagen original que cae en el centro del círculo.
    const cx = s.imgW / 2 - s.tx / s.scale;
    const cy = s.imgH / 2 - s.ty / s.scale;
    const sx = cx - sizeOrig / 2;
    const sy = cy - sizeOrig / 2;

    const canvas = document.createElement("canvas");
    canvas.width = 512;
    canvas.height = 512;
    const ctx = canvas.getContext("2d")!;
    ctx.imageSmoothingQuality = "high";
    ctx.drawImage($cropImg, sx, sy, sizeOrig, sizeOrig, 0, 0, 512, 512);

    return new Promise((resolve, reject) => {
      canvas.toBlob(
        (b) => b ? resolve(b) : reject(new Error("No se pudo procesar la imagen.")),
        "image/jpeg",
        0.9
      );
    });
  }

  // ── Handlers del cropper ──
  $cropZoom.addEventListener("input", () => {
    if (!cropState) return;
    const userScale = parseFloat($cropZoom.value);
    cropState.scale = cropState.scaleMin * userScale;
    clampOffset(cropState);
    aplicarTransformCrop(cropState);
  });

  let dragCrop = false;
  let dragCropStart = { x: 0, y: 0, tx: 0, ty: 0 };
  $cropStage.addEventListener("pointerdown", (e) => {
    if (!cropState) return;
    dragCrop = true;
    $cropStage.setPointerCapture(e.pointerId);
    dragCropStart = { x: e.clientX, y: e.clientY, tx: cropState.tx, ty: cropState.ty };
  });
  $cropStage.addEventListener("pointermove", (e) => {
    if (!dragCrop || !cropState) return;
    cropState.tx = dragCropStart.tx + (e.clientX - dragCropStart.x);
    cropState.ty = dragCropStart.ty + (e.clientY - dragCropStart.y);
    clampOffset(cropState);
    aplicarTransformCrop(cropState);
  });
  function finDrag(e: PointerEvent) {
    dragCrop = false;
    if ($cropStage.hasPointerCapture(e.pointerId)) {
      $cropStage.releasePointerCapture(e.pointerId);
    }
  }
  $cropStage.addEventListener("pointerup", finDrag);
  $cropStage.addEventListener("pointercancel", finDrag);

  $cropCancel.addEventListener("click", () => cerrarCropper(null));
  $cropApply.addEventListener("click", async () => {
    try {
      const blob = await generarBlobRecortado();
      cerrarCropper(blob);
    } catch (err) {
      const msg = err instanceof Error ? err.message : String(err);
      showToast(`Error al recortar: ${msg}`, "error");
    }
  });

  // ESC en el dialog dispara `close` nativo → tratamos como cancelar.
  $cropModal.addEventListener("close", () => {
    if (cropResolver) {
      cropResolver(null);
      cropResolver = null;
    }
  });

  /** Pinta el avatar: img si hay url, iniciales si no. */
  function renderAvatar(profile: ProfileFull) {
    if (profile.avatar_url) {
      $avatar.innerHTML = `<img src="${esc(profile.avatar_url)}" alt="Foto de perfil" class="perfil__avatar-img" />`;
      $avatar.classList.add("perfil__avatar--con-foto");
      ($btnQuitarFoto as HTMLElement).hidden = false;
    } else {
      $avatar.textContent = iniciales(profile.nombre);
      $avatar.classList.remove("perfil__avatar--con-foto");
      ($btnQuitarFoto as HTMLElement).hidden = true;
    }
  }

  async function cargar() {
    const auth = await requireSession();
    if (!auth) return;

    // Traemos profile completo.
    const { data: profile, error } = await supabase
      .from("profiles")
      .select("id, nombre, email, rol, creado_en, avatar_url, bio, pais, ciudad, intereses")
      .eq("id", auth.session.user.id)
      .single<ProfileFull>();

    if (error || !profile) {
      $loader.hidden = true;
      $errorBox.hidden = false;
      $errorBox.textContent = `Error: ${error?.message ?? "no se pudo cargar el perfil"}`;
      return;
    }

    // Render del header.
    $avatar.classList.add(`perfil__avatar--${profile.rol}`);
    renderAvatar(profile);
    $nombre.textContent = profile.nombre;
    $mail.textContent = profile.email;
    $rolBadge.textContent = labelRol[profile.rol];
    $rolBadge.classList.add(`perfil__rol-badge--${profile.rol}`);
    $creadoEn.textContent = `Cuenta creada el ${formatoFechaLarga(profile.creado_en)}.`;

    // El "← Volver" lleva al home del rol del user.
    $volver.href = homePorRol[profile.rol];

    // Pre-rellenamos los inputs del form de datos personales.
    (document.getElementById("input-nombre") as HTMLInputElement).value = profile.nombre;
    (document.getElementById("input-pais") as HTMLInputElement).value = profile.pais ?? "";
    (document.getElementById("input-ciudad") as HTMLInputElement).value = profile.ciudad ?? "";
    const $bio = document.getElementById("input-bio") as HTMLTextAreaElement;
    $bio.value = profile.bio ?? "";
    actualizarContadorBio();

    // Conectar handlers.
    enchufarFormDatos(profile);
    enchufarFormPassword();
    enchufarTogglePass();
    enchufarLogout();
    enchufarAvatar(profile);
    enchufarIntereses(profile);

    $loader.hidden = true;
    $contenido.hidden = false;
  }

  /**
   * Subida / borrado del avatar.
   *   · Click en el avatar o en "Cambiar foto" → abre el file picker.
   *   · Al elegir, procesa la imagen (resize + jpeg) y la sube al bucket
   *     "avatares" en la carpeta {userId}/.
   *   · Guarda la URL pública en profiles.avatar_url y refresca la UI.
   *   · "Quitar foto" borra el archivo y blanquea avatar_url.
   */
  function enchufarAvatar(profile: ProfileFull) {
    const elegirFoto = () => $avatarInput.click();
    $avatar.addEventListener("click", elegirFoto);
    $btnCambiarFoto.addEventListener("click", elegirFoto);

    $avatarInput.addEventListener("change", async () => {
      const file = $avatarInput.files?.[0];
      $avatarInput.value = "";
      if (!file) return;

      // Validamos el tamaño ANTES de abrir el cropper para no procesar
      // archivos absurdamente grandes.
      if (file.size > AVATAR_MAX_BYTES) {
        showToast("La imagen pesa más de 5 MB. Probá con una más liviana.", "error");
        return;
      }

      // Abrimos el cropper. Si el usuario cancela, la promesa resuelve null
      // y no hacemos nada más.
      let blob: Blob | null;
      try {
        blob = await abrirCropper(file);
      } catch (err) {
        const msg = err instanceof Error ? err.message : String(err);
        showToast(`No se pudo abrir el recortador: ${msg}`, "error");
        return;
      }
      if (!blob) return;

      try {
        // Path estable: siempre sobrescribimos avatar.jpg del usuario.
        // Le agregamos ?v=timestamp a la URL final para evitar cache.
        const path = `${profile.id}/avatar.jpg`;

        const { error: upErr } = await supabase.storage
          .from("avatares")
          .upload(path, blob, { upsert: true, contentType: "image/jpeg" });
        if (upErr) throw upErr;

        // URL pública + cache-buster.
        const { data: pub } = supabase.storage.from("avatares").getPublicUrl(path);
        const urlConVersion = `${pub.publicUrl}?v=${Date.now()}`;

        const { error: dbErr } = await supabase
          .from("profiles")
          .update({ avatar_url: urlConVersion })
          .eq("id", profile.id);
        if (dbErr) throw dbErr;

        profile.avatar_url = urlConVersion;
        renderAvatar(profile);
        showToast("Foto actualizada");
      } catch (err) {
        const msg = err instanceof Error ? err.message : String(err);
        showToast(`No se pudo actualizar la foto: ${msg}`, "error");
      }
    });

    $btnQuitarFoto.addEventListener("click", async () => {
      const ok = await confirmModal({
        titulo: "Quitar foto",
        mensaje: "¿Querés volver a mostrar tus iniciales en lugar de la foto?",
        confirmLabel: "Quitar foto",
      });
      if (!ok) return;

      try {
        // Borramos el archivo. Si falla por not-found lo ignoramos:
        // lo importante es blanquear la columna.
        await supabase.storage.from("avatares").remove([`${profile.id}/avatar.jpg`]);

        const { error: dbErr } = await supabase
          .from("profiles")
          .update({ avatar_url: null })
          .eq("id", profile.id);
        if (dbErr) throw dbErr;

        profile.avatar_url = null;
        renderAvatar(profile);
        showToast("Foto eliminada");
      } catch (err) {
        const msg = err instanceof Error ? err.message : String(err);
        showToast(`No se pudo quitar la foto: ${msg}`, "error");
      }
    });
  }

  /** Contador "X / 280" debajo del label de bio. */
  function actualizarContadorBio() {
    const $bio = document.getElementById("input-bio") as HTMLTextAreaElement;
    const $cont = document.getElementById("bio-contador") as HTMLElement;
    $cont.textContent = `${$bio.value.length} / ${LIMITES.bio}`;
  }

  function enchufarFormDatos(profile: ProfileFull) {
    const $form = document.getElementById("form-datos") as HTMLFormElement;
    const $inputNombre = document.getElementById("input-nombre") as HTMLInputElement;
    const $inputPais = document.getElementById("input-pais") as HTMLInputElement;
    const $inputCiudad = document.getElementById("input-ciudad") as HTMLInputElement;
    const $bio = document.getElementById("input-bio") as HTMLTextAreaElement;
    const $btn = $form.querySelector("button[type='submit']") as HTMLButtonElement;
    const $ok = document.getElementById("msg-datos-ok") as HTMLElement;
    const $err = document.getElementById("msg-datos-error") as HTMLElement;

    // El contador de bio se actualiza en vivo.
    $bio.addEventListener("input", actualizarContadorBio);

    $form.addEventListener("submit", async (e) => {
      e.preventDefault();
      $ok.hidden = true; $err.hidden = true;

      const nombre = limpiar($inputNombre.value, 60);
      if (nombre.length < 2) {
        showToast("El nombre tiene que tener al menos 2 caracteres.", "error");
        return;
      }
      const pais = limpiar($inputPais.value, LIMITES.pais) || null;
      const ciudad = limpiar($inputCiudad.value, LIMITES.ciudad) || null;
      const bio = $bio.value.trim().slice(0, LIMITES.bio) || null;

      $btn.disabled = true;
      $btn.textContent = "Guardando…";

      const { error } = await supabase
        .from("profiles")
        .update({ nombre, pais, ciudad, bio, intereses: profile.intereses })
        .eq("id", profile.id);

      $btn.disabled = false;
      $btn.textContent = "Guardar cambios";

      if (error) {
        showToast(`No se pudo guardar: ${error.message}`, "error");
        return;
      }

      profile.nombre = nombre;
      profile.pais = pais;
      profile.ciudad = ciudad;
      profile.bio = bio;
      $nombre.textContent = nombre;
      if (!profile.avatar_url) $avatar.textContent = iniciales(nombre);
      showToast("Datos actualizados");
    });
  }

  /**
   * Chips de intereses. El estado vive en profile.intereses; al guardar
   * datos personales se envían junto con el resto. Acá solo manejamos
   * agregar/quitar y re-render local.
   */
  function enchufarIntereses(profile: ProfileFull) {
    const $cont = document.getElementById("chips-intereses") as HTMLElement;
    const $input = document.getElementById("input-interes") as HTMLInputElement;
    if (!profile.intereses) profile.intereses = [];

    function render() {
      // Limpiar todo menos el input.
      $cont.querySelectorAll(".chips__chip").forEach((c) => c.remove());
      (profile.intereses ?? []).forEach((tag, i) => {
        const chip = document.createElement("span");
        chip.className = "chips__chip";
        chip.innerHTML = `<span>${esc(tag)}</span><button type="button" aria-label="Quitar ${esc(tag)}" data-i="${i}">×</button>`;
        $cont.insertBefore(chip, $input);
      });
      $input.placeholder = (profile.intereses ?? []).length === 0
        ? "Música, ciencia, diseño, lectura…"
        : "Sumá otro…";
    }

    function agregar(raw: string) {
      const tag = limpiar(raw, LIMITES.interes);
      if (!tag) return;
      if ((profile.intereses ?? []).length >= LIMITES.cantidadIntereses) {
        showToast(`Máximo ${LIMITES.cantidadIntereses} intereses.`, "info");
        return;
      }
      // Sin duplicados (case insensitive).
      if ((profile.intereses ?? []).some((t) => t.toLowerCase() === tag.toLowerCase())) {
        showToast("Ese interés ya está.", "info");
        return;
      }
      profile.intereses!.push(tag);
      render();
    }

    $input.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === ",") {
        e.preventDefault();
        agregar($input.value);
        $input.value = "";
      } else if (e.key === "Backspace" && $input.value === "" && (profile.intereses ?? []).length > 0) {
        // Backspace en input vacío borra el último chip.
        profile.intereses!.pop();
        render();
      }
    });

    $cont.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest("button[data-i]");
      if (!btn) return;
      const i = Number(btn.getAttribute("data-i"));
      if (!Number.isNaN(i)) {
        profile.intereses!.splice(i, 1);
        render();
      }
    });

    render();
  }

  function enchufarFormPassword() {
    const $form = document.getElementById("form-password") as HTMLFormElement;
    const $btn = $form.querySelector("button") as HTMLButtonElement;
    const $ok = document.getElementById("msg-pass-ok") as HTMLElement;
    const $err = document.getElementById("msg-pass-error") as HTMLElement;

    $form.addEventListener("submit", async (e) => {
      e.preventDefault();
      $ok.hidden = true; $err.hidden = true;

      const fd = new FormData($form);
      const pass = String(fd.get("pass"));
      const pass2 = String(fd.get("pass2"));

      if (pass.length < 8) {
        showToast("La contraseña tiene que tener al menos 8 caracteres.", "error");
        return;
      }
      if (pass !== pass2) {
        showToast("Las dos contraseñas no coinciden.", "error");
        return;
      }

      $btn.disabled = true;
      $btn.textContent = "Cambiando…";

      const { error } = await supabase.auth.updateUser({ password: pass });

      $btn.disabled = false;
      $btn.textContent = "Cambiar contraseña";

      if (error) {
        showToast(`No se pudo cambiar: ${error.message}`, "error");
        return;
      }

      showToast("Contraseña actualizada.");
      $form.reset();
    });
  }

  /**
   * Ojito mostrar/ocultar contraseña. Cada botón [data-toggle-pass]
   * está dentro de un .form__pass-wrap junto a un <input type="password">.
   * Usamos toggleAttribute porque en <svg> la propiedad .hidden no se
   * refleja como atributo y el selector CSS [hidden] no engancha.
   */
  function enchufarTogglePass() {
    document.querySelectorAll<HTMLButtonElement>("[data-toggle-pass]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const wrap = btn.closest(".form__pass-wrap");
        const input = wrap?.querySelector("input") as HTMLInputElement | null;
        if (!input) return;
        const yaVisible = input.type === "text";
        input.type = yaVisible ? "password" : "text";
        const ahoraVisible = !yaVisible;
        btn.setAttribute("aria-pressed", String(ahoraVisible));
        btn.setAttribute("aria-label", ahoraVisible ? "Ocultar contraseña" : "Mostrar contraseña");
        btn.querySelector(".icono-ojo")?.toggleAttribute("hidden", ahoraVisible);
        btn.querySelector(".icono-ojo-tachado")?.toggleAttribute("hidden", !ahoraVisible);
      });
    });
  }

  function enchufarLogout() {
    const $btn = document.getElementById("btn-logout") as HTMLButtonElement;
    $btn.addEventListener("click", async () => {
      const ok = await confirmModal({
        titulo: "Cerrar sesión",
        mensaje: "¿Querés salir del aula?",
        confirmLabel: "Cerrar sesión",
      });
      if (!ok) return;
      await supabase.auth.signOut();
      window.location.href = "/aula/login";
    });
  }

  cargar().catch((err) => {
    console.error("[perfil]", err);
    $loader.hidden = true;
    $errorBox.hidden = false;
    $errorBox.textContent = `Error inesperado: ${err instanceof Error ? err.message : String(err)}`;
  });
</script>

