---
/*
  /aula/test-conexion — TEMPORAL.
  Prueba que las credenciales de Supabase funcionen.
  Cuando confirmemos que conecta, esta página se borra.
*/

import AulaLayout from "../../layouts/AulaLayout.astro";
import { supabase } from "../../lib/supabase";

// Probamos la conexión más básica: leer la sesión actual.
// Si las credenciales son válidas devuelve { session: null } (no hay user logueado).
// Si las credenciales están mal, devuelve un error.
let resultado: { ok: boolean; mensaje: string; detalle?: string };

try {
  const { data, error } = await supabase.auth.getSession();
  if (error) {
    resultado = {
      ok: false,
      mensaje: "Error al consultar la sesión",
      detalle: error.message,
    };
  } else {
    resultado = {
      ok: true,
      mensaje: "Conexión OK · Las credenciales son válidas.",
      detalle: data.session
        ? `Sesión activa: ${data.session.user.email}`
        : "Sin sesión activa (esperado: todavía no hay login).",
    };
  }
} catch (err) {
  resultado = {
    ok: false,
    mensaje: "No se pudo conectar a Supabase",
    detalle: err instanceof Error ? err.message : String(err),
  };
}

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
---

<AulaLayout title="Test de conexión · Vocational Lab" nav={false}>
  <main class="test">
    <div class="test__card">
      <h1>Test de conexión a Supabase</h1>

      <p class="test__url">
        <strong>URL del proyecto:</strong><br />
        <code>{supabaseUrl}</code>
      </p>

      <div class={`test__resultado ${resultado.ok ? "is-ok" : "is-error"}`}>
        <span class="test__estado">
          {resultado.ok ? "✓" : "✗"} {resultado.mensaje}
        </span>
        {resultado.detalle && <p class="test__detalle">{resultado.detalle}</p>}
      </div>

      <p class="test__nota">
        Esta es una página temporal. Cuando confirmemos que la conexión
        funciona se borra y avanzamos con crear las tablas.
      </p>

      <a href="/aula/login" class="test__volver">← Volver al login</a>
    </div>
  </main>
</AulaLayout>

<style>
  .test {
    flex: 1;
    display: grid;
    place-items: center;
    padding: 3rem 1.5rem;
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-surface) 100%);
  }
  .test__card {
    width: 100%;
    max-width: 560px;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    padding: 2.5rem 2rem;
  }
  .test__card h1 {
    font-size: 1.6rem;
    margin: 0 0 1.5rem;
  }
  .test__url {
    background: var(--color-bg);
    padding: 0.9rem 1rem;
    border-radius: var(--radius-sm);
    font-size: 0.88rem;
    margin: 0 0 1.5rem;
    color: var(--color-ink-soft);
    line-height: 1.5;
  }
  .test__url code {
    font-family: ui-monospace, "Cascadia Code", Menlo, monospace;
    color: var(--color-ink);
    word-break: break-all;
  }
  .test__resultado {
    padding: 1.2rem 1.3rem;
    border-radius: var(--radius-sm);
    margin-bottom: 1.5rem;
  }
  .test__resultado.is-ok {
    background: rgba(36, 58, 130, 0.08);
    border-left: 3px solid var(--color-deep);
  }
  .test__resultado.is-error {
    background: rgba(216, 85, 42, 0.1);
    border-left: 3px solid var(--color-accent);
  }
  .test__estado {
    display: block;
    font-weight: 500;
    margin-bottom: 0.4rem;
  }
  .test__detalle {
    margin: 0;
    color: var(--color-ink-soft);
    font-size: 0.9rem;
  }
  .test__nota {
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    font-style: italic;
    margin: 0 0 1.5rem;
  }
  .test__volver {
    font-size: 0.9rem;
    color: var(--color-ink-soft);
  }
  .test__volver:hover { color: var(--color-ink); }
</style>
