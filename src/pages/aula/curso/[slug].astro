---
/*
  /aula/curso/[slug] — vista de un curso.
  Muestra el detalle del curso: módulos, archivos para descargar
  y tareas para entregar / corregidas / pendientes.

  Datos: por ahora vienen del archivo cursos-demo.ts. Cuando haya
  backend, esta página va a ir a buscar el curso a Supabase.
*/

import AulaLayout from "../../../layouts/AulaLayout.astro";
import { cursosDemo, obtenerCurso } from "../../../data/cursos-demo";

export function getStaticPaths() {
  return cursosDemo.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const curso = obtenerCurso(slug!);

// Si el slug no existe, redirigimos a mis-cursos.
if (!curso) {
  return Astro.redirect("/aula/mis-cursos");
}

// Etiquetas legibles por estado de tarea
const estadoLabels: Record<string, string> = {
  pendiente: "Pendiente de entrega",
  entregada: "Entregada — esperando corrección",
  corregida: "Corregida",
};
---

<AulaLayout title={`${curso.titulo} · Aula Vocational Lab`}>
  <main class="curso">
    <div class="container">
      {/* Breadcrumb mínimo */}
      <a href="/aula/mis-cursos" class="curso__volver">← Volver a mis cursos</a>

      <header class="curso__head">
        <span class="curso__periodo">{curso.periodo}</span>
        <h1 class="curso__titulo">{curso.titulo}</h1>
        <p class="curso__resumen">{curso.resumen}</p>
        <p class="curso__profe">Con <strong>{curso.profesor}</strong></p>

        <div class="curso__progreso">
          <div class="curso__barra">
            <span style={`width: ${curso.progreso}%`}></span>
          </div>
          <span class="curso__porcentaje">{curso.progreso}% completado</span>
        </div>
      </header>

      <section class="curso__modulos">
        {curso.modulos.map((m) => (
          <article class="modulo">
            <header class="modulo__head">
              <span class="modulo__numero">Módulo {m.numero}</span>
              <h2 class="modulo__titulo">{m.titulo}</h2>
              <p class="modulo__descripcion">{m.descripcion}</p>
            </header>

            <div class="modulo__bloques">
              {/* Bloque 1: archivos */}
              <div class="bloque">
                <h3 class="bloque__titulo">Material</h3>
                <ul class="archivos">
                  {m.archivos.map((a) => (
                    <li class="archivo">
                      <span class={`archivo__icono archivo__icono--${a.tipo}`} aria-hidden="true">
                        {a.tipo === "pdf" && "📄"}
                        {a.tipo === "video" && "▶︎"}
                        {a.tipo === "audio" && "♪"}
                        {a.tipo === "link" && "↗"}
                      </span>
                      <div class="archivo__cuerpo">
                        <span class="archivo__nombre">{a.nombre}</span>
                        <span class="archivo__meta">{a.peso}</span>
                      </div>
                      <a href="#" class="archivo__btn">Descargar</a>
                    </li>
                  ))}
                </ul>
              </div>

              {/* Bloque 2: tarea (si hay) */}
              {m.tarea && (
                <div class="bloque">
                  <h3 class="bloque__titulo">Tarea</h3>
                  <div class={`tarea tarea--${m.tarea.estado}`}>
                    <div class="tarea__head">
                      <h4 class="tarea__titulo">{m.tarea.titulo}</h4>
                      <span class="tarea__estado">{estadoLabels[m.tarea.estado]}</span>
                    </div>
                    <p class="tarea__consigna">{m.tarea.consigna}</p>
                    <p class="tarea__fecha">
                      <strong>Entrega:</strong> {m.tarea.fechaEntrega}
                    </p>

                    {m.tarea.estado === "pendiente" && (
                      <div class="tarea__accion">
                        <label class="tarea__upload">
                          <input type="file" />
                          <span class="tarea__btn">Subir entrega</span>
                        </label>
                      </div>
                    )}

                    {m.tarea.estado === "entregada" && (
                      <p class="tarea__nota">
                        Tu entrega está en camino. Vas a recibir una devolución por mail
                        cuando esté corregida.
                      </p>
                    )}

                    {m.tarea.estado === "corregida" && m.tarea.devolucion && (
                      <div class="tarea__devolucion">
                        <p class="tarea__devolucion-nota">
                          <strong>Nota:</strong> {m.tarea.devolucion.nota}
                        </p>
                        <blockquote class="tarea__devolucion-comentario">
                          “{m.tarea.devolucion.comentario}”
                        </blockquote>
                      </div>
                    )}
                  </div>
                </div>
              )}
            </div>
          </article>
        ))}
      </section>
    </div>
  </main>
</AulaLayout>

<style>
  .curso {
    flex: 1;
    padding: clamp(2rem, 5vw, 3rem) 0 5rem;
  }

  .curso__volver {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--color-ink-soft);
    margin-bottom: 1.5rem;
    transition: color 0.15s ease;
  }
  .curso__volver:hover { color: var(--color-ink); }

  /* ===== Encabezado del curso ===== */
  .curso__head {
    max-width: 780px;
    margin-bottom: 3.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--color-line);
  }
  .curso__periodo {
    display: inline-block;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: 0.9rem;
  }
  .curso__titulo {
    font-size: clamp(2rem, 4.5vw, 2.8rem);
    margin: 0 0 0.8rem;
  }
  .curso__resumen {
    color: var(--color-ink-soft);
    font-size: 1.05rem;
    margin: 0 0 0.6rem;
    max-width: 60ch;
  }
  .curso__profe {
    margin: 0 0 1.5rem;
    color: var(--color-ink-soft);
    font-size: 0.95rem;
  }
  .curso__profe strong { color: var(--color-ink); font-weight: 500; }

  .curso__progreso {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    max-width: 480px;
  }
  .curso__barra {
    flex: 1;
    height: 8px;
    background: var(--color-line);
    border-radius: 99px;
    overflow: hidden;
  }
  .curso__barra span {
    display: block;
    height: 100%;
    background: var(--color-accent);
    border-radius: 99px;
  }
  .curso__porcentaje {
    font-size: 0.88rem;
    color: var(--color-ink-soft);
  }

  /* ===== Módulos ===== */
  .curso__modulos {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .modulo {
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    padding: 2rem;
  }

  .modulo__head { margin-bottom: 1.8rem; }
  .modulo__numero {
    display: inline-block;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 500;
    margin-bottom: 0.6rem;
  }
  .modulo__titulo {
    font-size: 1.5rem;
    margin: 0 0 0.6rem;
  }
  .modulo__descripcion {
    color: var(--color-ink-soft);
    margin: 0;
    max-width: 60ch;
  }

  .modulo__bloques {
    display: grid;
    gap: 2rem;
  }
  @media (min-width: 880px) {
    .modulo__bloques {
      grid-template-columns: 1fr 1fr;
    }
  }

  .bloque__titulo {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin: 0 0 0.9rem;
  }

  /* ===== Lista de archivos ===== */
  .archivos {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .archivo {
    display: grid;
    grid-template-columns: 32px 1fr auto;
    align-items: center;
    gap: 0.8rem;
    padding: 0.7rem 0.9rem;
    background: var(--color-bg);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
  }
  .archivo__icono {
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-sm);
    background: #fff;
    font-size: 1rem;
    color: var(--color-ink-soft);
  }
  .archivo__cuerpo {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }
  .archivo__nombre {
    font-size: 0.95rem;
    color: var(--color-ink);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .archivo__meta {
    font-size: 0.78rem;
    color: var(--color-ink-muted);
  }
  .archivo__btn {
    font-size: 0.85rem;
    color: var(--color-deep);
    font-weight: 500;
  }
  .archivo__btn:hover { color: var(--color-accent); }

  /* ===== Tarea ===== */
  .tarea {
    padding: 1.1rem 1.2rem;
    background: var(--color-bg);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    border-left: 3px solid var(--color-ink-muted);
  }
  .tarea--pendiente { border-left-color: var(--color-accent); }
  .tarea--entregada { border-left-color: var(--color-deep); }
  .tarea--corregida { border-left-color: var(--color-gold); }

  .tarea__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }
  .tarea__titulo { font-size: 1.05rem; margin: 0; }
  .tarea__estado {
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    white-space: nowrap;
  }
  .tarea__consigna {
    margin: 0 0 0.7rem;
    color: var(--color-ink-soft);
    font-size: 0.95rem;
  }
  .tarea__fecha {
    margin: 0 0 0.9rem;
    font-size: 0.88rem;
    color: var(--color-ink-soft);
  }
  .tarea__fecha strong { color: var(--color-ink); font-weight: 500; }

  /* Acción "Subir entrega" */
  .tarea__upload input { display: none; }
  .tarea__btn {
    display: inline-block;
    padding: 0.55rem 1rem;
    background: var(--color-accent);
    color: #fff;
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .tarea__btn:hover { background: var(--color-accent-dark); }

  .tarea__nota {
    margin: 0;
    color: var(--color-ink-soft);
    font-size: 0.9rem;
    font-style: italic;
  }

  /* Devolución del profe */
  .tarea__devolucion { display: flex; flex-direction: column; gap: 0.5rem; }
  .tarea__devolucion-nota { margin: 0; font-size: 0.95rem; }
  .tarea__devolucion-nota strong { color: var(--color-ink); font-weight: 500; }
  .tarea__devolucion-comentario {
    margin: 0;
    padding: 0.75rem 1rem;
    background: #fff;
    border-left: 2px solid var(--color-gold);
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-ink);
    line-height: 1.5;
  }
</style>
