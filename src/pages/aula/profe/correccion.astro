---
/*
  /aula/profe/correccion?id=ENTREGA_ID — pantalla para CORREGIR una entrega.
  ---
  Muestra los datos del alumno, la consigna, el archivo entregado y
  un form para dar nota + comentario. Submit hace UPDATE en entregas.
*/

import AulaLayout from "../../../layouts/AulaLayout.astro";
---

<AulaLayout title="Corrección · Vocational Lab" rol="profe">
  <main class="correccion">
    <div class="container">
      <a href="/aula/profe/entregas" class="correccion__volver">← Volver a entregas</a>

      <div id="correc-loader" class="correccion__loader">Cargando…</div>

      <div id="correc-contenido" hidden>
        <header class="correccion__head">
          <span class="correccion__eyebrow">Corrección de entrega</span>
          <h1 class="correccion__titulo" id="c-tarea-titulo"></h1>
          <p class="correccion__meta" id="c-curso-meta"></p>
        </header>

        <div class="correccion__grid">
          <section class="bloque">
            <h2 class="bloque__titulo">Protagonista</h2>
            <div class="alumno-card">
              <div class="alumno-card__avatar" id="c-alumno-iniciales"></div>
              <div>
                <span class="alumno-card__nombre" id="c-alumno-nombre"></span>
                <span class="alumno-card__mail" id="c-alumno-mail"></span>
              </div>
            </div>

            <h2 class="bloque__titulo">Consigna</h2>
            <p class="consigna" id="c-consigna"></p>
            <p class="consigna-meta" id="c-fechas"></p>

            <h2 class="bloque__titulo">Archivo entregado</h2>
            <div id="c-archivo"></div>
          </section>

          <section class="bloque bloque--accion">
            <h2 class="bloque__titulo">Devolución</h2>
            <div id="c-form-wrap"></div>
          </section>
        </div>
      </div>

      <div id="correc-error" class="correccion__error" hidden></div>
    </div>
  </main>
</AulaLayout>

<script>
  import { supabase } from "../../../lib/supabase";
  import { requireRol, requireSession } from "../../../lib/auth-guard";

  const $loader = document.getElementById("correc-loader") as HTMLElement;
  const $contenido = document.getElementById("correc-contenido") as HTMLElement;
  const $errorBox = document.getElementById("correc-error") as HTMLElement;

  const $tareaTitulo = document.getElementById("c-tarea-titulo")!;
  const $cursoMeta = document.getElementById("c-curso-meta")!;
  const $alumnoIni = document.getElementById("c-alumno-iniciales")!;
  const $alumnoNombre = document.getElementById("c-alumno-nombre")!;
  const $alumnoMail = document.getElementById("c-alumno-mail")!;
  const $consigna = document.getElementById("c-consigna")!;
  const $fechas = document.getElementById("c-fechas")!;
  const $archivo = document.getElementById("c-archivo")!;
  const $formWrap = document.getElementById("c-form-wrap")!;

  function esc(s: string | null | undefined) {
    return String(s ?? "")
      .replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;").replace(/'/g, "&#039;");
  }

  function mostrarError(msg: string) {
    $loader.hidden = true;
    $contenido.hidden = true;
    $errorBox.hidden = false;
    $errorBox.textContent = msg;
  }

  function iniciales(nombre: string) {
    return nombre.split(" ").map((n) => n[0]).join("").slice(0, 2).toUpperCase();
  }

  function formatoFecha(iso: string) {
    try {
      return new Date(iso).toLocaleDateString("es-AR", { day: "numeric", month: "long", year: "numeric" });
    } catch {
      return iso;
    }
  }

  type EntregaCompleta = {
    id: string;
    alumno_id: string;
    storage_path: string;
    archivo_nombre: string;
    enviada_en: string;
    nota: string | null;
    comentario: string | null;
    corregida_en: string | null;
    profiles: { id: string; nombre: string } | null;
    tareas: {
      id: string;
      titulo: string;
      consigna: string;
      fecha_entrega: string | null;
      modulos: { numero: number; cursos: { titulo: string } | null } | null;
    } | null;
  };

  async function cargar() {
    const auth = await requireRol(["profe", "admin"]);
    if (!auth) return;

    const id = new URLSearchParams(window.location.search).get("id");
    if (!id) {
      mostrarError("Falta el parámetro 'id' en la URL.");
      return;
    }

    // 1. Cargar entrega con datos del alumno y la tarea.
    const { data, error } = await supabase
      .from("entregas")
      .select(`
        id, alumno_id, storage_path, archivo_nombre, enviada_en,
        nota, comentario, corregida_en,
        profiles!entregas_alumno_id_fkey (id, nombre, avatar_url),
        tareas (
          id, titulo, consigna, fecha_entrega,
          modulos (numero, cursos (titulo))
        )
      `)
      .eq("id", id)
      .maybeSingle();

    if (error) {
      mostrarError(`Error al cargar la entrega: ${error.message}`);
      return;
    }
    if (!data) {
      mostrarError("No encontramos esa entrega (o no tienes permiso para verla).");
      return;
    }

    const entrega = data as unknown as EntregaCompleta;

    // 2. Email del alumno (no está en profiles, lo traemos por separado).
    const { data: userInfo } = await supabase.auth.admin.getUserById?.(entrega.alumno_id) ?? { data: null };
    // ⬆️ Esto no funciona desde el cliente. En su lugar, dejamos el mail vacío
    // o sumamos email a profiles más adelante. Por ahora mostramos solo el nombre.
    void userInfo;

    // 3. URL firmada para descargar el archivo (60 segundos).
    const { data: signed } = await supabase.storage
      .from("entregas-alumnos")
      .createSignedUrl(entrega.storage_path, 60);

    // 4. Render.
    const tarea = entrega.tareas;
    const alumno = entrega.profiles;
    const modulo = tarea?.modulos;
    const curso = modulo?.cursos;

    $tareaTitulo.textContent = tarea?.titulo ?? "(tarea)";
    $cursoMeta.textContent = `${curso?.titulo ?? ""} · Módulo ${modulo?.numero ?? "?"}`;
    // Avatar: foto si el protagonista subió una; iniciales si no.
    const avatarUrl = (alumno as { avatar_url?: string | null } | undefined)?.avatar_url;
    if (avatarUrl) {
      $alumnoIni.innerHTML = `<img src="${esc(avatarUrl)}" alt="" />`;
      $alumnoIni.classList.add("alumno-card__avatar--con-foto");
    } else {
      $alumnoIni.textContent = iniciales(alumno?.nombre ?? "?");
      $alumnoIni.classList.remove("alumno-card__avatar--con-foto");
    }
    $alumnoNombre.textContent = alumno?.nombre ?? "(protagonista)";
    $alumnoMail.textContent = ""; // mail no disponible desde el cliente

    $consigna.textContent = tarea?.consigna ?? "(sin consigna)";
    $fechas.innerHTML = `
      <strong>Entrega original:</strong> ${esc(tarea?.fecha_entrega ? formatoFecha(tarea.fecha_entrega) : "—")}<br />
      <strong>Subida el:</strong> ${esc(formatoFecha(entrega.enviada_en))}
    `;

    const urlDescarga = signed?.signedUrl ?? "#";
    $archivo.innerHTML = `
      <a href="${esc(urlDescarga)}" target="_blank" rel="noopener" class="archivo-entrega">
        <span class="archivo-entrega__icono" aria-hidden="true">📄</span>
        <span class="archivo-entrega__nombre">${esc(entrega.archivo_nombre)}</span>
        <span class="archivo-entrega__cta">Descargar</span>
      </a>
    `;

    if (entrega.corregida_en) {
      $formWrap.innerHTML = `
        <div class="ya-corregida">
          <p class="ya-corregida__label">Ya corregida</p>
          <p class="ya-corregida__nota"><strong>Nota:</strong> ${esc(entrega.nota)}</p>
          <blockquote class="ya-corregida__comentario">"${esc(entrega.comentario)}"</blockquote>
          <button id="editar-correccion" type="button" class="form-devolucion__submit form-devolucion__submit--ghost">Editar devolución</button>
        </div>
      `;
      document.getElementById("editar-correccion")?.addEventListener("click", () => {
        renderForm(entrega);
      });
    } else {
      renderForm(entrega);
    }

    $loader.hidden = true;
    $contenido.hidden = false;
  }

  function renderForm(entrega: EntregaCompleta) {
    $formWrap.innerHTML = `
      <form id="form-devolucion" class="form-devolucion">
        <label class="form-devolucion__label">
          <span>Nota</span>
          <select name="nota" required>
            <option value="">Elegí una nota</option>
            <option ${entrega.nota === "Excelente" ? "selected" : ""}>Excelente</option>
            <option ${entrega.nota === "Muy bien" ? "selected" : ""}>Muy bien</option>
            <option ${entrega.nota === "Bien" ? "selected" : ""}>Bien</option>
            <option ${entrega.nota === "A revisar" ? "selected" : ""}>A revisar</option>
          </select>
        </label>
        <label class="form-devolucion__label">
          <span>Comentario para el protagonista</span>
          <textarea name="comentario" rows="8" required placeholder="Escribí tu devolución con calma — el protagonista la va a leer con atención.">${esc(entrega.comentario ?? "")}</textarea>
        </label>
        <button type="submit" id="submit-correccion" class="form-devolucion__submit">Enviar devolución</button>
        <p id="form-error" class="form-devolucion__error" hidden></p>
      </form>
    `;

    const $form = document.getElementById("form-devolucion") as HTMLFormElement;
    const $submit = document.getElementById("submit-correccion") as HTMLButtonElement;
    const $error = document.getElementById("form-error") as HTMLElement;

    $form.addEventListener("submit", async (e) => {
      e.preventDefault();
      $error.hidden = true;
      $submit.disabled = true;
      $submit.textContent = "Guardando…";

      const fd = new FormData($form);
      const nota = String(fd.get("nota"));
      const comentario = String(fd.get("comentario"));

      const auth = await requireSession();
      if (!auth) return;

      const { error: errUpdate } = await supabase
        .from("entregas")
        .update({
          nota,
          comentario,
          corregida_en: new Date().toISOString(),
          corregida_por: auth.session.user.id,
        })
        .eq("id", entrega.id);

      if (errUpdate) {
        $error.textContent = `Error: ${errUpdate.message}`;
        $error.hidden = false;
        $submit.disabled = false;
        $submit.textContent = "Enviar devolución";
        return;
      }

      window.location.href = "/aula/profe/entregas";
    });
  }

  cargar().catch((err) => {
    console.error("[correccion]", err);
    mostrarError(`Error inesperado: ${err instanceof Error ? err.message : String(err)}`);
  });
</script>

<style>
  .correccion { flex: 1; padding: clamp(2rem, 5vw, 3rem) 0 5rem; }
  .correccion__loader, .correccion__error {
    color: var(--color-ink-soft);
    font-style: italic;
    padding: 2rem 0;
  }
  .correccion__error { color: var(--color-accent); font-style: normal; }

  .correccion__volver {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--color-ink-soft);
    margin-bottom: 1.5rem;
  }
  .correccion__volver:hover { color: var(--color-ink); }

  .correccion__head {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-line);
  }
  .correccion__eyebrow {
    display: inline-block;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-deep);
    font-weight: 500;
    margin-bottom: 0.9rem;
  }
  .correccion__titulo { font-size: clamp(1.8rem, 4vw, 2.4rem); margin: 0 0 0.6rem; }
  .correccion__meta { color: var(--color-ink-soft); margin: 0; }

  .correccion__grid { display: grid; gap: 1.5rem; }
  @media (min-width: 900px) { .correccion__grid { grid-template-columns: 1fr 1fr; } }

  :global(.bloque) {
    padding: 1.8rem;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
  }
  :global(.bloque--accion) { border-left: 3px solid var(--color-deep); }
  :global(.bloque__titulo) {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin: 0 0 0.8rem;
  }
  :global(.bloque__titulo + .bloque__titulo),
  :global(.bloque__titulo:not(:first-child)) {
    margin-top: 1.6rem;
  }

  :global(.alumno-card) {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.8rem;
    background: var(--color-bg);
    border-radius: var(--radius-sm);
  }
  :global(.alumno-card__avatar) {
    display: grid; place-items: center;
    width: 44px; height: 44px; border-radius: 50%;
    background: var(--color-deep);
    color: #fff;
    font-weight: 500;
    overflow: hidden;
  }
  :global(.alumno-card__avatar--con-foto) { background: transparent; }
  :global(.alumno-card__avatar img) { width: 100%; height: 100%; object-fit: cover; display: block; }
  :global(.alumno-card__nombre) { display: block; font-weight: 500; }
  :global(.alumno-card__mail) {
    display: block;
    font-size: 0.85rem;
    color: var(--color-ink-muted);
  }

  :global(.consigna) { margin: 0 0 0.8rem; color: var(--color-ink-soft); }
  :global(.consigna-meta) { margin: 0; font-size: 0.88rem; color: var(--color-ink-soft); }
  :global(.consigna-meta strong) { color: var(--color-ink); font-weight: 500; }

  :global(.archivo-entrega) {
    display: grid;
    grid-template-columns: 36px 1fr auto;
    align-items: center;
    gap: 0.8rem;
    padding: 0.8rem 1rem;
    background: var(--color-bg);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    color: var(--color-ink);
  }
  :global(.archivo-entrega__icono) {
    display: grid; place-items: center;
    width: 36px; height: 36px;
    border-radius: var(--radius-sm);
    background: #fff;
  }
  :global(.archivo-entrega__nombre) { font-size: 0.95rem; }
  :global(.archivo-entrega__cta) {
    font-size: 0.85rem;
    color: var(--color-deep);
    font-weight: 500;
  }

  :global(.form-devolucion) {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  :global(.form-devolucion__label) {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.85rem;
    color: var(--color-ink-soft);
    font-weight: 500;
  }
  :global(.form-devolucion__label select),
  :global(.form-devolucion__label textarea) {
    font-family: inherit;
    font-size: 1rem;
    padding: 0.7rem 0.9rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    color: var(--color-ink);
    resize: vertical;
  }
  :global(.form-devolucion__label select:focus),
  :global(.form-devolucion__label textarea:focus) {
    outline: none;
    border-color: var(--color-deep);
    background: #fff;
  }
  :global(.form-devolucion__submit) {
    padding: 0.9rem 1rem;
    border: 0;
    border-radius: var(--radius-sm);
    background: var(--color-deep);
    color: #fff;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s ease;
  }
  :global(.form-devolucion__submit:hover:not(:disabled)) { background: #1a2c64; }
  :global(.form-devolucion__submit:disabled) { opacity: 0.7; cursor: wait; }
  :global(.form-devolucion__submit--ghost) {
    background: transparent;
    color: var(--color-deep);
    border: 1px solid var(--color-deep);
  }
  :global(.form-devolucion__submit--ghost:hover) {
    background: var(--color-deep);
    color: #fff;
  }
  :global(.form-devolucion__error) {
    margin: 0;
    padding: 0.6rem 0.8rem;
    background: rgba(216, 85, 42, 0.1);
    border-left: 3px solid var(--color-accent);
    color: var(--color-accent);
    font-size: 0.88rem;
    border-radius: var(--radius-sm);
  }

  :global(.ya-corregida) {
    background: rgba(201, 162, 76, 0.12);
    border: 1px solid rgba(201, 162, 76, 0.4);
    border-radius: var(--radius-sm);
    padding: 1.2rem;
  }
  :global(.ya-corregida__label) {
    margin: 0 0 0.6rem;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #7a5f1f;
    font-weight: 500;
  }
  :global(.ya-corregida__nota) { margin: 0 0 0.6rem; }
  :global(.ya-corregida__nota strong) { font-weight: 500; }
  :global(.ya-corregida__comentario) {
    margin: 0 0 1rem;
    padding: 0.7rem 1rem;
    background: #fff;
    border-left: 2px solid var(--color-gold);
    font-family: var(--font-serif);
    font-style: italic;
    line-height: 1.5;
  }
</style>
