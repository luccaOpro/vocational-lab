---
/*
  /aula/profe/entregas — lista TODAS las entregas (pendientes + corregidas).
  Permite filtrar visualmente por estado y hacer click para corregir.
*/

import AulaLayout from "../../../../layouts/AulaLayout.astro";
import {
  entregasDemo,
  profeDemo,
  obtenerAlumno,
  obtenerCurso,
} from "../../../../data/cursos-demo";

// Filtramos a los cursos del profe.
const entregas = entregasDemo.filter((e) => profeDemo.cursos.includes(e.cursoSlug));
const pendientes = entregas.filter((e) => e.estado === "pendiente");
const corregidas = entregas.filter((e) => e.estado === "corregida");
---

<AulaLayout title="Entregas · Profe · Vocational Lab" rol="profe">
  <main class="entregasp">
    <div class="container">
      <header class="entregasp__head">
        <p class="entregasp__eyebrow">Profe</p>
        <h1 class="entregasp__titulo">Entregas</h1>
        <p class="entregasp__bajada">
          {pendientes.length} pendiente{pendientes.length === 1 ? "" : "s"} · {corregidas.length} corregida{corregidas.length === 1 ? "" : "s"}
        </p>
      </header>

      {/* Pendientes */}
      <section class="entregasp__seccion">
        <h2 class="entregasp__seccion-titulo">Pendientes de corregir</h2>
        {pendientes.length === 0 ? (
          <p class="entregasp__vacio">Nada pendiente. 🎯</p>
        ) : (
          <ul class="lista">
            {pendientes.map((e) => {
              const a = obtenerAlumno(e.alumnoId);
              const c = obtenerCurso(e.cursoSlug);
              const m = c?.modulos.find((mm) => mm.numero === e.moduloNumero);
              return (
                <li class="item">
                  <div class="item__cuerpo">
                    <span class="item__alumno">{a?.nombre}</span>
                    <span class="item__tarea">{m?.tarea?.titulo}</span>
                    <span class="item__meta">{c?.titulo} · Módulo {e.moduloNumero} · Entregada el {e.enviadaEl}</span>
                  </div>
                  <a href={`/aula/profe/entregas/${e.id}`} class="item__cta item__cta--primary">Corregir →</a>
                </li>
              );
            })}
          </ul>
        )}
      </section>

      {/* Corregidas */}
      <section class="entregasp__seccion">
        <h2 class="entregasp__seccion-titulo">Ya corregidas</h2>
        {corregidas.length === 0 ? (
          <p class="entregasp__vacio">Todavía no corregiste ninguna.</p>
        ) : (
          <ul class="lista">
            {corregidas.map((e) => {
              const a = obtenerAlumno(e.alumnoId);
              const c = obtenerCurso(e.cursoSlug);
              const m = c?.modulos.find((mm) => mm.numero === e.moduloNumero);
              return (
                <li class="item item--ok">
                  <div class="item__cuerpo">
                    <span class="item__alumno">{a?.nombre}</span>
                    <span class="item__tarea">{m?.tarea?.titulo}</span>
                    <span class="item__meta">{c?.titulo} · Nota: <strong>{e.devolucion?.nota}</strong></span>
                  </div>
                  <a href={`/aula/profe/entregas/${e.id}`} class="item__cta">Ver →</a>
                </li>
              );
            })}
          </ul>
        )}
      </section>
    </div>
  </main>
</AulaLayout>

<style>
  .entregasp { flex: 1; padding: clamp(2.5rem, 6vw, 4rem) 0 5rem; }
  .entregasp__head { max-width: 720px; margin-bottom: 2.5rem; }
  .entregasp__eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-deep);
    font-weight: 500;
    margin: 0 0 0.9rem;
  }
  .entregasp__titulo {
    font-size: clamp(2rem, 4.5vw, 2.6rem);
    margin: 0 0 0.6rem;
  }
  .entregasp__bajada { color: var(--color-ink-soft); margin: 0; }

  .entregasp__seccion { margin-bottom: 3rem; }
  .entregasp__seccion-titulo {
    font-size: 1.25rem;
    margin: 0 0 1.2rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-line);
  }
  .entregasp__vacio { color: var(--color-ink-soft); font-style: italic; margin: 0; }

  .lista { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.2rem;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
  }
  .item--ok { opacity: 0.75; }
  .item__cuerpo { display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; }
  .item__alumno { font-weight: 500; }
  .item__tarea { font-size: 0.95rem; }
  .item__meta { font-size: 0.82rem; color: var(--color-ink-muted); }
  .item__meta strong { color: var(--color-ink); font-weight: 500; }

  .item__cta {
    padding: 0.5rem 0.95rem;
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-deep);
    border: 1px solid var(--color-line);
    white-space: nowrap;
  }
  .item__cta--primary {
    background: var(--color-deep);
    color: #fff;
    border-color: var(--color-deep);
  }
  .item__cta:hover { background: var(--color-bg); }
  .item__cta--primary:hover { background: #1a2c64; }

  @media (max-width: 600px) {
    .item { flex-direction: column; align-items: flex-start; }
    .item__cta { align-self: stretch; text-align: center; }
  }
</style>
