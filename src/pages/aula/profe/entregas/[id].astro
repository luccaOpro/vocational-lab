---
/*
  /aula/profe/entregas/[id] — pantalla para CORREGIR una entrega.
  ---
  Muestra:
   · datos del alumno
   · la consigna original de la tarea
   · el archivo que subió el alumno
   · un form para dar nota + comentario
  El "Enviar devolución" todavía no guarda nada (es maqueta).
*/

import AulaLayout from "../../../../layouts/AulaLayout.astro";
import {
  entregasDemo,
  obtenerEntrega,
  obtenerAlumno,
  obtenerCurso,
} from "../../../../data/cursos-demo";

export function getStaticPaths() {
  return entregasDemo.map((e) => ({ params: { id: e.id } }));
}

const { id } = Astro.params;
const entrega = obtenerEntrega(id!);
if (!entrega) return Astro.redirect("/aula/profe");

const alumno = obtenerAlumno(entrega.alumnoId);
const curso = obtenerCurso(entrega.cursoSlug);
const modulo = curso?.modulos.find((m) => m.numero === entrega.moduloNumero);
const tarea = modulo?.tarea;
---

<AulaLayout title={`Corrección · ${alumno?.nombre} · Vocational Lab`} rol="profe">
  <main class="correccion">
    <div class="container">
      <a href="/aula/profe" class="correccion__volver">← Volver al dashboard</a>

      <header class="correccion__head">
        <span class="correccion__eyebrow">Corrección de entrega</span>
        <h1 class="correccion__titulo">{tarea?.titulo}</h1>
        <p class="correccion__meta">
          {curso?.titulo} · Módulo {entrega.moduloNumero}
        </p>
      </header>

      <div class="correccion__grid">
        {/* Columna izquierda: datos del alumno + consigna + archivo */}
        <section class="bloque">
          <h2 class="bloque__titulo">Alumno</h2>
          <div class="alumno-card">
            <div class="alumno-card__avatar">
              {alumno?.nombre.split(" ").map((n) => n[0]).join("").slice(0, 2)}
            </div>
            <div>
              <span class="alumno-card__nombre">{alumno?.nombre}</span>
              <span class="alumno-card__mail">{alumno?.email}</span>
            </div>
          </div>

          <h2 class="bloque__titulo">Consigna</h2>
          <p class="consigna">{tarea?.consigna}</p>
          <p class="consigna-meta">
            <strong>Entrega original:</strong> {tarea?.fechaEntrega}<br />
            <strong>Subida el:</strong> {entrega.enviadaEl}
          </p>

          <h2 class="bloque__titulo">Archivo entregado</h2>
          <a href="#" class="archivo-entrega">
            <span class="archivo-entrega__icono" aria-hidden="true">📄</span>
            <span class="archivo-entrega__nombre">{entrega.archivo}</span>
            <span class="archivo-entrega__cta">Descargar</span>
          </a>
        </section>

        {/* Columna derecha: formulario de devolución */}
        <section class="bloque bloque--accion">
          <h2 class="bloque__titulo">Tu devolución</h2>

          {entrega.estado === "corregida" ? (
            <div class="ya-corregida">
              <p class="ya-corregida__label">Ya corregida</p>
              <p class="ya-corregida__nota"><strong>Nota:</strong> {entrega.devolucion?.nota}</p>
              <blockquote class="ya-corregida__comentario">
                “{entrega.devolucion?.comentario}”
              </blockquote>
              <p class="ya-corregida__hint">Podés volver a editarla si querés.</p>
            </div>
          ) : (
            <form class="form-devolucion" action="/aula/profe" method="get">
              <label class="form-devolucion__label">
                <span>Nota</span>
                <select name="nota" required>
                  <option value="">Elegí una nota</option>
                  <option>Excelente</option>
                  <option>Muy bien</option>
                  <option>Bien</option>
                  <option>A revisar</option>
                </select>
              </label>

              <label class="form-devolucion__label">
                <span>Comentario para {alumno?.nombre.split(" ")[0]}</span>
                <textarea
                  name="comentario"
                  rows="8"
                  placeholder="Escribí tu devolución con calma — el alumno la va a leer con atención."
                  required
                ></textarea>
              </label>

              <button type="submit" class="form-devolucion__submit">
                Enviar devolución
              </button>
            </form>
          )}
        </section>
      </div>
    </div>
  </main>
</AulaLayout>

<style>
  .correccion { flex: 1; padding: clamp(2rem, 5vw, 3rem) 0 5rem; }

  .correccion__volver {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--color-ink-soft);
    margin-bottom: 1.5rem;
  }
  .correccion__volver:hover { color: var(--color-ink); }

  .correccion__head {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-line);
  }
  .correccion__eyebrow {
    display: inline-block;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-deep);
    font-weight: 500;
    margin-bottom: 0.9rem;
  }
  .correccion__titulo { font-size: clamp(1.8rem, 4vw, 2.4rem); margin: 0 0 0.6rem; }
  .correccion__meta { color: var(--color-ink-soft); margin: 0; }

  .correccion__grid {
    display: grid;
    gap: 1.5rem;
  }
  @media (min-width: 900px) {
    .correccion__grid { grid-template-columns: 1fr 1fr; }
  }

  .bloque {
    padding: 1.8rem;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
  }
  .bloque--accion { border-left: 3px solid var(--color-deep); }
  .bloque__titulo {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin: 0 0 0.8rem;
  }
  .bloque__titulo + .bloque__titulo {
    margin-top: 1.6rem;
  }

  .alumno-card {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.8rem;
    background: var(--color-bg);
    border-radius: var(--radius-sm);
  }
  .alumno-card__avatar {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--color-deep);
    color: #fff;
    font-weight: 500;
  }
  .alumno-card__nombre { display: block; font-weight: 500; }
  .alumno-card__mail {
    display: block;
    font-size: 0.85rem;
    color: var(--color-ink-muted);
  }

  .consigna { margin: 0 0 0.8rem; color: var(--color-ink-soft); }
  .consigna-meta { margin: 0; font-size: 0.88rem; color: var(--color-ink-soft); }
  .consigna-meta strong { color: var(--color-ink); font-weight: 500; }

  .archivo-entrega {
    display: grid;
    grid-template-columns: 36px 1fr auto;
    align-items: center;
    gap: 0.8rem;
    padding: 0.8rem 1rem;
    background: var(--color-bg);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    color: var(--color-ink);
  }
  .archivo-entrega__icono {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
    background: #fff;
  }
  .archivo-entrega__nombre { font-size: 0.95rem; }
  .archivo-entrega__cta {
    font-size: 0.85rem;
    color: var(--color-deep);
    font-weight: 500;
  }

  /* Form de devolución */
  .form-devolucion {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .form-devolucion__label {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.85rem;
    color: var(--color-ink-soft);
    font-weight: 500;
  }
  .form-devolucion__label select,
  .form-devolucion__label textarea {
    font-family: inherit;
    font-size: 1rem;
    padding: 0.7rem 0.9rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    color: var(--color-ink);
    resize: vertical;
  }
  .form-devolucion__label select:focus,
  .form-devolucion__label textarea:focus {
    outline: none;
    border-color: var(--color-deep);
    background: #fff;
  }
  .form-devolucion__submit {
    padding: 0.9rem 1rem;
    border: 0;
    border-radius: var(--radius-sm);
    background: var(--color-deep);
    color: #fff;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .form-devolucion__submit:hover { background: #1a2c64; }

  /* Si ya está corregida */
  .ya-corregida {
    background: rgba(201, 162, 76, 0.12);
    border: 1px solid rgba(201, 162, 76, 0.4);
    border-radius: var(--radius-sm);
    padding: 1.2rem;
  }
  .ya-corregida__label {
    margin: 0 0 0.6rem;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #7a5f1f;
    font-weight: 500;
  }
  .ya-corregida__nota { margin: 0 0 0.6rem; }
  .ya-corregida__nota strong { font-weight: 500; }
  .ya-corregida__comentario {
    margin: 0 0 1rem;
    padding: 0.7rem 1rem;
    background: #fff;
    border-left: 2px solid var(--color-gold);
    font-family: var(--font-serif);
    font-style: italic;
    line-height: 1.5;
  }
  .ya-corregida__hint {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    font-style: italic;
  }
</style>
