---
/*
  /aula/profe/curso/[slug] — vista del PROFE de un curso.
  ---
  Muestra los alumnos inscriptos y los módulos del curso.
  Por ahora solo lectura; cuando haya backend, sumamos "editar módulo",
  "subir material", "agregar alumno".
*/

import AulaLayout from "../../../../layouts/AulaLayout.astro";
import {
  cursosDemo,
  obtenerCurso,
  alumnosDemo,
  entregasDemo,
} from "../../../../data/cursos-demo";

export function getStaticPaths() {
  return cursosDemo.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const curso = obtenerCurso(slug!);
if (!curso) return Astro.redirect("/aula/profe");

// Alumnos inscriptos en este curso.
const alumnos = alumnosDemo.filter((a) => a.cursos.includes(slug!));

// Entregas pendientes de este curso.
const pendientes = entregasDemo.filter(
  (e) => e.cursoSlug === slug && e.estado === "pendiente"
);
---

<AulaLayout title={`${curso.titulo} · Profe · Vocational Lab`} rol="profe">
  <main class="cursop">
    <div class="container">
      <a href="/aula/profe" class="cursop__volver">← Volver al dashboard</a>

      <header class="cursop__head">
        <span class="cursop__periodo">{curso.periodo}</span>
        <h1 class="cursop__titulo">{curso.titulo}</h1>
        <p class="cursop__resumen">{curso.resumen}</p>
      </header>

      {/* Resumen */}
      <section class="kpis">
        <article class="kpi">
          <span class="kpi__numero">{alumnos.length}</span>
          <span class="kpi__label">Alumnos inscriptos</span>
        </article>
        <article class="kpi">
          <span class="kpi__numero">{curso.modulos.length}</span>
          <span class="kpi__label">Módulos del curso</span>
        </article>
        <article class="kpi">
          <span class="kpi__numero">{pendientes.length}</span>
          <span class="kpi__label">Entregas pendientes</span>
        </article>
      </section>

      {/* Lista de alumnos */}
      <section class="cursop__seccion">
        <h2 class="cursop__seccion-titulo">Alumnos del curso</h2>
        <ul class="alumnos">
          {alumnos.map((a) => (
            <li class="alumno">
              <div class="alumno__avatar" aria-hidden="true">
                {a.nombre.split(" ").map((n) => n[0]).join("").slice(0, 2)}
              </div>
              <div class="alumno__cuerpo">
                <span class="alumno__nombre">{a.nombre}</span>
                <span class="alumno__mail">{a.email}</span>
              </div>
              <span class="alumno__inscripto">Inscripto el {a.inscripto}</span>
            </li>
          ))}
        </ul>
      </section>

      {/* Módulos del curso */}
      <section class="cursop__seccion">
        <h2 class="cursop__seccion-titulo">Módulos del curso</h2>
        <div class="modulosp">
          {curso.modulos.map((m) => (
            <article class="modulop">
              <header class="modulop__head">
                <span class="modulop__numero">Módulo {m.numero}</span>
                <h3 class="modulop__titulo">{m.titulo}</h3>
              </header>
              <p class="modulop__descripcion">{m.descripcion}</p>
              <p class="modulop__meta">
                {m.archivos.length} archivo{m.archivos.length === 1 ? "" : "s"}
                {m.tarea && <> · 1 tarea</>}
              </p>
              <div class="modulop__acciones">
                <button type="button" class="btn-link">Editar módulo</button>
                <button type="button" class="btn-link">Subir material</button>
              </div>
            </article>
          ))}
        </div>
      </section>
    </div>
  </main>
</AulaLayout>

<style>
  .cursop { flex: 1; padding: clamp(2rem, 5vw, 3rem) 0 5rem; }

  .cursop__volver {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--color-ink-soft);
    margin-bottom: 1.5rem;
  }
  .cursop__volver:hover { color: var(--color-ink); }

  .cursop__head {
    max-width: 780px;
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-line);
  }
  .cursop__periodo {
    display: inline-block;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-deep);
    font-weight: 500;
    margin-bottom: 0.9rem;
  }
  .cursop__titulo { font-size: clamp(1.8rem, 4vw, 2.4rem); margin: 0 0 0.6rem; }
  .cursop__resumen { color: var(--color-ink-soft); margin: 0; max-width: 60ch; }

  .kpis {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    margin-bottom: 3rem;
  }
  .kpi {
    padding: 1.2rem 1.2rem;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .kpi__numero {
    font-family: var(--font-serif);
    font-size: 2.2rem;
    line-height: 1;
    color: var(--color-deep);
  }
  .kpi__label {
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }

  .cursop__seccion { margin-bottom: 3rem; }
  .cursop__seccion-titulo {
    font-size: 1.3rem;
    margin: 0 0 1.2rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-line);
  }

  /* Lista de alumnos */
  .alumnos {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .alumno {
    display: grid;
    grid-template-columns: 40px 1fr auto;
    align-items: center;
    gap: 0.9rem;
    padding: 0.7rem 1rem;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
  }
  .alumno__avatar {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-deep);
    color: #fff;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.04em;
  }
  .alumno__cuerpo {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }
  .alumno__nombre { font-weight: 500; }
  .alumno__mail { font-size: 0.85rem; color: var(--color-ink-muted); }
  .alumno__inscripto {
    font-size: 0.82rem;
    color: var(--color-ink-muted);
    white-space: nowrap;
  }
  @media (max-width: 600px) {
    .alumno { grid-template-columns: 40px 1fr; }
    .alumno__inscripto { grid-column: 2; }
  }

  /* Módulos */
  .modulosp {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.2rem;
  }
  .modulop {
    padding: 1.4rem;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
  }
  .modulop__head { margin-bottom: 0.6rem; }
  .modulop__numero {
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-deep);
    font-weight: 500;
  }
  .modulop__titulo { font-size: 1.1rem; margin: 0.3rem 0 0; }
  .modulop__descripcion {
    margin: 0 0 0.6rem;
    color: var(--color-ink-soft);
    font-size: 0.93rem;
  }
  .modulop__meta {
    margin: 0 0 1rem;
    color: var(--color-ink-muted);
    font-size: 0.85rem;
  }
  .modulop__acciones {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
    border-top: 1px solid var(--color-line);
    padding-top: 0.8rem;
  }
  .btn-link {
    background: transparent;
    border: 0;
    padding: 0;
    color: var(--color-deep);
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    font-family: inherit;
  }
  .btn-link:hover { color: var(--color-accent); }
</style>
