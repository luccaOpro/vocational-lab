---
/*
  /aula/profe — dashboard del PROFESOR.
  ---
  Trae los cursos que el profe enseña (vía RLS de cursos_profesores)
  y las entregas pendientes de corregir en esos cursos.
*/

import AulaLayout from "../../../layouts/AulaLayout.astro";
---

<AulaLayout title="Profe · Aula Vocational Lab" rol="profe">
  <main class="profe">
    <div class="container">
      {/* Skeleton que imita el panel del profe (saludo + KPIs + listas). */}
      <div id="profe-loader" class="profe__loader" role="status" aria-label="Cargando tu panel…">
        <div class="skeleton-stack" aria-hidden="true">
          <span class="skeleton skeleton--text" style="width: 80px;"></span>
          <span class="skeleton skeleton--title"></span>
          <div class="skeleton-row" style="margin-top: 0.5rem;">
            <span class="skeleton skeleton--kpi" style="flex:1"></span>
            <span class="skeleton skeleton--kpi" style="flex:1"></span>
          </div>
          <span class="skeleton skeleton--card" style="margin-top: 1rem;"></span>
        </div>
      </div>

      <div id="profe-contenido" hidden>
        <header class="profe__head">
          <p class="profe__eyebrow">Profe</p>
          <h1 class="profe__titulo" id="saludo">Hola</h1>
          <p class="profe__bajada" id="bajada">Cargando tu panel…</p>
        </header>

        <section class="kpis stagger-in">
          <article class="kpi">
            <span class="kpi__numero" id="kpi-cursos">0</span>
            <span class="kpi__label">Cursos activos</span>
          </article>
          <article class="kpi">
            <span class="kpi__numero" id="kpi-pendientes">0</span>
            <span class="kpi__label">Entregas a corregir</span>
          </article>
        </section>

        <section class="profe__seccion">
          <h2 class="profe__seccion-titulo">Mis cursos</h2>
          <div id="profe-cursos"></div>
        </section>

        <section class="profe__seccion">
          <h2 class="profe__seccion-titulo">Entregas pendientes</h2>
          <div id="profe-entregas"></div>
        </section>
      </div>
    </div>
  </main>
</AulaLayout>

<script>
  import { supabase } from "../../../lib/supabase";
  import { requireRol } from "../../../lib/auth-guard";
  import { traducirError, countUp } from "../../../lib/ui";
  import { iconHtml } from "../../../lib/icons";

  const $loader = document.getElementById("profe-loader") as HTMLElement;
  const $contenido = document.getElementById("profe-contenido") as HTMLElement;
  const $saludo = document.getElementById("saludo")!;
  const $bajada = document.getElementById("bajada")!;
  const $kpiCursos = document.getElementById("kpi-cursos")!;
  const $kpiPendientes = document.getElementById("kpi-pendientes")!;
  const $cursos = document.getElementById("profe-cursos")!;
  const $entregas = document.getElementById("profe-entregas")!;

  function esc(s: string | null | undefined) {
    return String(s ?? "")
      .replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;").replace(/'/g, "&#039;");
  }

  type CursoRow = { id: string; slug: string; titulo: string; resumen: string | null; periodo: string | null };
  type AlumnoRow = { id: string; nombre: string };
  type ModuloRow = { id: string; numero: number; curso_id: string; cursos: { titulo: string } | null };
  type TareaRow = { id: string; titulo: string; modulos: ModuloRow | null };
  type EntregaRow = {
    id: string;
    enviada_en: string;
    archivo_nombre: string;
    tarea_id: string;
    profiles: AlumnoRow | null;
    tareas: TareaRow | null;
  };

  async function cargar() {
    const auth = await requireRol(["profe", "admin"]);
    if (!auth) return;
    const { profile } = auth;

    // 1. Cursos que el profe ve (RLS los filtra).
    const { data: cursos, error: errCursos } = await supabase
      .from("cursos")
      .select("id, slug, titulo, resumen, periodo")
      .eq("publicado", true)
      .order("creado_en", { ascending: false });
    if (errCursos) {
      mostrarError(`Error al cargar cursos: ${traducirError(errCursos)}`);
      return;
    }

    // 2. Entregas pendientes (sin corregida_en) en los cursos visibles.
    // Trae datos del alumno (profiles) y de la tarea + módulo + curso.
    const { data: entregas, error: errEntregas } = await supabase
      .from("entregas")
      .select(`
        id, enviada_en, archivo_nombre, tarea_id,
        profiles!entregas_alumno_id_fkey (id, nombre),
        tareas (
          id, titulo,
          modulos (
            id, numero, curso_id,
            cursos (titulo)
          )
        )
      `)
      .is("corregida_en", null)
      .order("enviada_en", { ascending: false });
    if (errEntregas) {
      mostrarError(`Error al cargar entregas: ${traducirError(errEntregas)}`);
      return;
    }

    // 3. Render.
    $saludo.textContent = `Hola, ${profile.nombre.split(" ")[0]}`;
    const np = entregas?.length ?? 0;
    $bajada.textContent = np === 0
      ? "Estás al día. No tienes entregas para corregir."
      : `Tienes ${np} entrega${np === 1 ? "" : "s"} esperando devolución.`;
    // Números animados, como en el panel de admin.
    countUp($kpiCursos, cursos?.length ?? 0);
    countUp($kpiPendientes, np);

    $cursos.innerHTML = (cursos ?? []).length === 0
      ? `<div class="empty-state">
          <span class="empty-state__icono" aria-hidden="true">${iconHtml("book-open", 28)}</span>
          <h3 class="empty-state__titulo">Sin cursos asignados todavía</h3>
          <p class="empty-state__bajada">Cuando te asignen un curso, va a aparecer acá.</p>
        </div>`
      : `<div class="profe__cursos">${(cursos as CursoRow[]).map(renderCurso).join("")}</div>`;

    $entregas.innerHTML = np === 0
      ? `<div class="empty-state">
          <span class="empty-state__icono" aria-hidden="true">${iconHtml("target", 28)}</span>
          <h3 class="empty-state__titulo">¡Todo al día!</h3>
          <p class="empty-state__bajada">No tienes entregas esperando devolución por ahora.</p>
        </div>`
      : `<ul class="entregas">${(entregas as unknown as EntregaRow[]).map(renderEntrega).join("")}</ul>`;

    $loader.hidden = true;
    $contenido.hidden = false;
  }

  function mostrarError(msg: string) {
    $loader.innerHTML = `<p class="profe__error">${msg.replace(/</g, "&lt;")}</p>`;
  }

  function renderCurso(c: CursoRow): string {
    return `
      <a href="/aula/curso?slug=${encodeURIComponent(c.slug)}" class="curso-profe">
        <span class="curso-profe__periodo">${esc(c.periodo)}</span>
        <h3 class="curso-profe__titulo">${esc(c.titulo)}</h3>
        <p class="curso-profe__resumen">${esc(c.resumen)}</p>
        <span class="curso-profe__cta">Ver curso →</span>
      </a>
    `;
  }

  function renderEntrega(e: EntregaRow): string {
    const alumno = e.profiles?.nombre ?? "(protagonista desconocido)";
    const tarea = e.tareas;
    const tareaTitulo = tarea?.titulo ?? "(tarea)";
    const modulo = tarea?.modulos;
    const cursoTitulo = modulo?.cursos?.titulo ?? "";
    const moduloNumero = modulo?.numero ?? "?";
    return `
      <li class="entrega">
        <div class="entrega__cuerpo">
          <span class="entrega__alumno">${esc(alumno)}</span>
          <span class="entrega__tarea">${esc(tareaTitulo)}</span>
          <span class="entrega__meta">${esc(cursoTitulo)} · Módulo ${esc(String(moduloNumero))} · Entregada el ${esc(formatoFecha(e.enviada_en))}</span>
        </div>
        <a href="/aula/profe/correccion?id=${encodeURIComponent(e.id)}" class="entrega__cta">
          Corregir →
        </a>
      </li>
    `;
  }

  function formatoFecha(iso: string) {
    try {
      return new Date(iso).toLocaleDateString("es-AR", { day: "numeric", month: "long" });
    } catch {
      return iso;
    }
  }

  cargar().catch((err) => {
    console.error("[profe]", err);
    mostrarError(`Error inesperado: ${err instanceof Error ? err.message : String(err)}`);
  });
</script>

<style>
  .profe { flex: 1; padding: clamp(2.5rem, 6vw, 4rem) 0 5rem; }
  .profe__loader { color: var(--color-ink-soft); font-style: italic; padding: 2rem 0; }

  .profe__head { max-width: 720px; margin-bottom: 2.5rem; }
  .profe__eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-deep);
    font-weight: 500;
    margin: 0 0 0.9rem;
  }
  .profe__titulo { font-size: clamp(2rem, 4.5vw, 2.8rem); margin: 0 0 0.6rem; }
  .profe__bajada { color: var(--color-ink-soft); font-size: 1.05rem; margin: 0; }

  .kpis {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    margin-bottom: 3rem;
  }
  .kpi {
    padding: 1.4rem;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .kpi__numero { font-family: var(--font-serif); font-size: 2.4rem; line-height: 1; color: var(--color-deep); }
  .kpi__label {
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }

  .profe__seccion { margin-bottom: 3rem; }
  .profe__seccion-titulo {
    font-size: 1.4rem;
    margin: 0 0 1.2rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-line);
  }
  .profe__vacio { color: var(--color-ink-soft); font-style: italic; margin: 0; }

  :global(.profe__cursos) {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.2rem;
  }
  :global(.curso-profe) {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding: 1.5rem;
    background: #fff;
    border: 1px solid var(--color-line);
    border-left: 3px solid var(--color-deep);
    border-radius: var(--radius-md);
    color: var(--color-ink);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  :global(.curso-profe:hover) {
    transform: translateY(-3px);
    box-shadow: 0 18px 40px rgba(19, 27, 61, 0.08);
  }
  :global(.curso-profe__periodo) {
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }
  :global(.curso-profe__titulo) { font-size: 1.2rem; margin: 0; }
  :global(.curso-profe__resumen) { margin: 0; color: var(--color-ink-soft); font-size: 0.95rem; }
  :global(.curso-profe__cta) {
    margin-top: 0.4rem;
    color: var(--color-deep);
    font-weight: 500;
    font-size: 0.9rem;
  }

  :global(.entregas) { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.6rem; }
  :global(.entrega) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.2rem;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
  }
  :global(.entrega__cuerpo) { display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; }
  :global(.entrega__alumno) { font-weight: 500; }
  :global(.entrega__tarea) { font-size: 0.95rem; }
  :global(.entrega__meta) { font-size: 0.82rem; color: var(--color-ink-muted); }
  :global(.entrega__cta) {
    padding: 0.5rem 0.95rem;
    background: var(--color-deep);
    color: #fff;
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    font-weight: 500;
    white-space: nowrap;
  }
  :global(.entrega__cta:hover) { background: #1a2c64; }

  @media (max-width: 600px) {
    :global(.entrega) { flex-direction: column; align-items: flex-start; }
    :global(.entrega__cta) { align-self: stretch; text-align: center; }
  }
</style>
