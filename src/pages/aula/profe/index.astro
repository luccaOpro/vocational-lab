---
/*
  /aula/profe — dashboard del PROFESOR (Julia, Laura).
  ---
  Muestra al profe sus cursos y sus entregas pendientes de corregir.
  Datos demo. Cuando haya backend, vienen de Supabase filtrados por
  profesor_id del usuario logueado.
*/

import AulaLayout from "../../../layouts/AulaLayout.astro";
import {
  profeDemo,
  cursosDemo,
  entregasDemo,
  obtenerAlumno,
  obtenerCurso,
} from "../../../data/cursos-demo";

// Cursos que enseña el profe.
const misCursos = cursosDemo.filter((c) => profeDemo.cursos.includes(c.slug));

// Entregas pendientes en los cursos del profe.
const pendientes = entregasDemo.filter(
  (e) => e.estado === "pendiente" && profeDemo.cursos.includes(e.cursoSlug)
);
---

<AulaLayout title="Profe · Aula Vocational Lab" rol="profe">
  <main class="profe">
    <div class="container">
      <header class="profe__head">
        <p class="profe__eyebrow">Profe</p>
        <h1 class="profe__titulo">Hola, {profeDemo.nombre.split(" ")[0]}.</h1>
        <p class="profe__bajada">
          {pendientes.length === 0
            ? "Estás al día. No tenés entregas para corregir."
            : `Tenés ${pendientes.length} entrega${pendientes.length === 1 ? "" : "s"} esperando devolución.`}
        </p>
      </header>

      {/* Resumen rápido */}
      <section class="kpis">
        <article class="kpi">
          <span class="kpi__numero">{misCursos.length}</span>
          <span class="kpi__label">Cursos activos</span>
        </article>
        <article class="kpi">
          <span class="kpi__numero">{pendientes.length}</span>
          <span class="kpi__label">Entregas a corregir</span>
        </article>
      </section>

      {/* Mis cursos */}
      <section class="profe__seccion">
        <h2 class="profe__seccion-titulo">Mis cursos</h2>
        <div class="profe__cursos">
          {misCursos.map((c) => (
            <a href={`/aula/profe/curso/${c.slug}`} class="curso-profe">
              <span class="curso-profe__periodo">{c.periodo}</span>
              <h3 class="curso-profe__titulo">{c.titulo}</h3>
              <p class="curso-profe__resumen">{c.resumen}</p>
              <span class="curso-profe__cta">Gestionar curso →</span>
            </a>
          ))}
        </div>
      </section>

      {/* Entregas pendientes */}
      <section class="profe__seccion">
        <h2 class="profe__seccion-titulo">Entregas pendientes</h2>
        {pendientes.length === 0 ? (
          <p class="profe__vacio">Todo corregido por ahora. 🎯</p>
        ) : (
          <ul class="entregas">
            {pendientes.map((e) => {
              const alumno = obtenerAlumno(e.alumnoId);
              const curso = obtenerCurso(e.cursoSlug);
              const modulo = curso?.modulos.find((m) => m.numero === e.moduloNumero);
              return (
                <li class="entrega">
                  <div class="entrega__cuerpo">
                    <span class="entrega__alumno">{alumno?.nombre ?? "?"}</span>
                    <span class="entrega__tarea">{modulo?.tarea?.titulo}</span>
                    <span class="entrega__meta">
                      {curso?.titulo} · Módulo {e.moduloNumero} · Entregada el {e.enviadaEl}
                    </span>
                  </div>
                  <a href={`/aula/profe/entregas/${e.id}`} class="entrega__cta">
                    Corregir →
                  </a>
                </li>
              );
            })}
          </ul>
        )}
      </section>
    </div>
  </main>
</AulaLayout>

<style>
  .profe {
    flex: 1;
    padding: clamp(2.5rem, 6vw, 4rem) 0 5rem;
  }
  .profe__head { max-width: 720px; margin-bottom: 2.5rem; }
  .profe__eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-deep);
    font-weight: 500;
    margin: 0 0 0.9rem;
  }
  .profe__titulo {
    font-size: clamp(2rem, 4.5vw, 2.8rem);
    margin: 0 0 0.6rem;
  }
  .profe__bajada { color: var(--color-ink-soft); font-size: 1.05rem; margin: 0; }

  /* KPIs */
  .kpis {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    margin-bottom: 3rem;
  }
  .kpi {
    padding: 1.4rem 1.4rem;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .kpi__numero {
    font-family: var(--font-serif);
    font-size: 2.4rem;
    line-height: 1;
    color: var(--color-deep);
  }
  .kpi__label {
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }

  .profe__seccion { margin-bottom: 3rem; }
  .profe__seccion-titulo {
    font-size: 1.4rem;
    margin: 0 0 1.2rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-line);
  }
  .profe__vacio {
    color: var(--color-ink-soft);
    font-style: italic;
    margin: 0;
  }

  /* Cursos del profe */
  .profe__cursos {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.2rem;
  }
  .curso-profe {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding: 1.5rem;
    background: #fff;
    border: 1px solid var(--color-line);
    border-left: 3px solid var(--color-deep);
    border-radius: var(--radius-md);
    color: var(--color-ink);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .curso-profe:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 40px rgba(19, 27, 61, 0.08);
  }
  .curso-profe__periodo {
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }
  .curso-profe__titulo { font-size: 1.2rem; margin: 0; }
  .curso-profe__resumen { margin: 0; color: var(--color-ink-soft); font-size: 0.95rem; }
  .curso-profe__cta {
    margin-top: 0.4rem;
    color: var(--color-deep);
    font-weight: 500;
    font-size: 0.9rem;
  }

  /* Entregas pendientes */
  .entregas {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .entrega {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.2rem;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
  }
  .entrega__cuerpo {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }
  .entrega__alumno {
    font-weight: 500;
    color: var(--color-ink);
  }
  .entrega__tarea {
    color: var(--color-ink);
    font-size: 0.95rem;
  }
  .entrega__meta {
    font-size: 0.82rem;
    color: var(--color-ink-muted);
  }
  .entrega__cta {
    padding: 0.5rem 0.95rem;
    background: var(--color-deep);
    color: #fff;
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    font-weight: 500;
    white-space: nowrap;
    transition: background 0.15s ease;
  }
  .entrega__cta:hover { background: #1a2c64; }

  @media (max-width: 600px) {
    .entrega { flex-direction: column; align-items: flex-start; }
    .entrega__cta { align-self: stretch; text-align: center; }
  }
</style>
